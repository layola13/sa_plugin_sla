L_WHILE_BODY_1:
    !tmp_3
    tmp_4 = 1
    x = tmp_4
    jmp L_WHILE_HEAD_3

L_WHILE_HEAD_3:
    tmp_5 = 3
    tmp_6 = sle x, tmp_5
    !tmp_5
