@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_query_sum = vtable { call = @sla__query_sum }
@sla__QueryPV_iter_len(&self: ptr) -> i64:
L_ENTRY:
    tmp_0 = load self+0 as i64
    return tmp_0

@sla__QueryPV_iter_at(&self: ptr, index: i64) -> ptr:
L_ENTRY:
    tmp_1 = 0
    first = tmp_1
    tmp_2 = eq index, first
    br tmp_2 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_2
    tmp_3 = alloc 8
    tmp_4 = load self+8 as i32
    store tmp_3+0, tmp_4 as i32
    !tmp_4
    tmp_5 = load self+12 as i32
    store tmp_3+4, tmp_5 as i32
    !tmp_5
    !first
    !index
    return tmp_3

L_ELSE_1:
    !tmp_2
    jmp L_MERGE_2

L_MERGE_2:
    tmp_7 = alloc 8
    tmp_8 = load self+16 as i32
    store tmp_7+0, tmp_8 as i32
    !tmp_8
    tmp_9 = load self+20 as i32
    store tmp_7+4, tmp_9 as i32
    !tmp_9
    !first
    !index
    return tmp_7

@sla__query_sum(query: ptr) -> i32:
L_ENTRY:
    item_slot = stack_alloc 8
    tmp_10 = 0
    total = tmp_10
    tmp_11 = call @sla__QueryPV_iter_len(&query)
    store item_slot+0, 0 as i64
    jmp L_LOOP_HEAD_3

L_LOOP_HEAD_3:
    tmp_12 = load item_slot+0 as i64
    tmp_13 = slt tmp_12, tmp_11
    br tmp_13 -> L_LOOP_BODY_4, L_LOOP_COND_FALSE_6

L_LOOP_BODY_4:
    !tmp_13
    item = call @sla__QueryPV_iter_at(&query, tmp_12)
    tmp_14 = load item+0 as i32
    tmp_15 = add total, tmp_14
    !tmp_14
    !total
    total = tmp_15
L_LOOP_CONTINUE_5:
    tmp_16 = add tmp_12, 1
    store item_slot+0, tmp_16 as i64
    !tmp_16
    !tmp_12
    !item
    jmp L_LOOP_HEAD_3

L_LOOP_COND_FALSE_6:
    !tmp_13
    !tmp_12
    jmp L_LOOP_EXIT_7

L_LOOP_EXIT_7:
    !tmp_11
    !query
    return total

@test "for in uses iterable protocol methods"():
L_TEST_ENTRY_8:
    query = alloc 24
    tmp_17 = 2
    store query+0, tmp_17 as i64
    !tmp_17
    tmp_18 = 1
    store query+8, tmp_18 as i32
    !tmp_18
    tmp_19 = 2
    store query+12, tmp_19 as i32
    !tmp_19
    tmp_20 = 3
    store query+16, tmp_20 as i32
    !tmp_20
    tmp_21 = 4
    store query+20, tmp_21 as i32
    !tmp_21
    tmp_22 = call @sla__query_sum(query)
    got = tmp_22
    tmp_23 = 4
    expected = tmp_23
    tmp_24 = ne got, expected
    br tmp_24 -> L_THEN_9, L_ELSE_10

L_THEN_9:
    !tmp_24
    panic(1201)

L_ELSE_10:
    !tmp_24
    jmp L_MERGE_11

L_MERGE_11:
    !expected
    !query
    !got
    return

