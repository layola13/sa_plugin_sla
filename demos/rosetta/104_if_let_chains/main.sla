// Sla companion for SA rosetta demo 104 If Let Chains.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_104_value() -> int {
    let seed = 5;
    let shifted = seed + 104;
    let scaled = shifted * 7;
    let result = scaled - 17;
    return result;
};

fn main() -> int {
    let result = rosetta_104_value();
    return result;
};

@test "rosetta 104 104_if_let_chains"() {
    let got = rosetta_104_value();
    if got != 746 {
        panic(104);
    }