@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

struct Pair { a: u32, b: u32 }
fn c_repr_pair_sum() -> u32 { let pair = Pair { a: 1, b: 2 }; return pair.a + pair.b; }
fn main() -> i32 { let result = c_repr_pair_sum(); println("{}", result); return 0; }
@test "rosetta 150 150_c_repr_alignment"() { let got = c_repr_pair_sum(); if got != 3 { panic(150); }; }
