@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_io_uring_submission_count = vtable { call = @sla__io_uring_submission_count }
@const SLA_FNPTR_VT_submit_io = vtable { call = @sla__submit_io }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__io_uring_submission_count() -> i32:
L_ENTRY:
    tmp_0 = 2
    queue_depth = tmp_0
    tmp_1 = 0
    tmp_2 = call @sla__submit_io(queue_depth, tmp_1)
    !tmp_1
    submitted = tmp_2
    tmp_3 = call @sla__submit_io(queue_depth, submitted)
    return tmp_3

@sla__submit_io(depth: i32, used: i32) -> i32:
L_ENTRY:
    tmp_4 = slt used, depth
    br tmp_4 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_4
    tmp_5 = 1
    tmp_6 = add used, tmp_5
    !tmp_5
    !depth
    return tmp_6

L_ELSE_1:
    !tmp_4
    !depth
    return used


@main() -> i32:
L_ENTRY:
    tmp_8 = 2
    queue_depth = tmp_8
    tmp_9 = 0
    tmp_10 = call @sla__submit_io(queue_depth, tmp_9)
    !tmp_9
    submitted = tmp_10
    tmp_11 = call @sla__submit_io(queue_depth, submitted)
    result = tmp_11
    tmp_12 = call @sa_fmt_u64(result, 10)
    tmp_13 = call @sa_fmt_buffer_data(tmp_12)
    tmp_14 = call @sa_fmt_buffer_len(tmp_12)
    tmp_15 = tmp_13
    call @sa_print_bytes(&tmp_15, tmp_14)
    call @sa_fmt_buffer_free(^tmp_12)
    !tmp_15
    !tmp_14
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !queue_depth
    !submitted
    return result

@test "rosetta 137 137_io_uring_submission"():
L_TEST_ENTRY_3:
    tmp_16 = call @sla__io_uring_submission_count()
    got = tmp_16
    tmp_17 = 2
    tmp_18 = ne got, tmp_17
    !tmp_17
    br tmp_18 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_18
    panic(137)

L_ELSE_5:
    !tmp_18
    jmp L_MERGE_6

L_MERGE_6:
    !got
    return

