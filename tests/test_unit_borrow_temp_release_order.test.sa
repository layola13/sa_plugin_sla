@test "vec arc refcell indexed borrow survives loop and branch temps"():
L_TEST_ENTRY_71:
    EXPAND VEC_NEW tmp_254
    items = tmp_254
    tmp_255 = alloc 8
    tmp_256 = 3
    store tmp_255+0, tmp_256 as i64
    !tmp_256
    EXPAND REFCELL_U64_NEW tmp_257, tmp_255
    !tmp_255
    EXPAND ARC_NEW tmp_258, tmp_257
    !tmp_257
