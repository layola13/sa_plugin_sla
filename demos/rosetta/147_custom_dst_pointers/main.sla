@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn custom_dst_bytes_len() -> usize { let bytes_len: usize = 3; return bytes_len; }
fn main() -> i32 { let result = custom_dst_bytes_len(); println("{}", result); return 0; }
@test "rosetta 147 147_custom_dst_pointers"() { let got = custom_dst_bytes_len(); if got != 3 { panic(147); }; }
