fn router_table_value() -> i32 {
    let router = HashMap::new();
    router.insert("/home", 1);
    router.insert("/api", 2);
    return router["/api"];
}

fn main() -> i32 {
    let value = router_table_value();
    println("{}", value);
    return 0;
}

@test "rosetta 063 63_router_table"() {
    let got = router_table_value();
    if got != 2 {
        panic(63);
    };
}
