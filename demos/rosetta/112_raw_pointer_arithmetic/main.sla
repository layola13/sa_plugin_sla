fn rosetta_112_value() -> i32 {
    let data: [i32; 4] = [1, 2, 3, 4];
    let third = unsafe { *data.as_ptr().add(2) };
    return third;
}

fn main() -> i32 {
    let result = rosetta_112_value();
    println("{}", result);
    return result;
}

@test "rosetta 112 112_raw_pointer_arithmetic"() {
    let got = rosetta_112_value();
    if got != 3 {
        panic(112);
    };
};
