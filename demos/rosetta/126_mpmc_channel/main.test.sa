@sla_thread_worker_2(&slot: ptr) -> i32:
L_ENTRY:
    tmp_8 = load slot+16 as ptr
    tmp_9 = 1
    tmp_10 = 2
    tmp_11 = call @sla__send_pair(tmp_8, tmp_9, tmp_10)
    !tmp_9
    !tmp_10
