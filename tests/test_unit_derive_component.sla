@derive(Component)
struct DerivedComponentPosition {
    x: i32,
    y: i32,
}

@derive(Component)
struct DerivedComponentVelocity {
    dx: i32,
    dy: i32,
}

fn derived_component_metadata_score() -> i32 {
    let position_id = DerivedComponentPosition::component_type_id();
    let position_id_again = DerivedComponentPosition::component_type_id();
    let velocity_id = DerivedComponentVelocity::component_type_id();
    if position_id <= 0 { panic(9101); };
    if position_id != position_id_again { panic(9102); };
    if position_id == velocity_id { panic(9103); };
    if DerivedComponentPosition::component_storage_kind() != 0 { panic(9104); };
    return 7;
}

@test "derive component exposes stable metadata"() {
    if derived_component_metadata_score() != 7 { panic(9105); };
}
