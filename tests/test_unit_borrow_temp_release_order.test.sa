    !tmp_140
    store holder+0, tmp_141 as ptr
    !tmp_141
    tmp_142 = load holder+0 as ptr
    EXPAND RC_GET tmp_143, tmp_142
    !tmp_142
    tmp_144 = &tmp_143
    borrowed_cell = tmp_144
    tmp_145 = 59
    call @sla__borrow_refcell_box_write(borrowed_cell, tmp_145)
    tmp_146 = call @sla__borrow_refcell_box_read(borrowed_cell)
    tmp_147 = 59
    tmp_148 = ne tmp_146, tmp_147
    !tmp_146
    !tmp_147
    br tmp_148 -> L_THEN_44, L_ELSE_45

L_THEN_44:
    !tmp_148
    panic(8)

L_ELSE_45:
    !tmp_148
    jmp L_MERGE_46

L_MERGE_46:
    !borrowed_cell
    !tmp_143
    !holder
    return

@test "repeated smart pointer field borrows release each owner temp"():
L_TEST_ENTRY_47:
    holder = alloc 8
    tmp_151 = alloc 8
    tmp_152 = 17
    store tmp_151+0, tmp_152 as i64
    !tmp_152
    EXPAND RC_NEW tmp_153, tmp_151
    !tmp_151
    store holder+0, tmp_153 as ptr
    !tmp_153
    tmp_154 = 0
    total = tmp_154
    tmp_155 = 0
    i = tmp_155
    jmp L_WHILE_HEAD_48

L_WHILE_HEAD_48:
    tmp_156 = 3
    tmp_157 = slt i, tmp_156
    !tmp_156
    br tmp_157 -> L_WHILE_BODY_49, L_WHILE_COND_FALSE_50

L_WHILE_BODY_49:
    !tmp_157
    tmp_158 = load holder+0 as ptr
    tmp_159 = &tmp_158
    borrowed_rc = tmp_159
    tmp_160 = call @sla__borrow_read_rc(borrowed_rc)
    tmp_161 = add total, tmp_160
    !tmp_160
    !total
    total = tmp_161
    tmp_162 = 1
    tmp_163 = add i, tmp_162
    !tmp_162
    !i
    i = tmp_163
    !borrowed_rc
    !tmp_158
    jmp L_WHILE_HEAD_48

L_WHILE_COND_FALSE_50:
    !tmp_157
    jmp L_WHILE_EXIT_51

L_WHILE_EXIT_51:
    tmp_164 = 51
    tmp_165 = ne total, tmp_164
    !tmp_164
    br tmp_165 -> L_THEN_52, L_ELSE_53

L_THEN_52:
    !tmp_165
    panic(9)

L_ELSE_53:
    !tmp_165
    jmp L_MERGE_54

L_MERGE_54:
    !i
    !total
    !holder
    return

@test "vec field smart pointer index borrow releases owner temps"():
L_TEST_ENTRY_55:
    EXPAND VEC_NEW tmp_168
    items = tmp_168
    tmp_169 = alloc 8
    tmp_170 = 3
    store tmp_169+0, tmp_170 as i64
    !tmp_170
    EXPAND BOX_NEW tmp_171, tmp_169
    !tmp_169
    EXPAND VEC_PUSH items, tmp_171, 8
    !tmp_171
    tmp_172 = alloc 8
    tmp_173 = 4
    store tmp_172+0, tmp_173 as i64
    !tmp_173
    EXPAND BOX_NEW tmp_174, tmp_172
    !tmp_172
    EXPAND VEC_PUSH items, tmp_174, 8
    !tmp_174
    holder = alloc 8
    store holder+0, items as ptr
    tmp_175 = load holder+0 as ptr
    tmp_176 = 0
    EXPAND VEC_GET tmp_177, tmp_175, tmp_176
    !tmp_176
    !tmp_175
    tmp_178 = tmp_177 as ptr
    tmp_179 = &tmp_178
    first = tmp_179
    tmp_180 = load holder+0 as ptr
    tmp_181 = 1
    EXPAND VEC_GET tmp_182, tmp_180, tmp_181
    !tmp_181
    !tmp_180
    tmp_183 = tmp_182 as ptr
    tmp_184 = &tmp_183
    second = tmp_184
    tmp_185 = call @sla__borrow_read_box(first)
    tmp_186 = call @sla__borrow_read_box(second)
    tmp_187 = add tmp_185, tmp_186
    !tmp_185
    !tmp_186
    tmp_188 = 7
    tmp_189 = ne tmp_187, tmp_188
    !tmp_187
    !tmp_188
    br tmp_189 -> L_THEN_56, L_ELSE_57

L_THEN_56:
    !tmp_189
    panic(10)

L_ELSE_57:
    !tmp_189
    jmp L_MERGE_58

L_MERGE_58:
    !first
    !tmp_178
    !items
    !holder
    !second
    !tmp_183
    return
