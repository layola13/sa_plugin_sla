@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_blanket_impl_len = vtable { call = @sla__blanket_impl_len }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__blanket_impl_len() -> i32:
L_ENTRY:
    array_pair = alloc 8
    tmp_0 = 1
    store array_pair+0, tmp_0 as i32
    tmp_1 = 2
    store array_pair+4, tmp_1 as i32
    tmp_2 = 2
    return tmp_2

@main() -> i32:
L_ENTRY:
    array_pair = alloc 8
    tmp_3 = 1
    store array_pair+0, tmp_3 as i32
    tmp_4 = 2
    store array_pair+4, tmp_4 as i32
    tmp_5 = 2
    result = tmp_5
    tmp_6 = call @sa_fmt_u64(result, 10)
    tmp_7 = call @sa_fmt_buffer_data(tmp_6)
    tmp_8 = call @sa_fmt_buffer_len(tmp_6)
    tmp_9 = tmp_7
    call @sa_print_bytes(&tmp_9, tmp_8)
    call @sa_fmt_buffer_free(^tmp_6)
    !tmp_9
    !tmp_8
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !array_pair
    return result

@test "rosetta 165 165_blanket_impl_resolution"():
L_TEST_ENTRY_0:
    tmp_10 = call @sla__blanket_impl_len()
    got = tmp_10
    tmp_11 = 2
    tmp_12 = ne got, tmp_11
    !tmp_11
    br tmp_12 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_12
    panic(165)

L_ELSE_2:
    !tmp_12
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

