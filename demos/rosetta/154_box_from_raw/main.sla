@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/box.sa"

fn box_from_raw_value() -> i32 { let boxed = Box::new(11); return *boxed; }
fn main() -> i32 { let result = box_from_raw_value(); println("{}", result); return result; }
@test "rosetta 154 154_box_from_raw"() { let got = box_from_raw_value(); if got != 11 { panic(154); }; }
