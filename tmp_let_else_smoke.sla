fn let_else_some() -> i32 {
    let value = Some(5);
    let Some(x) = value else {
        return 0;
    };
    return x;
}

fn let_else_none() -> i32 {
    let value = None;
    let Some(x) = value else {
        return 7;
    };
    return x;
}

@test "let else some"() {
    if let_else_some() != 5 {
        panic(1);
    };
}

@test "let else none"() {
    if let_else_none() != 7 {
        panic(2);
    };
}
