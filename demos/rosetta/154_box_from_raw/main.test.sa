[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/box.sa"
@const SLA_FNPTR_VT_box_from_raw_value = vtable { call = @sla__box_from_raw_value }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__box_from_raw_value() -> i32:
L_ENTRY:
    tmp_0 = 11
    EXPAND BOX_NEW tmp_1, tmp_0
    EXPAND BOX_INTO_RAW tmp_2, tmp_1
    raw = tmp_2
    EXPAND BOX_FROM_RAW tmp_4, raw
    tmp_3 = tmp_4
    boxed = tmp_3
    tmp_5 = load boxed+0 as i32
    !raw
    !boxed
    return tmp_5

@main() -> i32:
L_ENTRY:
    tmp_6 = 11
    EXPAND BOX_NEW tmp_7, tmp_6
    EXPAND BOX_INTO_RAW tmp_8, tmp_7
    raw = tmp_8
    EXPAND BOX_FROM_RAW tmp_10, raw
    tmp_9 = tmp_10
    boxed = tmp_9
    tmp_11 = load boxed+0 as i32
    result = tmp_11
    tmp_12 = call @sa_fmt_u64(result, 10)
    tmp_13 = call @sa_fmt_buffer_data(tmp_12)
    tmp_14 = call @sa_fmt_buffer_len(tmp_12)
    tmp_15 = tmp_13
    call @sa_print_bytes(&tmp_15, tmp_14)
    call @sa_fmt_buffer_free(^tmp_12)
    !tmp_15
    !tmp_14
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !raw
    !boxed
    return result

@test "rosetta 154 154_box_from_raw"():
L_TEST_ENTRY_0:
    tmp_16 = call @sla__box_from_raw_value()
    got = tmp_16
    tmp_17 = 11
    tmp_18 = ne got, tmp_17
    !tmp_17
    br tmp_18 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_18
    panic(154)

L_ELSE_2:
    !tmp_18
    jmp L_MERGE_3

L_MERGE_3:
