@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/mem.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_main = vtable { call = @main }
@main() -> i32:
L_ENTRY:
    data = alloc 4
    tmp_0 = 0
    tmp_1 = tmp_0 as u8
    EXPAND SLA_ARRAY_FILL_U8 data, tmp_1, 4
    !tmp_1
    tmp_2 = 7
    EXPAND SLA_ARRAY_FILL_U8 data, tmp_2, 4
    !tmp_2
    tmp_3 = 0
    tmp_4 = mul tmp_3, 1
    tmp_5 = ptr_add data, tmp_4
    !tmp_4
    !tmp_3
    tmp_6 = load tmp_5+0 as u8
    !tmp_5
    tmp_7 = call @sa_fmt_u64(tmp_6, 10)
    tmp_8 = call @sa_fmt_buffer_data(tmp_7)
    tmp_9 = call @sa_fmt_buffer_len(tmp_7)
    tmp_10 = tmp_8
    call @sa_print_bytes(&tmp_10, tmp_9)
    call @sa_fmt_buffer_free(^tmp_7)
    !tmp_10
    !tmp_9
    !tmp_6
    @const SLA_STR_0 = utf8:","
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_11 = 1
    tmp_12 = mul tmp_11, 1
    tmp_13 = ptr_add data, tmp_12
    !tmp_12
    !tmp_11
    tmp_14 = load tmp_13+0 as u8
    !tmp_13
    tmp_15 = call @sa_fmt_u64(tmp_14, 10)
    tmp_16 = call @sa_fmt_buffer_data(tmp_15)
    tmp_17 = call @sa_fmt_buffer_len(tmp_15)
    tmp_18 = tmp_16
    call @sa_print_bytes(&tmp_18, tmp_17)
    call @sa_fmt_buffer_free(^tmp_15)
    !tmp_18
    !tmp_17
    !tmp_14
    @const SLA_STR_1 = utf8:","
    call @sa_print_bytes(&SLA_STR_1, 1)
    tmp_19 = 2
    tmp_20 = mul tmp_19, 1
    tmp_21 = ptr_add data, tmp_20
    !tmp_20
    !tmp_19
    tmp_22 = load tmp_21+0 as u8
    !tmp_21
    tmp_23 = call @sa_fmt_u64(tmp_22, 10)
    tmp_24 = call @sa_fmt_buffer_data(tmp_23)
    tmp_25 = call @sa_fmt_buffer_len(tmp_23)
    tmp_26 = tmp_24
    call @sa_print_bytes(&tmp_26, tmp_25)
    call @sa_fmt_buffer_free(^tmp_23)
    !tmp_26
    !tmp_25
    !tmp_22
    @const SLA_STR_2 = utf8:","
    call @sa_print_bytes(&SLA_STR_2, 1)
    tmp_27 = 3
    tmp_28 = mul tmp_27, 1
    tmp_29 = ptr_add data, tmp_28
    !tmp_28
    !tmp_27
    tmp_30 = load tmp_29+0 as u8
    !tmp_29
    tmp_31 = call @sa_fmt_u64(tmp_30, 10)
    tmp_32 = call @sa_fmt_buffer_data(tmp_31)
    tmp_33 = call @sa_fmt_buffer_len(tmp_31)
    tmp_34 = tmp_32
    call @sa_print_bytes(&tmp_34, tmp_33)
    call @sa_fmt_buffer_free(^tmp_31)
    !tmp_34
    !tmp_33
    !tmp_30
    @const SLA_STR_3 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_3, 1)
    tmp_35 = 0
    !data
    return tmp_35

@test "rosetta 054 mem fill"():
L_TEST_ENTRY_0:
    data = alloc 4
    tmp_36 = 0
    tmp_37 = tmp_36 as u8
    EXPAND SLA_ARRAY_FILL_U8 data, tmp_37, 4
    !tmp_37
    tmp_38 = 7
    EXPAND SLA_ARRAY_FILL_U8 data, tmp_38, 4
