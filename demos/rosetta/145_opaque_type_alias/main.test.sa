@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_item_make = vtable { call = @sla__item_make }
@const SLA_FNPTR_VT_opaque_alias_make_value = vtable { call = @sla__opaque_alias_make_value }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__item_make() -> i32:
L_ENTRY:
    tmp_0 = 5
    return tmp_0

@sla__opaque_alias_make_value() -> i32:
L_ENTRY:
    tmp_1 = call @sla__item_make()
    return tmp_1

@main() -> i32:
L_ENTRY:
    tmp_2 = call @sla__opaque_alias_make_value()
    result = tmp_2
    tmp_3 = call @sa_fmt_u64(result, 10)
    tmp_4 = call @sa_fmt_buffer_data(tmp_3)
    tmp_5 = call @sa_fmt_buffer_len(tmp_3)
    tmp_6 = tmp_4
    call @sa_print_bytes(&tmp_6, tmp_5)
    call @sa_fmt_buffer_free(^tmp_3)
    !tmp_6
    !tmp_5
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 145 145_opaque_type_alias"():
L_TEST_ENTRY_0:
    tmp_7 = call @sla__opaque_alias_make_value()
    got = tmp_7
    tmp_8 = 5
    tmp_9 = ne got, tmp_8
    !tmp_8
    br tmp_9 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_9
    panic(145)

L_ELSE_2:
    !tmp_9
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

