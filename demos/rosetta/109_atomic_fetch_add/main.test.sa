@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/sync/atomic.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/sync/atomic.sa"
@const SLA_FNPTR_VT_atomic_fetch_add_sum = vtable { call = @sla__atomic_fetch_add_sum }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__atomic_fetch_add_sum() -> i32:
L_ENTRY:
    tmp_0 = 5
    value = stack_alloc AtomicI32_SIZE
    EXPAND ATOMIC_I32_INIT value, tmp_0
    !tmp_0
    tmp_1 = 3
    EXPAND ATOMIC_I32_FETCH_ADD tmp_2, value, tmp_1, seq_cst
    !tmp_1
    old = tmp_2
    EXPAND ATOMIC_I32_LOAD tmp_3, value, seq_cst
    new = tmp_3
    tmp_4 = add old, new
    return tmp_4

@main() -> i32:
L_ENTRY:
    tmp_5 = 5
    value = stack_alloc AtomicI32_SIZE
    EXPAND ATOMIC_I32_INIT value, tmp_5
    !tmp_5
    tmp_6 = 3
    EXPAND ATOMIC_I32_FETCH_ADD tmp_7, value, tmp_6, seq_cst
    !tmp_6
    old = tmp_7
    EXPAND ATOMIC_I32_LOAD tmp_8, value, seq_cst
    new = tmp_8
    tmp_9 = add old, new
    result = tmp_9
    tmp_10 = call @sa_fmt_u64(result, 10)
    tmp_11 = call @sa_fmt_buffer_data(tmp_10)
    tmp_12 = call @sa_fmt_buffer_len(tmp_10)
    tmp_13 = tmp_11
    call @sa_print_bytes(&tmp_13, tmp_12)
    call @sa_fmt_buffer_free(^tmp_10)
    !tmp_13
    !tmp_12
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !old
    !new
    return result

@test "rosetta 109 109_atomic_fetch_add"():
L_TEST_ENTRY_0:
    tmp_14 = call @sla__atomic_fetch_add_sum()
    got = tmp_14
    tmp_15 = 13
    tmp_16 = ne got, tmp_15
    !tmp_15
    br tmp_16 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_16
    panic(109)

L_ELSE_2:
    !tmp_16
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

