@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn parse_ok() -> Result<i32, i32> {
    Ok(7)
}

fn main() -> i32 {
    let value = parse_ok().unwrap();
    println("{}", value + 5);
    return 0;
}

@test "rosetta 050 error chain"() {
    let value = parse_ok().unwrap();
    if value + 5 != 12 {
        panic(50);
    };
}
