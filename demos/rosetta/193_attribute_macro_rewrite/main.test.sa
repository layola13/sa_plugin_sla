@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_rewrite_value_surrogate = vtable { call = @sla__rewrite_value_surrogate }
@const SLA_FNPTR_VT_attribute_macro_rewrite_value = vtable { call = @sla__attribute_macro_rewrite_value }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__rewrite_value_surrogate(rewrite_input: i32) -> i32:
L_ENTRY:
    return rewrite_input

@sla__attribute_macro_rewrite_value() -> i32:
L_ENTRY:
    tmp_0 = 2
    value = tmp_0
    tmp_1 = call @sla__rewrite_value_surrogate(value)
    rewritten_value = tmp_1
    !value
    return rewritten_value

@main() -> i32:
L_ENTRY:
    tmp_2 = call @sla__attribute_macro_rewrite_value()
    result = tmp_2
    tmp_3 = call @sa_fmt_u64(result, 10)
    tmp_4 = call @sa_fmt_buffer_data(tmp_3)
    tmp_5 = call @sa_fmt_buffer_len(tmp_3)
    tmp_6 = tmp_4
    call @sa_print_bytes(&tmp_6, tmp_5)
    call @sa_fmt_buffer_free(^tmp_3)
    !tmp_6
    !tmp_5
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 193 193_attribute_macro_rewrite"():
L_TEST_ENTRY_0:
    tmp_7 = call @sla__attribute_macro_rewrite_value()
    got = tmp_7
    tmp_8 = 2
    tmp_9 = ne got, tmp_8
    !tmp_8
    br tmp_9 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_9
    panic(193)

L_ELSE_2:
    !tmp_9
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

