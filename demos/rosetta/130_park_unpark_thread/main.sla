// Sla companion for SA rosetta demo 130 Park Unpark Thread.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_130_value() -> int {
    let total = 0;
    for i in 1..5 {
        total = total + i;
    }    let result = total + 20;
    return result;
};

fn main() -> int {
    let result = rosetta_130_value();
    return result;
};

@test "rosetta 130 130_park_unpark_thread"() {
    let got = rosetta_130_value();
    if got != 30 {
        panic(130);
    }