@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_assert_macro_result = vtable { call = @sla__assert_macro_result }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__assert_macro_result() -> i32:
L_ENTRY:
    tmp_0 = 1
    tmp_1 = 1
    tmp_2 = add tmp_0, tmp_1
    !tmp_0
    !tmp_1
    tmp_3 = 2
    tmp_4 = ne tmp_2, tmp_3
    !tmp_2
    !tmp_3
    br tmp_4 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_4
    panic(179)

L_ELSE_1:
    !tmp_4
    jmp L_MERGE_2

L_MERGE_2:
    tmp_7 = 2
    return tmp_7

@main() -> i32:
L_ENTRY:
    tmp_8 = 1
    tmp_9 = 1
    tmp_10 = add tmp_8, tmp_9
    !tmp_8
    !tmp_9
    tmp_11 = 2
    tmp_12 = ne tmp_10, tmp_11
    !tmp_10
    !tmp_11
    br tmp_12 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_12
    panic(179)

L_ELSE_4:
    !tmp_12
    jmp L_MERGE_5

L_MERGE_5:
    tmp_15 = 2
    result = tmp_15
    tmp_16 = call @sa_fmt_u64(result, 10)
    tmp_17 = call @sa_fmt_buffer_data(tmp_16)
    tmp_18 = call @sa_fmt_buffer_len(tmp_16)
    tmp_19 = tmp_17
    call @sa_print_bytes(&tmp_19, tmp_18)
    call @sa_fmt_buffer_free(^tmp_16)
    !tmp_19
    !tmp_18
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 179 179_assert_macro_expansion"():
L_TEST_ENTRY_6:
    tmp_20 = call @sla__assert_macro_result()
    got = tmp_20
    tmp_21 = 2
    tmp_22 = ne got, tmp_21
    !tmp_21
    br tmp_22 -> L_THEN_7, L_ELSE_8

L_THEN_7:
    !tmp_22
    panic(179)

L_ELSE_8:
    !tmp_22
    jmp L_MERGE_9

L_MERGE_9:
    !got
    return

