@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_exported_value = vtable { call = @sla__exported_value }
@const SLA_FNPTR_VT_internal_value = vtable { call = @sla__internal_value }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__exported_value() -> i32:
L_ENTRY:
    tmp_0 = 7
    return tmp_0

@sla__internal_value() -> i32:
L_ENTRY:
    tmp_1 = 5
    return tmp_1

@main() -> i32:
L_ENTRY:
    tmp_2 = call @sla__exported_value()
    left = tmp_2
    tmp_3 = call @sla__internal_value()
    right = tmp_3
    tmp_4 = add left, right
    total = tmp_4
    tmp_5 = call @sa_fmt_u64(total, 10)
    tmp_6 = call @sa_fmt_buffer_data(tmp_5)
    tmp_7 = call @sa_fmt_buffer_len(tmp_5)
    tmp_8 = tmp_6
    call @sa_print_bytes(&tmp_8, tmp_7)
    call @sa_fmt_buffer_free(^tmp_5)
    !tmp_8
    !tmp_7
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_9 = 0
    !right
    !left
    !total
    return tmp_9

@test "rosetta 042 export visibility"():
L_TEST_ENTRY_0:
    tmp_10 = call @sla__exported_value()
    left = tmp_10
    tmp_11 = call @sla__internal_value()
    right = tmp_11
    tmp_12 = add left, right
    total = tmp_12
    tmp_13 = 12
    tmp_14 = ne total, tmp_13
    !tmp_13
    br tmp_14 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_14
    panic(42)

L_ELSE_2:
    !tmp_14
    jmp L_MERGE_3

L_MERGE_3:
    !right
    !left
    !total
    return

