[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/sync/atomic.sal"
@import "sa_std/sync/atomic.sa"
@sla__rosetta_076_value() -> i32:
L_ENTRY:
    tmp_0 = 1
    counter = stack_alloc AtomicI32_SIZE
    EXPAND ATOMIC_I32_INIT counter, tmp_0
    !tmp_0
    tmp_1 = 2
    EXPAND ATOMIC_I32_FETCH_ADD tmp_2, counter, tmp_1, seq_cst
    !tmp_1
    !tmp_2
    EXPAND ATOMIC_I32_LOAD tmp_3, counter, seq_cst
    return tmp_3

@main() -> i32:
L_ENTRY:
    tmp_4 = call @sla__rosetta_076_value()
    value = tmp_4
    tmp_5 = call @sa_fmt_u64(value, 10)
    tmp_6 = call @sa_fmt_buffer_data(tmp_5)
