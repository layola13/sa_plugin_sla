@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/mem.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_fill_zero = vtable { call = @sla__fill_zero }
@const SLA_FNPTR_VT_zeroed_buffer_sum = vtable { call = @sla__zeroed_buffer_sum }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__fill_zero(arr: ptr) -> ptr:
L_ENTRY:
    tmp_0 = 0
    EXPAND SLA_ARRAY_FILL_U8 arr, tmp_0, 4
    !tmp_0
    return arr

@sla__zeroed_buffer_sum() -> i32:
L_ENTRY:
    buffer = alloc 4
    tmp_1 = 1
    tmp_2 = tmp_1 as u8
    store buffer+0, tmp_2 as u8
    tmp_3 = 2
    store buffer+1, tmp_3 as u8
    tmp_4 = 3
    store buffer+2, tmp_4 as u8
    tmp_5 = 4
    store buffer+3, tmp_5 as u8
    tmp_6 = call @sla__fill_zero(buffer)
    zeroed = tmp_6
    tmp_7 = 0
    tmp_8 = mul tmp_7, 1
    tmp_9 = ptr_add zeroed, tmp_8
    !tmp_8
    !tmp_7
    tmp_10 = load tmp_9+0 as u8
    !tmp_9
    tmp_11 = tmp_10 as i32
    tmp_12 = 1
    tmp_13 = mul tmp_12, 1
    tmp_14 = ptr_add zeroed, tmp_13
    !tmp_13
    !tmp_12
    tmp_15 = load tmp_14+0 as u8
    !tmp_14
    tmp_16 = tmp_15 as i32
    tmp_17 = add tmp_11, tmp_16
    !tmp_11
    !tmp_16
    tmp_18 = 2
    tmp_19 = mul tmp_18, 1
    tmp_20 = ptr_add zeroed, tmp_19
    !tmp_19
    !tmp_18
    tmp_21 = load tmp_20+0 as u8
    !tmp_20
    tmp_22 = tmp_21 as i32
    tmp_23 = add tmp_17, tmp_22
    !tmp_17
    !tmp_22
    tmp_24 = 3
    tmp_25 = mul tmp_24, 1
    tmp_26 = ptr_add zeroed, tmp_25
    !tmp_25
    !tmp_24
    tmp_27 = load tmp_26+0 as u8
    !tmp_26
    tmp_28 = tmp_27 as i32
    tmp_29 = add tmp_23, tmp_28
    !tmp_23
    !tmp_28
    !zeroed
    !buffer
    return tmp_29

@main() -> i32:
L_ENTRY:
    buffer = alloc 4
    tmp_30 = 1
    tmp_31 = tmp_30 as u8
    store buffer+0, tmp_31 as u8
    tmp_32 = 2
    store buffer+1, tmp_32 as u8
    tmp_33 = 3
    store buffer+2, tmp_33 as u8
    tmp_34 = 4
    store buffer+3, tmp_34 as u8
    tmp_35 = call @sla__fill_zero(buffer)
    zeroed = tmp_35
    @const SLA_STR_0 = utf8:"["
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_36 = 0
    tmp_37 = mul tmp_36, 1
    tmp_38 = ptr_add zeroed, tmp_37
    !tmp_37
    !tmp_36
    tmp_39 = load tmp_38+0 as u8
    !tmp_38
    tmp_40 = call @sa_fmt_u64(tmp_39, 10)
    tmp_41 = call @sa_fmt_buffer_data(tmp_40)
    tmp_42 = call @sa_fmt_buffer_len(tmp_40)
    tmp_43 = tmp_41
    call @sa_print_bytes(&tmp_43, tmp_42)
    call @sa_fmt_buffer_free(^tmp_40)
    !tmp_43
    !tmp_42
    !tmp_39
    @const SLA_STR_1 = utf8:","
    call @sa_print_bytes(&SLA_STR_1, 1)
    tmp_44 = 1
    tmp_45 = mul tmp_44, 1
    tmp_46 = ptr_add zeroed, tmp_45
    !tmp_45
    !tmp_44
    tmp_47 = load tmp_46+0 as u8
    !tmp_46
    tmp_48 = call @sa_fmt_u64(tmp_47, 10)
    tmp_49 = call @sa_fmt_buffer_data(tmp_48)
    tmp_50 = call @sa_fmt_buffer_len(tmp_48)
    tmp_51 = tmp_49
    call @sa_print_bytes(&tmp_51, tmp_50)
    call @sa_fmt_buffer_free(^tmp_48)
    !tmp_51
    !tmp_50
    !tmp_47
    @const SLA_STR_2 = utf8:","
    call @sa_print_bytes(&SLA_STR_2, 1)
    tmp_52 = 2
    tmp_53 = mul tmp_52, 1
    tmp_54 = ptr_add zeroed, tmp_53
    !tmp_53
    !tmp_52
    tmp_55 = load tmp_54+0 as u8
    !tmp_54
    tmp_56 = call @sa_fmt_u64(tmp_55, 10)
    tmp_57 = call @sa_fmt_buffer_data(tmp_56)
    tmp_58 = call @sa_fmt_buffer_len(tmp_56)
    tmp_59 = tmp_57
    call @sa_print_bytes(&tmp_59, tmp_58)
    call @sa_fmt_buffer_free(^tmp_56)
    !tmp_59
    !tmp_58
    !tmp_55
    @const SLA_STR_3 = utf8:","
    call @sa_print_bytes(&SLA_STR_3, 1)
    tmp_60 = 3
    tmp_61 = mul tmp_60, 1
    tmp_62 = ptr_add zeroed, tmp_61
    !tmp_61
    !tmp_60
    tmp_63 = load tmp_62+0 as u8
    !tmp_62
    tmp_64 = call @sa_fmt_u64(tmp_63, 10)
    tmp_65 = call @sa_fmt_buffer_data(tmp_64)
    tmp_66 = call @sa_fmt_buffer_len(tmp_64)
    tmp_67 = tmp_65
    call @sa_print_bytes(&tmp_67, tmp_66)
    call @sa_fmt_buffer_free(^tmp_64)
    !tmp_67
    !tmp_66
    !tmp_63
    @const SLA_STR_4 = utf8:"]"
    call @sa_print_bytes(&SLA_STR_4, 1)
    @const SLA_STR_5 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_5, 1)
    tmp_68 = 0
    !zeroed
    !buffer
    return tmp_68

@test "rosetta 004 04_loop"():
L_TEST_ENTRY_0:
    tmp_69 = call @sla__zeroed_buffer_sum()
    got = tmp_69
    tmp_70 = 0
    tmp_71 = ne got, tmp_70
    !tmp_70
    br tmp_71 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_71
    panic(4)

L_ELSE_2:
    !tmp_71
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

