// Sla companion for SA rosetta demo 114 Callback From C.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_114_value() -> int {
    let total = 0;
    for i in 1..5 {
        total = total + i;
    }    let result = total + 27;
    return result;
};

fn main() -> int {
    let result = rosetta_114_value();
    return result;
};

@test "rosetta 114 114_callback_from_c"() {
    let got = rosetta_114_value();
    if got != 37 {
        panic(114);
    }