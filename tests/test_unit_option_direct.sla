@import "sa_std/core/option.sa"

@test "direct option constructors and query methods"() {
    let some: Option<i32> = Some(7);
    let none: Option<i32> = None;

    if !some.is_some() { panic(31201); };
    if some.is_none() { panic(31202); };
    if none.is_some() { panic(31203); };
    if !none.is_none() { panic(31204); };
    if some.unwrap() != 7 { panic(31205); };
    if some.unwrap_or(9) != 7 { panic(31206); };
    if none.unwrap_or(9) != 9 { panic(31207); };
};
