@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn pkg_default_feature_count() -> i32 {
    let std_feature = 1;
    return std_feature;
}

fn main() -> i32 { let result = pkg_default_feature_count(); println("{}", result); return result; }
@test "rosetta 213 pkg default features"() { let got = pkg_default_feature_count(); if got != 1 { panic(213); }; }
