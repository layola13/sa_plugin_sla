@import "sa_std/future.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"
@import "sa_std/core/mem.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/option.sa"
@import "sa_std/vec.sa"
@sla__task_one() -> ptr:
L_ENTRY:
    tmp_0 = 1
    EXPAND FUTURE_READY_STATE_NEW tmp_1, tmp_0
    return tmp_1

@sla__task_two() -> ptr:
L_ENTRY:
    tmp_2 = 2
    EXPAND FUTURE_READY_STATE_NEW tmp_3, tmp_2
    return tmp_3

@sla__task_three() -> ptr:
L_ENTRY:
    tmp_4 = 3
    EXPAND FUTURE_READY_STATE_NEW tmp_5, tmp_4
    return tmp_5

@sla__rosetta_136_value() -> i32:
L_ENTRY:
    EXPAND VEC_NEW tmp_6
    tmp_7 = call @sla__task_one()
    EXPAND VEC_PUSH tmp_6, tmp_7, 8
    !tmp_7
    tmp_8 = call @sla__task_two()
    EXPAND VEC_PUSH tmp_6, tmp_8, 8
    !tmp_8
    tmp_9 = call @sla__task_three()
    EXPAND VEC_PUSH tmp_6, tmp_9, 8
    !tmp_9
    queue = tmp_6
    tmp_10 = 0
    total = tmp_10
    jmp L_WHILE_HEAD_0

L_WHILE_HEAD_0:
    tmp_13 = alloc 8
    tmp_11 = call @sa_vec_try_pop(&queue, &tmp_13)
    tmp_12 = load tmp_13+0 as u64
    !tmp_13
    br tmp_11 -> L_VEC_POP_SOME_4, L_VEC_POP_NONE_5

L_VEC_POP_SOME_4:
    !tmp_11
    EXPAND OPTION_NEW_SOME tmp_14, tmp_12
    !tmp_12
    jmp L_VEC_POP_END_6

L_VEC_POP_NONE_5:
    !tmp_11
    !tmp_12
    EXPAND OPTION_NEW_NONE tmp_14
    jmp L_VEC_POP_END_6

L_VEC_POP_END_6:
    EXPAND OPTION_IS_SOME tmp_15, tmp_14
    br tmp_15 -> L_WHILE_BODY_1, L_WHILE_COND_FALSE_2

L_WHILE_BODY_1:
    !tmp_15
    EXPAND OPTION_GET task, tmp_14
    !tmp_14
    EXPAND FUTURE_READY_STATE_INTO_INNER tmp_16, task
    !task
    tmp_17 = add total, tmp_16
    !tmp_16
    !total
    total = tmp_17
    jmp L_WHILE_HEAD_0

L_WHILE_COND_FALSE_2:
    !tmp_15
    !tmp_14
    jmp L_WHILE_EXIT_3

L_WHILE_EXIT_3:
    !queue
    return total

@main() -> i32:
L_ENTRY:
    tmp_18 = call @sla__rosetta_136_value()
    value = tmp_18
    tmp_19 = call @sa_fmt_u64(value, 10)
    tmp_20 = call @sa_fmt_buffer_data(tmp_19)
    tmp_21 = call @sa_fmt_buffer_len(tmp_19)
    tmp_22 = tmp_20
    call @sa_print_bytes(&tmp_22, tmp_21)
    call @sa_fmt_buffer_free(^tmp_19)
    !tmp_22
    !tmp_21
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return value

@test "rosetta 136 136_executor_task_queue"():
L_TEST_ENTRY_7:
    tmp_23 = call @sla__rosetta_136_value()
    got = tmp_23
    tmp_24 = 6
    tmp_25 = ne got, tmp_24
    !tmp_24
    br tmp_25 -> L_THEN_8, L_ELSE_9

L_THEN_8:
    !tmp_25
    panic(136)

L_ELSE_9:
    !tmp_25
    jmp L_MERGE_10

L_MERGE_10:
    !got
    return

