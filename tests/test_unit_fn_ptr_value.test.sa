@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/vec.sa"
@const SLA_FNPTR_VT_fn_ptr_inc = vtable { call = @sla__fn_ptr_inc }
@const SLA_FNPTR_VT_fn_ptr_apply = vtable { call = @sla__fn_ptr_apply }
@const SLA_FNPTR_VT_fn_ptr_false = vtable { call = @sla__fn_ptr_false }
@const SLA_FNPTR_VT_fn_ptr_true = vtable { call = @sla__fn_ptr_true }
@const SLA_FNPTR_VT_fn_ptr_holder_new = vtable { call = @sla__fn_ptr_holder_new }
@const SLA_FNPTR_VT_fn_ptr_vec_push = vtable { call = @sla__fn_ptr_vec_push }
@const SLA_FNPTR_VT_fn_ptr_generic_identity_i32 = vtable { call = @sla__fn_ptr_generic_identity_i32 }
@sla__fn_ptr_inc(x: i32) -> i32:
L_ENTRY:
    tmp_0 = 1
    tmp_1 = add x, tmp_0
    !tmp_0
    return tmp_1

@sla__fn_ptr_apply(f: ptr, value: i32) -> i32:
L_ENTRY:
    tmp_2 = load f+0 as ptr
    tmp_3 = call_indirect tmp_2(value)
    !tmp_2
    !f
    return tmp_3

@sla__fn_ptr_false(x: i32) -> u8:
L_ENTRY:
    tmp_4 = 0
    !x
    return tmp_4

@sla__fn_ptr_true(x: i32) -> u8:
L_ENTRY:
    tmp_5 = 1
    !x
    return tmp_5

@sla__fn_ptr_holder_new(f: ptr) -> ptr:
L_ENTRY:
    tmp_6 = alloc 8
    store tmp_6+0, f as ptr
    return tmp_6

@sla__fn_ptr_vec_push(values: ptr, f: ptr) -> ptr:
L_ENTRY:
    EXPAND VEC_PUSH values, f, 8
    !f
    return values

@sla__fn_ptr_generic_identity_i32(value: i32) -> i32:
L_ENTRY:
    return value

@test "function pointer can be stored and called"():
L_TEST_ENTRY_0:
    tmp_7 = &SLA_FNPTR_VT_fn_ptr_inc
    f = tmp_7
    tmp_8 = load f+0 as ptr
    tmp_9 = 4
    tmp_10 = call_indirect tmp_8(tmp_9)
    !tmp_8
    !tmp_9
    got = tmp_10
    tmp_11 = 5
    tmp_12 = ne got, tmp_11
    !tmp_11
    br tmp_12 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_12
    panic(1401)

L_ELSE_2:
    !tmp_12
    jmp L_MERGE_3

L_MERGE_3:
    !f
    !got
    return

@test "function pointer can be passed as argument"():
L_TEST_ENTRY_4:
    tmp_15 = &SLA_FNPTR_VT_fn_ptr_inc
    tmp_16 = 9
    tmp_17 = call @sla__fn_ptr_apply(tmp_15, tmp_16)
    !tmp_15
    !tmp_16
    got = tmp_17
    tmp_18 = 10
    tmp_19 = ne got, tmp_18
    !tmp_18
    br tmp_19 -> L_THEN_5, L_ELSE_6

L_THEN_5:
    !tmp_19
    panic(1402)

L_ELSE_6:
    !tmp_19
    jmp L_MERGE_7

L_MERGE_7:
    !got
    return

@test "generic function can be specialized as function pointer value"():
L_TEST_ENTRY_8:
    tmp_22 = &SLA_FNPTR_VT_fn_ptr_generic_identity_i32
    f = tmp_22
    tmp_23 = load f+0 as ptr
    tmp_24 = 12
    tmp_25 = call_indirect tmp_23(tmp_24)
    !tmp_23
    !tmp_24
    got = tmp_25
    tmp_26 = 12
    tmp_27 = ne got, tmp_26
    !tmp_26
    br tmp_27 -> L_THEN_9, L_ELSE_10

L_THEN_9:
    !tmp_27
    panic(1403)

L_ELSE_10:
    !tmp_27
    jmp L_MERGE_11

L_MERGE_11:
    !f
    !got
    return

@test "generic function specialization can be passed as argument"():
L_TEST_ENTRY_12:
    tmp_30 = &SLA_FNPTR_VT_fn_ptr_generic_identity_i32
    tmp_31 = 14
    tmp_32 = call @sla__fn_ptr_apply(tmp_30, tmp_31)
    !tmp_30
    !tmp_31
    got = tmp_32
    tmp_33 = 14
    tmp_34 = ne got, tmp_33
    !tmp_33
    br tmp_34 -> L_THEN_13, L_ELSE_14

L_THEN_13:
    !tmp_34
    panic(1404)

L_ELSE_14:
    !tmp_34
    jmp L_MERGE_15

L_MERGE_15:
    !got
    return

@test "function pointer survives struct return"():
L_TEST_ENTRY_16:
    tmp_37 = &SLA_FNPTR_VT_fn_ptr_true
    tmp_38 = call @sla__fn_ptr_holder_new(tmp_37)
    !tmp_37
    holder = tmp_38
    tmp_39 = load holder+0 as ptr
    f = tmp_39
    tmp_40 = load f+0 as ptr
    tmp_41 = 1
    tmp_42 = call_indirect tmp_40(tmp_41)
    !tmp_40
    !tmp_41
    tmp_43 = 1
    tmp_44 = ne tmp_42, tmp_43
    !tmp_42
    !tmp_43
    br tmp_44 -> L_THEN_17, L_ELSE_18

L_THEN_17:
    !tmp_44
    panic(1405)

L_ELSE_18:
    !tmp_44
    jmp L_MERGE_19

L_MERGE_19:
    !f
    !holder
    return

@test "function pointer survives vec push through function"():
L_TEST_ENTRY_20:
    EXPAND VEC_NEW tmp_47
    values = tmp_47
    tmp_48 = &SLA_FNPTR_VT_fn_ptr_false
    tmp_49 = call @sla__fn_ptr_vec_push(values, tmp_48)
    !tmp_48
    values1 = tmp_49
    tmp_50 = &SLA_FNPTR_VT_fn_ptr_true
    tmp_51 = call @sla__fn_ptr_vec_push(values1, tmp_50)
    !tmp_50
    values2 = tmp_51
    tmp_52 = 0
    EXPAND VEC_GET tmp_53, values2, tmp_52
    !tmp_52
    tmp_54 = tmp_53 as ptr
    f0 = tmp_54
    tmp_55 = 1
    EXPAND VEC_GET tmp_56, values2, tmp_55
    !tmp_55
    tmp_57 = tmp_56 as ptr
    f1 = tmp_57
    tmp_58 = load f0+0 as ptr
    tmp_59 = 2
    tmp_60 = call_indirect tmp_58(tmp_59)
    !tmp_58
    !tmp_59
    br tmp_60 -> L_THEN_21, L_ELSE_22

L_THEN_21:
    !tmp_60
    panic(1406)

L_ELSE_22:
    !tmp_60
    jmp L_MERGE_23

L_MERGE_23:
    tmp_63 = load f1+0 as ptr
    tmp_64 = 2
    tmp_65 = call_indirect tmp_63(tmp_64)
    !tmp_63
    !tmp_64
    tmp_66 = 1
    tmp_67 = ne tmp_65, tmp_66
    !tmp_65
    !tmp_66
    br tmp_67 -> L_THEN_24, L_ELSE_25

L_THEN_24:
    !tmp_67
    panic(1407)

L_ELSE_25:
    !tmp_67
    jmp L_MERGE_26

L_MERGE_26:
    !f1
    !values2
    !values
    !f0
    !values1
    return

