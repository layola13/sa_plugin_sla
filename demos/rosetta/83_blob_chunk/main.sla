@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn chunk_count(bytes: i32, chunk_size: i32) -> i32 {
    return (bytes + chunk_size - 1) / chunk_size;
}

fn main() -> i32 {
    let result = chunk_count(10, 4);
    println("{}", result);
    return result;
};

@test "rosetta 083 83_blob_chunk"() {
    let got = chunk_count(10, 4);
    if got != 3 {
        panic(83);
    };
};
