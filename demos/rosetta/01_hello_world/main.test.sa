@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_main = vtable { call = @main }
@main() -> i32:
L_ENTRY:
    @const SLA_STR_0 = utf8:"hello, saasm"
    call @sa_print_bytes(&SLA_STR_0, 12)
    @const SLA_STR_1 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_1, 1)
    tmp_0 = 0
    return tmp_0

@test "rosetta 001 01_hello_world"():
L_TEST_ENTRY_0:
    @const SLA_STR_2 = utf8:"hello, saasm"
    tmp_2 = 12
    tmp_1 = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW tmp_1, &SLA_STR_2, tmp_2
    !tmp_2
    @const SLA_STR_3 = utf8:"hello, saasm"
    tmp_4 = 12
    tmp_3 = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW tmp_3, &SLA_STR_3, tmp_4
    !tmp_4
    EXPAND STR_EQ tmp_5, tmp_1, tmp_3
    tmp_6 = 1
    tmp_7 = ne tmp_5, tmp_6
    !tmp_5
    !tmp_6
    br tmp_7 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_7
    panic(1)

L_ELSE_2:
    !tmp_7
    jmp L_MERGE_3

L_MERGE_3:
    return

