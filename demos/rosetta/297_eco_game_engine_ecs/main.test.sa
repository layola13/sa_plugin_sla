@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_eco_ecs_component_types = vtable { call = @sla__eco_ecs_component_types }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__eco_ecs_component_types() -> i32:
L_ENTRY:
    tmp_0 = 1
    transform = tmp_0
    tmp_1 = 1
    velocity = tmp_1
    tmp_2 = 1
    sprite = tmp_2
    tmp_3 = add transform, velocity
    tmp_4 = add tmp_3, sprite
    !tmp_3
    return tmp_4

@main() -> i32:
L_ENTRY:
    tmp_5 = 1
    transform = tmp_5
    tmp_6 = 1
    velocity = tmp_6
    tmp_7 = 1
    sprite = tmp_7
    tmp_8 = add transform, velocity
    tmp_9 = add tmp_8, sprite
    !tmp_8
    result = tmp_9
    tmp_10 = call @sa_fmt_u64(result, 10)
    tmp_11 = call @sa_fmt_buffer_data(tmp_10)
    tmp_12 = call @sa_fmt_buffer_len(tmp_10)
    tmp_13 = tmp_11
    call @sa_print_bytes(&tmp_13, tmp_12)
    call @sa_fmt_buffer_free(^tmp_10)
    !tmp_13
    !tmp_12
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !velocity
    !sprite
    !transform
    return result

@test "rosetta 297 eco game engine ecs"():
L_TEST_ENTRY_0:
    tmp_14 = call @sla__eco_ecs_component_types()
    got = tmp_14
    tmp_15 = 3
    tmp_16 = ne got, tmp_15
    !tmp_15
    br tmp_16 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_16
    panic(297)

L_ELSE_2:
    !tmp_16
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

