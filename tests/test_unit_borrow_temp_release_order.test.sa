    tmp_278 = 1
    EXPAND VEC_GET tmp_279, tmp_277, tmp_278
    !tmp_278
    !tmp_277
    tmp_280 = tmp_279 as ptr
    EXPAND ARC_GET tmp_281, tmp_280
    !tmp_280
    tmp_282 = &tmp_281
    cell = tmp_282
    tmp_283 = call @sla__borrow_refcell_read(cell)
    tmp_284 = add total, tmp_283
    !tmp_283
    !total
    total = tmp_284
    !cell
    !tmp_281
    jmp L_MERGE_78

L_MERGE_78:
    tmp_286 = 1
    tmp_287 = add i, tmp_286
    !tmp_286
    !i
    i = tmp_287
    jmp L_WHILE_HEAD_72

L_WHILE_COND_FALSE_74:
    !tmp_266
