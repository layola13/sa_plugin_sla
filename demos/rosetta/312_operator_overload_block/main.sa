    jmp L_MERGE_9

L_MERGE_9:
    tmp_55 = load c+4 as i32
    tmp_56 = 9
    tmp_57 = ne tmp_55, tmp_56
    !tmp_55
    !tmp_56
    br tmp_57 -> L_THEN_10, L_ELSE_11

L_THEN_10:
