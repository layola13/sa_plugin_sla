@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_asan_buffer_edge_sum = vtable { call = @sla__asan_buffer_edge_sum }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__asan_buffer_edge_sum() -> u8:
L_ENTRY:
    tmp_0 = 1
    first_byte = tmp_0
    tmp_1 = 4
    last_byte = tmp_1
    tmp_2 = add first_byte, last_byte
    !last_byte
    !first_byte
    return tmp_2

@main() -> i32:
L_ENTRY:
    tmp_3 = call @sla__asan_buffer_edge_sum()
    result = tmp_3
    tmp_4 = call @sa_fmt_u64(result, 10)
    tmp_5 = call @sa_fmt_buffer_data(tmp_4)
    tmp_6 = call @sa_fmt_buffer_len(tmp_4)
    tmp_7 = tmp_5
    call @sa_print_bytes(&tmp_7, tmp_6)
    call @sa_fmt_buffer_free(^tmp_4)
    !tmp_7
    !tmp_6
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_8 = 0
    !result
    return tmp_8

@test "rosetta 199 199_address_sanitizer_asan"():
L_TEST_ENTRY_0:
    tmp_9 = call @sla__asan_buffer_edge_sum()
    got = tmp_9
    tmp_10 = 5
    tmp_11 = ne got, tmp_10
    !tmp_10
    br tmp_11 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_11
    panic(199)

L_ELSE_2:
    !tmp_11
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

