@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn main() -> i32 {
    let values: [i32; 4] = [1, 2, 3, 4];
    let sum: i32 = values.iter().sum();
    println("{}", sum);
    return 0;
};

@test "rosetta 013 array sum"() {
    let values: [i32; 4] = [1, 2, 3, 4];
    let sum: i32 = values.iter().sum();
    if sum != 10 {
        panic(13);
    };
};
