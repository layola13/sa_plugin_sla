[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/box.sa"
@const SLA_FNPTR_VT_box_into_raw_value = vtable { call = @sla__box_into_raw_value }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__box_into_raw_value() -> i32:
L_ENTRY:
    tmp_0 = 9
    EXPAND BOX_NEW tmp_1, tmp_0
    boxed = tmp_1
    EXPAND BOX_INTO_RAW tmp_2, boxed
    raw = tmp_2
    tmp_4 = load raw+0 as i32
    tmp_3 = tmp_4
    value = tmp_3
    !raw
    return value

@main() -> i32:
L_ENTRY:
    tmp_5 = 9
    EXPAND BOX_NEW tmp_6, tmp_5
    boxed = tmp_6
    EXPAND BOX_INTO_RAW tmp_7, boxed
    raw = tmp_7
    tmp_9 = load raw+0 as i32
    tmp_8 = tmp_9
    result = tmp_8
    tmp_10 = call @sa_fmt_u64(result, 10)
