@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_walk_cost = vtable { call = @sla__walk_cost }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__walk_cost(graph: ptr) -> i32:
L_ENTRY:
    tmp_0 = 0
    tmp_1 = mul tmp_0, 8
    tmp_2 = ptr_add graph, tmp_1
    !tmp_1
    !tmp_0
    tmp_3 = load tmp_2+0 as ptr
    !tmp_2
    tmp_4 = load tmp_3+0 as i32
    tmp_5 = 0
    tmp_6 = mul tmp_5, 8
    tmp_7 = ptr_add graph, tmp_6
    !tmp_6
    !tmp_5
    tmp_8 = load tmp_7+0 as ptr
    !tmp_7
    tmp_9 = load tmp_8+4 as i32
    tmp_10 = add tmp_4, tmp_9
    !tmp_4
    !tmp_9
    tmp_11 = 0
    tmp_12 = mul tmp_11, 8
    tmp_13 = ptr_add graph, tmp_12
    !tmp_12
    !tmp_11
    tmp_14 = load tmp_13+0 as ptr
    !tmp_13
    tmp_15 = load tmp_14+8 as i32
    tmp_16 = add tmp_10, tmp_15
    !tmp_10
    !tmp_15
    tmp_17 = 1
    tmp_18 = mul tmp_17, 8
    tmp_19 = ptr_add graph, tmp_18
    !tmp_18
    !tmp_17
    tmp_20 = load tmp_19+0 as ptr
    !tmp_19
    tmp_21 = load tmp_20+4 as i32
    tmp_22 = add tmp_16, tmp_21
    !tmp_16
    !tmp_21
    tmp_23 = 1
    tmp_24 = mul tmp_23, 8
    tmp_25 = ptr_add graph, tmp_24
    !tmp_24
    !tmp_23
    tmp_26 = load tmp_25+0 as ptr
    !tmp_25
    tmp_27 = load tmp_26+8 as i32
    tmp_28 = add tmp_22, tmp_27
    !tmp_22
    !tmp_27
    !graph
    return tmp_28

@main() -> i32:
L_ENTRY:
    graph = alloc 16
    tmp_29 = alloc 12
    tmp_30 = 0
    store tmp_29+0, tmp_30 as i32
    tmp_31 = 1
    store tmp_29+4, tmp_31 as i32
    tmp_32 = 3
    store tmp_29+8, tmp_32 as i32
    store graph+0, tmp_29 as ptr
    tmp_33 = alloc 12
    tmp_34 = 1
    store tmp_33+0, tmp_34 as i32
    tmp_35 = 2
    store tmp_33+4, tmp_35 as i32
    tmp_36 = 5
    store tmp_33+8, tmp_36 as i32
    store graph+8, tmp_33 as ptr
    tmp_37 = call @sla__walk_cost(graph)
    total = tmp_37
    tmp_38 = call @sa_fmt_u64(total, 10)
    tmp_39 = call @sa_fmt_buffer_data(tmp_38)
    tmp_40 = call @sa_fmt_buffer_len(tmp_38)
    tmp_41 = tmp_39
    call @sa_print_bytes(&tmp_41, tmp_40)
    call @sa_fmt_buffer_free(^tmp_38)
    !tmp_41
    !tmp_40
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !graph
    return total

@test "rosetta 072 72_graph_walk"():
L_TEST_ENTRY_0:
    tmp_42 = call @main()
    tmp_43 = 11
    tmp_44 = ne tmp_42, tmp_43
    !tmp_42
    !tmp_43
    br tmp_44 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_44
    panic(72)

L_ELSE_2:
    !tmp_44
    jmp L_MERGE_3

L_MERGE_3:
    return

