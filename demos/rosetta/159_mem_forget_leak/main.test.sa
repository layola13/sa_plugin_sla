@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/box.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_mem_forget_observable_value = vtable { call = @sla__mem_forget_observable_value }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__mem_forget_observable_value() -> i32:
L_ENTRY:
    tmp_0 = 9
    EXPAND BOX_NEW tmp_1, tmp_0
    value = tmp_1
    tmp_2 = load value+0 as i32
    !value
    return tmp_2

@main() -> i32:
L_ENTRY:
    tmp_3 = call @sla__mem_forget_observable_value()
    result = tmp_3
    tmp_4 = call @sa_fmt_u64(result, 10)
    tmp_5 = call @sa_fmt_buffer_data(tmp_4)
    tmp_6 = call @sa_fmt_buffer_len(tmp_4)
    tmp_7 = tmp_5
    call @sa_print_bytes(&tmp_7, tmp_6)
    call @sa_fmt_buffer_free(^tmp_4)
    !tmp_7
    !tmp_6
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 159 159_mem_forget_leak"():
L_TEST_ENTRY_0:
    tmp_8 = call @sla__mem_forget_observable_value()
    got = tmp_8
    tmp_9 = 9
    tmp_10 = ne got, tmp_9
    !tmp_9
    br tmp_10 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_10
