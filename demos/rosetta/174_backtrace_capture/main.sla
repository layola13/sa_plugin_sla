// Sla companion for SA rosetta demo 174 Backtrace Capture.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_174_value() -> int {
    let total = 0;
    for i in 1..9 {
        total = total + i;
    }    let result = total + 18;
    return result;
};

fn main() -> int {
    let result = rosetta_174_value();
    return result;
};

@test "rosetta 174 174_backtrace_capture"() {
    let got = rosetta_174_value();
    if got != 54 {
        panic(174);
    }