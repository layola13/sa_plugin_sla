// Sla companion for SA rosetta demo 084 Sync Gate.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_084_value() -> int {
    let seed = 19;
    let shifted = seed + 84;
    let scaled = shifted * 5;
    let result = scaled - 20;
    return result;
};

fn main() -> int {
    let result = rosetta_084_value();
    return result;
};

@test "rosetta 084 84_sync_gate"() {
    let got = rosetta_084_value();
    if got != 495 {
        panic(84);
    };
