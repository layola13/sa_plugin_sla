@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/sync/atomic.sa"
@import "sa_std/core/box.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/box.sa"
@const SLA_FNPTR_VT_hazard_pointer_result = vtable { call = @sla__hazard_pointer_result }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__hazard_pointer_result() -> i32:
L_ENTRY:
    tmp_0 = 9
    EXPAND BOX_NEW tmp_1, tmp_0
    EXPAND BOX_INTO_RAW tmp_2, tmp_1
    raw = tmp_2
    shared = stack_alloc AtomicPtr_SIZE
    EXPAND ATOMIC_PTR_INIT shared, raw
    EXPAND ATOMIC_PTR_LOAD tmp_3, shared, acquire
    loaded = tmp_3
    hazard = stack_alloc AtomicPtr_SIZE
    EXPAND ATOMIC_PTR_INIT hazard, loaded
    EXPAND ATOMIC_PTR_LOAD tmp_4, hazard, acquire
    tmp_5 = eq tmp_4, loaded
    !tmp_4
    still_protected = tmp_5
    tmp_6 = 1
    tmp_7 = eq still_protected, tmp_6
    !tmp_6
    tmp_8 = alloc 4
    br tmp_7 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_7
    tmp_9 = 1
    store tmp_8+0, tmp_9 as i32
    !tmp_9
    jmp L_MERGE_2

L_ELSE_1:
    !tmp_7
    tmp_10 = 0
    store tmp_8+0, tmp_10 as i32
    !tmp_10
    jmp L_MERGE_2

L_MERGE_2:
    tmp_11 = load tmp_8+0 as i32
    !tmp_8
    protected = tmp_11
    tmp_13 = load loaded+0 as i32
    tmp_12 = tmp_13
    tmp_14 = add tmp_12, protected
    !tmp_12
    result = tmp_14
    EXPAND ATOMIC_PTR_LOAD tmp_16, shared, acquire
    EXPAND BOX_FROM_RAW tmp_17, tmp_16
    !tmp_16
    tmp_15 = tmp_17
    boxed = tmp_15
    !still_protected
    !raw
    !loaded
    !protected
    !boxed
    return result

@main() -> i32:
L_ENTRY:
    tmp_18 = call @sla__hazard_pointer_result()
    result = tmp_18
    tmp_19 = call @sa_fmt_u64(result, 10)
    tmp_20 = call @sa_fmt_buffer_data(tmp_19)
    tmp_21 = call @sa_fmt_buffer_len(tmp_19)
    tmp_22 = tmp_20
    call @sa_print_bytes(&tmp_22, tmp_21)
    call @sa_fmt_buffer_free(^tmp_19)
    !tmp_22
    !tmp_21
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 127 127_hazard_pointers"():
L_TEST_ENTRY_3:
    tmp_23 = call @sla__hazard_pointer_result()
    got = tmp_23
    tmp_24 = 10
    tmp_25 = ne got, tmp_24
    !tmp_24
    br tmp_25 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_25
    panic(127)

L_ELSE_5:
    !tmp_25
    jmp L_MERGE_6

L_MERGE_6:
    !got
    return

