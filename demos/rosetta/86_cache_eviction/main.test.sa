@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/mem.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/vec.sa"
@sla__rosetta_086_value() -> i32:
L_ENTRY:
    EXPAND VEC_NEW tmp_0
    tmp_1 = 10
    EXPAND VEC_PUSH tmp_0, tmp_1, 8
    !tmp_1
    tmp_2 = 20
    EXPAND VEC_PUSH tmp_0, tmp_2, 8
    !tmp_2
    tmp_3 = 30
    EXPAND VEC_PUSH tmp_0, tmp_3, 8
    !tmp_3
    cache = tmp_0
    tmp_4 = 0
    EXPAND VEC_REMOVE tmp_5, tmp_6, cache, tmp_4, 8
    br tmp_5 -> L_VEC_REMOVE_OK_0, L_VEC_REMOVE_OOB_1

L_VEC_REMOVE_OOB_1:
    panic(86)

L_VEC_REMOVE_OK_0:
    !tmp_5
    !tmp_4
    tmp_7 = tmp_6 as i32
    !tmp_7
    tmp_8 = 0
    EXPAND VEC_GET tmp_9, cache, tmp_8
    !tmp_8
    tmp_10 = tmp_9 as i32
    !cache
    return tmp_10

@main() -> i32:
L_ENTRY:
    tmp_11 = call @sla__rosetta_086_value()
    value = tmp_11
    tmp_12 = call @sa_fmt_u64(value, 10)
    tmp_13 = call @sa_fmt_buffer_data(tmp_12)
    tmp_14 = call @sa_fmt_buffer_len(tmp_12)
    tmp_15 = tmp_13
    call @sa_print_bytes(&tmp_15, tmp_14)
    call @sa_fmt_buffer_free(^tmp_12)
    !tmp_15
    !tmp_14
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return value

@test "rosetta 086 86_cache_eviction"():
L_TEST_ENTRY_2:
    tmp_16 = call @sla__rosetta_086_value()
    got = tmp_16
    tmp_17 = 20
    tmp_18 = ne got, tmp_17
    !tmp_17
    br tmp_18 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_18
    panic(86)

L_ELSE_4:
    !tmp_18
    jmp L_MERGE_5

L_MERGE_5:
    !got
    return

