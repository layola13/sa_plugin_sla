@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_create_point = vtable { call = @sla__create_point }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__create_point(x: i32, y: i32) -> ptr:
L_ENTRY:
    tmp_0 = alloc 8
    store tmp_0+0, x as i32
    store tmp_0+4, y as i32
    return tmp_0

@main() -> i32:
L_ENTRY:
    tmp_1 = 10
    tmp_2 = 20
    tmp_3 = call @sla__create_point(tmp_1, tmp_2)
    !tmp_1
    !tmp_2
    point = tmp_3
    @const SLA_STR_0 = utf8:"("
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_4 = load point+0 as i32
    tmp_5 = call @sa_fmt_u64(tmp_4, 10)
    tmp_6 = call @sa_fmt_buffer_data(tmp_5)
    tmp_7 = call @sa_fmt_buffer_len(tmp_5)
    tmp_8 = tmp_6
    call @sa_print_bytes(&tmp_8, tmp_7)
    call @sa_fmt_buffer_free(^tmp_5)
    !tmp_8
    !tmp_7
    !tmp_4
    @const SLA_STR_1 = utf8:","
    call @sa_print_bytes(&SLA_STR_1, 1)
    tmp_9 = load point+4 as i32
    tmp_10 = call @sa_fmt_u64(tmp_9, 10)
    tmp_11 = call @sa_fmt_buffer_data(tmp_10)
    tmp_12 = call @sa_fmt_buffer_len(tmp_10)
    tmp_13 = tmp_11
    call @sa_print_bytes(&tmp_13, tmp_12)
    call @sa_fmt_buffer_free(^tmp_10)
    !tmp_13
    !tmp_12
    !tmp_9
    @const SLA_STR_2 = utf8:")"
    call @sa_print_bytes(&SLA_STR_2, 1)
    @const SLA_STR_3 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_3, 1)
    tmp_14 = 0
    !point
    return tmp_14

@test "rosetta 005 05_struct"():
L_TEST_ENTRY_0:
    tmp_15 = 10
    tmp_16 = 20
    tmp_17 = call @sla__create_point(tmp_15, tmp_16)
    !tmp_15
    !tmp_16
    point = tmp_17
    tmp_18 = load point+0 as i32
    x = tmp_18
    tmp_19 = load point+4 as i32
    y = tmp_19
    tmp_20 = add x, y
    tmp_21 = 30
    tmp_22 = ne tmp_20, tmp_21
    !tmp_20
    !tmp_21
    br tmp_22 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_22
    panic(5)

L_ELSE_2:
    !tmp_22
    jmp L_MERGE_3

L_MERGE_3:
    !x
    !y
    !point
    return

