// Sla companion for SA rosetta demo 218 Pkg Metadata Custom.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_218_value() -> int {
    let total = 0;
    for i in 1..5 {
        total = total + i;
    }    let result = total + 16;
    return result;
};

fn main() -> int {
    let result = rosetta_218_value();
    return result;
};

@test "rosetta 218 218_pkg_metadata_custom"() {
    let got = rosetta_218_value();
    if got != 26 {
        panic(218);
    }