@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn scene_nodes_sum() -> i32 {
    let nodes = [4, 5, 6];
    return nodes.iter().sum();
}

fn main() -> i32 {
    let nodes = [4, 5, 6];
    println("{}", nodes.iter().sum());
    return 0;
}

@test "rosetta 073 73_scene_nodes"() {
    let got = scene_nodes_sum();
    if got != 15 {
        panic(73);
    };
}
