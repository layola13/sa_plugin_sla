@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn resource_pool_value() -> i32 {
    let pool = [10, 20, 30];
    return pool[1];
}

fn main() -> i32 {
    let value = resource_pool_value();
    println("{}", value);
    return 0;
}

@test "rosetta 067 67_resource_pool"() {
    let got = resource_pool_value();
    if got != 20 {
        panic(67);
    };
}
