@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_transparent_repr_inner = vtable { call = @sla__transparent_repr_inner }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__transparent_repr_inner() -> i32:
L_ENTRY:
    tmp_0 = alloc 4
    tmp_1 = 7
    store tmp_0+0, tmp_1 as i32
    !tmp_1
    tmp_2 = load tmp_0+0 as i32
    value = tmp_2
    return value

@main() -> i32:
L_ENTRY:
    tmp_3 = alloc 4
    tmp_4 = 7
    store tmp_3+0, tmp_4 as i32
    !tmp_4
    tmp_5 = load tmp_3+0 as i32
    result = tmp_5
    tmp_6 = call @sa_fmt_u64(result, 10)
    tmp_7 = call @sa_fmt_buffer_data(tmp_6)
    tmp_8 = call @sa_fmt_buffer_len(tmp_6)
    tmp_9 = tmp_7
    call @sa_print_bytes(&tmp_9, tmp_8)
    call @sa_fmt_buffer_free(^tmp_6)
    !tmp_9
    !tmp_8
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 148 148_transparent_repr"():
L_TEST_ENTRY_0:
    tmp_10 = call @sla__transparent_repr_inner()
    got = tmp_10
    tmp_11 = 7
    tmp_12 = ne got, tmp_11
    !tmp_11
    br tmp_12 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_12
    panic(148)

L_ELSE_2:
    !tmp_12
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

