    tmp_130 = 0
    tmp_131 = ptr_add encoded, tmp_130
    tmp_132 = load tmp_131+0 as u8
    EXPAND STRING_BUF_PUSH_BYTE tmp_129, tmp_132
    !tmp_130
    !tmp_131
    !tmp_132
    tmp_133 = 1
    tmp_134 = ptr_add encoded, tmp_133
    tmp_135 = load tmp_134+0 as u8
    EXPAND STRING_BUF_PUSH_BYTE tmp_129, tmp_135
    !tmp_133
    !tmp_134
    !tmp_135
    tmp_136 = 2
    tmp_137 = ptr_add encoded, tmp_136
    tmp_138 = load tmp_137+0 as u8
    EXPAND STRING_BUF_PUSH_BYTE tmp_129, tmp_138
    !tmp_136
    !tmp_137
    !tmp_138
    tmp_139 = 3
    tmp_140 = ptr_add encoded, tmp_139
    tmp_141 = load tmp_140+0 as u8
