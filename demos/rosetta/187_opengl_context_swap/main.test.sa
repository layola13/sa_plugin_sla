@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/ptr.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_gl_make_current = vtable { call = @gl_make_current }
@const SLA_FNPTR_VT_gl_swap_buffers = vtable { call = @gl_swap_buffers }
@const SLA_FNPTR_VT_opengl_swap_result = vtable { call = @sla__opengl_swap_result }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@gl_make_current(ctx: ptr) -> i32:
L_ENTRY:
    tmp_0 = 0
    !ctx
    return tmp_0

@gl_swap_buffers(ctx: ptr) -> i32:
L_ENTRY:
    tmp_1 = 1
    !ctx
    return tmp_1

@sla__opengl_swap_result() -> i32:
L_ENTRY:
    EXPAND PTR_NULL tmp_2
    ctx = tmp_2
    tmp_3 = call @gl_make_current(ctx)
    _ = tmp_3
    tmp_4 = call @gl_swap_buffers(ctx)
    swapped = tmp_4
    !ctx
    !_
    return swapped

@main() -> i32:
L_ENTRY:
    tmp_5 = call @sla__opengl_swap_result()
    result = tmp_5
    tmp_6 = call @sa_fmt_u64(result, 10)
    tmp_7 = call @sa_fmt_buffer_data(tmp_6)
    tmp_8 = call @sa_fmt_buffer_len(tmp_6)
    tmp_9 = tmp_7
    call @sa_print_bytes(&tmp_9, tmp_8)
    call @sa_fmt_buffer_free(^tmp_6)
    !tmp_9
    !tmp_8
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 187 187_opengl_context_swap"():
L_TEST_ENTRY_0:
    tmp_10 = call @sla__opengl_swap_result()
    got = tmp_10
    tmp_11 = 1
    tmp_12 = ne got, tmp_11
    !tmp_11
    br tmp_12 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_12
    panic(187)

L_ELSE_2:
    !tmp_12
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

