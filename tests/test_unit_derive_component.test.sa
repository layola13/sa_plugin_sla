@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_derived_component_metadata_score = vtable { call = @sla__derived_component_metadata_score }
@const SLA_FNPTR_VT_derived_resource_metadata_score = vtable { call = @sla__derived_resource_metadata_score }
@sla__derived_component_metadata_score() -> i32:
L_ENTRY:
    tmp_0 = 927450922
    position_id = tmp_0
    tmp_1 = 927450922
    position_id_again = tmp_1
    tmp_2 = 252253522
    velocity_id = tmp_2
    tmp_3 = 0
    tmp_4 = sle position_id, tmp_3
    !tmp_3
    br tmp_4 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_4
    panic(9101)

L_ELSE_1:
    !tmp_4
    jmp L_MERGE_2

L_MERGE_2:
    tmp_7 = ne position_id, position_id_again
    br tmp_7 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_7
    panic(9102)

L_ELSE_4:
    !tmp_7
    jmp L_MERGE_5

L_MERGE_5:
    tmp_10 = eq position_id, velocity_id
    br tmp_10 -> L_THEN_6, L_ELSE_7

L_THEN_6:
    !tmp_10
    panic(9103)

L_ELSE_7:
    !tmp_10
    jmp L_MERGE_8

L_MERGE_8:
    tmp_13 = 0
    tmp_14 = 0
    tmp_15 = ne tmp_13, tmp_14
    !tmp_13
    !tmp_14
    br tmp_15 -> L_THEN_9, L_ELSE_10

L_THEN_9:
    !tmp_15
    panic(9104)

L_ELSE_10:
    !tmp_15
    jmp L_MERGE_11

L_MERGE_11:
    tmp_18 = 7
    !velocity_id
    !position_id_again
    !position_id
    return tmp_18

@sla__derived_resource_metadata_score() -> i32:
L_ENTRY:
    tmp_19 = 2064793383
    time_id = tmp_19
    tmp_20 = 2064793383
    time_id_again = tmp_20
    tmp_21 = 0
    tmp_22 = sle time_id, tmp_21
    !tmp_21
    br tmp_22 -> L_THEN_12, L_ELSE_13

L_THEN_12:
    !tmp_22
    panic(9111)

L_ELSE_13:
    !tmp_22
    jmp L_MERGE_14

L_MERGE_14:
    tmp_25 = ne time_id, time_id_again
    br tmp_25 -> L_THEN_15, L_ELSE_16

L_THEN_15:
    !tmp_25
    panic(9112)

L_ELSE_16:
    !tmp_25
    jmp L_MERGE_17

L_MERGE_17:
    tmp_28 = 927450922
    tmp_29 = eq time_id, tmp_28
    !tmp_28
    br tmp_29 -> L_THEN_18, L_ELSE_19

L_THEN_18:
    !tmp_29
    panic(9113)

L_ELSE_19:
    !tmp_29
    jmp L_MERGE_20

L_MERGE_20:
    tmp_32 = 11
    !time_id_again
    !time_id
    return tmp_32

@test "derive component exposes stable metadata"():
L_TEST_ENTRY_21:
    tmp_33 = call @sla__derived_component_metadata_score()
    tmp_34 = 7
    tmp_35 = ne tmp_33, tmp_34
    !tmp_33
    !tmp_34
    br tmp_35 -> L_THEN_22, L_ELSE_23

L_THEN_22:
    !tmp_35
    panic(9105)

L_ELSE_23:
    !tmp_35
    jmp L_MERGE_24

L_MERGE_24:
    return

@test "derive resource exposes stable metadata"():
L_TEST_ENTRY_25:
    tmp_38 = call @sla__derived_resource_metadata_score()
    tmp_39 = 11
    tmp_40 = ne tmp_38, tmp_39
    !tmp_38
    !tmp_39
    br tmp_40 -> L_THEN_26, L_ELSE_27

L_THEN_26:
