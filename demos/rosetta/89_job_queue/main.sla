fn rosetta_089_value() -> i32 {
    let queue = VecDeque::new();
    queue.push_back(5);
    queue.push_back(7);
    return queue.pop_front().unwrap() + queue.pop_front().unwrap();
}

fn main() -> i32 {
    let value = rosetta_089_value();
    println("{}", value);
    return value;
}

@test "rosetta 089 89_job_queue"() {
    let got = rosetta_089_value();
    if got != 12 {
        panic(89);
    };
}
