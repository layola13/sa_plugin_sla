fn rosetta_104_value() -> i32 {
    let left = Some(2);
    let middle = Some(3);
    let right = Some(4);

    let result = if let Some(x) = left && let Some(y) = middle && let Some(z) = right {
        x + y + z
    } else {
        0
    };

    return result;
}

fn main() -> i32 {
    let value = rosetta_104_value();
    println("{}", value);
    return value;
}

@test "rosetta 104 104_if_let_chains"() {
    let got = rosetta_104_value();
    if got != 9 {
        panic(104);
    };
}
