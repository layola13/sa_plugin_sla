@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
fn asan_buffer_edge_sum() -> u8 { let first_byte: u8 = 1; let last_byte: u8 = 4; return first_byte + last_byte; }
fn main() -> i32 { let result = asan_buffer_edge_sum(); println("{}", result); return 0; }
@test "rosetta 199 199_address_sanitizer_asan"() { let got = asan_buffer_edge_sum(); if got != 5 { panic(199); }; }
