@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
fn cfg_target_arch_len() -> usize { let arch_len: usize = 3; return arch_len; }
fn main() -> i32 { let result = cfg_target_arch_len(); println("{}", result); return 0; }
@test "rosetta 194 194_cfg_conditional_compilation"() { let got = cfg_target_arch_len(); if got != 3 { panic(194); }; }
