@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__Vec2_square_len(&self: ptr) -> i32:
L_ENTRY:
    tmp_0 = alloc 8
    tmp_1 = load self+0 as i32
    tmp_2 = load self+0 as i32
    tmp_3 = mul tmp_1, tmp_2
    store tmp_0+0, tmp_3 as i32
    tmp_4 = load self+4 as i32
    tmp_5 = mul tmp_1, tmp_4
    store tmp_0+4, tmp_5 as i32
    !tmp_1
    tmp_6 = load tmp_0+0 as i32
    xx = tmp_6
    tmp_7 = alloc 8
    tmp_8 = load self+4 as i32
    tmp_9 = load self+0 as i32
    tmp_10 = mul tmp_8, tmp_9
    store tmp_7+0, tmp_10 as i32
    tmp_11 = load self+4 as i32
    tmp_12 = mul tmp_8, tmp_11
    store tmp_7+4, tmp_12 as i32
    !tmp_8
    tmp_13 = load tmp_7+4 as i32
    yy = tmp_13
    tmp_14 = add xx, yy
    return tmp_14

@main() -> i32:
L_ENTRY:
    v = alloc 8
    tmp_15 = 3
    store v+0, tmp_15 as i32
    tmp_16 = 4
    store v+4, tmp_16 as i32
    tmp_17 = call @sla__Vec2_square_len(&v)
    tmp_18 = call @sa_fmt_u64(tmp_17, 10)
    tmp_19 = call @sa_fmt_buffer_data(tmp_18)
    tmp_20 = call @sa_fmt_buffer_len(tmp_18)
    tmp_21 = tmp_19
    call @sa_print_bytes(&tmp_21, tmp_20)
    call @sa_fmt_buffer_free(^tmp_18)
    !tmp_21
    !tmp_20
    !tmp_17
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_22 = 0
    !v
    return tmp_22

@test "rosetta 016 methods"():
L_TEST_ENTRY_0:
    v = alloc 8
    tmp_23 = 3
    store v+0, tmp_23 as i32
    tmp_24 = 4
    store v+4, tmp_24 as i32
    tmp_25 = call @sla__Vec2_square_len(&v)
    tmp_26 = 25
    tmp_27 = ne tmp_25, tmp_26
    !tmp_25
    !tmp_26
    br tmp_27 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_27
    panic(16)

L_ELSE_2:
    !tmp_27
    jmp L_MERGE_3

L_MERGE_3:
    !v
    return

