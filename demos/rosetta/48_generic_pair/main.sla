@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn pair_sum<T>(a: T, b: T) -> (T, T) {
    (a, b)
}

fn main() -> i32 {
    let pair = pair_sum(11, 31);
    println("{},{}", pair.0, pair.1);
    return 0;
}

@test "rosetta 048 generic pair"() {
    let pair = pair_sum(11, 31);
    if pair.0 != 11 {
        panic(48);
    };
    if pair.1 != 31 {
        panic(148);
    };
}
