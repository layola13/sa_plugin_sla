@test "vec field smart pointer index borrow releases owner temps"():
L_TEST_ENTRY_55:
    EXPAND VEC_NEW tmp_168
    items = tmp_168
    tmp_169 = alloc 8
    tmp_170 = 3
    store tmp_169+0, tmp_170 as i64
    !tmp_170
    EXPAND BOX_NEW tmp_171, tmp_169
    !tmp_169
    EXPAND VEC_PUSH items, tmp_171, 8
    !tmp_171
    tmp_172 = alloc 8
    tmp_173 = 4
    store tmp_172+0, tmp_173 as i64
    !tmp_173
    EXPAND BOX_NEW tmp_174, tmp_172
    !tmp_172
    EXPAND VEC_PUSH items, tmp_174, 8
    !tmp_174
    holder = alloc 8
    store holder+0, items as ptr
    tmp_175 = load holder+0 as ptr
    tmp_176 = 0
    EXPAND VEC_GET tmp_177, tmp_175, tmp_176
    !tmp_176
    !tmp_175
    tmp_178 = tmp_177 as ptr
    tmp_179 = &tmp_178
    first = tmp_179
    tmp_180 = load holder+0 as ptr
    tmp_181 = 1
    EXPAND VEC_GET tmp_182, tmp_180, tmp_181
    !tmp_181
    !tmp_180
    tmp_183 = tmp_182 as ptr
    tmp_184 = &tmp_183
    second = tmp_184
    tmp_185 = call @sla__borrow_read_box(first)
    tmp_186 = call @sla__borrow_read_box(second)
    tmp_187 = add tmp_185, tmp_186
    !tmp_185
    !tmp_186
    tmp_188 = 7
    tmp_189 = ne tmp_187, tmp_188
    !tmp_187
    !tmp_188
    br tmp_189 -> L_THEN_56, L_ELSE_57

L_THEN_56:
    !tmp_189
    panic(10)

L_ELSE_57:
    !tmp_189
    jmp L_MERGE_58

L_MERGE_58:
    !first
    !tmp_178
    !items
    !holder
    !second
    !tmp_183
    return

