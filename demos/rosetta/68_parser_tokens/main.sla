fn parser_token_count() -> usize {
    let tokens = ["let", "x", "=", "1"];
    return tokens.len();
}

fn main() -> i32 {
    let count = parser_token_count();
    println("{}", count);
    return 0;
}

@test "rosetta 068 68_parser_tokens"() {
    let got = parser_token_count();
    if got != 4 {
        panic(68);
    };
}
