fn rosetta_106_value() -> i32 {
    let value = Cell::new(10);
    let first = value.get();
    value.set(20);
    let second = value.get();
    return first + second;
}

fn main() -> i32 {
    let result = rosetta_106_value();
    println("{}", result);
    return result;
}

@test "rosetta 106 106_cell_interior_mut"() {
    let got = rosetta_106_value();
    if got != 30 {
        panic(106);
    };
};
