    tmp_116 = &tmp_115
    borrowed_rc = tmp_116
    tmp_117 = call @sla__borrow_read_rc(borrowed_rc)
    tmp_118 = add total, tmp_117
    !tmp_117
    !total
    total = tmp_118
    !borrowed_rc
    !tmp_115
