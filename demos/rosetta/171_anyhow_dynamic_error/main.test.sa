@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/result.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/result.sa"
@const SLA_FNPTR_VT_fail = vtable { call = @sla__fail }
@const SLA_FNPTR_VT_anyhow_fallback_value = vtable { call = @sla__anyhow_fallback_value }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__fail() -> ptr:
L_ENTRY:
    tmp_0 = 7
    EXPAND RESULT_NEW_ERR tmp_1, tmp_0
    !tmp_0
    return tmp_1

@sla__anyhow_fallback_value() -> i32:
L_ENTRY:
    tmp_2 = call @sla__fail()
    EXPAND RESULT_IS_OK tmp_3, tmp_2
    br tmp_3 -> L_RESULT_MAP_OK_0, L_RESULT_MAP_ERR_1

L_RESULT_MAP_OK_0:
    !tmp_3
    EXPAND RESULT_GET_OK tmp_5, tmp_2
    tmp_6 = 1
    tmp_7 = add tmp_5, tmp_6
    !tmp_6
    EXPAND RESULT_NEW_OK tmp_4, tmp_7
    !tmp_5
    !tmp_7
    jmp L_RESULT_MAP_END_2

L_RESULT_MAP_ERR_1:
    !tmp_3
    EXPAND RESULT_GET_ERR tmp_8, tmp_2
    EXPAND RESULT_NEW_ERR tmp_4, tmp_8
    !tmp_8
    jmp L_RESULT_MAP_END_2

L_RESULT_MAP_END_2:
    !tmp_2
    result = tmp_4
    tmp_9 = 0
    EXPAND RESULT_UNWRAP_OR tmp_10, result, tmp_9
    !tmp_9
    return tmp_10

@main() -> i32:
L_ENTRY:
    tmp_11 = call @sla__fail()
    EXPAND RESULT_IS_OK tmp_12, tmp_11
    br tmp_12 -> L_RESULT_MAP_OK_3, L_RESULT_MAP_ERR_4

L_RESULT_MAP_OK_3:
    !tmp_12
    EXPAND RESULT_GET_OK tmp_14, tmp_11
    tmp_15 = 1
    tmp_16 = add tmp_14, tmp_15
    !tmp_15
    EXPAND RESULT_NEW_OK tmp_13, tmp_16
    !tmp_14
    !tmp_16
    jmp L_RESULT_MAP_END_5

L_RESULT_MAP_ERR_4:
    !tmp_12
    EXPAND RESULT_GET_ERR tmp_17, tmp_11
    EXPAND RESULT_NEW_ERR tmp_13, tmp_17
    !tmp_17
    jmp L_RESULT_MAP_END_5

L_RESULT_MAP_END_5:
    !tmp_11
    tmp_18 = 0
    EXPAND RESULT_UNWRAP_OR tmp_19, tmp_13, tmp_18
    !tmp_13
    !tmp_18
    result = tmp_19
    tmp_20 = call @sa_fmt_u64(result, 10)
    tmp_21 = call @sa_fmt_buffer_data(tmp_20)
    tmp_22 = call @sa_fmt_buffer_len(tmp_20)
    tmp_23 = tmp_21
    call @sa_print_bytes(&tmp_23, tmp_22)
    call @sa_fmt_buffer_free(^tmp_20)
    !tmp_23
    !tmp_22
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 171 171_anyhow_dynamic_error"():
L_TEST_ENTRY_6:
    tmp_24 = call @sla__anyhow_fallback_value()
    got = tmp_24
    tmp_25 = 0
    tmp_26 = ne got, tmp_25
    !tmp_25
    br tmp_26 -> L_THEN_7, L_ELSE_8

L_THEN_7:
    !tmp_26
    panic(171)

L_ELSE_8:
    !tmp_26
    jmp L_MERGE_9

L_MERGE_9:
    !got
    return

