// Sla companion for SA rosetta demo 022 Break Continue.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_022_value() -> int {
    let total = 0;
    for i in 1..9 {
        total = total + i;
    }    let result = total + 27;
    return result;
};

fn main() -> int {
    let result = rosetta_022_value();
    return result;
};

@test "rosetta 022 22_break_continue"() {
    let got = rosetta_022_value();
    if got != 63 {
        panic(22);
    };
