@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/option.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/option.sa"
@const SLA_FNPTR_VT_main = vtable { call = @main }
@main() -> i32:
L_ENTRY:
    tmp_0 = 3
    EXPAND OPTION_NEW_SOME tmp_1, tmp_0
    !tmp_0
    EXPAND OPTION_IS_SOME tmp_2, tmp_1
    br tmp_2 -> L_OPTION_MAP_SOME_0, L_OPTION_MAP_NONE_1

L_OPTION_MAP_SOME_0:
    !tmp_2
    EXPAND OPTION_GET tmp_4, tmp_1
    tmp_5 = 5
    tmp_6 = add tmp_4, tmp_5
    !tmp_5
    EXPAND OPTION_NEW_SOME tmp_3, tmp_6
    !tmp_4
    !tmp_6
    jmp L_OPTION_MAP_END_2

L_OPTION_MAP_NONE_1:
    !tmp_2
    EXPAND OPTION_NEW_NONE tmp_3
    jmp L_OPTION_MAP_END_2

L_OPTION_MAP_END_2:
    !tmp_1
    tmp_7 = 0
    EXPAND OPTION_UNWRAP_OR tmp_8, tmp_3, tmp_7
    !tmp_3
    !tmp_7
    value = tmp_8
    tmp_9 = call @sa_fmt_u64(value, 10)
    tmp_10 = call @sa_fmt_buffer_data(tmp_9)
    tmp_11 = call @sa_fmt_buffer_len(tmp_9)
    tmp_12 = tmp_10
    call @sa_print_bytes(&tmp_12, tmp_11)
    call @sa_fmt_buffer_free(^tmp_9)
    !tmp_12
    !tmp_11
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_13 = 0
    !value
    return tmp_13

@test "rosetta 018 option map"():
L_TEST_ENTRY_3:
    tmp_14 = 3
    EXPAND OPTION_NEW_SOME tmp_15, tmp_14
    !tmp_14
    EXPAND OPTION_IS_SOME tmp_16, tmp_15
    br tmp_16 -> L_OPTION_MAP_SOME_4, L_OPTION_MAP_NONE_5

L_OPTION_MAP_SOME_4:
    !tmp_16
    EXPAND OPTION_GET tmp_18, tmp_15
    tmp_19 = 5
    tmp_20 = add tmp_18, tmp_19
    !tmp_19
    EXPAND OPTION_NEW_SOME tmp_17, tmp_20
    !tmp_18
    !tmp_20
    jmp L_OPTION_MAP_END_6

L_OPTION_MAP_NONE_5:
    !tmp_16
    EXPAND OPTION_NEW_NONE tmp_17
    jmp L_OPTION_MAP_END_6

L_OPTION_MAP_END_6:
    !tmp_15
    tmp_21 = 0
    EXPAND OPTION_UNWRAP_OR tmp_22, tmp_17, tmp_21
    !tmp_17
    !tmp_21
    value = tmp_22
    tmp_23 = 8
    tmp_24 = ne value, tmp_23
    !tmp_23
    br tmp_24 -> L_THEN_7, L_ELSE_8

L_THEN_7:
    !tmp_24
    panic(18)

L_ELSE_8:
    !tmp_24
    jmp L_MERGE_9

L_MERGE_9:
    !value
    return

