@test "距离平方公式 d^2=(x2-x1)^2+(y2-y1)^2 (0,0)-(3,4) == 25"() {
    let x1 = 0;
    let y1 = 0;
    let x2 = 3;
    let y2 = 4;
    let dx = x2 - x1;
    let dy = y2 - y1;
    let d2 = (dx * dx) + (dy * dy);
    let ok = d2 == 25;
    if ok { } else { panic(1); };
}

