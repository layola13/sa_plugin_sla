@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_custom_dst_pointer_bytes_len_surrogate = vtable { call = @sla__custom_dst_pointer_bytes_len_surrogate }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__custom_dst_pointer_bytes_len_surrogate() -> u64:
L_ENTRY:
    @const SLA_STR_0 = utf8:"abc"
    tmp_0 = 3
    bytes = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW bytes, &SLA_STR_0, tmp_0
    !tmp_0
    EXPAND STRING_LEN tmp_1, bytes
    return tmp_1

@main() -> i32:
L_ENTRY:
    @const SLA_STR_1 = utf8:"abc"
    tmp_2 = 3
    bytes = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW bytes, &SLA_STR_1, tmp_2
    !tmp_2
    EXPAND STRING_LEN tmp_3, bytes
    result = tmp_3
    tmp_4 = call @sa_fmt_u64(result, 10)
    tmp_5 = call @sa_fmt_buffer_data(tmp_4)
    tmp_6 = call @sa_fmt_buffer_len(tmp_4)
    tmp_7 = tmp_5
    call @sa_print_bytes(&tmp_7, tmp_6)
    call @sa_fmt_buffer_free(^tmp_4)
    !tmp_7
    !tmp_6
    @const SLA_STR_2 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_2, 1)
    tmp_8 = 0
    !result
    return tmp_8

@test "rosetta 147 147_custom_dst_pointers"():
L_TEST_ENTRY_0:
    tmp_9 = call @sla__custom_dst_pointer_bytes_len_surrogate()
    got = tmp_9
    tmp_10 = 3
    tmp_11 = ne got, tmp_10
    !tmp_10
    br tmp_11 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_11
    panic(147)

L_ELSE_2:
    !tmp_11
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

