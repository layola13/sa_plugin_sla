[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_directory_module_endpoint_count = vtable { call = @sla__directory_module_endpoint_count }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__directory_module_endpoint_count() -> i32:
L_ENTRY:
    tmp_0 = 1
    index_route = tmp_0
    tmp_1 = 1
    health_route = tmp_1
    tmp_2 = add index_route, health_route
    return tmp_2

@main() -> i32:
L_ENTRY:
    tmp_3 = 1
    index_route = tmp_3
    tmp_4 = 1
    health_route = tmp_4
    tmp_5 = add index_route, health_route
    result = tmp_5
    tmp_6 = call @sa_fmt_u64(result, 10)
    tmp_7 = call @sa_fmt_buffer_data(tmp_6)
    tmp_8 = call @sa_fmt_buffer_len(tmp_6)
    tmp_9 = tmp_7
    call @sa_print_bytes(&tmp_9, tmp_8)
    call @sa_fmt_buffer_free(^tmp_6)
    !tmp_9
    !tmp_8
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !index_route
    !health_route
    return result

@test "rosetta 231 mod directory module"():
L_TEST_ENTRY_0:
    tmp_10 = call @sla__directory_module_endpoint_count()
    got = tmp_10
    tmp_11 = 2
    tmp_12 = ne got, tmp_11
    !tmp_11
    br tmp_12 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_12
    panic(231)

L_ELSE_2:
    !tmp_12
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

