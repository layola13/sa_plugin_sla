fn graph_walk_sum() -> i32 {
    let graph = [(0, 1), (1, 2)];
    let sum = graph[0].0 + graph[0].1 + graph[1].1;
    return sum;
}

fn main() -> i32 {
    let graph = [(0, 1), (1, 2)];
    let sum = graph[0].0 + graph[0].1 + graph[1].1;
    println("{}", sum);
    return 0;
}

@test "rosetta 072 72_graph_walk"() {
    let got = graph_walk_sum();
    if got != 3 {
        panic(72);
    };
}
