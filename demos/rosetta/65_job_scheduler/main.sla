fn job_scheduler_done() -> i32 {
    let jobs = [1, 2, 3, 4];
    let done = 0;
    for job in jobs {
        done += job;
    }
    return done;
}

fn main() -> i32 {
    let done = job_scheduler_done();
    println("{}", done);
    return 0;
}

@test "rosetta 065 65_job_scheduler"() {
    let got = job_scheduler_done();
    if got != 10 {
        panic(65);
    };
}
