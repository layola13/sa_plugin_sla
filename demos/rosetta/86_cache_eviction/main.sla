fn rosetta_086_value() -> i32 {
    let cache = vec(10, 20, 30);
    cache.remove(0);
    return cache[0];
}

fn main() -> i32 {
    let value = rosetta_086_value();
    println("{}", value);
    return value;
}

@test "rosetta 086 86_cache_eviction"() {
    let got = rosetta_086_value();
    if got != 20 {
        panic(86);
    };
}
