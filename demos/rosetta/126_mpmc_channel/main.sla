// Sla companion for SA rosetta demo 126 Mpmc Channel.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_126_value() -> int {
    let total = 0;
    for i in 1..9 {
        total = total + i;
    }
    let result = total + 16;
    return result;
}

fn main() -> int {
    let result = rosetta_126_value();
    return result;
};

@test "rosetta 126 126_mpmc_channel"() {
    let got = rosetta_126_value();
    if got != 52 {
        panic(126);
    };
};
