@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_sqlite_insert = vtable { call = @sqlite_insert }
@const SLA_FNPTR_VT_sqlite_insert_result_code = vtable { call = @sla__sqlite_insert_result_code }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sqlite_insert(row: ptr) -> i32:
L_ENTRY:
    tmp_0 = load row+4 as i32
    !row
    return tmp_0

@sla__sqlite_insert_result_code() -> i32:
L_ENTRY:
    row = alloc 12
    tmp_1 = 7
    store row+0, tmp_1 as i32
    tmp_2 = 1
    store row+4, tmp_2 as i32
    tmp_3 = 0
    store row+8, tmp_3 as i32
    tmp_5 = call @sqlite_insert(&row)
    tmp_4 = tmp_5
    code = tmp_4
    !row
    return code

@main() -> i32:
L_ENTRY:
    tmp_6 = call @sla__sqlite_insert_result_code()
    result = tmp_6
    tmp_7 = call @sa_fmt_u64(result, 10)
    tmp_8 = call @sa_fmt_buffer_data(tmp_7)
    tmp_9 = call @sa_fmt_buffer_len(tmp_7)
    tmp_10 = tmp_8
    call @sa_print_bytes(&tmp_10, tmp_9)
    call @sa_fmt_buffer_free(^tmp_7)
    !tmp_10
    !tmp_9
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 186 186_sqlite_c_api_binding"():
L_TEST_ENTRY_0:
    tmp_11 = call @sla__sqlite_insert_result_code()
    got = tmp_11
    tmp_12 = 1
    tmp_13 = ne got, tmp_12
    !tmp_12
    br tmp_13 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_13
    panic(186)

L_ELSE_2:
    !tmp_13
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

