@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
fn object_safe_draw_result() -> i32 { return 4; }
fn main() -> i32 { let result = object_safe_draw_result(); println("{}", result); return result; }
@test "rosetta 163 163_object_safety_rules"() { let got = object_safe_draw_result(); if got != 4 { panic(163); }; }
