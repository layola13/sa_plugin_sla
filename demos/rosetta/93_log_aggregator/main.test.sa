@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_severity_score = vtable { call = @sla__severity_score }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__severity_score(info: i32, warn: i32, error: i32) -> i32:
L_ENTRY:
    tmp_0 = 10
    tmp_1 = mul warn, tmp_0
    !tmp_0
    tmp_2 = add info, tmp_1
    !tmp_1
    tmp_3 = 100
    tmp_4 = mul error, tmp_3
    !tmp_3
    tmp_5 = add tmp_2, tmp_4
    !tmp_2
    !tmp_4
    !info
    !warn
    !error
    return tmp_5

@main() -> i32:
L_ENTRY:
    tmp_6 = 4
    tmp_7 = 2
    tmp_8 = 1
    tmp_9 = call @sla__severity_score(tmp_6, tmp_7, tmp_8)
    !tmp_6
    !tmp_7
    !tmp_8
    result = tmp_9
    tmp_10 = call @sa_fmt_u64(result, 10)
    tmp_11 = call @sa_fmt_buffer_data(tmp_10)
    tmp_12 = call @sa_fmt_buffer_len(tmp_10)
    tmp_13 = tmp_11
    call @sa_print_bytes(&tmp_13, tmp_12)
    call @sa_fmt_buffer_free(^tmp_10)
    !tmp_13
    !tmp_12
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 093 93_log_aggregator"():
L_TEST_ENTRY_0:
    tmp_14 = 4
    tmp_15 = 2
    tmp_16 = 1
    tmp_17 = call @sla__severity_score(tmp_14, tmp_15, tmp_16)
    !tmp_14
    !tmp_15
    !tmp_16
    got = tmp_17
    tmp_18 = 124
    tmp_19 = ne got, tmp_18
    !tmp_18
    br tmp_19 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_19
    panic(93)

L_ELSE_2:
    !tmp_19
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

