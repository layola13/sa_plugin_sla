@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_sa_asm_quine_source_len = vtable { call = @sa_asm_quine_source_len }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sa_asm_quine_source_len() -> u64:
L_ENTRY:
    @const SLA_STR_0 = utf8:"const SOURCE"
    tmp_0 = 12
    source = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW source, &SLA_STR_0, tmp_0
    !tmp_0
    EXPAND STRING_LEN tmp_1, source
    return tmp_1

@main() -> i32:
L_ENTRY:
    @const SLA_STR_1 = utf8:"const SOURCE"
    tmp_2 = 12
    source = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW source, &SLA_STR_1, tmp_2
    !tmp_2
    EXPAND STRING_PTR tmp_3, source
    EXPAND STRING_LEN tmp_4, source
    call @sa_print_bytes(&tmp_3, tmp_4)
    !tmp_3
    !tmp_4
    @const SLA_STR_2 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_2, 1)
    tmp_5 = 0
    return tmp_5

@test "rosetta 200 200_sa_asm_quine"():
L_TEST_ENTRY_0:
    tmp_6 = call @sa_asm_quine_source_len()
    got = tmp_6
    tmp_7 = 12
    tmp_8 = ne got, tmp_7
    !tmp_7
    br tmp_8 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_8
    panic(200)

L_ELSE_2:
    !tmp_8
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

