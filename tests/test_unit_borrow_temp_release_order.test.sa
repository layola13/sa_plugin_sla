@import "sa_std/core/box.sa"
@import "sa_std/core/cell.sa"
@import "sa_std/core/rc.sa"
@import "sa_std/core/arc.sa"
@import "sa_std/core/refcell.sa"
@import "sa_std/alloc/vec.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/rc.sa"
@import "sa_std/core/refcell.sa"
@import "sa_std/core/box.sa"
@import "sa_std/vec.sa"
@const SLA_FNPTR_VT_borrow_read_box = vtable { call = @sla__borrow_read_box }
@const SLA_FNPTR_VT_borrow_read_rc = vtable { call = @sla__borrow_read_rc }
@const SLA_FNPTR_VT_borrow_read_arc = vtable { call = @sla__borrow_read_arc }
@const SLA_FNPTR_VT_borrow_read_rc_box = vtable { call = @sla__borrow_read_rc_box }
@const SLA_FNPTR_VT_borrow_read_box_rc = vtable { call = @sla__borrow_read_box_rc }
@const SLA_FNPTR_VT_borrow_refcell_read = vtable { call = @sla__borrow_refcell_read }
@const SLA_FNPTR_VT_borrow_refcell_write = vtable { call = @sla__borrow_refcell_write }
@const SLA_FNPTR_VT_borrow_refcell_box_read = vtable { call = @sla__borrow_refcell_box_read }
@const SLA_FNPTR_VT_borrow_refcell_box_write = vtable { call = @sla__borrow_refcell_box_write }
@const SLA_FNPTR_VT_borrow_sum_box_rc_arc = vtable { call = @sla__borrow_sum_box_rc_arc }
@const SLA_FNPTR_VT_borrow_sum_refcell_box_pair = vtable { call = @sla__borrow_sum_refcell_box_pair }
@const SLA_FNPTR_VT_borrow_refcell_box_copy_increment = vtable { call = @sla__borrow_refcell_box_copy_increment }
@const SLA_FNPTR_VT_borrow_deep_return_value = vtable { call = @sla__borrow_deep_return_value }
@const SLA_FNPTR_VT_borrow_pick_index = vtable { call = @sla__borrow_pick_index }
@sla__borrow_read_box(item: ptr) -> i64:
L_ENTRY:
    tmp_0 = load item+0 as ptr
    tmp_1 = &tmp_0
    payload = tmp_1
    tmp_2 = load payload+0 as i64
    return tmp_2

@sla__borrow_read_rc(item: ptr) -> i64:
L_ENTRY:
    EXPAND RC_GET tmp_3, item
    tmp_4 = &tmp_3
    payload = tmp_4
    tmp_5 = load payload+0 as i64
    return tmp_5

@sla__borrow_read_arc(item: ptr) -> i64:
L_ENTRY:
    EXPAND ARC_GET tmp_6, item
    tmp_7 = &tmp_6
    payload = tmp_7
    tmp_8 = load payload+0 as i64
    return tmp_8

@sla__borrow_read_rc_box(item: ptr) -> i64:
L_ENTRY:
    EXPAND RC_GET tmp_9, item
    tmp_10 = &tmp_9
    boxed = tmp_10
    tmp_11 = load boxed+0 as ptr
    tmp_12 = &tmp_11
    payload = tmp_12
    tmp_13 = load payload+0 as i64
    return tmp_13

@sla__borrow_read_box_rc(item: ptr) -> i64:
L_ENTRY:
    tmp_14 = load item+0 as ptr
    tmp_15 = &tmp_14
    rc_value = tmp_15
    EXPAND RC_GET tmp_16, rc_value
    tmp_17 = &tmp_16
    payload = tmp_17
    tmp_18 = load payload+0 as i64
    return tmp_18

@sla__borrow_refcell_read(cell: ptr) -> i64:
L_ENTRY:
    EXPAND REFCELL_U64_TRY_BORROW tmp_19, tmp_20, cell
    br tmp_19 -> L_REFCELL_BORROW_END_1, L_REFCELL_BORROW_PANIC_0

L_REFCELL_BORROW_PANIC_0:
    !tmp_19
    panic(107)

L_REFCELL_BORROW_END_1:
    !tmp_19
    tmp_21 = load tmp_20+0 as ptr
    !tmp_20
    borrowed = tmp_21
    tmp_22 = load borrowed+0 as i64
    EXPAND REFCELL_U64_RELEASE_SHARED cell
    return tmp_22

@sla__borrow_refcell_write(cell: ptr, value: i64):
L_ENTRY:
    EXPAND REFCELL_U64_TRY_BORROW_MUT tmp_23, tmp_24, cell
    br tmp_23 -> L_REFCELL_BORROW_END_3, L_REFCELL_BORROW_PANIC_2

L_REFCELL_BORROW_PANIC_2:
    !tmp_23
    panic(107)

L_REFCELL_BORROW_END_3:
    !tmp_23
    tmp_25 = load tmp_24+0 as ptr
    !tmp_24
    borrowed = tmp_25
    store borrowed+0, value as i64
    EXPAND REFCELL_U64_RELEASE_MUT cell
    !borrowed
    return

@sla__borrow_refcell_box_read(cell: ptr) -> i64:
L_ENTRY:
    EXPAND REFCELL_U64_TRY_BORROW tmp_26, tmp_27, cell
    br tmp_26 -> L_REFCELL_BORROW_END_5, L_REFCELL_BORROW_PANIC_4

L_REFCELL_BORROW_PANIC_4:
    !tmp_26
    panic(107)

L_REFCELL_BORROW_END_5:
    !tmp_26
    tmp_28 = load tmp_27+0 as ptr
    !tmp_27
    borrowed_box = tmp_28
    tmp_29 = load borrowed_box+0 as ptr
    tmp_30 = &tmp_29
    payload = tmp_30
    tmp_31 = load payload+0 as i64
    EXPAND REFCELL_U64_RELEASE_SHARED cell
    return tmp_31

@sla__borrow_refcell_box_write(cell: ptr, value: i64):
L_ENTRY:
    EXPAND REFCELL_U64_TRY_BORROW_MUT tmp_32, tmp_33, cell
    br tmp_32 -> L_REFCELL_BORROW_END_7, L_REFCELL_BORROW_PANIC_6

L_REFCELL_BORROW_PANIC_6:
    !tmp_32
    panic(107)

L_REFCELL_BORROW_END_7:
    !tmp_32
    tmp_34 = load tmp_33+0 as ptr
    !tmp_33
    borrowed_box = tmp_34
    tmp_35 = load borrowed_box+0 as ptr
    tmp_36 = &tmp_35
    payload = tmp_36
    store payload+0, value as i64
    !payload
    !tmp_35
    EXPAND REFCELL_U64_RELEASE_MUT cell
    !borrowed_box
    return

@sla__borrow_sum_box_rc_arc(item_box: ptr, item_rc: ptr, item_arc: ptr) -> i64:
L_ENTRY:
    tmp_37 = call @sla__borrow_read_box(item_box)
    tmp_38 = call @sla__borrow_read_rc(item_rc)
    tmp_39 = add tmp_37, tmp_38
    !tmp_37
    !tmp_38
    tmp_40 = call @sla__borrow_read_arc(item_arc)
    tmp_41 = add tmp_39, tmp_40
    !tmp_39
    !tmp_40
    return tmp_41

@sla__borrow_sum_refcell_box_pair(left: ptr, right: ptr) -> i64:
L_ENTRY:
    tmp_42 = call @sla__borrow_refcell_box_read(left)
    tmp_43 = call @sla__borrow_refcell_box_read(right)
    tmp_44 = add tmp_42, tmp_43
    !tmp_42
    !tmp_43
    return tmp_44

@sla__borrow_refcell_box_copy_increment(dst: ptr, src: ptr):
L_ENTRY:
    tmp_45 = call @sla__borrow_refcell_box_read(src)
    value = tmp_45
    tmp_46 = 1
    tmp_47 = add value, tmp_46
    !tmp_46
    call @sla__borrow_refcell_box_write(dst, tmp_47)
    !tmp_47
    !value
    return

@sla__borrow_deep_return_value(flag: u8) -> i64:
L_ENTRY:
    holder = alloc 8
    tmp_48 = alloc 8
    tmp_49 = 61
    store tmp_48+0, tmp_49 as i64
    !tmp_49
    EXPAND BOX_NEW tmp_50, tmp_48
    !tmp_48
    EXPAND REFCELL_U64_NEW tmp_51, tmp_50
    !tmp_50
    EXPAND RC_NEW tmp_52, tmp_51
    !tmp_51
    EXPAND BOX_NEW tmp_53, tmp_52
    !tmp_52
    store holder+0, tmp_53 as ptr
    !tmp_53
    br flag -> L_THEN_8, L_ELSE_9

L_THEN_8:
    !flag
    tmp_54 = load holder+0 as ptr
    tmp_55 = load tmp_54+0 as ptr
    !tmp_54
    EXPAND RC_GET tmp_56, tmp_55
    !tmp_55
    tmp_57 = &tmp_56
    tmp_58 = call @sla__borrow_refcell_box_read(tmp_57)
    !tmp_57
    !tmp_56
    !holder
    return tmp_58

L_ELSE_9:
    !flag
    jmp L_MERGE_10

L_MERGE_10:
    tmp_60 = load holder+0 as ptr
    tmp_61 = load tmp_60+0 as ptr
    !tmp_60
    EXPAND RC_GET tmp_62, tmp_61
    !tmp_61
    tmp_63 = &tmp_62
    tmp_64 = 67
    call @sla__borrow_refcell_box_write(tmp_63, tmp_64)
    !tmp_63
    !tmp_62
    !tmp_64
    tmp_65 = load holder+0 as ptr
    tmp_66 = load tmp_65+0 as ptr
    !tmp_65
    EXPAND RC_GET tmp_67, tmp_66
    !tmp_66
    tmp_68 = &tmp_67
    tmp_69 = call @sla__borrow_refcell_box_read(tmp_68)
    !tmp_68
    !tmp_67
    !holder
    return tmp_69

@sla__borrow_pick_index(flag: u8) -> i64:
L_ENTRY:
    br flag -> L_THEN_11, L_ELSE_12

L_THEN_11:
    !flag
    tmp_70 = 1
    return tmp_70

L_ELSE_12:
    !flag
    jmp L_MERGE_13

L_MERGE_13:
    tmp_72 = 0
    return tmp_72

@test "borrowed field call argument releases before field owner temp"():
L_TEST_ENTRY_14:
    nested = alloc 8
    tmp_73 = alloc 8
    tmp_74 = alloc 8
    tmp_75 = 11
    store tmp_74+0, tmp_75 as i64
    !tmp_75
    EXPAND BOX_NEW tmp_76, tmp_74
    !tmp_74
    store tmp_73+0, tmp_76 as ptr
    !tmp_76
    store nested+0, tmp_73 as ptr
    !tmp_73
    tmp_77 = load nested+0 as ptr
    tmp_78 = load tmp_77+0 as ptr
    !tmp_77
    tmp_79 = &tmp_78
    tmp_80 = call @sla__borrow_read_box(tmp_79)
    !tmp_79
    !tmp_78
    tmp_81 = 11
    tmp_82 = ne tmp_80, tmp_81
    !tmp_80
    !tmp_81
    br tmp_82 -> L_THEN_15, L_ELSE_16

L_THEN_15:
    !tmp_82
    panic(1)

L_ELSE_16:
    !tmp_82
    jmp L_MERGE_17

L_MERGE_17:
    !nested
    return

@test "borrowed field temp releases across loop iterations"():
L_TEST_ENTRY_18:
    tmp_85 = 0
    total = tmp_85
    tmp_86 = 0
    i = tmp_86
    jmp L_WHILE_HEAD_19

L_WHILE_HEAD_19:
    tmp_87 = 4
    tmp_88 = slt i, tmp_87
    !tmp_87
    br tmp_88 -> L_WHILE_BODY_20, L_WHILE_COND_FALSE_21

L_WHILE_BODY_20:
    !tmp_88
    slot = alloc 8
    tmp_89 = alloc 8
    tmp_90 = alloc 8
    tmp_91 = 1
    tmp_92 = add i, tmp_91
    !tmp_91
    store tmp_90+0, tmp_92 as i64
    !tmp_92
    EXPAND BOX_NEW tmp_93, tmp_90
    !tmp_90
    store tmp_89+0, tmp_93 as ptr
    !tmp_93
    store slot+0, tmp_89 as ptr
    !tmp_89
    tmp_94 = load slot+0 as ptr
    tmp_95 = load tmp_94+0 as ptr
    !tmp_94
    tmp_96 = &tmp_95
    borrowed_box = tmp_96
    tmp_97 = load borrowed_box+0 as ptr
    tmp_98 = &tmp_97
    payload = tmp_98
    tmp_99 = load payload+0 as i64
    tmp_100 = add total, tmp_99
    !tmp_99
    !total
    total = tmp_100
    tmp_101 = 1
    tmp_102 = add i, tmp_101
    !tmp_101
    !i
    i = tmp_102
    !payload
    !tmp_97
    !borrowed_box
    !tmp_95
    !slot
    jmp L_WHILE_HEAD_19

L_WHILE_COND_FALSE_21:
    !tmp_88
    jmp L_WHILE_EXIT_22

L_WHILE_EXIT_22:
    tmp_103 = 10
    tmp_104 = ne total, tmp_103
    !tmp_103
    br tmp_104 -> L_THEN_23, L_ELSE_24

L_THEN_23:
    !tmp_104
    panic(2)

L_ELSE_24:
    !tmp_104
    jmp L_MERGE_25

L_MERGE_25:
    !i
    !total
    return

@test "borrowed field temp releases across branch merge"():
L_TEST_ENTRY_26:
    left = alloc 8
    tmp_107 = alloc 8
    tmp_108 = 7
    store tmp_107+0, tmp_108 as i64
    !tmp_108
    EXPAND RC_NEW tmp_109, tmp_107
    !tmp_107
    store left+0, tmp_109 as ptr
    !tmp_109
    right = alloc 8
    tmp_110 = alloc 8
    tmp_111 = 13
    store tmp_110+0, tmp_111 as i64
    !tmp_111
    EXPAND BOX_NEW tmp_112, tmp_110
    !tmp_110
    store right+0, tmp_112 as ptr
    !tmp_112
    tmp_113 = 0
    total = tmp_113
    tmp_114 = 1
    choose_left = tmp_114
