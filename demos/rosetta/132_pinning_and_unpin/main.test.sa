@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/pin.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_pinning_stability_score = vtable { call = @sla__pinning_stability_score }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__pinning_stability_score() -> i32:
L_ENTRY:
    tmp_0 = 8
    value = tmp_0
    pinned = stack_alloc 16
    EXPAND PIN_NEW pinned, value
    pinned_ref = stack_alloc 16
    EXPAND PIN_AS_REF pinned_ref, pinned
    EXPAND PIN_GET_REF tmp_1, pinned
    before = tmp_1
    EXPAND PIN_GET_REF tmp_2, pinned_ref
    after = tmp_2
    tmp_3 = eq before, after
    stable = tmp_3
    tmp_4 = 1
    tmp_5 = eq stable, tmp_4
    !tmp_4
    br tmp_5 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_5
    tmp_6 = 1
    tmp_7 = add value, tmp_6
    !tmp_6
    !before
    !after
    !stable
    return tmp_7

L_ELSE_1:
    !tmp_5
    !before
    !after
    !stable
    return value


@main() -> i32:
L_ENTRY:
    tmp_9 = 8
    value = tmp_9
    pinned = stack_alloc 16
    EXPAND PIN_NEW pinned, value
    pinned_ref = stack_alloc 16
    EXPAND PIN_AS_REF pinned_ref, pinned
    EXPAND PIN_GET_REF tmp_10, pinned
    before = tmp_10
    EXPAND PIN_GET_REF tmp_11, pinned_ref
    after = tmp_11
    tmp_12 = eq before, after
    stable = tmp_12
    tmp_13 = 1
    tmp_14 = eq stable, tmp_13
    !tmp_13
    tmp_15 = alloc 4
    br tmp_14 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_14
    tmp_16 = 1
    tmp_17 = add value, tmp_16
    !tmp_16
    store tmp_15+0, tmp_17 as i32
    !tmp_17
    jmp L_MERGE_5

L_ELSE_4:
    !tmp_14
    tmp_18 = add value, 0
    store tmp_15+0, tmp_18 as i32
    !tmp_18
    jmp L_MERGE_5

L_MERGE_5:
    tmp_19 = load tmp_15+0 as i32
    !tmp_15
    result = tmp_19
    tmp_20 = call @sa_fmt_u64(result, 10)
    tmp_21 = call @sa_fmt_buffer_data(tmp_20)
    tmp_22 = call @sa_fmt_buffer_len(tmp_20)
    tmp_23 = tmp_21
    call @sa_print_bytes(&tmp_23, tmp_22)
    call @sa_fmt_buffer_free(^tmp_20)
    !tmp_23
    !tmp_22
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !value
    !before
    !after
    !stable
    return result

@test "rosetta 132 132_pinning_and_unpin"():
L_TEST_ENTRY_6:
    tmp_24 = call @sla__pinning_stability_score()
    got = tmp_24
    tmp_25 = 9
    tmp_26 = ne got, tmp_25
    !tmp_25
    br tmp_26 -> L_THEN_7, L_ELSE_8

L_THEN_7:
    !tmp_26
    panic(132)

L_ELSE_8:
    !tmp_26
    jmp L_MERGE_9

L_MERGE_9:
    !got
    return

