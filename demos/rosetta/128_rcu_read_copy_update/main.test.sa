@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_rcu_snapshot_total = vtable { call = @sla__rcu_snapshot_total }
@const SLA_FNPTR_VT_rcu_read = vtable { call = @sla__rcu_read }
@const SLA_FNPTR_VT_rcu_update = vtable { call = @sla__rcu_update }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__rcu_snapshot_total() -> i32:
L_ENTRY:
    tmp_0 = 1
    tmp_1 = call @sla__rcu_read(tmp_0)
    !tmp_0
    old_snapshot = tmp_1
    tmp_2 = 1
    tmp_3 = call @sla__rcu_update(old_snapshot, tmp_2)
    !tmp_2
    new_snapshot = tmp_3
    tmp_4 = call @sla__rcu_read(new_snapshot)
    tmp_5 = add old_snapshot, tmp_4
    !tmp_4
    !new_snapshot
    !old_snapshot
    return tmp_5

@sla__rcu_read(snapshot: i32) -> i32:
L_ENTRY:
    return snapshot

@sla__rcu_update(snapshot: i32, delta: i32) -> i32:
L_ENTRY:
    tmp_6 = add snapshot, delta
    !delta
    !snapshot
    return tmp_6

@main() -> i32:
L_ENTRY:
    tmp_7 = call @sla__rcu_snapshot_total()
    result = tmp_7
    tmp_8 = call @sa_fmt_u64(result, 10)
    tmp_9 = call @sa_fmt_buffer_data(tmp_8)
    tmp_10 = call @sa_fmt_buffer_len(tmp_8)
    tmp_11 = tmp_9
    call @sa_print_bytes(&tmp_11, tmp_10)
    call @sa_fmt_buffer_free(^tmp_8)
    !tmp_11
    !tmp_10
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 128 128_rcu_read_copy_update"():
L_TEST_ENTRY_0:
    tmp_12 = call @sla__rcu_snapshot_total()
    got = tmp_12
    tmp_13 = 3
    tmp_14 = ne got, tmp_13
    !tmp_13
    br tmp_14 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_14
    panic(128)

L_ELSE_2:
    !tmp_14
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

