@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"

fn config_error_message(path: ptr) -> String {
    return format("invalid config: {}", path);
}

fn main() -> i32 {
    let err = config_error_message("oops");
    println("{}", err);
    return 0;
}

@test "rosetta 175 175_thiserror_macro_derive"() {
    let err = config_error_message("oops");
    if str_eq(err, "invalid config: oops") != true {
        panic(175);
    };
}
