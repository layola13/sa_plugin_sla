@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn pkg_dev_dependency_count() -> i32 {
    let test_only_dependency = 1;
    return test_only_dependency;
}

fn main() -> i32 { let result = pkg_dev_dependency_count(); println("{}", result); return result; }
@test "rosetta 208 pkg dev dependencies"() { let got = pkg_dev_dependency_count(); if got != 1 { panic(208); }; }
