@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/option.sa"
@import "sa_std/hashmap.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/option.sa"
@import "sa_std/hashmap.sa"

[MACRO] SLA_MAP_TRY_GET_OPTION %out_opt, %map_reg, %key_reg
    EXPAND MAP_TRY_GET __sla_map_get_ok_%out_opt, __sla_map_get_ptr_%out_opt, %map_reg, %key_reg
    br __sla_map_get_ok_%out_opt -> L_SLA_MAP_GET_SOME_%out_opt, L_SLA_MAP_GET_NONE_%out_opt
L_SLA_MAP_GET_SOME_%out_opt:
    EXPAND OPTION_NEW_SOME %out_opt, __sla_map_get_ptr_%out_opt
    !__sla_map_get_ptr_%out_opt
    !__sla_map_get_ok_%out_opt
    jmp L_SLA_MAP_GET_END_%out_opt
L_SLA_MAP_GET_NONE_%out_opt:
    EXPAND OPTION_NEW_NONE %out_opt
    !__sla_map_get_ptr_%out_opt
    !__sla_map_get_ok_%out_opt
L_SLA_MAP_GET_END_%out_opt:
[END_MACRO]

[MACRO] SLA_MAP_INSERT_OPTION_U64 %out_opt, %map_reg, %key_reg, %value_reg
    EXPAND MAP_INSERT __sla_map_insert_replaced_%out_opt, __sla_map_insert_old_ptr_%out_opt, %map_reg, %key_reg, %value_reg
    br __sla_map_insert_replaced_%out_opt -> L_SLA_MAP_INSERT_SOME_%out_opt, L_SLA_MAP_INSERT_NONE_%out_opt
L_SLA_MAP_INSERT_SOME_%out_opt:
    __sla_map_insert_old_value_%out_opt = load __sla_map_insert_old_ptr_%out_opt+0 as u64
    EXPAND OPTION_NEW_SOME %out_opt, __sla_map_insert_old_value_%out_opt
    !__sla_map_insert_old_value_%out_opt
    !__sla_map_insert_old_ptr_%out_opt
    !__sla_map_insert_replaced_%out_opt
    jmp L_SLA_MAP_INSERT_END_%out_opt
L_SLA_MAP_INSERT_NONE_%out_opt:
    EXPAND OPTION_NEW_NONE %out_opt
    !__sla_map_insert_old_ptr_%out_opt
    !__sla_map_insert_replaced_%out_opt
L_SLA_MAP_INSERT_END_%out_opt:
[END_MACRO]
@const SLA_FNPTR_VT_router_table_value = vtable { call = @sla__router_table_value }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__router_table_value() -> i32:
L_ENTRY:
    EXPAND MAP_NEW tmp_0
    router = tmp_0
    @const SLA_STR_0 = utf8:"/home"
    tmp_2 = 5
    tmp_1 = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW tmp_1, &SLA_STR_0, tmp_2
    !tmp_2
    tmp_3 = 1
    tmp_4 = stack_alloc 8
    store tmp_4+0, tmp_3 as u64
    !tmp_3
    EXPAND SLA_MAP_INSERT_OPTION_U64 tmp_5, router, tmp_1, tmp_4
    !tmp_5
    @const SLA_STR_1 = utf8:"/api"
    tmp_7 = 4
    tmp_6 = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW tmp_6, &SLA_STR_1, tmp_7
    !tmp_7
    tmp_8 = 2
    tmp_9 = stack_alloc 8
    store tmp_9+0, tmp_8 as u64
    !tmp_8
    EXPAND SLA_MAP_INSERT_OPTION_U64 tmp_10, router, tmp_6, tmp_9
    !tmp_10
    EXPAND MAP_GET tmp_11, router, tmp_6
    tmp_12 = ne tmp_11, 0
    br tmp_12 -> L_HASHMAP_INDEX_HIT_0, L_HASHMAP_INDEX_MISS_1

L_HASHMAP_INDEX_MISS_1:
    !tmp_12
    panic(404)

L_HASHMAP_INDEX_HIT_0:
    !tmp_12
    tmp_13 = load tmp_11+0 as i32
    !tmp_11
    EXPAND MAP_FREE router
    return tmp_13

@main() -> i32:
L_ENTRY:
    tmp_14 = call @sla__router_table_value()
    value = tmp_14
    tmp_15 = call @sa_fmt_u64(value, 10)
    tmp_16 = call @sa_fmt_buffer_data(tmp_15)
    tmp_17 = call @sa_fmt_buffer_len(tmp_15)
    tmp_18 = tmp_16
    call @sa_print_bytes(&tmp_18, tmp_17)
    call @sa_fmt_buffer_free(^tmp_15)
    !tmp_18
    !tmp_17
    @const SLA_STR_2 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_2, 1)
    return value

@test "rosetta 063 63_router_table"():
L_TEST_ENTRY_2:
    tmp_19 = call @sla__router_table_value()
    got = tmp_19
    tmp_20 = 2
    tmp_21 = ne got, tmp_20
    !tmp_20
    br tmp_21 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_21
    panic(63)

L_ELSE_4:
    !tmp_21
    jmp L_MERGE_5

L_MERGE_5:
    !got
    return

