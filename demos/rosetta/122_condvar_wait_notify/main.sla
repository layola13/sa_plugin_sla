// Sla companion for SA rosetta demo 122 Condvar Wait Notify.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_122_value() -> int {
    let total = 0;
    for i in 1..5 {
        total = total + i;
    }    let result = total + 12;
    return result;
};

fn main() -> int {
    let result = rosetta_122_value();
    return result;
};

@test "rosetta 122 122_condvar_wait_notify"() {
    let got = rosetta_122_value();
    if got != 22 {
        panic(122);
    }