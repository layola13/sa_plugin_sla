@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
fn file_descriptor_raw_fd() -> i32 { let raw_fd = 3; return raw_fd; }
fn main() -> i32 { let result = file_descriptor_raw_fd(); println("{}", result); return result; }
