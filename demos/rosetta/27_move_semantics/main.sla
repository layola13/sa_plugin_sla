@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

struct Data {
    value: i32,
}

fn consume(data: Data) -> i32 {
    data.value
}

fn main() -> i32 {
    let data = Data { value: 11 };
    println("{}", consume(data));
    return 0;
};

@test "rosetta 027 move semantics"() {
    let data = Data { value: 11 };
    let result: i32 = consume(data);
    if result != 11 {
        panic(27);
    };
};
