@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_merge = vtable { call = @sla__merge }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__merge(base: ptr, override_cfg: ptr) -> ptr:
L_ENTRY:
    tmp_0 = alloc 8
    tmp_1 = load override_cfg+0 as u32
    tmp_2 = 0
    tmp_3 = eq tmp_1, tmp_2
    !tmp_1
    !tmp_2
    tmp_4 = alloc 4
    br tmp_3 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_3
    tmp_5 = load base+0 as u32
    store tmp_4+0, tmp_5 as u32
    !tmp_5
    jmp L_MERGE_2

L_ELSE_1:
    !tmp_3
    tmp_6 = load override_cfg+0 as u32
    store tmp_4+0, tmp_6 as u32
    !tmp_6
    jmp L_MERGE_2

L_MERGE_2:
    tmp_7 = load tmp_4+0 as u32
    !tmp_4
    store tmp_0+0, tmp_7 as u32
    tmp_8 = load override_cfg+4 as u32
    tmp_9 = 0
    tmp_10 = eq tmp_8, tmp_9
    !tmp_8
    !tmp_9
    tmp_11 = alloc 4
    br tmp_10 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_10
    tmp_12 = load base+4 as u32
    store tmp_11+0, tmp_12 as u32
    !tmp_12
    jmp L_MERGE_5

L_ELSE_4:
    !tmp_10
    tmp_13 = load override_cfg+4 as u32
    store tmp_11+0, tmp_13 as u32
    !tmp_13
    jmp L_MERGE_5

L_MERGE_5:
    tmp_14 = load tmp_11+0 as u32
    !tmp_11
    store tmp_0+4, tmp_14 as u32
    return tmp_0

@main() -> i32:
L_ENTRY:
    tmp_15 = alloc 8
    tmp_16 = 4
    store tmp_15+0, tmp_16 as u32
    tmp_17 = 1
    store tmp_15+4, tmp_17 as u32
    tmp_18 = alloc 8
    tmp_19 = 0
    store tmp_18+0, tmp_19 as u32
    tmp_20 = 3
    store tmp_18+4, tmp_20 as u32
    tmp_21 = call @sla__merge(tmp_15, tmp_18)
    !tmp_15
    !tmp_18
    merged = tmp_21
    tmp_22 = load merged+0 as u32
    tmp_23 = call @sa_fmt_u64(tmp_22, 10)
    tmp_24 = call @sa_fmt_buffer_data(tmp_23)
    tmp_25 = call @sa_fmt_buffer_len(tmp_23)
    tmp_26 = tmp_24
    call @sa_print_bytes(&tmp_26, tmp_25)
    call @sa_fmt_buffer_free(^tmp_23)
    !tmp_26
    !tmp_25
    !tmp_22
    @const SLA_STR_0 = utf8:" "
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_27 = load merged+4 as u32
    tmp_28 = call @sa_fmt_u64(tmp_27, 10)
    tmp_29 = call @sa_fmt_buffer_data(tmp_28)
    tmp_30 = call @sa_fmt_buffer_len(tmp_28)
    tmp_31 = tmp_29
    call @sa_print_bytes(&tmp_31, tmp_30)
    call @sa_fmt_buffer_free(^tmp_28)
    !tmp_31
    !tmp_30
    !tmp_27
    @const SLA_STR_1 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_1, 1)
    tmp_32 = 0
    !merged
    return tmp_32

@test "rosetta 045 config merge"():
L_TEST_ENTRY_6:
    tmp_33 = alloc 8
    tmp_34 = 4
    store tmp_33+0, tmp_34 as u32
    tmp_35 = 1
    store tmp_33+4, tmp_35 as u32
    tmp_36 = alloc 8
    tmp_37 = 0
    store tmp_36+0, tmp_37 as u32
    tmp_38 = 3
    store tmp_36+4, tmp_38 as u32
    tmp_39 = call @sla__merge(tmp_33, tmp_36)
    !tmp_33
    !tmp_36
    merged = tmp_39
    tmp_40 = load merged+0 as u32
    tmp_41 = 4
    tmp_42 = ne tmp_40, tmp_41
    !tmp_40
    !tmp_41
    br tmp_42 -> L_THEN_7, L_ELSE_8

L_THEN_7:
    !tmp_42
    panic(45)

L_ELSE_8:
    !tmp_42
    jmp L_MERGE_9

L_MERGE_9:
    tmp_45 = load merged+4 as u32
    tmp_46 = 3
    tmp_47 = ne tmp_45, tmp_46
    !tmp_45
    !tmp_46
    br tmp_47 -> L_THEN_10, L_ELSE_11

L_THEN_10:
    !tmp_47
    panic(145)

L_ELSE_11:
    !tmp_47
    jmp L_MERGE_12

L_MERGE_12:
    !merged
    return

