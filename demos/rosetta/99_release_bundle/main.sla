@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

struct BundleManifest {
    binary: bool,
    config: bool,
    checksums: bool,
}

fn release_ready(manifest: BundleManifest) -> bool {
    if manifest.binary == true {
        if manifest.config == true {
            return manifest.checksums;
        };
    };
    return false;
}

fn main() -> i32 {
    let manifest = BundleManifest { binary: true, config: true, checksums: true };
    let result = release_ready(manifest);
    println("{}", result);
    return 0;
};

@test "rosetta 099 99_release_bundle"() {
    let manifest = BundleManifest { binary: true, config: true, checksums: true };
    let got = release_ready(manifest);
    if got != true {
        panic(99);
    };
};
