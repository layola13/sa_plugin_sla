@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
fn panic_hook_observable() -> i32 { let hook_printed = 1; return hook_printed; }
fn main() -> i32 { let result = panic_hook_observable(); println("{}", result); return result; }
@test "rosetta 178 178_panic_hook_override"() { let got = panic_hook_observable(); if got != 1 { panic(178); }; }
