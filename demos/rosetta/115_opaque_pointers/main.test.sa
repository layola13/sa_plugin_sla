@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/ptr.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_opaque_value = vtable { call = @opaque_value }
@const SLA_FNPTR_VT_opaque_pointer_result = vtable { call = @sla__opaque_pointer_result }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@opaque_value(ptr: ptr) -> i32:
L_ENTRY:
    tmp_0 = 0
    !ptr
    return tmp_0

@sla__opaque_pointer_result() -> i32:
L_ENTRY:
    EXPAND PTR_NULL tmp_1
    ptr = tmp_1
    tmp_3 = call @opaque_value(ptr)
    tmp_2 = tmp_3
    _ignored = tmp_2
    tmp_4 = 0
    !ptr
    !_ignored
    return tmp_4

@main() -> i32:
L_ENTRY:
    tmp_5 = call @sla__opaque_pointer_result()
    result = tmp_5
    tmp_6 = call @sa_fmt_u64(result, 10)
    tmp_7 = call @sa_fmt_buffer_data(tmp_6)
    tmp_8 = call @sa_fmt_buffer_len(tmp_6)
    tmp_9 = tmp_7
    call @sa_print_bytes(&tmp_9, tmp_8)
    call @sa_fmt_buffer_free(^tmp_6)
    !tmp_9
    !tmp_8
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 115 115_opaque_pointers"():
L_TEST_ENTRY_0:
    tmp_10 = call @sla__opaque_pointer_result()
    got = tmp_10
    tmp_11 = 0
    tmp_12 = ne got, tmp_11
    !tmp_11
    br tmp_12 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_12
    panic(115)

L_ELSE_2:
    !tmp_12
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

