@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/result.sa"
@import "sa_std/sync/mutex.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/result.sa"
@const SLA_FNPTR_VT_inspect = vtable { call = @sla__inspect }
@const SLA_FNPTR_VT_raii_guard_total = vtable { call = @sla__raii_guard_total }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__inspect(counter: ptr, skip: u8) -> i32:
L_ENTRY:
    EXPAND MUTEX_LOCK counter
    tmp_0 = ptr_add counter, Mutex_data
    EXPAND RESULT_NEW_OK tmp_1, tmp_0
    !tmp_0
    EXPAND RESULT_UNWRAP tmp_2, tmp_1
    !tmp_1
    guard = tmp_2
    br skip -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !skip
    tmp_3 = load guard+0 as i32
    value = tmp_3
    EXPAND MUTEX_UNLOCK counter
    !guard
    return value

L_ELSE_1:
    !skip
    jmp L_MERGE_2

L_MERGE_2:
    tmp_5 = load guard+0 as i32
    current = tmp_5
    tmp_6 = 3
    tmp_7 = add current, tmp_6
    !tmp_6
    updated = tmp_7
    store guard+0, updated as i32
    EXPAND MUTEX_UNLOCK counter
    !guard
    !current
    return updated

@sla__raii_guard_total() -> i32:
L_ENTRY:
    tmp_8 = 0
    EXPAND MUTEX_NEW_I32 tmp_9, tmp_8
    !tmp_8
    counter = tmp_9
    tmp_10 = 1
    tmp_11 = call @sla__inspect(&counter, tmp_10)
    !tmp_10
    first = tmp_11
    tmp_12 = 0
    tmp_13 = call @sla__inspect(&counter, tmp_12)
    !tmp_12
    second = tmp_13
    tmp_14 = add first, second
    !counter
    return tmp_14

@main() -> i32:
L_ENTRY:
    tmp_15 = 0
    EXPAND MUTEX_NEW_I32 tmp_16, tmp_15
    !tmp_15
    counter = tmp_16
    tmp_17 = 1
    tmp_18 = call @sla__inspect(&counter, tmp_17)
    !tmp_17
    first = tmp_18
    tmp_19 = 0
    tmp_20 = call @sla__inspect(&counter, tmp_19)
    !tmp_19
    second = tmp_20
    tmp_21 = add first, second
    result = tmp_21
    tmp_22 = call @sa_fmt_u64(result, 10)
    tmp_23 = call @sa_fmt_buffer_data(tmp_22)
    tmp_24 = call @sa_fmt_buffer_len(tmp_22)
    tmp_25 = tmp_23
    call @sa_print_bytes(&tmp_25, tmp_24)
    call @sa_fmt_buffer_free(^tmp_22)
    !tmp_25
    !tmp_24
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !first
    !counter
    !second
    return result

@test "rosetta 102 102_raii_guard"():
L_TEST_ENTRY_3:
    tmp_26 = call @sla__raii_guard_total()
    got = tmp_26
    tmp_27 = 3
    tmp_28 = ne got, tmp_27
    !tmp_27
    br tmp_28 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_28
    panic(102)

L_ELSE_5:
    !tmp_28
    jmp L_MERGE_6

L_MERGE_6:
    !got
    return

