@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn dynamically_sized_bytes_len() -> usize {
    let bytes_len: usize = 2;
    return bytes_len;
}

fn main() -> i32 { let result = dynamically_sized_bytes_len(); println("{}", result); return 0; }

@test "rosetta 141 141_dynamically_sized_types"() { let got = dynamically_sized_bytes_len(); if got != 2 { panic(141); }; }
