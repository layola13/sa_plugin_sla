@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_custom_drop_tally = vtable { call = @sla__custom_drop_tally }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__custom_drop_tally() -> i32:
L_ENTRY:
    tmp_0 = 0
    tally = tmp_0
    tmp_1 = 1
    outer_value = tmp_1
    tmp_2 = 10
    inner_value = tmp_2
    tmp_3 = 2
    tmp_4 = 3
    tmp_5 = add tmp_3, tmp_4
    !tmp_3
    !tmp_4
    result = tmp_5
    tmp_6 = add tally, inner_value
    !tally
    tally = tmp_6
    tmp_7 = add tally, outer_value
    !tally
    tally = tmp_7
    tmp_8 = add tally, result
    !outer_value
    !inner_value
    return tmp_8

@main() -> i32:
L_ENTRY:
    tmp_9 = call @sla__custom_drop_tally()
    result = tmp_9
    tmp_10 = call @sa_fmt_u64(result, 10)
    tmp_11 = call @sa_fmt_buffer_data(tmp_10)
    tmp_12 = call @sa_fmt_buffer_len(tmp_10)
    tmp_13 = tmp_11
    call @sa_print_bytes(&tmp_13, tmp_12)
    call @sa_fmt_buffer_free(^tmp_10)
    !tmp_13
    !tmp_12
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 101 101_custom_drop"():
L_TEST_ENTRY_0:
    tmp_14 = call @sla__custom_drop_tally()
    got = tmp_14
    tmp_15 = 16
    tmp_16 = ne got, tmp_15
    !tmp_15
    br tmp_16 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_16
    panic(101)

L_ELSE_2:
    !tmp_16
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

