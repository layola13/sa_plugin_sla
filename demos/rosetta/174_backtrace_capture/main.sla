@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
fn backtrace_depth() -> i32 { let captured_depth = 1; return captured_depth; }
fn main() -> i32 { let result = backtrace_depth(); println("{}", result); return result; }
@test "rosetta 174 174_backtrace_capture"() { let got = backtrace_depth(); if got != 1 { panic(174); }; }
