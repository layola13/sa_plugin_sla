@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_derived_annotation_score = vtable { call = @sla__derived_annotation_score }
@sla__DerivedAnnotationOne_metadata_score() -> i32:
L_ENTRY:
    tmp_0 = 7
    return tmp_0

@sla__DerivedAnnotationTwo_metadata_score() -> i32:
L_ENTRY:
    tmp_1 = 11
    return tmp_1

@sla__derived_annotation_score() -> i32:
L_ENTRY:
    one = alloc 4
    tmp_2 = 3
    store one+0, tmp_2 as i32
    !tmp_2
    two = alloc 8
    tmp_3 = 5
    store two+0, tmp_3 as i32
    !tmp_3
    tmp_4 = 9
    store two+4, tmp_4 as i32
    !tmp_4
    tmp_5 = load one+0 as i32
    tmp_6 = load two+0 as i32
    tmp_7 = add tmp_5, tmp_6
    !tmp_5
    !tmp_6
    tmp_8 = load two+4 as i32
    tmp_9 = add tmp_7, tmp_8
    !tmp_7
    !tmp_8
    tmp_10 = call @sla__DerivedAnnotationOne_metadata_score()
    tmp_11 = add tmp_9, tmp_10
    !tmp_9
    !tmp_10
    tmp_12 = call @sla__DerivedAnnotationTwo_metadata_score()
    tmp_13 = add tmp_11, tmp_12
    !tmp_11
    !tmp_12
    !one
    !two
    return tmp_13

@test "derive annotations are language-neutral"():
L_TEST_ENTRY_0:
    tmp_14 = call @sla__derived_annotation_score()
    tmp_15 = 35
    tmp_16 = ne tmp_14, tmp_15
    !tmp_14
    !tmp_15
    br tmp_16 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_16
    panic(9101)

L_ELSE_2:
    !tmp_16
    jmp L_MERGE_3

L_MERGE_3:
    return

