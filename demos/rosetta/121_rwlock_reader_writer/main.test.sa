    !tmp_27
    jmp L_RWLOCK_RESULT_END_8

L_RWLOCK_RESULT_END_8:
    !tmp_25
    !tmp_26
    EXPAND RESULT_UNWRAP tmp_29, tmp_28
    !tmp_28
    writer = tmp_29
    tmp_30 = load writer+0 as i32
    current = tmp_30
    tmp_31 = 2
    tmp_32 = add current, tmp_31
    !tmp_31
    updated = tmp_32
    store writer+0, updated as i32
    !updated
    EXPAND RWLOCK_RELEASE_WRITE tmp_24
    !tmp_24
    !writer
    !current
    EXPAND ARC_GET tmp_33, shared
    EXPAND RWLOCK_TRY_READ_NOERR tmp_34, tmp_35, tmp_33
    br tmp_34 -> L_RWLOCK_RESULT_OK_10, L_RWLOCK_RESULT_ERR_9

L_RWLOCK_RESULT_ERR_9:
    EXPAND RESULT_NEW_ERR tmp_37, 1
    jmp L_RWLOCK_RESULT_END_11

L_RWLOCK_RESULT_OK_10:
    tmp_36 = ptr_add tmp_33, RwLock_data
    EXPAND RESULT_NEW_OK tmp_37, tmp_36
    !tmp_36
    jmp L_RWLOCK_RESULT_END_11

L_RWLOCK_RESULT_END_11:
    !tmp_34
    !tmp_35
    EXPAND RESULT_UNWRAP tmp_38, tmp_37
    !tmp_37
    reader = tmp_38
    tmp_39 = load reader+0 as i32
    second = tmp_39
    tmp_40 = add first, second
    !cloned
    EXPAND RWLOCK_RELEASE_READ tmp_33
    !tmp_33
    !reader
    !shared
    return tmp_40

@main() -> i32:
L_ENTRY:
    tmp_41 = 1
    EXPAND RWLOCK_NEW_I32 tmp_42, tmp_41
    !tmp_41
    EXPAND ARC_NEW tmp_43, tmp_42
