@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__Counter_new(seed: i32) -> ptr:
L_ENTRY:
    tmp_0 = alloc 4
    tmp_1 = 2
    tmp_2 = add seed, tmp_1
    !tmp_1
    store tmp_0+0, tmp_2 as i32
    return tmp_0

@main() -> i32:
L_ENTRY:
    tmp_3 = 40
    tmp_4 = call @sla__Counter_new(tmp_3)
    !tmp_3
    counter = tmp_4
    tmp_5 = load counter+0 as i32
    tmp_6 = call @sa_fmt_u64(tmp_5, 10)
    tmp_7 = call @sa_fmt_buffer_data(tmp_6)
    tmp_8 = call @sa_fmt_buffer_len(tmp_6)
    tmp_9 = tmp_7
    call @sa_print_bytes(&tmp_9, tmp_8)
    call @sa_fmt_buffer_free(^tmp_6)
    !tmp_9
    !tmp_8
    !tmp_5
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_10 = 0
    !counter
    return tmp_10

@test "rosetta 017 associated fn"():
L_TEST_ENTRY_0:
    tmp_11 = 40
    tmp_12 = call @sla__Counter_new(tmp_11)
    !tmp_11
    counter = tmp_12
    tmp_13 = load counter+0 as i32
    tmp_14 = 42
    tmp_15 = ne tmp_13, tmp_14
    !tmp_13
    !tmp_14
    br tmp_15 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_15
    panic(17)

L_ELSE_2:
    !tmp_15
    jmp L_MERGE_3

L_MERGE_3:
    !counter
    return

