// Sla companion for SA rosetta demo 170 Marker Traits.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_170_value() -> int {
    let total = 0;
    for i in 1..5 {
        total = total + i;
    }    let result = total + 14;
    return result;
};

fn main() -> int {
    let result = rosetta_170_value();
    return result;
};

@test "rosetta 170 170_marker_traits"() {
    let got = rosetta_170_value();
    if got != 24 {
        panic(170);
    }