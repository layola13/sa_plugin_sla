@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn main() -> i32 {
    let values: [i32; 4] = [1, 2, 3, 4];
    let window_sum: i32 = values[1..3].iter().sum();
    println("{}", window_sum);
    return 0;
};

@test "rosetta 014 slice window"() {
    let values: [i32; 4] = [1, 2, 3, 4];
    let window_sum: i32 = values[1..3].iter().sum();
    if window_sum != 5 {
        panic(14);
    };
};
