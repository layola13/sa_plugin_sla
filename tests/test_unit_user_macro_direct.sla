@import "sa_std/core/box.sa"
@import "sa_std/core/refcell.sa"

macro add_one_macro(var_ref) {
    let temp = 1;
    var_ref = var_ref + temp;
}

macro add_two_macro(var_ref) {
    {
        let temp = 1;
        var_ref = var_ref + temp;
    }
    {
        let temp = 1;
        var_ref = var_ref + temp;
    }
}

struct DirectMacroPoint { left: i64, right: i64 }
struct DirectMacroBorrowPoint { left: i64, right: i64 }
struct DirectMacroCounter { value: i64 }

enum DirectMacroMessage {
    Empty,
    Pair { left: i64, right: i64 },
}

fn direct_macro_add(value: i64, delta: i64) -> i64 {
    value + delta
}

fn direct_macro_read_i64(value: &i64) -> i64 {
    *value
}

fn direct_macro_consume_box(^value: Box<i64>) -> i64 {
    *value
}

macro scoped_shadow_macro(var_ref) {
    let temp = 1;
    {
        let temp = 100;
        var_ref = var_ref + temp;
    }
    var_ref = var_ref + temp;
}

macro branch_call_cast_macro(var_ref, cond, delta) {
    {
        if cond {
            let widened = delta as i64;
            var_ref = direct_macro_add(var_ref, widened);
        } else {
            var_ref = var_ref - (delta as i64);
        }
    }
}

macro aggregate_macro(out, seed) {
    {
        let point = DirectMacroPoint { left: seed, right: seed + 1 };
        let tuple = (point.left, point.right);
        let values: [i64; 3] = [tuple.0, tuple.1, seed + 2];
        out = 0;
        for i in 0..3 {
            out = out + values[i];
        }
    }
}

macro nested_add_macro(var_ref, delta) {
    var_ref = var_ref + delta;
}

macro wrapper_macro(var_ref, delta) {
    {
        let local_delta = delta + 1;
        nested_add_macro(var_ref, local_delta);
    }
}

macro borrow_address_macro(out, point, values, ptr) {
    {
        out = direct_macro_read_i64(&point.left);
        out = out + direct_macro_read_i64(&values[1]);
        out = out + direct_macro_read_i64(&*ptr);
    }
}

macro borrow_smart_address_macro(out, boxed, nested_box) {
    {
        out = direct_macro_read_i64(&*boxed);
        out = out + direct_macro_read_i64(&**nested_box);
    }
}

macro evaluate_value_once_macro(out, value) {
    out = value + value;
}

macro evaluate_call_value_once_macro(out, value) {
    out = direct_macro_add(value, value);
}

macro loop_control_macro(out) {
    out = 0;
    for i in 0..5 {
        if i == 1 {
            continue;
        };
        if i == 4 {
            break;
        };
        out = out + i;
    }
}

macro enum_literal_macro(out, left, right) {
    out = DirectMacroMessage::Pair { left: left, right: right };
}

macro enum_unit_literal_macro(out) {
    out = DirectMacroMessage::Empty;
}

macro move_box_macro(out, value) {
    out = ^value;
}

macro forwarding_move_box_macro(out, value) {
    move_box_macro(out, value);
}

macro branch_move_box_macro(out, value, cond) {
    if cond {
        out = ^value;
    } else {
        out = ^value;
    }
}

macro call_move_box_macro(out, value) {
    out = direct_macro_consume_box(^value);
}

fn macro_next_value(cell: &RefCell<DirectMacroCounter>) -> i64 {
    let borrowed: &DirectMacroCounter = cell.borrow_mut();
    borrowed.value = borrowed.value + 1;
    borrowed.value
}

fn macro_hygiene_direct(value: i64) -> i64 {
    let temp = value;
    add_one_macro(temp);
    temp
}

fn macro_block_direct(value: i64) -> i64 {
    let item = value;
    add_two_macro(item);
    item
}

@test "direct user macro hygiene"() {
    if macro_hygiene_direct(5) != 6 { panic(31801); };
    if macro_block_direct(5) != 7 { panic(31802); };
}

fn macro_shadow_direct(value: i64) -> i64 {
    let item = value;
    scoped_shadow_macro(item);
    item
}

fn macro_branch_direct(value: i64, cond: bool, delta: i32) -> i64 {
    let item = value;
    branch_call_cast_macro(item, cond, delta);
    item
}

fn macro_aggregate_direct(seed: i64) -> i64 {
    let total = 99;
    aggregate_macro(total, seed);
    total
}

fn macro_nested_call_direct(value: i64) -> i64 {
    let item = value;
    wrapper_macro(item, 2);
    item
}

fn macro_address_direct() -> i64 {
    let point = DirectMacroBorrowPoint { left: 11, right: 17 };
    let values: [i64; 3] = [3, 5, 7];
    let tail = 17;
    let ptr = &tail;
    let total = 0;
    borrow_address_macro(total, point, values, ptr);
    total
}

fn macro_smart_address_direct() -> i64 {
    let boxed: Box<i64> = Box::new(19i64);
    let nested_box: Box<Box<i64>> = Box::new(Box::new(23i64));
    let total = 0i64;
    borrow_smart_address_macro(total, boxed, nested_box);
    total
}

fn macro_value_arg_evaluated_once() -> i64 {
    let cell = RefCell::new(DirectMacroCounter { value: 0 });
    let total = 0i64;
    evaluate_value_once_macro(total, macro_next_value(&cell));
    let borrowed: &DirectMacroCounter = cell.borrow();
    if borrowed.value != 1 { panic(31810); };
    total
}

fn macro_call_value_arg_evaluated_once() -> i64 {
    let cell = RefCell::new(DirectMacroCounter { value: 0 });
    let total = 0i64;
    evaluate_call_value_once_macro(total, macro_next_value(&cell));
    let borrowed: &DirectMacroCounter = cell.borrow();
    if borrowed.value != 1 { panic(31812); };
    total
}

fn macro_loop_control_direct() -> i64 {
    let total = 99i64;
    loop_control_macro(total);
    total
}

fn macro_enum_literal_direct() -> i64 {
    let msg = DirectMacroMessage::Empty;
    enum_literal_macro(msg, 19, 23);
    match msg {
        DirectMacroMessage::Empty => { 0 },
        DirectMacroMessage::Pair { left, right } => { left + right },
    }
}

fn macro_enum_unit_literal_direct() -> i64 {
    let msg = DirectMacroMessage::Pair { left: 1, right: 2 };
    enum_unit_literal_macro(msg);
    match msg {
        DirectMacroMessage::Empty => { 7 },
        DirectMacroMessage::Pair { left, right } => { left + right },
    }
}

fn macro_move_box_direct() -> i64 {
    let source = Box::new(42i64);
    let destination = Box::new(1i64);
    move_box_macro(destination, source);
    *destination
}

fn macro_nested_move_box_direct() -> i64 {
    let source = Box::new(40i64);
    let destination = Box::new(2i64);
    forwarding_move_box_macro(destination, source);
    *destination
}

fn macro_branch_move_box_direct(cond: bool) -> i64 {
    let source = Box::new(41i64);
    let destination = Box::new(1i64);
    branch_move_box_macro(destination, source, cond);
    *destination
}

fn macro_call_move_box_direct() -> i64 {
    let source = Box::new(39i64);
    let result = 0i64;
    call_move_box_macro(result, source);
    result
}

@test "direct user macro nested expansion"() {
    if macro_shadow_direct(5) != 106 { panic(31803); };
    if macro_branch_direct(10, true, 4) != 14 { panic(31804); };
    if macro_branch_direct(10, false, 4) != 6 { panic(31805); };
    if macro_aggregate_direct(3) != 12 { panic(31806); };
    if macro_nested_call_direct(7) != 10 { panic(31807); };
    if macro_address_direct() != 33 { panic(31808); };
    if macro_smart_address_direct() != 42 { panic(31809); };
    if macro_value_arg_evaluated_once() != 2 { panic(31811); };
    if macro_call_value_arg_evaluated_once() != 2 { panic(31813); };
    if macro_loop_control_direct() != 5 { panic(31814); };
    if macro_enum_literal_direct() != 42 { panic(31815); };
    if macro_enum_unit_literal_direct() != 7 { panic(31816); };
    if macro_move_box_direct() != 42 { panic(31817); };
    if macro_nested_move_box_direct() != 40 { panic(31818); };
    if macro_branch_move_box_direct(true) != 41 { panic(31819); };
    if macro_branch_move_box_direct(false) != 41 { panic(31820); };
    if macro_call_move_box_direct() != 39 { panic(31821); };
}
