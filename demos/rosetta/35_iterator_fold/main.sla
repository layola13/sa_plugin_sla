@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn main() -> i32 {
    let total: usize = ["sa", "asm", "!!"].into_iter().fold(0, |acc: usize, item: ptr| acc + item.len());
    println("{}", total);
    return 0;
}

@test "rosetta 035 iterator fold"() {
    let total: usize = ["sa", "asm", "!!"].into_iter().fold(0, |acc: usize, item: ptr| acc + item.len());
    if total != 7 {
        panic(35);
    };
}
