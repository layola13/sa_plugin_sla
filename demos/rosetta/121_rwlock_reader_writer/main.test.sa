[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/result.sa"
@const SLA_THREAD_VT_0 = vtable { call = @sla_thread_worker_0 }
@const SLA_THREAD_VT_1 = vtable { call = @sla_thread_worker_1 }

@ffi_wrapper sla_thread_spawn_0(*slot: ptr) -> i32:
L_ENTRY:
    worker_vt = &SLA_THREAD_VT_0
    worker_fn = load worker_vt+0 as ptr
    worker_raw = *worker_fn
    worker_safe = assume_safe worker_raw
    EXPAND THREAD_SPAWN handle, *worker_safe, *slot
    !slot
    return handle

@sla_thread_worker_0(&slot: ptr) -> i32:
L_ENTRY:
    tmp_0 = load slot+16 as ptr
    tmp_1 = call @sla__read_shared(tmp_0)
    store slot+8, tmp_1 as i32
    !slot
    return tmp_1

@ffi_wrapper sla_thread_spawn_1(*slot: ptr) -> i32:
L_ENTRY:
    worker_vt = &SLA_THREAD_VT_1
    worker_fn = load worker_vt+0 as ptr
    worker_raw = *worker_fn
    worker_safe = assume_safe worker_raw
    EXPAND THREAD_SPAWN handle, *worker_safe, *slot
    !slot
    return handle

@sla_thread_worker_1(&slot: ptr) -> i32:
L_ENTRY:
    tmp_2 = load slot+16 as ptr
    tmp_3 = call @sla__read_shared(tmp_2)
    store slot+8, tmp_3 as i32
    !slot
    return tmp_3

@const SLA_FNPTR_VT_read_shared = vtable { call = @sla__read_shared }
@const SLA_FNPTR_VT_rwlock_reader_writer_total = vtable { call = @sla__rwlock_reader_writer_total }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__read_shared(shared: ptr) -> i32:
L_ENTRY:
    EXPAND ARC_GET tmp_4, shared
    EXPAND RWLOCK_TRY_READ_NOERR tmp_5, tmp_6, tmp_4
    br tmp_5 -> L_RWLOCK_RESULT_OK_1, L_RWLOCK_RESULT_ERR_0

L_RWLOCK_RESULT_ERR_0:
    EXPAND RESULT_NEW_ERR tmp_8, 1
    jmp L_RWLOCK_RESULT_END_2

L_RWLOCK_RESULT_OK_1:
    tmp_7 = ptr_add tmp_4, RwLock_data
    EXPAND RESULT_NEW_OK tmp_8, tmp_7
    !tmp_7
    jmp L_RWLOCK_RESULT_END_2

L_RWLOCK_RESULT_END_2:
    !tmp_5
    !tmp_6
    EXPAND RESULT_UNWRAP tmp_9, tmp_8
    !tmp_8
    reader = tmp_9
    tmp_10 = load reader+0 as i32
    value = tmp_10
    EXPAND RWLOCK_RELEASE_READ tmp_4
    !tmp_4
    !reader
    !shared
    return value

@sla__rwlock_reader_writer_total() -> i32:
L_ENTRY:
    tmp_11 = 1
    EXPAND RWLOCK_NEW_I32 tmp_12, tmp_11
    !tmp_11
    EXPAND ARC_NEW tmp_13, tmp_12
    !tmp_12
    shared = tmp_13
    tmp_14 = add shared, 0
    EXPAND ARC_CLONE tmp_14
    cloned = tmp_14
    tmp_15 = alloc 24
    store tmp_15+0, 0 as i32
    store tmp_15+8, 0 as i32
    store tmp_15+16, cloned as ptr
    tmp_16 = call @sla_thread_spawn_0(*tmp_15)
    store tmp_15+0, tmp_16 as i32
    !tmp_16
    first_reader = tmp_15
    tmp_17 = load first_reader+0 as i32
    EXPAND THREAD_JOIN_STATUS tmp_18, tmp_17, *first_reader
    EXPAND THREAD_DROP tmp_17
    tmp_19 = eq tmp_18, 0
    br tmp_19 -> L_THREAD_JOIN_OK_3, L_THREAD_JOIN_ERR_4

L_THREAD_JOIN_OK_3:
    !tmp_19
    tmp_21 = load first_reader+8 as i32
    EXPAND RESULT_NEW_OK tmp_20, tmp_21
    !tmp_21
    jmp L_THREAD_JOIN_END_5

L_THREAD_JOIN_ERR_4:
    !tmp_19
    tmp_22 = add tmp_18, 0
    EXPAND RESULT_NEW_ERR tmp_20, tmp_22
    !tmp_22
    jmp L_THREAD_JOIN_END_5

L_THREAD_JOIN_END_5:
    !tmp_18
    !tmp_17
    !first_reader
    EXPAND RESULT_UNWRAP tmp_23, tmp_20
    !tmp_20
    first = tmp_23
    EXPAND ARC_GET tmp_24, shared
    EXPAND RWLOCK_TRY_WRITE_NOERR tmp_25, tmp_26, tmp_24
    br tmp_25 -> L_RWLOCK_RESULT_OK_7, L_RWLOCK_RESULT_ERR_6

L_RWLOCK_RESULT_ERR_6:
    EXPAND RESULT_NEW_ERR tmp_28, 1
    jmp L_RWLOCK_RESULT_END_8

L_RWLOCK_RESULT_OK_7:
    tmp_27 = ptr_add tmp_24, RwLock_data
