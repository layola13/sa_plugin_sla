@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_main = vtable { call = @main }
@main() -> i32:
L_ENTRY:
    values = alloc 12
    tmp_0 = 1
    store values+0, tmp_0 as i32
    tmp_1 = 2
    store values+4, tmp_1 as i32
    tmp_2 = 3
    store values+8, tmp_2 as i32
    tmp_3 = 0
    tmp_4 = 0
    tmp_5 = ptr_add values, tmp_4
    tmp_6 = load tmp_5+0 as i32
    tmp_7 = 2
    tmp_8 = mul tmp_6, tmp_7
    !tmp_7
    tmp_9 = add tmp_3, tmp_8
    !tmp_4
    !tmp_5
    !tmp_6
    !tmp_8
    !tmp_3
    tmp_10 = 4
    tmp_11 = ptr_add values, tmp_10
    tmp_12 = load tmp_11+0 as i32
    tmp_13 = 2
    tmp_14 = mul tmp_12, tmp_13
    !tmp_13
    tmp_15 = add tmp_9, tmp_14
    !tmp_10
    !tmp_11
    !tmp_12
    !tmp_14
    !tmp_9
    tmp_16 = 8
    tmp_17 = ptr_add values, tmp_16
    tmp_18 = load tmp_17+0 as i32
    tmp_19 = 2
    tmp_20 = mul tmp_18, tmp_19
    !tmp_19
    tmp_21 = add tmp_15, tmp_20
    !tmp_16
    !tmp_17
    !tmp_18
    !tmp_20
    !tmp_15
    total = tmp_21
    tmp_22 = call @sa_fmt_u64(total, 10)
    tmp_23 = call @sa_fmt_buffer_data(tmp_22)
    tmp_24 = call @sa_fmt_buffer_len(tmp_22)
    tmp_25 = tmp_23
    call @sa_print_bytes(&tmp_25, tmp_24)
    call @sa_fmt_buffer_free(^tmp_22)
    !tmp_25
    !tmp_24
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_26 = 0
    !values
    !total
    return tmp_26

@test "rosetta 049 pipeline map"():
L_TEST_ENTRY_0:
    values = alloc 12
    tmp_27 = 1
    store values+0, tmp_27 as i32
    tmp_28 = 2
    store values+4, tmp_28 as i32
    tmp_29 = 3
    store values+8, tmp_29 as i32
    tmp_30 = 0
    tmp_31 = 0
    tmp_32 = ptr_add values, tmp_31
    tmp_33 = load tmp_32+0 as i32
    tmp_34 = 2
    tmp_35 = mul tmp_33, tmp_34
    !tmp_34
    tmp_36 = add tmp_30, tmp_35
    !tmp_31
    !tmp_32
    !tmp_33
    !tmp_35
    !tmp_30
    tmp_37 = 4
    tmp_38 = ptr_add values, tmp_37
    tmp_39 = load tmp_38+0 as i32
    tmp_40 = 2
    tmp_41 = mul tmp_39, tmp_40
    !tmp_40
    tmp_42 = add tmp_36, tmp_41
    !tmp_37
    !tmp_38
    !tmp_39
    !tmp_41
    !tmp_36
    tmp_43 = 8
    tmp_44 = ptr_add values, tmp_43
    tmp_45 = load tmp_44+0 as i32
    tmp_46 = 2
    tmp_47 = mul tmp_45, tmp_46
    !tmp_46
    tmp_48 = add tmp_42, tmp_47
    !tmp_43
    !tmp_44
    !tmp_45
    !tmp_47
    !tmp_42
    total = tmp_48
    tmp_49 = 12
    tmp_50 = ne total, tmp_49
    !tmp_49
    br tmp_50 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_50
    panic(49)

L_ELSE_2:
    !tmp_50
    jmp L_MERGE_3

L_MERGE_3:
    !values
    !total
    return

