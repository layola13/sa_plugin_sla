    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_146 = 0
    EXPAND STRING_BUF_FREE text
    return tmp_146

@test "rosetta 190 190_base64_encode_simd"():
L_TEST_ENTRY_0:
    tmp_147 = call @sla__encoded_text()
    text = tmp_147
    @const SLA_STR_1 = utf8:"TWFu"
    tmp_149 = 4
    tmp_148 = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW tmp_148, &SLA_STR_1, tmp_149
    !tmp_149
    EXPAND STRING_BUF_AS_STR tmp_150, text
    EXPAND STR_EQ tmp_151, tmp_150, tmp_148
    !tmp_150
    tmp_152 = 1
    tmp_153 = ne tmp_151, tmp_152
    !tmp_151
    !tmp_152
    br tmp_153 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_153
    panic(190)

L_ELSE_2:
    !tmp_153
    jmp L_MERGE_3

L_MERGE_3:
    EXPAND STRING_BUF_FREE text
    return

