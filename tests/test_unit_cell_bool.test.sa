@import "sa_std/core/cell.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/cell.sa"
@test "cell bool get and set"():
L_TEST_ENTRY_0:
    tmp_0 = 0
    flag = stack_alloc Cell_SIZE
    EXPAND CELL_SET flag, tmp_0
    !tmp_0
    EXPAND CELL_GET tmp_1, flag
    tmp_2 = 0
    tmp_3 = ne tmp_1, tmp_2
    !tmp_1
    !tmp_2
    br tmp_3 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_3
    panic(1)

L_ELSE_2:
    !tmp_3
    jmp L_MERGE_3

L_MERGE_3:
    tmp_6 = 1
    EXPAND CELL_SET flag, tmp_6
    !tmp_6
    EXPAND CELL_GET tmp_7, flag
    tmp_8 = 1
    tmp_9 = ne tmp_7, tmp_8
    !tmp_7
    !tmp_8
    br tmp_9 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_9
    panic(2)

L_ELSE_5:
    !tmp_9
    jmp L_MERGE_6

L_MERGE_6:
    return

