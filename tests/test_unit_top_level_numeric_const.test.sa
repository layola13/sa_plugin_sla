@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@test "top level numeric const codegen"():
L_TEST_ENTRY_0:
    tmp_0 = 41
    tmp_1 = 1
    tmp_2 = add tmp_0, tmp_1
    !tmp_1
    value = tmp_2
    tmp_3 = 42
    tmp_4 = ne value, tmp_3
    !tmp_3
    br tmp_4 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_4
    panic(14101)

L_ELSE_2:
    !tmp_4
    jmp L_MERGE_3

L_MERGE_3:
    tmp_7 = 1
    tmp_8 = 1
    tmp_9 = ne tmp_7, tmp_8
    !tmp_8
    br tmp_9 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_9
    panic(14102)

L_ELSE_5:
    !tmp_9
    jmp L_MERGE_6

L_MERGE_6:
    !value
    return

