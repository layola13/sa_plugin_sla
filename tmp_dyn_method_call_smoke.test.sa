@import "sa_std/string.sa"
@import "sa_std/core/trait_object.sa"
@score_value(&value: ptr) -> i32:
L_ENTRY:
    EXPAND DYN_CALL tmp_0, value, 0
    return tmp_0

@main() -> i32:
L_ENTRY:
    tmp_1 = 0
    return tmp_1

@test "dyn method call smoke"():
L_TEST_ENTRY_0:
    tmp_2 = call @main()
    tmp_3 = 0
    tmp_4 = ne tmp_2, tmp_3
    !tmp_2
    !tmp_3
    br tmp_4 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_4
    panic(903)

L_ELSE_2:
    !tmp_4
    jmp L_MERGE_3

L_MERGE_3:
    return

