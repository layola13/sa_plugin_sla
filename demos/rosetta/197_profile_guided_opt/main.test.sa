@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_hot = vtable { call = @sla__hot }
@const SLA_FNPTR_VT_cold = vtable { call = @sla__cold }
@const SLA_FNPTR_VT_pgo_hot_cold_total = vtable { call = @sla__pgo_hot_cold_total }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__hot() -> i32:
L_ENTRY:
    tmp_0 = 3
    return tmp_0

@sla__cold() -> i32:
L_ENTRY:
    tmp_1 = 1
    return tmp_1

@sla__pgo_hot_cold_total() -> i32:
L_ENTRY:
    tmp_2 = 0
    total = tmp_2
    tmp_3 = 1
    i = tmp_3
    jmp L_WHILE_HEAD_0

L_WHILE_HEAD_0:
    tmp_4 = 3
    tmp_5 = sle i, tmp_4
    !tmp_4
    br tmp_5 -> L_WHILE_BODY_1, L_WHILE_COND_FALSE_2

L_WHILE_BODY_1:
    !tmp_5
    tmp_6 = call @sla__hot()
    step = tmp_6
    tmp_7 = add total, step
    !total
    total = tmp_7
    tmp_8 = 1
    tmp_9 = add i, tmp_8
    !tmp_8
    !i
    i = tmp_9
    !step
    jmp L_WHILE_HEAD_0

L_WHILE_COND_FALSE_2:
    !tmp_5
    jmp L_WHILE_EXIT_3

L_WHILE_EXIT_3:
    tmp_10 = call @sla__cold()
    tail = tmp_10
    tmp_11 = add total, tail
    !i
    return tmp_11

@main() -> i32:
L_ENTRY:
    tmp_12 = call @sla__pgo_hot_cold_total()
    result = tmp_12
    tmp_13 = call @sa_fmt_u64(result, 10)
    tmp_14 = call @sa_fmt_buffer_data(tmp_13)
    tmp_15 = call @sa_fmt_buffer_len(tmp_13)
    tmp_16 = tmp_14
    call @sa_print_bytes(&tmp_16, tmp_15)
    call @sa_fmt_buffer_free(^tmp_13)
    !tmp_16
    !tmp_15
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 197 197_profile_guided_opt"():
L_TEST_ENTRY_4:
    tmp_17 = call @sla__pgo_hot_cold_total()
    got = tmp_17
    tmp_18 = 10
    tmp_19 = ne got, tmp_18
    !tmp_18
    br tmp_19 -> L_THEN_5, L_ELSE_6

L_THEN_5:
    !tmp_19
    panic(197)

L_ELSE_6:
    !tmp_19
    jmp L_MERGE_7

L_MERGE_7:
    !got
    return

