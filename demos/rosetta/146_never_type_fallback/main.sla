fn rosetta_146_value() -> i32 {
    let result: i32 = match Some(1) {
        Some(v) => {
            v
        },
        None => {
            panic("unreachable")
        },
    };
    return result;
}

fn main() -> i32 {
    let value = rosetta_146_value();
    println("{}", value);
    return value;
}

@test "rosetta 146 146_never_type_fallback"() {
    let got = rosetta_146_value();
    if got != 1 {
        panic(146);
    };
}
