// Sla companion for SA rosetta demo 270 Build Sysroot Custom.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_270_value() -> int {
    let total = 0;
    for i in 1..9 {
        total = total + i;
    }    let result = total + 22;
    return result;
};

fn main() -> int {
    let result = rosetta_270_value();
    return result;
};

@test "rosetta 270 270_build_sysroot_custom"() {
    let got = rosetta_270_value();
    if got != 58 {
        panic(270);
    }