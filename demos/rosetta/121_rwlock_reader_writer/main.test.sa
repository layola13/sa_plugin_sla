@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_rwlock_reader_writer_total = vtable { call = @sla__rwlock_reader_writer_total }
@const SLA_FNPTR_VT_rwlock_read = vtable { call = @sla__rwlock_read }
@const SLA_FNPTR_VT_rwlock_write = vtable { call = @sla__rwlock_write }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__rwlock_reader_writer_total() -> i32:
L_ENTRY:
    tmp_0 = 1
    tmp_1 = call @sla__rwlock_read(tmp_0)
    !tmp_0
    first_read = tmp_1
    tmp_2 = 2
    tmp_3 = call @sla__rwlock_write(first_read, tmp_2)
    !tmp_2
    written = tmp_3
    tmp_4 = call @sla__rwlock_read(written)
    second_read = tmp_4
    tmp_5 = add first_read, second_read
    !written
    !first_read
    !second_read
    return tmp_5

@sla__rwlock_read(value: i32) -> i32:
L_ENTRY:
    return value

@sla__rwlock_write(value: i32, delta: i32) -> i32:
L_ENTRY:
    tmp_6 = add value, delta
    !value
    !delta
    return tmp_6

@main() -> i32:
L_ENTRY:
    tmp_7 = call @sla__rwlock_reader_writer_total()
    result = tmp_7
    tmp_8 = call @sa_fmt_u64(result, 10)
    tmp_9 = call @sa_fmt_buffer_data(tmp_8)
    tmp_10 = call @sa_fmt_buffer_len(tmp_8)
    tmp_11 = tmp_9
    call @sa_print_bytes(&tmp_11, tmp_10)
    call @sa_fmt_buffer_free(^tmp_8)
    !tmp_11
    !tmp_10
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 121 121_rwlock_reader_writer"():
L_TEST_ENTRY_0:
    tmp_12 = call @sla__rwlock_reader_writer_total()
    got = tmp_12
    tmp_13 = 4
    tmp_14 = ne got, tmp_13
    !tmp_13
    br tmp_14 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_14
    panic(121)

L_ELSE_2:
    !tmp_14
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

