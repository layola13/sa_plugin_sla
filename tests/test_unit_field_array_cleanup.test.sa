@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_fill_first = vtable { call = @sla__fill_first }
@const SLA_FNPTR_VT_demo = vtable { call = @sla__demo }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__fill_first(slots: ptr) -> ptr:
L_ENTRY:
    tmp_0 = 0
    i = tmp_0
    jmp L_WHILE_HEAD_0

L_WHILE_HEAD_0:
    tmp_1 = 2
    tmp_2 = slt i, tmp_1
    !tmp_1
    br tmp_2 -> L_WHILE_BODY_1, L_WHILE_COND_FALSE_2

L_WHILE_BODY_1:
    !tmp_2
    tmp_3 = load slots+0 as ptr
    tmp_4 = mul i, 1
    tmp_5 = ptr_add tmp_3, tmp_4
    !tmp_4
    tmp_6 = load tmp_5+0 as u8
    !tmp_5
    !tmp_3
    tmp_7 = 0
    tmp_8 = eq tmp_6, tmp_7
    !tmp_6
    !tmp_7
    br tmp_8 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_8
    tmp_9 = load slots+0 as ptr
    tmp_10 = mul i, 1
    tmp_11 = ptr_add tmp_9, tmp_10
    !tmp_10
    tmp_12 = 1
    store tmp_11+0, tmp_12 as u8
    !tmp_11
    !tmp_9
    !tmp_12
    tmp_13 = load slots+8 as ptr
    tmp_14 = mul i, 4
    tmp_15 = ptr_add tmp_13, tmp_14
    !tmp_14
    tmp_16 = 7
    store tmp_15+0, tmp_16 as i32
    !tmp_15
    !tmp_13
    !tmp_16
    tmp_17 = load slots+8 as ptr
    tmp_18 = mul i, 4
    tmp_19 = ptr_add tmp_17, tmp_18
    !tmp_18
    tmp_20 = load slots+8 as ptr
    tmp_21 = mul i, 4
    tmp_22 = ptr_add tmp_20, tmp_21
    !tmp_21
    tmp_23 = load tmp_22+0 as i32
    !tmp_22
    !tmp_20
    tmp_24 = load slots+16 as ptr
    tmp_25 = mul i, 4
    tmp_26 = ptr_add tmp_24, tmp_25
    !tmp_25
    tmp_27 = load tmp_26+0 as i32
    !tmp_26
    !tmp_24
    tmp_28 = add tmp_23, tmp_27
    !tmp_23
    !tmp_27
    store tmp_19+0, tmp_28 as i32
    !tmp_19
    !tmp_17
    !tmp_28
    !i
    return slots

L_ELSE_5:
    !tmp_8
    jmp L_MERGE_6

L_MERGE_6:
    tmp_30 = 1
    tmp_31 = add i, tmp_30
    !tmp_30
    !i
    i = tmp_31
    jmp L_WHILE_HEAD_0

L_WHILE_COND_FALSE_2:
    !tmp_2
    jmp L_WHILE_EXIT_3

L_WHILE_EXIT_3:
    !i
    return slots

@sla__demo() -> i32:
L_ENTRY:
    slots = alloc 24
    tmp_32 = alloc 2
    tmp_33 = 0
    store tmp_32+0, tmp_33 as u8
    !tmp_33
    tmp_34 = 0
    store tmp_32+1, tmp_34 as u8
    !tmp_34
    store slots+0, tmp_32 as ptr
    !tmp_32
    tmp_35 = alloc 8
    tmp_36 = 0
    store tmp_35+0, tmp_36 as i32
    !tmp_36
    tmp_37 = 0
    store tmp_35+4, tmp_37 as i32
    !tmp_37
    store slots+8, tmp_35 as ptr
    !tmp_35
    tmp_38 = alloc 8
    tmp_39 = 5
    store tmp_38+0, tmp_39 as i32
    !tmp_39
    tmp_40 = 0
    store tmp_38+4, tmp_40 as i32
    !tmp_40
    store slots+16, tmp_38 as ptr
    !tmp_38
    tmp_41 = call @sla__fill_first(slots)
    out = tmp_41
    tmp_42 = load out+8 as ptr
    tmp_43 = 0
    tmp_44 = mul tmp_43, 4
    tmp_45 = ptr_add tmp_42, tmp_44
    !tmp_44
    !tmp_43
    tmp_46 = load tmp_45+0 as i32
    !tmp_45
    !tmp_42
    !out
    !slots
    return tmp_46

@main() -> i32:
L_ENTRY:
    tmp_47 = call @sla__demo()
    return tmp_47

@test "field array cleanup across while"():
L_TEST_ENTRY_7:
    tmp_48 = call @sla__demo()
    got = tmp_48
    tmp_49 = 12
    tmp_50 = ne got, tmp_49
    !tmp_49
    br tmp_50 -> L_THEN_8, L_ELSE_9

L_THEN_8:
    !tmp_50
    panic(1200)

L_ELSE_9:
    !tmp_50
    jmp L_MERGE_10

L_MERGE_10:
    !got
    return

