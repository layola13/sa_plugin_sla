@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/iter.sa"
@const SLA_FNPTR_VT_sum4 = vtable { call = @sla__sum4 }
@const SLA_FNPTR_VT_fill_zero = vtable { call = @sla__fill_zero }
@const SLA_FNPTR_VT_iter = vtable { call = @sla__iter }
@const SLA_FNPTR_VT_sum = vtable { call = @sla__sum }
@sla__sum4(values: ptr) -> i64:
L_ENTRY:
    tmp_0 = 0
    tmp_1 = mul tmp_0, 8
    tmp_2 = ptr_add values, tmp_1
    !tmp_1
    !tmp_0
    tmp_3 = load tmp_2+0 as i64
    !tmp_2
    tmp_4 = 1
    tmp_5 = mul tmp_4, 8
    tmp_6 = ptr_add values, tmp_5
    !tmp_5
    !tmp_4
    tmp_7 = load tmp_6+0 as i64
    !tmp_6
    tmp_8 = add tmp_3, tmp_7
    !tmp_3
    !tmp_7
    tmp_9 = 2
    tmp_10 = mul tmp_9, 8
    tmp_11 = ptr_add values, tmp_10
    !tmp_10
    !tmp_9
    tmp_12 = load tmp_11+0 as i64
    !tmp_11
    tmp_13 = add tmp_8, tmp_12
    !tmp_8
    !tmp_12
    tmp_14 = 3
    tmp_15 = mul tmp_14, 8
    tmp_16 = ptr_add values, tmp_15
    !tmp_15
    !tmp_14
    tmp_17 = load tmp_16+0 as i64
    !tmp_16
    tmp_18 = add tmp_13, tmp_17
    !tmp_13
    !tmp_17
    total = tmp_18
    !values
    return total

@sla__fill_zero(^values: ptr) -> ptr:
L_ENTRY:
    i_slot = stack_alloc 8
    tmp_19 = 0
    tmp_20 = 4
    store i_slot+0, tmp_19 as i64
    !tmp_19
    jmp L_LOOP_HEAD_0

L_LOOP_HEAD_0:
    tmp_21 = load i_slot+0 as i64
    tmp_22 = slt tmp_21, tmp_20
    br tmp_22 -> L_LOOP_BODY_1, L_LOOP_COND_FALSE_3

L_LOOP_BODY_1:
    !tmp_22
    i = add tmp_21, 0
    tmp_23 = mul i, 8
    tmp_24 = ptr_add values, tmp_23
    !tmp_23
    tmp_25 = 0
    store tmp_24+0, tmp_25 as i64
    !tmp_24
    !tmp_25
L_LOOP_CONTINUE_2:
    tmp_26 = add tmp_21, 1
    store i_slot+0, tmp_26 as i64
    !tmp_26
    !tmp_21
    !i
    jmp L_LOOP_HEAD_0

L_LOOP_COND_FALSE_3:
    !tmp_22
    !tmp_21
    jmp L_LOOP_EXIT_4

L_LOOP_EXIT_4:
    !tmp_20
    return values

@sla__iter(values: ptr) -> ptr:
L_ENTRY:
    return values

@sla__sum(values: ptr) -> i64:
L_ENTRY:
    i_slot = stack_alloc 8
    tmp_27 = 0
    total = tmp_27
    tmp_28 = 0
    tmp_29 = 4
    store i_slot+0, tmp_28 as i64
    !tmp_28
    jmp L_LOOP_HEAD_5

L_LOOP_HEAD_5:
    tmp_30 = load i_slot+0 as i64
    tmp_31 = slt tmp_30, tmp_29
    br tmp_31 -> L_LOOP_BODY_6, L_LOOP_COND_FALSE_8

L_LOOP_BODY_6:
    !tmp_31
    i = add tmp_30, 0
    tmp_32 = mul i, 8
    tmp_33 = ptr_add values, tmp_32
    !tmp_32
    tmp_34 = load tmp_33+0 as i64
    !tmp_33
    tmp_35 = add total, tmp_34
    !tmp_34
    !total
    total = tmp_35
L_LOOP_CONTINUE_7:
    tmp_36 = add tmp_30, 1
    store i_slot+0, tmp_36 as i64
    !tmp_36
    !tmp_30
    !i
    jmp L_LOOP_HEAD_5

L_LOOP_COND_FALSE_8:
    !tmp_31
    !tmp_30
    jmp L_LOOP_EXIT_9

L_LOOP_EXIT_9:
    !tmp_29
    !values
    return total

@test "array literal index read write"():
L_TEST_ENTRY_10:
    values = alloc 32
    tmp_37 = 1
    store values+0, tmp_37 as i64
    !tmp_37
    tmp_38 = 2
    store values+8, tmp_38 as i64
    !tmp_38
    tmp_39 = 3
    store values+16, tmp_39 as i64
    !tmp_39
    tmp_40 = 4
    store values+24, tmp_40 as i64
    !tmp_40
    tmp_41 = 2
    tmp_42 = mul tmp_41, 8
    tmp_43 = ptr_add values, tmp_42
    !tmp_42
    !tmp_41
    tmp_44 = 9
    store tmp_43+0, tmp_44 as i64
    !tmp_43
    !tmp_44
    tmp_45 = call @sla__sum4(values)
    total = tmp_45
    tmp_46 = 16
    tmp_47 = ne total, tmp_46
    !tmp_46
    br tmp_47 -> L_THEN_11, L_ELSE_12

L_THEN_11:
    !tmp_47
    panic(1)

L_ELSE_12:
    !tmp_47
    jmp L_MERGE_13

L_MERGE_13:
    !values
    !total
    return

@test "array for loop index write"():
L_TEST_ENTRY_14:
    values = alloc 32
    tmp_50 = 1
    store values+0, tmp_50 as i64
    !tmp_50
    tmp_51 = 2
    store values+8, tmp_51 as i64
    !tmp_51
    tmp_52 = 3
    store values+16, tmp_52 as i64
    !tmp_52
    tmp_53 = 4
    store values+24, tmp_53 as i64
    !tmp_53
    tmp_54 = call @sla__fill_zero(^values)
    zeroed = tmp_54
    tmp_55 = call @sla__sum4(zeroed)
    total = tmp_55
    tmp_56 = 0
    tmp_57 = ne total, tmp_56
    !tmp_56
    br tmp_57 -> L_THEN_15, L_ELSE_16

L_THEN_15:
    !tmp_57
    panic(2)

L_ELSE_16:
    !tmp_57
    jmp L_MERGE_17

L_MERGE_17:
    !zeroed
    !total
    return

@test "array method chain sum"():
L_TEST_ENTRY_18:
    values = alloc 32
    tmp_60 = 1
    store values+0, tmp_60 as i64
    !tmp_60
    tmp_61 = 2
    store values+8, tmp_61 as i64
    !tmp_61
    tmp_62 = 3
    store values+16, tmp_62 as i64
    !tmp_62
    tmp_63 = 4
    store values+24, tmp_63 as i64
    !tmp_63
    tmp_64 = 0
    tmp_65 = 0
    tmp_66 = ptr_add values, tmp_65
    tmp_67 = load tmp_66+0 as i64
    tmp_68 = add tmp_64, tmp_67
    !tmp_65
    !tmp_66
    !tmp_67
    !tmp_64
    tmp_69 = 8
    tmp_70 = ptr_add values, tmp_69
    tmp_71 = load tmp_70+0 as i64
    tmp_72 = add tmp_68, tmp_71
    !tmp_69
    !tmp_70
    !tmp_71
    !tmp_68
    tmp_73 = 16
    tmp_74 = ptr_add values, tmp_73
    tmp_75 = load tmp_74+0 as i64
    tmp_76 = add tmp_72, tmp_75
    !tmp_73
    !tmp_74
    !tmp_75
    !tmp_72
    tmp_77 = 24
    tmp_78 = ptr_add values, tmp_77
    tmp_79 = load tmp_78+0 as i64
    tmp_80 = add tmp_76, tmp_79
    !tmp_77
    !tmp_78
    !tmp_79
    !tmp_76
    total = tmp_80
    tmp_81 = 10
    tmp_82 = ne total, tmp_81
    !tmp_81
    br tmp_82 -> L_THEN_19, L_ELSE_20

L_THEN_19:
    !tmp_82
    panic(3)

L_ELSE_20:
    !tmp_82
    jmp L_MERGE_21

L_MERGE_21:
    !values
    !total
    return

