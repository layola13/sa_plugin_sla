@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_sum_active_x = vtable { call = @sla__sum_active_x }
@sla__sum_active_x(bag: ptr) -> i32:
L_ENTRY:
    tmp_0 = 0
    total = tmp_0
    tmp_1 = 0
    i = tmp_1
    jmp L_WHILE_HEAD_0

L_WHILE_HEAD_0:
    tmp_2 = 2
    tmp_3 = slt i, tmp_2
    !tmp_2
    br tmp_3 -> L_WHILE_BODY_1, L_WHILE_COND_FALSE_2

L_WHILE_BODY_1:
    !tmp_3
    tmp_4 = load bag+0 as ptr
    tmp_5 = mul i, 1
    tmp_6 = ptr_add tmp_4, tmp_5
    !tmp_5
    tmp_7 = load tmp_6+0 as u8
    !tmp_6
    !tmp_4
    tmp_8 = 1
    tmp_9 = eq tmp_7, tmp_8
    !tmp_7
    !tmp_8
    br tmp_9 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_9
    tmp_10 = load bag+8 as ptr
    tmp_11 = mul i, 8
    tmp_12 = ptr_add tmp_10, tmp_11
    !tmp_11
    tmp_13 = load tmp_12+0 as ptr
    !tmp_12
    !tmp_10
    tmp_14 = load tmp_13+0 as i32
    !tmp_13
    tmp_15 = add total, tmp_14
    !tmp_14
    !total
    total = tmp_15
    jmp L_MERGE_6

L_ELSE_5:
    !tmp_9
    jmp L_MERGE_6

L_MERGE_6:
    tmp_17 = 1
    tmp_18 = add i, tmp_17
    !tmp_17
    !i
    i = tmp_18
    jmp L_WHILE_HEAD_0

L_WHILE_COND_FALSE_2:
    !tmp_3
    jmp L_WHILE_EXIT_3

L_WHILE_EXIT_3:
    !i
    !bag
    return total

@test "array struct field cleanup across branch"():
L_TEST_ENTRY_7:
    bag = alloc 16
    tmp_19 = alloc 2
    tmp_20 = 1
    store tmp_19+0, tmp_20 as u8
    !tmp_20
    tmp_21 = 0
    store tmp_19+1, tmp_21 as u8
    !tmp_21
    store bag+0, tmp_19 as ptr
    !tmp_19
    tmp_22 = alloc 16
    tmp_23 = alloc 8
    tmp_24 = 7
    store tmp_23+0, tmp_24 as i32
    !tmp_24
    tmp_25 = 1
    store tmp_23+4, tmp_25 as i32
    !tmp_25
    store tmp_22+0, tmp_23 as ptr
    !tmp_23
    tmp_26 = alloc 8
    tmp_27 = 11
    store tmp_26+0, tmp_27 as i32
    !tmp_27
    tmp_28 = 2
    store tmp_26+4, tmp_28 as i32
    !tmp_28
    store tmp_22+8, tmp_26 as ptr
    !tmp_26
    store bag+8, tmp_22 as ptr
    !tmp_22
    tmp_29 = call @sla__sum_active_x(bag)
    got = tmp_29
    tmp_30 = 7
    tmp_31 = ne got, tmp_30
    !tmp_30
    br tmp_31 -> L_THEN_8, L_ELSE_9

L_THEN_8:
    !tmp_31
    panic(1300)

L_ELSE_9:
    !tmp_31
    jmp L_MERGE_10

L_MERGE_10:
    !got
    !bag
    return
