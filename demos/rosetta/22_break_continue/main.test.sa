@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_compute_sum = vtable { call = @sla__compute_sum }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__compute_sum() -> i32:
L_ENTRY:
    tmp_0 = 0
    i = tmp_0
    tmp_1 = 0
    sum = tmp_1
    jmp L_WHILE_HEAD_0

L_WHILE_HEAD_0:
    tmp_2 = 1
    tmp_3 = 1
    tmp_4 = eq tmp_2, tmp_3
    !tmp_2
    !tmp_3
    br tmp_4 -> L_WHILE_BODY_1, L_WHILE_COND_FALSE_2

L_WHILE_BODY_1:
    !tmp_4
    tmp_5 = 1
    tmp_6 = add i, tmp_5
    !tmp_5
    !i
    i = tmp_6
    tmp_7 = 2
    tmp_8 = rem i, tmp_7
    !tmp_7
    tmp_9 = 0
    tmp_10 = eq tmp_8, tmp_9
    !tmp_8
    !tmp_9
    br tmp_10 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_10
    jmp L_WHILE_HEAD_0

L_ELSE_5:
    !tmp_10
    jmp L_MERGE_6

L_MERGE_6:
    tmp_12 = 5
    tmp_13 = sgt i, tmp_12
    !tmp_12
    br tmp_13 -> L_THEN_7, L_ELSE_8

L_THEN_7:
    !tmp_13
    jmp L_WHILE_EXIT_3

L_ELSE_8:
    !tmp_13
    jmp L_MERGE_9

L_MERGE_9:
    tmp_15 = add sum, i
    !sum
    sum = tmp_15
    jmp L_WHILE_HEAD_0

L_WHILE_COND_FALSE_2:
    !tmp_4
    jmp L_WHILE_EXIT_3

L_WHILE_EXIT_3:
    !i
    return sum

@main() -> i32:
L_ENTRY:
    tmp_16 = call @sla__compute_sum()
    sum = tmp_16
    tmp_17 = call @sa_fmt_u64(sum, 10)
    tmp_18 = call @sa_fmt_buffer_data(tmp_17)
    tmp_19 = call @sa_fmt_buffer_len(tmp_17)
    tmp_20 = tmp_18
    call @sa_print_bytes(&tmp_20, tmp_19)
    call @sa_fmt_buffer_free(^tmp_17)
    !tmp_20
    !tmp_19
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_21 = 0
    !sum
    return tmp_21

@test "rosetta 022 break continue"():
L_TEST_ENTRY_10:
    tmp_22 = call @sla__compute_sum()
    sum = tmp_22
    tmp_23 = 9
    tmp_24 = ne sum, tmp_23
    !tmp_23
    br tmp_24 -> L_THEN_11, L_ELSE_12

L_THEN_11:
    !tmp_24
    panic(22)

L_ELSE_12:
    !tmp_24
    jmp L_MERGE_13

L_MERGE_13:
    !sum
    return

