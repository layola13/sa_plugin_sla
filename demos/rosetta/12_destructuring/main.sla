// Sla companion for SA rosetta demo 012 Destructuring.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_012_value() -> int {
    let seed = 15;
    let shifted = seed + 12;
    let scaled = shifted * 5;
    let result = scaled - 17;
    return result;
}

fn main() -> int {
    let result = rosetta_012_value();
    return result;
};

@test "rosetta 012 12_destructuring"() {
    let got = rosetta_012_value();
    if got != 118 {
        panic(12);
    };
};
