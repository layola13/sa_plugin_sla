fn rosetta_105_value() -> i32 {
    let value = Some(5);
    let Some(x) = value else {
        println("{}", 0);
        return 0;
    };

    return x;
}

fn main() -> i32 {
    let value = rosetta_105_value();
    println("{}", value);
    return value;
}

@test "rosetta 105 105_let_else"() {
    let got = rosetta_105_value();
    if got != 5 {
        panic(105);
    };
}
