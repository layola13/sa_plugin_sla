@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_choose_left = vtable { call = @sla__choose_left }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__choose_left(&left: ptr, &_right: ptr) -> &ptr:
L_ENTRY:
    return left

@main() -> i32:
L_ENTRY:
    tmp_0 = 9
    left = stack_alloc 4
    store left+0, tmp_0 as i32
    tmp_1 = 4
    right = stack_alloc 4
    store right+0, tmp_1 as i32
    tmp_2 = call @sla__choose_left(&left, &right)
    chosen = tmp_2
    tmp_3 = load chosen+0 as i32
    tmp_4 = call @sa_fmt_u64(tmp_3, 10)
    tmp_5 = call @sa_fmt_buffer_data(tmp_4)
    tmp_6 = call @sa_fmt_buffer_len(tmp_4)
    tmp_7 = tmp_5
    call @sa_print_bytes(&tmp_7, tmp_6)
    call @sa_fmt_buffer_free(^tmp_4)
    !tmp_7
    !tmp_6
    !tmp_3
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_8 = 0
    !chosen
    return tmp_8

@test "rosetta 026 reference return"():
L_TEST_ENTRY_0:
    tmp_9 = 9
    left = stack_alloc 4
    store left+0, tmp_9 as i32
    tmp_10 = 4
    right = stack_alloc 4
    store right+0, tmp_10 as i32
    tmp_11 = call @sla__choose_left(&left, &right)
    chosen = tmp_11
    tmp_12 = load chosen+0 as i32
    value = tmp_12
    tmp_13 = 9
    tmp_14 = ne value, tmp_13
    !tmp_13
    br tmp_14 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_14
    panic(26)

L_ELSE_2:
    !tmp_14
    jmp L_MERGE_3

L_MERGE_3:
    !value
    !chosen
    return

