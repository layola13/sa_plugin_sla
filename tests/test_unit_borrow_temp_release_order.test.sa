    !tmp_295
    EXPAND BOX_NEW tmp_297, tmp_296
    !tmp_296
    store holder+0, tmp_297 as ptr
    !tmp_297
    tmp_298 = load holder+0 as ptr
    tmp_299 = load tmp_298+0 as ptr
    tmp_300 = &tmp_299
    rc_value = tmp_300
    EXPAND RC_GET tmp_301, rc_value
    tmp_302 = &tmp_301
    cell = tmp_302
    tmp_303 = 89
    call @sla__borrow_refcell_box_write(cell, tmp_303)
    tmp_304 = call @sla__borrow_refcell_box_read(cell)
    tmp_305 = 89
    tmp_306 = ne tmp_304, tmp_305
    !tmp_304
    !tmp_305
