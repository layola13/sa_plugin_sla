@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_main = vtable { call = @main }
@main() -> i32:
L_ENTRY:
    tmp_0 = alloc 24
    @const SLA_STR_0 = utf8:"sa"
    tmp_2 = 2
    tmp_1 = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW tmp_1, &SLA_STR_0, tmp_2
    !tmp_2
    store tmp_0+0, tmp_1 as ptr
    @const SLA_STR_1 = utf8:"asm"
    tmp_4 = 3
    tmp_3 = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW tmp_3, &SLA_STR_1, tmp_4
    !tmp_4
    store tmp_0+8, tmp_3 as ptr
    @const SLA_STR_2 = utf8:"!!"
    tmp_6 = 2
    tmp_5 = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW tmp_5, &SLA_STR_2, tmp_6
    !tmp_6
    store tmp_0+16, tmp_5 as ptr
    tmp_7 = 0
    tmp_8 = stack_alloc 8
    store tmp_8+0, tmp_7 as u64
    !tmp_7
    tmp_9 = 0
    tmp_10 = ptr_add tmp_0, tmp_9
    tmp_11 = load tmp_10+0 as ptr
    tmp_12 = load tmp_8+0 as u64
    EXPAND STRING_LEN tmp_13, tmp_11
    tmp_14 = add tmp_12, tmp_13
    !tmp_13
    store tmp_8+0, tmp_14 as u64
    !tmp_9
    !tmp_10
    !tmp_11
    !tmp_12
    !tmp_14
    tmp_15 = 8
    tmp_16 = ptr_add tmp_0, tmp_15
    tmp_17 = load tmp_16+0 as ptr
    tmp_18 = load tmp_8+0 as u64
    EXPAND STRING_LEN tmp_19, tmp_17
    tmp_20 = add tmp_18, tmp_19
    !tmp_19
    store tmp_8+0, tmp_20 as u64
    !tmp_15
    !tmp_16
    !tmp_17
    !tmp_18
    !tmp_20
    tmp_21 = 16
    tmp_22 = ptr_add tmp_0, tmp_21
    tmp_23 = load tmp_22+0 as ptr
    tmp_24 = load tmp_8+0 as u64
    EXPAND STRING_LEN tmp_25, tmp_23
    tmp_26 = add tmp_24, tmp_25
    !tmp_25
    store tmp_8+0, tmp_26 as u64
    !tmp_21
    !tmp_22
    !tmp_23
    !tmp_24
    !tmp_26
    !tmp_0
    tmp_27 = load tmp_8+0 as u64
    total = tmp_27
    tmp_28 = call @sa_fmt_u64(total, 10)
    tmp_29 = call @sa_fmt_buffer_data(tmp_28)
    tmp_30 = call @sa_fmt_buffer_len(tmp_28)
    tmp_31 = tmp_29
    call @sa_print_bytes(&tmp_31, tmp_30)
    call @sa_fmt_buffer_free(^tmp_28)
    !tmp_31
    !tmp_30
    @const SLA_STR_3 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_3, 1)
    tmp_32 = 0
    !total
    return tmp_32

