@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
fn mmap_mapped_fd() -> i32 { let raw_fd = 3; let mapped_fd = raw_fd + 1; return mapped_fd; }
fn main() -> i32 { let result = mmap_mapped_fd(); println("{}", result); return result; }
@test "rosetta 182 182_mmap_memory_mapping"() { let got = mmap_mapped_fd(); if got != 4 { panic(182); }; }
