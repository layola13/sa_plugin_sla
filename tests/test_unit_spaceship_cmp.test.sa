@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/cmp.sa"
@const SLA_FNPTR_VT_ordering_value = vtable { call = @sla__ordering_value }
@const SLA_FNPTR_VT_make_key = vtable { call = @sla__make_key }
@sla__Ordering_less() -> ptr:
L_ENTRY:
    tmp_0 = alloc 8
    tmp_1 = 0
    tmp_2 = 1
    tmp_3 = sub tmp_1, tmp_2
    !tmp_1
    !tmp_2
    store tmp_0+0, tmp_3 as i64
    !tmp_3
    return tmp_0

@sla__Ordering_equal() -> ptr:
L_ENTRY:
    tmp_4 = alloc 8
    tmp_5 = 0
    store tmp_4+0, tmp_5 as i64
    !tmp_5
    return tmp_4

@sla__Ordering_greater() -> ptr:
L_ENTRY:
    tmp_6 = alloc 8
    tmp_7 = 1
    store tmp_6+0, tmp_7 as i64
    !tmp_7
    return tmp_6

@sla__Ordering_is_lt(self: ptr) -> u8:
L_ENTRY:
    tmp_8 = load self+0 as i64
    tmp_9 = 0
    tmp_10 = 1
    tmp_11 = sub tmp_9, tmp_10
    !tmp_9
    !tmp_10
    tmp_12 = eq tmp_8, tmp_11
    !tmp_8
    !tmp_11
    !self
    return tmp_12

@sla__Ordering_is_eq(self: ptr) -> u8:
L_ENTRY:
    tmp_13 = load self+0 as i64
    tmp_14 = 0
    tmp_15 = eq tmp_13, tmp_14
    !tmp_13
    !tmp_14
    !self
    return tmp_15

@sla__Ordering_is_gt(self: ptr) -> u8:
L_ENTRY:
    tmp_16 = load self+0 as i64
    tmp_17 = 1
    tmp_18 = eq tmp_16, tmp_17
    !tmp_16
    !tmp_17
    !self
    return tmp_18

@sla__Ordering_is_le(self: ptr) -> u8:
L_ENTRY:
    tmp_19 = load self+0 as i64
    tmp_20 = 0
    tmp_21 = sle tmp_19, tmp_20
    !tmp_19
    !tmp_20
    !self
    return tmp_21

@sla__Ordering_is_ge(self: ptr) -> u8:
L_ENTRY:
    tmp_22 = load self+0 as i64
    tmp_23 = 0
    tmp_24 = sge tmp_22, tmp_23
    !tmp_22
    !tmp_23
    !self
    return tmp_24

@sla__Ordering_reverse(self: ptr) -> ptr:
L_ENTRY:
    tmp_25 = load self+0 as i64
    tmp_26 = 0
    tmp_27 = slt tmp_25, tmp_26
    !tmp_25
    !tmp_26
    br tmp_27 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_27
    tmp_28 = call @sla__Ordering_greater()
    !self
    return tmp_28

L_ELSE_1:
    !tmp_27
    jmp L_MERGE_2

L_MERGE_2:
    tmp_30 = load self+0 as i64
    tmp_31 = 0
    tmp_32 = sgt tmp_30, tmp_31
    !tmp_30
    !tmp_31
    br tmp_32 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_32
    tmp_33 = call @sla__Ordering_less()
    !self
    return tmp_33

L_ELSE_4:
    !tmp_32
    jmp L_MERGE_5

L_MERGE_5:
    tmp_35 = call @sla__Ordering_equal()
    !self
    return tmp_35

@sla__Ordering_then(self: ptr, other: ptr) -> ptr:
L_ENTRY:
    tmp_36 = load self+0 as i64
    tmp_37 = 0
    tmp_38 = eq tmp_36, tmp_37
    !tmp_36
    !tmp_37
    br tmp_38 -> L_THEN_6, L_ELSE_7

L_THEN_6:
    !tmp_38
    !self
    return other

L_ELSE_7:
    !tmp_38
    jmp L_MERGE_8

L_MERGE_8:
    !other
    return self

@sla__ordering_value(ordering: ptr) -> i64:
L_ENTRY:
    tmp_40 = load ordering+0 as i64
    !ordering
    return tmp_40

@sla__make_key(major: i64, minor: i64) -> ptr:
L_ENTRY:
    tmp_41 = alloc 16
    store tmp_41+0, major as i64
    store tmp_41+8, minor as i64
    return tmp_41

@test "spaceship compares signed integers as Ordering"():
L_TEST_ENTRY_9:
    tmp_42 = 1
    tmp_43 = 2
    EXPAND CMP_COMPARE_I64 tmp_44, tmp_42, tmp_43
    tmp_45 = alloc 8
    store tmp_45+0, tmp_44 as i64
    !tmp_42
    !tmp_43
    less = tmp_45
    tmp_46 = call @sla__Ordering_is_lt(less)
    tmp_47 = 1
    tmp_48 = ne tmp_46, tmp_47
    !tmp_46
    !tmp_47
    br tmp_48 -> L_THEN_10, L_ELSE_11

L_THEN_10:
    !tmp_48
    panic(33000)

L_ELSE_11:
    !tmp_48
    jmp L_MERGE_12

L_MERGE_12:
    tmp_51 = call @sla__ordering_value(less)
    tmp_52 = 0
    tmp_53 = 1
    tmp_54 = sub tmp_52, tmp_53
    !tmp_52
    !tmp_53
    tmp_55 = ne tmp_51, tmp_54
    !tmp_51
    !tmp_54
    br tmp_55 -> L_THEN_13, L_ELSE_14

L_THEN_13:
    !tmp_55
    panic(33001)

L_ELSE_14:
    !tmp_55
    jmp L_MERGE_15

L_MERGE_15:
    tmp_58 = 2
    tmp_59 = 2
    EXPAND CMP_COMPARE_I64 tmp_60, tmp_58, tmp_59
    tmp_61 = alloc 8
    store tmp_61+0, tmp_60 as i64
    !tmp_58
    !tmp_59
    equal = tmp_61
    tmp_62 = call @sla__Ordering_is_eq(equal)
    tmp_63 = 1
    tmp_64 = ne tmp_62, tmp_63
    !tmp_62
    !tmp_63
    br tmp_64 -> L_THEN_16, L_ELSE_17

L_THEN_16:
    !tmp_64
    panic(33002)

L_ELSE_17:
    !tmp_64
    jmp L_MERGE_18

L_MERGE_18:
    tmp_67 = call @sla__ordering_value(equal)
    tmp_68 = 0
    tmp_69 = ne tmp_67, tmp_68
    !tmp_67
    !tmp_68
    br tmp_69 -> L_THEN_19, L_ELSE_20

L_THEN_19:
    !tmp_69
    panic(33003)

L_ELSE_20:
    !tmp_69
    jmp L_MERGE_21

L_MERGE_21:
    tmp_72 = 3
    tmp_73 = 2
    EXPAND CMP_COMPARE_I64 tmp_74, tmp_72, tmp_73
    tmp_75 = alloc 8
    store tmp_75+0, tmp_74 as i64
    !tmp_72
    !tmp_73
    greater = tmp_75
    tmp_76 = call @sla__Ordering_is_gt(greater)
    tmp_77 = 1
    tmp_78 = ne tmp_76, tmp_77
    !tmp_76
    !tmp_77
    br tmp_78 -> L_THEN_22, L_ELSE_23

L_THEN_22:
    !tmp_78
    panic(33004)

L_ELSE_23:
    !tmp_78
    jmp L_MERGE_24

L_MERGE_24:
    tmp_81 = call @sla__ordering_value(greater)
    tmp_82 = 1
    tmp_83 = ne tmp_81, tmp_82
    !tmp_81
    !tmp_82
    br tmp_83 -> L_THEN_25, L_ELSE_26

L_THEN_25:
    !tmp_83
    panic(33005)

L_ELSE_26:
    !tmp_83
    jmp L_MERGE_27

L_MERGE_27:
    !less
    !greater
    !equal
    return

@test "spaceship compares derived struct lexicographically"():
L_TEST_ENTRY_28:
    tmp_86 = 1
    tmp_87 = 9
    tmp_88 = call @sla__make_key(tmp_86, tmp_87)
    !tmp_86
    !tmp_87
    a = tmp_88
    tmp_89 = 2
    tmp_90 = 0
    tmp_91 = call @sla__make_key(tmp_89, tmp_90)
    !tmp_89
    !tmp_90
    b = tmp_91
    tmp_92 = 2
    tmp_93 = 3
    tmp_94 = call @sla__make_key(tmp_92, tmp_93)
    !tmp_92
    !tmp_93
    c = tmp_94
    tmp_95 = 2
    tmp_96 = 3
    tmp_97 = call @sla__make_key(tmp_95, tmp_96)
    !tmp_95
    !tmp_96
    d = tmp_97
    tmp_98 = alloc 8
    store tmp_98+0, CMP_ORDERING_EQUAL as i64
    tmp_99 = load a+0 as i64
    tmp_100 = load b+0 as i64
    tmp_101 = slt tmp_99, tmp_100
    br tmp_101 -> L_SPACESHIP_STRUCT_LESS_30, L_SPACESHIP_STRUCT_CHECK_GREATER_31

L_SPACESHIP_STRUCT_LESS_30:
    store tmp_98+0, CMP_ORDERING_LESS as i64
    jmp L_SPACESHIP_STRUCT_DONE_29

L_SPACESHIP_STRUCT_CHECK_GREATER_31:
    tmp_102 = sgt tmp_99, tmp_100
    br tmp_102 -> L_SPACESHIP_STRUCT_GREATER_32, L_SPACESHIP_STRUCT_NEXT_33

L_SPACESHIP_STRUCT_GREATER_32:
    store tmp_98+0, CMP_ORDERING_GREATER as i64
    jmp L_SPACESHIP_STRUCT_DONE_29

L_SPACESHIP_STRUCT_NEXT_33:
    tmp_103 = load a+8 as i64
    tmp_104 = load b+8 as i64
    tmp_105 = slt tmp_103, tmp_104
    br tmp_105 -> L_SPACESHIP_STRUCT_LESS_34, L_SPACESHIP_STRUCT_CHECK_GREATER_35

L_SPACESHIP_STRUCT_LESS_34:
    store tmp_98+0, CMP_ORDERING_LESS as i64
    jmp L_SPACESHIP_STRUCT_DONE_29

L_SPACESHIP_STRUCT_CHECK_GREATER_35:
    tmp_106 = sgt tmp_103, tmp_104
    br tmp_106 -> L_SPACESHIP_STRUCT_GREATER_36, L_SPACESHIP_STRUCT_NEXT_37

L_SPACESHIP_STRUCT_GREATER_36:
    store tmp_98+0, CMP_ORDERING_GREATER as i64
    jmp L_SPACESHIP_STRUCT_DONE_29

L_SPACESHIP_STRUCT_NEXT_37:
L_SPACESHIP_STRUCT_DONE_29:
    first_field = tmp_98
    tmp_107 = call @sla__Ordering_is_lt(first_field)
    tmp_108 = 1
    tmp_109 = ne tmp_107, tmp_108
    !tmp_107
    !tmp_108
    br tmp_109 -> L_THEN_38, L_ELSE_39

L_THEN_38:
    !tmp_109
    panic(33010)

L_ELSE_39:
    !tmp_109
    jmp L_MERGE_40

L_MERGE_40:
    tmp_112 = alloc 8
    store tmp_112+0, CMP_ORDERING_EQUAL as i64
    tmp_113 = load c+0 as i64
    tmp_114 = load b+0 as i64
    tmp_115 = slt tmp_113, tmp_114
    br tmp_115 -> L_SPACESHIP_STRUCT_LESS_42, L_SPACESHIP_STRUCT_CHECK_GREATER_43

L_SPACESHIP_STRUCT_LESS_42:
    store tmp_112+0, CMP_ORDERING_LESS as i64
    jmp L_SPACESHIP_STRUCT_DONE_41

L_SPACESHIP_STRUCT_CHECK_GREATER_43:
    tmp_116 = sgt tmp_113, tmp_114
    br tmp_116 -> L_SPACESHIP_STRUCT_GREATER_44, L_SPACESHIP_STRUCT_NEXT_45

L_SPACESHIP_STRUCT_GREATER_44:
    store tmp_112+0, CMP_ORDERING_GREATER as i64
    jmp L_SPACESHIP_STRUCT_DONE_41

L_SPACESHIP_STRUCT_NEXT_45:
    tmp_117 = load c+8 as i64
    tmp_118 = load b+8 as i64
    tmp_119 = slt tmp_117, tmp_118
    br tmp_119 -> L_SPACESHIP_STRUCT_LESS_46, L_SPACESHIP_STRUCT_CHECK_GREATER_47

L_SPACESHIP_STRUCT_LESS_46:
    store tmp_112+0, CMP_ORDERING_LESS as i64
    jmp L_SPACESHIP_STRUCT_DONE_41

L_SPACESHIP_STRUCT_CHECK_GREATER_47:
    tmp_120 = sgt tmp_117, tmp_118
    br tmp_120 -> L_SPACESHIP_STRUCT_GREATER_48, L_SPACESHIP_STRUCT_NEXT_49

L_SPACESHIP_STRUCT_GREATER_48:
    store tmp_112+0, CMP_ORDERING_GREATER as i64
    jmp L_SPACESHIP_STRUCT_DONE_41

L_SPACESHIP_STRUCT_NEXT_49:
L_SPACESHIP_STRUCT_DONE_41:
    second_field = tmp_112
    tmp_121 = call @sla__Ordering_is_gt(second_field)
    tmp_122 = 1
    tmp_123 = ne tmp_121, tmp_122
    !tmp_121
    !tmp_122
    br tmp_123 -> L_THEN_50, L_ELSE_51

L_THEN_50:
    !tmp_123
    panic(33011)

L_ELSE_51:
    !tmp_123
    jmp L_MERGE_52

L_MERGE_52:
    tmp_126 = alloc 8
    store tmp_126+0, CMP_ORDERING_EQUAL as i64
    tmp_127 = load c+0 as i64
    tmp_128 = load d+0 as i64
    tmp_129 = slt tmp_127, tmp_128
    br tmp_129 -> L_SPACESHIP_STRUCT_LESS_54, L_SPACESHIP_STRUCT_CHECK_GREATER_55

L_SPACESHIP_STRUCT_LESS_54:
    store tmp_126+0, CMP_ORDERING_LESS as i64
    jmp L_SPACESHIP_STRUCT_DONE_53

L_SPACESHIP_STRUCT_CHECK_GREATER_55:
    tmp_130 = sgt tmp_127, tmp_128
    br tmp_130 -> L_SPACESHIP_STRUCT_GREATER_56, L_SPACESHIP_STRUCT_NEXT_57

L_SPACESHIP_STRUCT_GREATER_56:
    store tmp_126+0, CMP_ORDERING_GREATER as i64
    jmp L_SPACESHIP_STRUCT_DONE_53

L_SPACESHIP_STRUCT_NEXT_57:
    tmp_131 = load c+8 as i64
    tmp_132 = load d+8 as i64
    tmp_133 = slt tmp_131, tmp_132
    br tmp_133 -> L_SPACESHIP_STRUCT_LESS_58, L_SPACESHIP_STRUCT_CHECK_GREATER_59

L_SPACESHIP_STRUCT_LESS_58:
    store tmp_126+0, CMP_ORDERING_LESS as i64
    jmp L_SPACESHIP_STRUCT_DONE_53

L_SPACESHIP_STRUCT_CHECK_GREATER_59:
    tmp_134 = sgt tmp_131, tmp_132
    br tmp_134 -> L_SPACESHIP_STRUCT_GREATER_60, L_SPACESHIP_STRUCT_NEXT_61

L_SPACESHIP_STRUCT_GREATER_60:
    store tmp_126+0, CMP_ORDERING_GREATER as i64
    jmp L_SPACESHIP_STRUCT_DONE_53

L_SPACESHIP_STRUCT_NEXT_61:
L_SPACESHIP_STRUCT_DONE_53:
    same = tmp_126
    tmp_135 = call @sla__Ordering_is_eq(same)
    tmp_136 = 1
    tmp_137 = ne tmp_135, tmp_136
    !tmp_135
    !tmp_136
    br tmp_137 -> L_THEN_62, L_ELSE_63

L_THEN_62:
    !tmp_137
    panic(33012)

L_ELSE_63:
    !tmp_137
    jmp L_MERGE_64

L_MERGE_64:
    !same
    !a
    !first_field
    !d
    !b
    !second_field
    !c
    return

@test "Ordering helper methods live in sla std"():
L_TEST_ENTRY_65:
    tmp_140 = call @sla__Ordering_less()
    less = tmp_140
    tmp_141 = call @sla__Ordering_equal()
    equal = tmp_141
    tmp_142 = call @sla__Ordering_greater()
    greater = tmp_142
    tmp_143 = call @sla__Ordering_is_lt(less)
    tmp_144 = 1
    tmp_145 = ne tmp_143, tmp_144
    !tmp_143
    !tmp_144
    br tmp_145 -> L_THEN_66, L_ELSE_67

L_THEN_66:
    !tmp_145
    panic(33020)

L_ELSE_67:
    !tmp_145
    jmp L_MERGE_68

L_MERGE_68:
    tmp_148 = call @sla__Ordering_is_eq(equal)
    tmp_149 = 1
    tmp_150 = ne tmp_148, tmp_149
    !tmp_148
    !tmp_149
    br tmp_150 -> L_THEN_69, L_ELSE_70

L_THEN_69:
    !tmp_150
    panic(33021)

L_ELSE_70:
    !tmp_150
    jmp L_MERGE_71

L_MERGE_71:
    tmp_153 = call @sla__Ordering_is_gt(greater)
    tmp_154 = 1
    tmp_155 = ne tmp_153, tmp_154
    !tmp_153
    !tmp_154
    br tmp_155 -> L_THEN_72, L_ELSE_73

L_THEN_72:
    !tmp_155
    panic(33022)

L_ELSE_73:
    !tmp_155
    jmp L_MERGE_74

L_MERGE_74:
    tmp_158 = call @sla__Ordering_reverse(less)
    tmp_159 = call @sla__Ordering_is_gt(tmp_158)
    !tmp_158
    tmp_160 = 1
    tmp_161 = ne tmp_159, tmp_160
    !tmp_159
    !tmp_160
    br tmp_161 -> L_THEN_75, L_ELSE_76

L_THEN_75:
    !tmp_161
    panic(33023)

L_ELSE_76:
    !tmp_161
    jmp L_MERGE_77

L_MERGE_77:
    tmp_164 = call @sla__Ordering_then(equal, greater)
    tmp_165 = call @sla__Ordering_is_gt(tmp_164)
    !tmp_164
    tmp_166 = 1
    tmp_167 = ne tmp_165, tmp_166
    !tmp_165
    !tmp_166
    br tmp_167 -> L_THEN_78, L_ELSE_79

L_THEN_78:
    !tmp_167
    panic(33024)

L_ELSE_79:
    !tmp_167
    jmp L_MERGE_80

L_MERGE_80:
    tmp_170 = call @sla__Ordering_then(less, greater)
    tmp_171 = call @sla__Ordering_is_lt(tmp_170)
    !tmp_170
    tmp_172 = 1
    tmp_173 = ne tmp_171, tmp_172
    !tmp_171
    !tmp_172
    br tmp_173 -> L_THEN_81, L_ELSE_82

L_THEN_81:
    !tmp_173
    panic(33025)

L_ELSE_82:
    !tmp_173
    jmp L_MERGE_83

L_MERGE_83:
    !less
    !greater
    !equal
    return

