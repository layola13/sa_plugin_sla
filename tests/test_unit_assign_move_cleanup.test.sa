@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_step = vtable { call = @sla__step }
@const SLA_FNPTR_VT_run_n = vtable { call = @sla__run_n }
@sla__step(input: ptr) -> ptr:
L_ENTRY:
    tmp_0 = alloc 4
    tmp_1 = load input+0 as i32
    tmp_2 = 1
    tmp_3 = add tmp_1, tmp_2
    !tmp_2
    store tmp_0+0, tmp_3 as i32
    !tmp_3
    !input
    return tmp_0

@sla__run_n(boxed: ptr, n: i32) -> ptr:
L_ENTRY:
    tmp_4 = 0
    i = tmp_4
    jmp L_WHILE_HEAD_0

L_WHILE_HEAD_0:
    tmp_5 = slt i, n
    br tmp_5 -> L_WHILE_BODY_1, L_WHILE_COND_FALSE_2

L_WHILE_BODY_1:
    !tmp_5
    tmp_6 = call @sla__step(boxed)
    next = tmp_6
    !boxed
    boxed = next
    tmp_7 = 1
    tmp_8 = add i, tmp_7
    !tmp_7
    !i
    i = tmp_8
    jmp L_WHILE_HEAD_0

L_WHILE_COND_FALSE_2:
    !tmp_5
    jmp L_WHILE_EXIT_3

L_WHILE_EXIT_3:
    !i
    !n
    return boxed

@test "assign moved local cleanup"():
L_TEST_ENTRY_4:
    tmp_9 = alloc 4
    tmp_10 = 1
    store tmp_9+0, tmp_10 as i32
    !tmp_10
    tmp_11 = 3
    tmp_12 = call @sla__run_n(tmp_9, tmp_11)
    !tmp_9
    !tmp_11
    out = tmp_12
    tmp_13 = load out+0 as i32
    tmp_14 = 4
    tmp_15 = ne tmp_13, tmp_14
    !tmp_14
    br tmp_15 -> L_THEN_5, L_ELSE_6

L_THEN_5:
    !tmp_15
    panic(1400)

L_ELSE_6:
    !tmp_15
    jmp L_MERGE_7

L_MERGE_7:
    !out
    return
