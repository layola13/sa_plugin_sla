@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
fn trait_upcast_method_sum() -> i32 { let base_method = 2; let derived_method = 3; return base_method + derived_method; }
fn main() -> i32 { let result = trait_upcast_method_sum(); println("{}", result); return result; }
@test "rosetta 164 164_trait_upcasting"() { let got = trait_upcast_method_sum(); if got != 5 { panic(164); }; }
