    tmp_13 = tmp_11
    call @sa_print_bytes(&tmp_13, tmp_12)
    call @sa_fmt_buffer_free(^tmp_10)
    !tmp_13
    !tmp_12
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !raw
    return result

@test "rosetta 153 153_box_into_raw"():
L_TEST_ENTRY_0:
    tmp_14 = call @sla__box_into_raw_value()
    got = tmp_14
    tmp_15 = 9
    tmp_16 = ne got, tmp_15
    !tmp_15
    br tmp_16 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_16
    panic(153)

L_ELSE_2:
