@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/mem.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_manually_drop_union_value = vtable { call = @sla__manually_drop_union_value }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__manually_drop_union_value() -> i32:
L_ENTRY:
    slot = alloc 8
    tmp_0 = 11
    tmp_1 = ptr_add slot, 0
    EXPAND MANUALLY_DROP_U64_NEW tmp_1, tmp_0
    !tmp_1
    !tmp_0
    tmp_3 = ptr_add slot, 0
    EXPAND MANUALLY_DROP_U64_INTO_INNER tmp_4, tmp_3
    !tmp_3
    tmp_2 = tmp_4
    value = tmp_2
    !slot
    return value

@main() -> i32:
L_ENTRY:
    slot = alloc 8
    tmp_5 = 11
    tmp_6 = ptr_add slot, 0
    EXPAND MANUALLY_DROP_U64_NEW tmp_6, tmp_5
    !tmp_6
    !tmp_5
    tmp_8 = ptr_add slot, 0
    EXPAND MANUALLY_DROP_U64_INTO_INNER tmp_9, tmp_8
    !tmp_8
    tmp_7 = tmp_9
    result = tmp_7
    tmp_10 = call @sa_fmt_u64(result, 10)
    tmp_11 = call @sa_fmt_buffer_data(tmp_10)
    tmp_12 = call @sa_fmt_buffer_len(tmp_10)
    tmp_13 = tmp_11
    call @sa_print_bytes(&tmp_13, tmp_12)
    call @sa_fmt_buffer_free(^tmp_10)
    !tmp_13
    !tmp_12
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !slot
    return result

@test "rosetta 160 160_manually_drop_union"():
L_TEST_ENTRY_0:
    tmp_14 = call @sla__manually_drop_union_value()
    got = tmp_14
    tmp_15 = 11
    tmp_16 = ne got, tmp_15
    !tmp_15
    br tmp_16 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_16
    panic(160)

L_ELSE_2:
    !tmp_16
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

