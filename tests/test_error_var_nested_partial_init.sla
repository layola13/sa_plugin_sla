fn bad_var_nested_partial_init(a: bool, b: bool) -> i32 {
    var x: i32;
    if a {
        if b {
            x = 1;
        } else {
            x = 2;
        };
    } else {
        if b {
            x = 3;
        };
    };
    return x;
}

fn main() -> i32 {
    return bad_var_nested_partial_init(false, false);
}
