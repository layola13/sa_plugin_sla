@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn pkg_multiple_versions_conflict() -> i32 {
    let conflict_reported = 1;
    return conflict_reported;
}

fn main() -> i32 { let result = pkg_multiple_versions_conflict(); println("{}", result); return result; }
