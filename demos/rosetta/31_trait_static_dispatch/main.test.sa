@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const VT_Square_Area = vtable { area = @sla__Square_area }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@const SLA_FNPTR_VT_area_of_Square = vtable { call = @sla__area_of_Square }
@sla__Square_area(&self: ptr) -> i32:
L_ENTRY:
    tmp_0 = alloc 4
    tmp_1 = load self+0 as i32
    tmp_2 = load self+0 as i32
    tmp_3 = mul tmp_1, tmp_2
    store tmp_0+0, tmp_3 as i32
    !tmp_1
    tmp_4 = load tmp_0+0 as i32
    return tmp_4

@main() -> i32:
L_ENTRY:
    square = alloc 4
    tmp_5 = 4
    store square+0, tmp_5 as i32
    tmp_6 = call @sla__area_of_Square(&square)
    tmp_7 = call @sa_fmt_u64(tmp_6, 10)
    tmp_8 = call @sa_fmt_buffer_data(tmp_7)
    tmp_9 = call @sa_fmt_buffer_len(tmp_7)
    tmp_10 = tmp_8
    call @sa_print_bytes(&tmp_10, tmp_9)
    call @sa_fmt_buffer_free(^tmp_7)
    !tmp_10
    !tmp_9
    !tmp_6
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_11 = 0
    !square
    return tmp_11

@sla__area_of_Square(&value: ptr) -> i32:
L_ENTRY:
    tmp_12 = call @sla__Square_area(&value)
    return tmp_12

@test "rosetta 031 trait static dispatch"():
L_TEST_ENTRY_0:
    square = alloc 4
    tmp_13 = 4
    store square+0, tmp_13 as i32
    tmp_14 = call @sla__area_of_Square(&square)
    result = tmp_14
    tmp_15 = 16
    tmp_16 = ne result, tmp_15
    !tmp_15
    br tmp_16 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_16
    panic(31)

L_ELSE_2:
    !tmp_16
    jmp L_MERGE_3

L_MERGE_3:
    !square
    !result
    return

