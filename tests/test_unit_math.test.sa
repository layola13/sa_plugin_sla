@test "整数对数下界 log2-64- == 6 via 2^6==64"():
L_TEST_ENTRY_152:
    tmp_325 = 2
    tmp_326 = 6
    tmp_327 = call @power(tmp_325, tmp_326)
    p = tmp_327
    tmp_328 = 64
    tmp_329 = eq p, tmp_328
    ok = tmp_329
    br ok -> L_THEN_153, L_ELSE_154

L_THEN_153:
    !ok
    jmp L_MERGE_155

L_ELSE_154:
    !ok
    panic(1)

L_MERGE_155:
    !p
    return

@test "梯形面积 -a+b-*h/2 -a=3,b=7,h=4- == 20"():
L_TEST_ENTRY_156:
    tmp_332 = 3
    a = tmp_332
    tmp_333 = 7
    b = tmp_333
    tmp_334 = 4
    h = tmp_334
    tmp_335 = add a, b
    tmp_336 = mul tmp_335, h
    tmp_337 = 2
    tmp_338 = div tmp_336, tmp_337
    area = tmp_338
    tmp_339 = 20
    tmp_340 = eq area, tmp_339
    ok = tmp_340
    br ok -> L_THEN_157, L_ELSE_158

L_THEN_157:
    !ok
    jmp L_MERGE_159

L_ELSE_158:
    !ok
    panic(1)

L_MERGE_159:
    !b
    !a
    !area
    !h
    return

@test "距离平方公式 d^2=-x2-x1-^2+-y2-y1-^2 -0,0---3,4- == 25"():
L_TEST_ENTRY_160:
    tmp_343 = 0
    x1 = tmp_343
    tmp_344 = 0
    y1 = tmp_344
    tmp_345 = 3
    x2 = tmp_345
    tmp_346 = 4
    y2 = tmp_346
    tmp_347 = sub x2, x1
    dx = tmp_347
    tmp_348 = sub y2, y1
    dy = tmp_348
    tmp_349 = mul dx, dx
    tmp_350 = mul dy, dy
    tmp_351 = add tmp_349, tmp_350
    d2 = tmp_351
    tmp_352 = 25
    tmp_353 = eq d2, tmp_352
    ok = tmp_353
    br ok -> L_THEN_161, L_ELSE_162

L_THEN_161:
    !ok
    jmp L_MERGE_163

L_ELSE_162:
    !ok
    panic(1)

L_MERGE_163:
    !y2
    !dx
    !y1
    !dy
    !d2
    !x2
    !x1
    return

