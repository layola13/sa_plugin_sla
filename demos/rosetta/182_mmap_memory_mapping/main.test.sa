@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/result.sa"
@import "sa_std/fs.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/result.sa"
@const SLA_FNPTR_VT_mmap_mapped_fd = vtable { call = @sla__mmap_mapped_fd }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__mmap_mapped_fd() -> i32:
L_ENTRY:
    tmp_0 = 0
    mapped_fd = tmp_0
    @const SLA_STR_0 = utf8:"/dev/zero"
    tmp_2 = 9
    tmp_1 = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW tmp_1, &SLA_STR_0, tmp_2
    !tmp_2
    tmp_3 = load tmp_1+Slice_ptr as ptr
    tmp_4 = load tmp_1+Slice_len as u64
    EXPAND FS_OPEN_READ tmp_5, tmp_6, tmp_3, tmp_4
    tmp_8 = eq tmp_5, SA_FS_OK
    br tmp_8 -> L_FILE_OPEN_OK_0, L_FILE_OPEN_ERR_1

L_FILE_OPEN_OK_0:
    EXPAND RESULT_NEW_OK tmp_7, tmp_6
    !tmp_5
    !tmp_6
    jmp L_FILE_OPEN_END_2

L_FILE_OPEN_ERR_1:
    EXPAND RESULT_NEW_ERR tmp_7, tmp_5
    !tmp_5
    !tmp_6
    jmp L_FILE_OPEN_END_2

L_FILE_OPEN_END_2:
    !tmp_8
    !tmp_4
    !tmp_3
    EXPAND RESULT_UNWRAP tmp_9, tmp_7
    !tmp_7
    file = tmp_9
    tmp_10 = add file, 0
    tmp_11 = tmp_10 as i32
    raw_fd = tmp_11
    tmp_12 = 1
    tmp_13 = add raw_fd, tmp_12
    !tmp_12
    !mapped_fd
    mapped_fd = tmp_13
    EXPAND FS_CLOSE tmp_14, file
    !tmp_14
    !raw_fd
    return mapped_fd

@main() -> i32:
L_ENTRY:
    @const SLA_STR_1 = utf8:"/dev/zero"
    tmp_16 = 9
    tmp_15 = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW tmp_15, &SLA_STR_1, tmp_16
    !tmp_16
    tmp_17 = load tmp_15+Slice_ptr as ptr
    tmp_18 = load tmp_15+Slice_len as u64
    EXPAND FS_OPEN_READ tmp_19, tmp_20, tmp_17, tmp_18
    tmp_22 = eq tmp_19, SA_FS_OK
    br tmp_22 -> L_FILE_OPEN_OK_3, L_FILE_OPEN_ERR_4

L_FILE_OPEN_OK_3:
    EXPAND RESULT_NEW_OK tmp_21, tmp_20
    !tmp_19
    !tmp_20
    jmp L_FILE_OPEN_END_5

L_FILE_OPEN_ERR_4:
    EXPAND RESULT_NEW_ERR tmp_21, tmp_19
    !tmp_19
    !tmp_20
    jmp L_FILE_OPEN_END_5

L_FILE_OPEN_END_5:
    !tmp_22
    !tmp_18
    !tmp_17
    EXPAND RESULT_UNWRAP tmp_23, tmp_21
    !tmp_21
    file = tmp_23
    tmp_24 = add file, 0
    tmp_25 = tmp_24 as i32
    raw_fd = tmp_25
    tmp_26 = 1
    tmp_27 = add raw_fd, tmp_26
    !tmp_26
    result = tmp_27
    tmp_28 = call @sa_fmt_u64(result, 10)
    tmp_29 = call @sa_fmt_buffer_data(tmp_28)
    tmp_30 = call @sa_fmt_buffer_len(tmp_28)
    tmp_31 = tmp_29
    call @sa_print_bytes(&tmp_31, tmp_30)
    call @sa_fmt_buffer_free(^tmp_28)
    !tmp_31
    !tmp_30
    @const SLA_STR_2 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_2, 1)
    EXPAND FS_CLOSE tmp_32, file
    !tmp_32
    !raw_fd
    return result

@test "rosetta 182 182_mmap_memory_mapping"():
L_TEST_ENTRY_6:
    tmp_33 = call @sla__mmap_mapped_fd()
    got = tmp_33
    tmp_34 = 0
    tmp_35 = sle got, tmp_34
    !tmp_34
    br tmp_35 -> L_THEN_7, L_ELSE_8

L_THEN_7:
    !tmp_35
    panic(182)

L_ELSE_8:
    !tmp_35
    jmp L_MERGE_9

L_MERGE_9:
    !got
    return

