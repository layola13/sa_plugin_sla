fn direct_if_len_then_loop(data: ptr, data_len: int) -> int {
    if data_len < 8 {
        return 0;
    };
    let i = 0;
    let count = 0;
    while i < 3 {
        count = count + 1;
        i = i + 1;
    }
    return count;
}

@test "direct sab if length guard before loop keeps compare temps valid"() {
    let got = direct_if_len_then_loop("abcdefgh", 8);
    if got != 3 {
        panic(61051);
    };
}
