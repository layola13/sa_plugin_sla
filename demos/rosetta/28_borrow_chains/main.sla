@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn read_twice(&value: i32) -> i32 {
    *value + *value
}

fn main() -> i32 {
    let value: i32 = 6;
    println("{}", read_twice(&value));
    return 0;
};

@test "rosetta 028 borrow chains"() {
    let value: i32 = 6;
    let result: i32 = read_twice(&value);
    if result != 12 {
        panic(28);
    };
};
