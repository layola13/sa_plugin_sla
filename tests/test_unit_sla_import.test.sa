@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_imported_area = vtable { call = @sla__imported_area }
@const SLA_FNPTR_VT_point_sum = vtable { call = @sla__point_sum }
@sla__imported_area(r: ptr) -> i32:
L_ENTRY:
    tmp_0 = load r+0 as i32
    tmp_1 = load r+4 as i32
    tmp_2 = mul tmp_0, tmp_1
    !r
    return tmp_2

@sla__point_sum(p: ptr) -> i32:
L_ENTRY:
    tmp_3 = load p+0 as i32
    tmp_4 = load p+4 as i32
    tmp_5 = add tmp_3, tmp_4
    !p
    return tmp_5

@test "imported struct literal and field access"():
L_TEST_ENTRY_0:
    p = alloc 8
    tmp_6 = 10
    store p+0, tmp_6 as i32
    !tmp_6
    tmp_7 = 20
    store p+4, tmp_7 as i32
    !tmp_7
    tmp_8 = call @sla__point_sum(p)
    tmp_9 = 30
    tmp_10 = ne tmp_8, tmp_9
    !tmp_8
    !tmp_9
    br tmp_10 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_10
    panic(1)

L_ELSE_2:
    !tmp_10
    jmp L_MERGE_3

L_MERGE_3:
    !p
    return

@test "imported function call"():
L_TEST_ENTRY_4:
    r = alloc 8
    tmp_13 = 4
    store r+0, tmp_13 as i32
    !tmp_13
    tmp_14 = 5
    store r+4, tmp_14 as i32
    !tmp_14
    tmp_15 = call @sla__imported_area(r)
    tmp_16 = 20
    tmp_17 = ne tmp_15, tmp_16
    !tmp_15
    !tmp_16
    br tmp_17 -> L_THEN_5, L_ELSE_6

L_THEN_5:
    !tmp_17
    panic(2)

L_ELSE_6:
    !tmp_17
    jmp L_MERGE_7

L_MERGE_7:
    !r
    return
