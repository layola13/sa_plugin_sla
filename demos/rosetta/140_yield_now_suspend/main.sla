@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/future.sa"

async fn yield_once() -> i32 {
    2
}

fn yield_now_value() -> i32 {
    let yielded = yield_once().await;
    return yielded;
}

fn main() -> i32 {
    let result = yield_now_value();
    println("{}", result);
    return result;
};

@test "rosetta 140 140_yield_now_suspend"() {
    let got = yield_now_value();
    if got != 2 {
        panic(140);
    };
};
