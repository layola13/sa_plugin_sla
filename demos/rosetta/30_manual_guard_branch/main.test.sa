[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/option.sa"
@const SLA_FNPTR_VT_main = vtable { call = @main }
@main() -> i32:
L_ENTRY:
    tmp_0 = 5
    EXPAND OPTION_NEW_SOME tmp_1, tmp_0
    !tmp_0
    value = tmp_1
    tmp_2 = alloc 4
    jmp L_OPTION_MATCH_CHECK_0_2

L_OPTION_MATCH_CHECK_0_2:
    EXPAND OPTION_IS_SOME tmp_3, value
    br tmp_3 -> L_OPTION_MATCH_CASE_0_2, L_OPTION_MATCH_CHECK_1_2

L_OPTION_MATCH_CASE_0_2:
    EXPAND OPTION_GET x, value
    tmp_4 = 3
    tmp_5 = sgt x, tmp_4
    !tmp_4
    br tmp_5 -> L_OPTION_MATCH_GUARD_BODY_3, L_OPTION_MATCH_GUARD_FAIL_4

L_OPTION_MATCH_GUARD_FAIL_4:
    !tmp_5
    !x
    jmp L_OPTION_MATCH_CHECK_1_2

L_OPTION_MATCH_GUARD_BODY_3:
    !tmp_5
    !tmp_3
    tmp_6 = add x, 0
    store tmp_2+0, tmp_6 as i32
    !tmp_6
    !x
    jmp L_OPTION_MATCH_MERGE_0

L_OPTION_MATCH_CHECK_1_2:
    !tmp_3
    EXPAND OPTION_IS_SOME tmp_7, value
    br tmp_7 -> L_OPTION_MATCH_CASE_1_2, L_OPTION_MATCH_CHECK_2_2

L_OPTION_MATCH_CASE_1_2:
    EXPAND OPTION_GET _, value
    !tmp_7
    tmp_8 = 0
    store tmp_2+0, tmp_8 as i32
    !tmp_8
    !_
    jmp L_OPTION_MATCH_MERGE_0

L_OPTION_MATCH_CHECK_2_2:
    !tmp_7
    EXPAND OPTION_IS_SOME tmp_9, value
    br tmp_9 -> L_OPTION_MATCH_NO_MATCH_1, L_OPTION_MATCH_CASE_2_2

L_OPTION_MATCH_CASE_2_2:
    !tmp_9
    tmp_10 = 0
    tmp_11 = 1
    tmp_12 = sub tmp_10, tmp_11
    !tmp_10
    !tmp_11
    store tmp_2+0, tmp_12 as i32
    !tmp_12
    jmp L_OPTION_MATCH_MERGE_0

L_OPTION_MATCH_NO_MATCH_1:
    !tmp_9
    panic(1)

L_OPTION_MATCH_MERGE_0:
    tmp_13 = load tmp_2+0 as i32
    !tmp_2
    result = tmp_13
    tmp_14 = call @sa_fmt_u64(result, 10)
    tmp_15 = call @sa_fmt_buffer_data(tmp_14)
    tmp_16 = call @sa_fmt_buffer_len(tmp_14)
    tmp_17 = tmp_15
    call @sa_print_bytes(&tmp_17, tmp_16)
    call @sa_fmt_buffer_free(^tmp_14)
    !tmp_17
    !tmp_16
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_18 = 0
    !value
    !result
    return tmp_18

