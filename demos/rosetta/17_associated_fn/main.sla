@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

struct Counter {
    value: i32,
}

impl Counter {
    fn new(seed: i32) -> Counter {
        return Counter { value: seed + 2 };
    }
}

fn main() -> i32 {
    let counter = Counter::new(40);
    println("{}", counter.value);
    return 0;
};

@test "rosetta 017 associated fn"() {
    let counter = Counter::new(40);
    if counter.value != 42 {
        panic(17);
    };
};
