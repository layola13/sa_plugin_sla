@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@main() -> i32:
L_ENTRY:
    @const SLA_STR_0 = utf8:"rust"
    word = &SLA_STR_0
    EXPAND STRING_LEN tmp_1, word
    tmp_2 = call @sa_fmt_u64(tmp_1, 10)
    tmp_3 = call @sa_fmt_buffer_data(tmp_2)
    tmp_4 = call @sa_fmt_buffer_len(tmp_2)
    tmp_5 = tmp_3
    call @sa_print_bytes(&tmp_5, tmp_4)
    call @sa_fmt_buffer_free(^tmp_2)
    @const SLA_STR_1 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_1, 1)
    tmp_6 = 0
    !word
    return tmp_6

@test "rosetta 015 string bytes"():
L_TEST_ENTRY_0:
    @const SLA_STR_2 = utf8:"rust"
    word = &SLA_STR_2
    EXPAND STRING_LEN tmp_8, word
    tmp_9 = 4
    tmp_10 = ne tmp_8, tmp_9
    !tmp_8
    !tmp_9
    br tmp_10 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_10
    panic(15)

L_ELSE_2:
    !tmp_10
    jmp L_MERGE_3

L_MERGE_3:
    !word
    return

