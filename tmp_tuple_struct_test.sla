@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

struct AddOne(i32);

fn score(&self: AddOne) -> i32 {
    self.0 + 1
}

fn main() -> i32 {
    let value = AddOne(4);
    println("{}", score(&value));
    return 0;
};

@test "tuple struct smoke"() {
    let value = AddOne(4);
    let result: i32 = score(&value);
    if result != 5 {
        panic(901);
    };
};
