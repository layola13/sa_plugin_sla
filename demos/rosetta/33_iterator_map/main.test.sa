    store tmp_0+8, tmp_3 as i32
    tmp_4 = 0
    tmp_5 = 0
    tmp_6 = ptr_add tmp_0, tmp_5
    tmp_7 = load tmp_6+0 as i32
    tmp_8 = 2
    tmp_9 = mul tmp_7, tmp_8
    !tmp_8
    tmp_10 = add tmp_4, tmp_9
    !tmp_5
    !tmp_6
    !tmp_7
    !tmp_9
    !tmp_4
    tmp_11 = 4
    tmp_12 = ptr_add tmp_0, tmp_11
    tmp_13 = load tmp_12+0 as i32
    tmp_14 = 2
    tmp_15 = mul tmp_13, tmp_14
    !tmp_14
    tmp_16 = add tmp_10, tmp_15
    !tmp_11
    !tmp_12
    !tmp_13
    !tmp_15
    !tmp_10
    tmp_17 = 8
    tmp_18 = ptr_add tmp_0, tmp_17
    tmp_19 = load tmp_18+0 as i32
    tmp_20 = 2
    tmp_21 = mul tmp_19, tmp_20
    !tmp_20
    tmp_22 = add tmp_16, tmp_21
    !tmp_17
    !tmp_18
    !tmp_19
    !tmp_21
    !tmp_16
    !tmp_0
    total = tmp_22
    tmp_23 = call @sa_fmt_u64(total, 10)
    tmp_24 = call @sa_fmt_buffer_data(tmp_23)
    tmp_25 = call @sa_fmt_buffer_len(tmp_23)
    tmp_26 = tmp_24
    call @sa_print_bytes(&tmp_26, tmp_25)
    call @sa_fmt_buffer_free(^tmp_23)
    !tmp_26
    !tmp_25
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_27 = 0
    !total
    return tmp_27

