@test "rosetta 127 127_hazard_pointers"():
L_TEST_ENTRY_6:
    tmp_40 = call @sla__hazard_pointer_result()
    got = tmp_40
    tmp_41 = 10
    tmp_42 = ne got, tmp_41
    !tmp_41
    br tmp_42 -> L_THEN_7, L_ELSE_8

L_THEN_7:
    !tmp_42
    panic(127)

L_ELSE_8:
    !tmp_42
    jmp L_MERGE_9

L_MERGE_9:
    !got
    return

