[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_file_descriptor_raw_fd = vtable { call = @sla__file_descriptor_raw_fd }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__file_descriptor_raw_fd() -> i32:
L_ENTRY:
    tmp_0 = 0
    raw_fd = tmp_0
    @const SLA_STR_0 = utf8:"/dev/null"
    tmp_2 = 9
    tmp_1 = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW tmp_1, &SLA_STR_0, tmp_2
    !tmp_2
    tmp_3 = load tmp_1+Slice_ptr as ptr
    tmp_4 = load tmp_1+Slice_len as u64
    EXPAND FS_OPEN_READ tmp_5, tmp_6, tmp_3, tmp_4
    tmp_8 = eq tmp_5, SA_FS_OK
    br tmp_8 -> L_FILE_OPEN_OK_0, L_FILE_OPEN_ERR_1

L_FILE_OPEN_OK_0:
    EXPAND RESULT_NEW_OK tmp_7, tmp_6
    !tmp_5
    !tmp_6
    jmp L_FILE_OPEN_END_2

L_FILE_OPEN_ERR_1:
    EXPAND RESULT_NEW_ERR tmp_7, tmp_5
    !tmp_5
    !tmp_6
    jmp L_FILE_OPEN_END_2

L_FILE_OPEN_END_2:
    !tmp_8
    !tmp_4
    !tmp_3
    EXPAND RESULT_UNWRAP tmp_9, tmp_7
    !tmp_7
    file = tmp_9
    tmp_10 = add file, 0
    tmp_11 = tmp_10 as i32
    !raw_fd
    raw_fd = tmp_11
    EXPAND FS_CLOSE tmp_12, file
    !tmp_12
    return raw_fd

@main() -> i32:
L_ENTRY:
    tmp_13 = call @sla__file_descriptor_raw_fd()
    result = tmp_13
    tmp_14 = call @sa_fmt_u64(result, 10)
    tmp_15 = call @sa_fmt_buffer_data(tmp_14)
    tmp_16 = call @sa_fmt_buffer_len(tmp_14)
    tmp_17 = tmp_15
    call @sa_print_bytes(&tmp_17, tmp_16)
    call @sa_fmt_buffer_free(^tmp_14)
    !tmp_17
    !tmp_16
    @const SLA_STR_1 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_1, 1)
    return result

@test "rosetta 181 181_file_descriptor_raii"():
L_TEST_ENTRY_3:
    tmp_18 = call @sla__file_descriptor_raw_fd()
    got = tmp_18
    tmp_19 = 0
    tmp_20 = slt got, tmp_19
    !tmp_19
