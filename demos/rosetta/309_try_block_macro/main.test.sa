@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/result.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/result.sa"
@const SLA_FNPTR_VT_parse_num = vtable { call = @sla__parse_num }
@const SLA_FNPTR_VT_compute = vtable { call = @sla__compute }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__parse_num(value: i32) -> ptr:
L_ENTRY:
    EXPAND RESULT_NEW_OK tmp_0, value
    return tmp_0

@sla__compute() -> ptr:
L_ENTRY:
    tmp_1 = 10
    tmp_2 = call @sla__parse_num(tmp_1)
    !tmp_1
    EXPAND RESULT_IS_OK tmp_3, tmp_2
    br tmp_3 -> L_TRY_RESULT_OK_0, L_TRY_RESULT_ERR_1

L_TRY_RESULT_ERR_1:
    !tmp_3
    return tmp_2

L_TRY_RESULT_OK_0:
    !tmp_3
    EXPAND RESULT_GET_OK tmp_4, tmp_2
    !tmp_2
    a = tmp_4
    tmp_5 = 20
    tmp_6 = call @sla__parse_num(tmp_5)
    !tmp_5
    EXPAND RESULT_IS_OK tmp_7, tmp_6
    br tmp_7 -> L_TRY_RESULT_OK_2, L_TRY_RESULT_ERR_3

L_TRY_RESULT_ERR_3:
    !tmp_7
    !a
    return tmp_6

L_TRY_RESULT_OK_2:
    !tmp_7
    EXPAND RESULT_GET_OK tmp_8, tmp_6
    !tmp_6
    b = tmp_8
    tmp_9 = add a, b
    EXPAND RESULT_NEW_OK tmp_10, tmp_9
    !tmp_9
    return tmp_10

@main() -> i32:
L_ENTRY:
    tmp_11 = call @sla__compute()
    tmp_12 = 0
    tmp_13 = 1
    tmp_14 = sub tmp_12, tmp_13
    !tmp_12
    !tmp_13
    EXPAND RESULT_UNWRAP_OR tmp_15, tmp_11, tmp_14
    !tmp_11
    !tmp_14
    result = tmp_15
    tmp_16 = call @sa_fmt_u64(result, 10)
    tmp_17 = call @sa_fmt_buffer_data(tmp_16)
    tmp_18 = call @sa_fmt_buffer_len(tmp_16)
    tmp_19 = tmp_17
    call @sa_print_bytes(&tmp_19, tmp_18)
    call @sa_fmt_buffer_free(^tmp_16)
    !tmp_19
    !tmp_18
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_20 = 30
    tmp_21 = eq result, tmp_20
    !tmp_20
    br tmp_21 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_21
    tmp_22 = 0
    !result
    return tmp_22

L_ELSE_5:
    !tmp_21
    tmp_23 = 1
    !result
    return tmp_23


@test "rosetta 309 try block macro"():
L_TEST_ENTRY_7:
    tmp_25 = call @sla__compute()
    tmp_26 = 0
    tmp_27 = 1
    tmp_28 = sub tmp_26, tmp_27
    !tmp_26
    !tmp_27
    EXPAND RESULT_UNWRAP_OR tmp_29, tmp_25, tmp_28
    !tmp_25
    !tmp_28
    result = tmp_29
    tmp_30 = 30
    tmp_31 = ne result, tmp_30
    !tmp_30
    br tmp_31 -> L_THEN_8, L_ELSE_9

L_THEN_8:
    !tmp_31
    panic(309)

L_ELSE_9:
    !tmp_31
    jmp L_MERGE_10

L_MERGE_10:
    !result
    return

