@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_add_one = vtable { call = @add_one }
@const SLA_FNPTR_VT_apply = vtable { call = @sla__apply }
@const SLA_FNPTR_VT_c_callback_result = vtable { call = @sla__c_callback_result }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@add_one(x: i32) -> i32:
L_ENTRY:
    tmp_0 = 1
    tmp_1 = add x, tmp_0
    !tmp_0
    return tmp_1

@sla__apply(cb: ptr, value: i32) -> i32:
L_ENTRY:
    tmp_2 = load cb+8 as ptr
    tmp_3 = load tmp_2+0 as ptr
    tmp_4 = call_indirect tmp_3(value)
    !tmp_3
    !tmp_2
    return tmp_4

@sla__c_callback_result() -> i32:
L_ENTRY:
    tmp_5 = stack_alloc 16
    store tmp_5+0, 0 as ptr
    store tmp_5+8, &SLA_FNPTR_VT_add_one as ptr
    tmp_6 = 41
    tmp_7 = call @sla__apply(tmp_5, tmp_6)
    !tmp_6
    result = tmp_7
    return result

@main() -> i32:
L_ENTRY:
    tmp_8 = call @sla__c_callback_result()
    result = tmp_8
    tmp_9 = call @sa_fmt_u64(result, 10)
    tmp_10 = call @sa_fmt_buffer_data(tmp_9)
    tmp_11 = call @sa_fmt_buffer_len(tmp_9)
    tmp_12 = tmp_10
    call @sa_print_bytes(&tmp_12, tmp_11)
    call @sa_fmt_buffer_free(^tmp_9)
    !tmp_12
    !tmp_11
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 114 114_callback_from_c"():
L_TEST_ENTRY_0:
    tmp_13 = call @sla__c_callback_result()
    got = tmp_13
    tmp_14 = 42
    tmp_15 = ne got, tmp_14
    !tmp_14
    br tmp_15 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_15
    panic(114)

L_ELSE_2:
    !tmp_15
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

