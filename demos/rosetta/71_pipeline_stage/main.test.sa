@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_pipeline_stage_value = vtable { call = @sla__pipeline_stage_value }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__pipeline_stage_value(input: ptr) -> i32:
L_ENTRY:
    tmp_0 = load input+0 as i32
    raw = tmp_0
    tmp_1 = load input+4 as i32
    scale = tmp_1
    tmp_2 = load input+8 as i32
    offset = tmp_2
    tmp_3 = mul raw, scale
    stage1 = tmp_3
    tmp_4 = add stage1, offset
    stage2 = tmp_4
    !raw
    !stage1
    !offset
    !scale
    !input
    return stage2

@main() -> i32:
L_ENTRY:
    input = alloc 12
    tmp_5 = 2
    store input+0, tmp_5 as i32
    tmp_6 = 3
    store input+4, tmp_6 as i32
    tmp_7 = 1
    store input+8, tmp_7 as i32
    tmp_8 = call @sla__pipeline_stage_value(input)
    result = tmp_8
    tmp_9 = call @sa_fmt_u64(result, 10)
    tmp_10 = call @sa_fmt_buffer_data(tmp_9)
    tmp_11 = call @sa_fmt_buffer_len(tmp_9)
    tmp_12 = tmp_10
    call @sa_print_bytes(&tmp_12, tmp_11)
    call @sa_fmt_buffer_free(^tmp_9)
    !tmp_12
    !tmp_11
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !input
    return result

@test "rosetta 071 71_pipeline_stage"():
L_TEST_ENTRY_0:
    input = alloc 12
    tmp_13 = 2
    store input+0, tmp_13 as i32
    tmp_14 = 3
    store input+4, tmp_14 as i32
    tmp_15 = 1
    store input+8, tmp_15 as i32
    tmp_16 = call @sla__pipeline_stage_value(input)
    got = tmp_16
    tmp_17 = 7
    tmp_18 = ne got, tmp_17
    !tmp_17
    br tmp_18 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_18
    panic(71)

L_ELSE_2:
    !tmp_18
    jmp L_MERGE_3

L_MERGE_3:
    !input
    !got
    return

