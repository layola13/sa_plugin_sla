@import "sa_std/core/option.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/option.sa"
@test "option is_some and is_none"():
L_TEST_ENTRY_0:
    tmp_0 = 7
    EXPAND OPTION_NEW_SOME tmp_1, tmp_0
    !tmp_0
    some = tmp_1
    EXPAND OPTION_NEW_NONE tmp_2
    none = tmp_2
    EXPAND OPTION_IS_SOME tmp_3, some
    tmp_4 = 0
    tmp_5 = eq tmp_3, tmp_4
    !tmp_3
    !tmp_4
    br tmp_5 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_5
    panic(1)

L_ELSE_2:
    !tmp_5
    jmp L_MERGE_3

L_MERGE_3:
    EXPAND OPTION_IS_NONE tmp_8, some
    br tmp_8 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_8
    panic(2)

L_ELSE_5:
    !tmp_8
    jmp L_MERGE_6

L_MERGE_6:
    EXPAND OPTION_IS_SOME tmp_11, none
    br tmp_11 -> L_THEN_7, L_ELSE_8

L_THEN_7:
    !tmp_11
    panic(3)

L_ELSE_8:
    !tmp_11
    jmp L_MERGE_9

L_MERGE_9:
    EXPAND OPTION_IS_NONE tmp_14, none
    tmp_15 = 0
    tmp_16 = eq tmp_14, tmp_15
    !tmp_14
    !tmp_15
    br tmp_16 -> L_THEN_10, L_ELSE_11

L_THEN_10:
    !tmp_16
    panic(4)

L_ELSE_11:
    !tmp_16
    jmp L_MERGE_12

L_MERGE_12:
    !some
    !none
    return

@test "option is_some is_none with struct payload"():
L_TEST_ENTRY_13:
    tmp_19 = alloc 4
    tmp_20 = 11
    store tmp_19+0, tmp_20 as i32
    !tmp_20
    EXPAND OPTION_NEW_SOME tmp_21, tmp_19
    !tmp_19
    some = tmp_21
    EXPAND OPTION_NEW_NONE tmp_22
    none = tmp_22
    EXPAND OPTION_IS_SOME tmp_23, some
    tmp_24 = 0
    tmp_25 = eq tmp_23, tmp_24
    !tmp_23
    !tmp_24
    br tmp_25 -> L_THEN_14, L_ELSE_15

L_THEN_14:
    !tmp_25
    panic(1)

L_ELSE_15:
    !tmp_25
    jmp L_MERGE_16

L_MERGE_16:
    EXPAND OPTION_IS_NONE tmp_28, none
    tmp_29 = 0
    tmp_30 = eq tmp_28, tmp_29
    !tmp_28
    !tmp_29
    br tmp_30 -> L_THEN_17, L_ELSE_18

L_THEN_17:
    !tmp_30
    panic(2)

L_ELSE_18:
    !tmp_30
    jmp L_MERGE_19

L_MERGE_19:
    !some
    !none
    return

@test "option unwrap and map"():
L_TEST_ENTRY_20:
    tmp_33 = 4
    EXPAND OPTION_NEW_SOME tmp_34, tmp_33
    !tmp_33
    some = tmp_34
    EXPAND OPTION_IS_SOME tmp_35, some
    br tmp_35 -> L_OPTION_MAP_SOME_21, L_OPTION_MAP_NONE_22

L_OPTION_MAP_SOME_21:
    !tmp_35
    EXPAND OPTION_GET tmp_37, some
    tmp_38 = 3
    tmp_39 = add tmp_37, tmp_38
    !tmp_38
    EXPAND OPTION_NEW_SOME tmp_36, tmp_39
    !tmp_37
    !tmp_39
    jmp L_OPTION_MAP_END_23

L_OPTION_MAP_NONE_22:
    !tmp_35
    EXPAND OPTION_NEW_NONE tmp_36
    jmp L_OPTION_MAP_END_23

L_OPTION_MAP_END_23:
    mapped = tmp_36
    EXPAND OPTION_IS_SOME tmp_40, mapped
    tmp_41 = 0
    tmp_42 = eq tmp_40, tmp_41
    !tmp_40
    !tmp_41
    br tmp_42 -> L_THEN_24, L_ELSE_25

L_THEN_24:
    !tmp_42
    panic(1)

L_ELSE_25:
    !tmp_42
    jmp L_MERGE_26

L_MERGE_26:
    EXPAND OPTION_UNWRAP tmp_45, mapped
    tmp_46 = 7
    tmp_47 = ne tmp_45, tmp_46
    !tmp_45
    !tmp_46
    br tmp_47 -> L_THEN_27, L_ELSE_28

L_THEN_27:
    !tmp_47
    panic(2)

L_ELSE_28:
    !tmp_47
    jmp L_MERGE_29

L_MERGE_29:
    !some
    !mapped
    return

@test "option and_then"():
L_TEST_ENTRY_30:
    tmp_50 = 4
    EXPAND OPTION_NEW_SOME tmp_51, tmp_50
    !tmp_50
    some = tmp_51
    EXPAND OPTION_IS_SOME tmp_52, some
    tmp_53 = stack_alloc 8
    br tmp_52 -> L_OPTION_AND_THEN_SOME_31, L_OPTION_AND_THEN_NONE_32

L_OPTION_AND_THEN_SOME_31:
    !tmp_52
    EXPAND OPTION_GET tmp_54, some
    tmp_55 = 6
    tmp_56 = add tmp_54, tmp_55
    !tmp_55
    EXPAND OPTION_NEW_SOME tmp_57, tmp_56
    !tmp_56
    store tmp_53+0, tmp_57 as ptr
    !tmp_54
    jmp L_OPTION_AND_THEN_END_33

L_OPTION_AND_THEN_NONE_32:
    !tmp_52
    EXPAND OPTION_NEW_NONE tmp_58
    store tmp_53+0, tmp_58 as ptr
    jmp L_OPTION_AND_THEN_END_33

L_OPTION_AND_THEN_END_33:
    tmp_59 = load tmp_53+0 as ptr
    chained = tmp_59
    EXPAND OPTION_IS_SOME tmp_60, chained
    tmp_61 = 0
    tmp_62 = eq tmp_60, tmp_61
    !tmp_60
    !tmp_61
    br tmp_62 -> L_THEN_34, L_ELSE_35

L_THEN_34:
    !tmp_62
    panic(1)

L_ELSE_35:
    !tmp_62
    jmp L_MERGE_36

L_MERGE_36:
    EXPAND OPTION_UNWRAP tmp_65, chained
    tmp_66 = 10
    tmp_67 = ne tmp_65, tmp_66
    !tmp_65
    !tmp_66
    br tmp_67 -> L_THEN_37, L_ELSE_38

L_THEN_37:
    !tmp_67
    panic(2)

L_ELSE_38:
    !tmp_67
    jmp L_MERGE_39

L_MERGE_39:
    EXPAND OPTION_NEW_NONE tmp_70
    none = tmp_70
    EXPAND OPTION_IS_SOME tmp_71, none
    tmp_72 = stack_alloc 8
    br tmp_71 -> L_OPTION_AND_THEN_SOME_40, L_OPTION_AND_THEN_NONE_41

L_OPTION_AND_THEN_SOME_40:
    !tmp_71
    EXPAND OPTION_GET tmp_73, none
    tmp_74 = 1
    tmp_75 = add tmp_73, tmp_74
    !tmp_74
    EXPAND OPTION_NEW_SOME tmp_76, tmp_75
    !tmp_75
    store tmp_72+0, tmp_76 as ptr
    !tmp_73
    jmp L_OPTION_AND_THEN_END_42

L_OPTION_AND_THEN_NONE_41:
    !tmp_71
    EXPAND OPTION_NEW_NONE tmp_77
    store tmp_72+0, tmp_77 as ptr
    jmp L_OPTION_AND_THEN_END_42

L_OPTION_AND_THEN_END_42:
    tmp_78 = load tmp_72+0 as ptr
    skipped = tmp_78
    EXPAND OPTION_IS_SOME tmp_79, skipped
    br tmp_79 -> L_THEN_43, L_ELSE_44

L_THEN_43:
    !tmp_79
    panic(3)

L_ELSE_44:
    !tmp_79
    jmp L_MERGE_45

L_MERGE_45:
    !some
    !skipped
    !none
    !chained
    return

@test "option unwrap_or_else"():
L_TEST_ENTRY_46:
    tmp_82 = 5
    EXPAND OPTION_NEW_SOME tmp_83, tmp_82
    !tmp_82
    some = tmp_83
    EXPAND OPTION_NEW_NONE tmp_84
    none = tmp_84
    EXPAND OPTION_IS_SOME tmp_85, some
    tmp_86 = stack_alloc 8
    br tmp_85 -> L_OPTION_UNWRAP_OR_ELSE_SOME_47, L_OPTION_UNWRAP_OR_ELSE_NONE_48

L_OPTION_UNWRAP_OR_ELSE_SOME_47:
    !tmp_85
    EXPAND OPTION_GET tmp_87, some
    store tmp_86+0, tmp_87 as i32
    !tmp_87
    jmp L_OPTION_UNWRAP_OR_ELSE_END_49

L_OPTION_UNWRAP_OR_ELSE_NONE_48:
    !tmp_85
    tmp_88 = 9
    store tmp_86+0, tmp_88 as i32
    !tmp_88
    jmp L_OPTION_UNWRAP_OR_ELSE_END_49

L_OPTION_UNWRAP_OR_ELSE_END_49:
    tmp_89 = load tmp_86+0 as i32
    tmp_90 = 5
    tmp_91 = ne tmp_89, tmp_90
    !tmp_89
    !tmp_90
    br tmp_91 -> L_THEN_50, L_ELSE_51

L_THEN_50:
    !tmp_91
    panic(1)

L_ELSE_51:
    !tmp_91
    jmp L_MERGE_52

L_MERGE_52:
    EXPAND OPTION_IS_SOME tmp_94, none
    tmp_95 = stack_alloc 8
    br tmp_94 -> L_OPTION_UNWRAP_OR_ELSE_SOME_53, L_OPTION_UNWRAP_OR_ELSE_NONE_54

L_OPTION_UNWRAP_OR_ELSE_SOME_53:
    !tmp_94
    EXPAND OPTION_GET tmp_96, none
    store tmp_95+0, tmp_96 as i32
    !tmp_96
    jmp L_OPTION_UNWRAP_OR_ELSE_END_55

L_OPTION_UNWRAP_OR_ELSE_NONE_54:
    !tmp_94
    tmp_97 = 9
    store tmp_95+0, tmp_97 as i32
    !tmp_97
    jmp L_OPTION_UNWRAP_OR_ELSE_END_55

L_OPTION_UNWRAP_OR_ELSE_END_55:
    tmp_98 = load tmp_95+0 as i32
    tmp_99 = 9
    tmp_100 = ne tmp_98, tmp_99
    !tmp_98
    !tmp_99
    br tmp_100 -> L_THEN_56, L_ELSE_57

L_THEN_56:
    !tmp_100
    panic(2)

L_ELSE_57:
    !tmp_100
    jmp L_MERGE_58

L_MERGE_58:
    !some
    !none
    return

