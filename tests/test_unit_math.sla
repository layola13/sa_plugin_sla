// Sla 单元测试 - 复杂数学表达式（含括号、嵌套、取模、一元负号）
// Run with: sa sla test tests/test_unit_math.sla

// ─── Helper: assert equals ────────────────────────────────────
// 由于 Sla 目前无内置 assert_eq 宏，使用内联写法：
//   let ok = expr == expected; if ok { } else { panic(1); };

// ─── 基础四则运算 ─────────────────────────────────────────────

fn abs(x: int) -> int {
    let neg = x < 0;
    if neg {
        return 0 - x;
    } else {
        return x;
    };
}

fn max(a: int, b: int) -> int {
    let gt = a > b;
    if gt {
        return a;
    } else {
        return b;
    };
}

fn min(a: int, b: int) -> int {
    let lt = a < b;
    if lt {
        return a;
    } else {
        return b;
    };
}

fn gcd(a: int, b: int) -> int {
    let is_zero = b == 0;
    if is_zero {
        return a;
    } else {
        let rem = a % b;
        let result = gcd(b, rem);
        return result;
    };
}

fn lcm(a: int, b: int) -> int {
    let g = gcd(a, b);
    let result = (a / g) * b;
    return result;
}

fn power(base: int, exp: int) -> int {
    let is_zero = exp == 0;
    if is_zero {
        return 1;
    } else {
        let half = exp / 2;
        let sub_result = power(base, half);
        let even = (exp % 2) == 0;
        if even {
            let result = sub_result * sub_result;
            return result;
        } else {
            let result = sub_result * sub_result * base;
            return result;
        };
    };
}

fn clamp(val: int, lo: int, hi: int) -> int {
    let below = val < lo;
    if below {
        return lo;
    } else {
        let above = val > hi;
        if above {
            return hi;
        } else {
            return val;
        };
    };
}

// ─── @test blocks ─────────────────────────────────────────────

@test "括号改变优先级 (2+3)*4 == 20"() {
    let result = (2 + 3) * 4;
    let ok = result == 20;
    if ok { } else { panic(1); };
}

@test "不带括号 2+3*4 == 14"() {
