@derive(Component)
struct DerivedComponentPosition {
    x: i32,
    y: i32,
}

@derive(Component)
struct DerivedComponentVelocity {
    dx: i32,
    dy: i32,
}

@derive(Component)
@component(storage = "SparseSet")
struct DerivedSparseMarker {
    value: i32,
}

@derive(Resource)
struct DerivedResourceTime {
    tick: i32,
}

@derive(Message)
struct DerivedMessageDamage {
    amount: i32,
}

@derive(Event)
struct DerivedEventSpeak {
    code: i32,
}

fn derived_component_metadata_score() -> i32 {
    let position_id = DerivedComponentPosition::component_type_id();
    let position_id_again = DerivedComponentPosition::component_type_id();
    let velocity_id = DerivedComponentVelocity::component_type_id();
    let marker_id = DerivedSparseMarker::component_type_id();
    if position_id <= 0 { panic(9101); };
    if position_id != position_id_again { panic(9102); };
    if position_id == velocity_id { panic(9103); };
    if DerivedComponentPosition::component_storage_kind() != 0 { panic(9104); };
    if marker_id == position_id { panic(9106); };
    if DerivedSparseMarker::component_storage_kind() != 1 { panic(9107); };
    return 7;
}

fn derived_resource_metadata_score() -> i32 {
    let time_id = DerivedResourceTime::resource_type_id();
    let time_id_again = DerivedResourceTime::resource_type_id();
    if time_id <= 0 { panic(9111); };
    if time_id != time_id_again { panic(9112); };
    if time_id == DerivedComponentPosition::component_type_id() { panic(9113); };
    return 11;
}

fn derived_message_metadata_score() -> i32 {
    let damage_id = DerivedMessageDamage::message_type_id();
    let damage_id_again = DerivedMessageDamage::message_type_id();
    if damage_id <= 0 { panic(9121); };
    if damage_id != damage_id_again { panic(9122); };
    if damage_id == DerivedComponentPosition::component_type_id() { panic(9123); };
    if damage_id == DerivedResourceTime::resource_type_id() { panic(9124); };
    return 13;
}

fn derived_event_metadata_score() -> i32 {
    let speak_id = DerivedEventSpeak::event_type_id();
    let speak_id_again = DerivedEventSpeak::event_type_id();
    if speak_id <= 0 { panic(9131); };
    if speak_id != speak_id_again { panic(9132); };
    if speak_id == DerivedComponentPosition::component_type_id() { panic(9133); };
    if speak_id == DerivedResourceTime::resource_type_id() { panic(9134); };
    if speak_id == DerivedMessageDamage::message_type_id() { panic(9135); };
    return 17;
}

@test "derive component exposes stable metadata"() {
    if derived_component_metadata_score() != 7 { panic(9105); };
}

@test "derive resource exposes stable metadata"() {
    if derived_resource_metadata_score() != 11 { panic(9114); };
}

@test "derive message exposes stable metadata"() {
    if derived_message_metadata_score() != 13 { panic(9125); };
}

@test "derive event exposes stable metadata"() {
    if derived_event_metadata_score() != 17 { panic(9136); };
}
