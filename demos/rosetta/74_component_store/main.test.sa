@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_component_sum = vtable { call = @sla__component_sum }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__component_sum(store: ptr) -> i32:
L_ENTRY:
    tmp_0 = 1
    tmp_1 = mul tmp_0, 8
    tmp_2 = ptr_add store, tmp_1
    !tmp_1
    !tmp_0
    tmp_3 = load tmp_2+0 as ptr
    !tmp_2
    pos = tmp_3
    tmp_4 = load pos+0 as i32
    entity = tmp_4
    tmp_5 = load pos+4 as i32
    x = tmp_5
    tmp_6 = load pos+8 as i32
    y = tmp_6
    tmp_7 = add entity, x
    tmp_8 = add tmp_7, y
    !tmp_7
    !pos
    !store
    return tmp_8

@main() -> i32:
L_ENTRY:
    positions = alloc 16
    tmp_9 = alloc 12
    tmp_10 = 1
    store tmp_9+0, tmp_10 as i32
    tmp_11 = 1
    store tmp_9+4, tmp_11 as i32
    tmp_12 = 2
    store tmp_9+8, tmp_12 as i32
    store positions+0, tmp_9 as ptr
    tmp_13 = alloc 12
    tmp_14 = 2
    store tmp_13+0, tmp_14 as i32
    tmp_15 = 3
    store tmp_13+4, tmp_15 as i32
    tmp_16 = 4
    store tmp_13+8, tmp_16 as i32
    store positions+8, tmp_13 as ptr
    tmp_17 = call @sla__component_sum(positions)
    total = tmp_17
    tmp_18 = call @sa_fmt_u64(total, 10)
    tmp_19 = call @sa_fmt_buffer_data(tmp_18)
    tmp_20 = call @sa_fmt_buffer_len(tmp_18)
    tmp_21 = tmp_19
    call @sa_print_bytes(&tmp_21, tmp_20)
    call @sa_fmt_buffer_free(^tmp_18)
    !tmp_21
    !tmp_20
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !positions
    return total

@test "rosetta 074 74_component_store"():
L_TEST_ENTRY_0:
    tmp_22 = call @main()
    tmp_23 = 9
    tmp_24 = ne tmp_22, tmp_23
    !tmp_22
    !tmp_23
    br tmp_24 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_24
    panic(74)

L_ELSE_2:
    !tmp_24
    jmp L_MERGE_3

L_MERGE_3:
    return

