@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_c_repr_pair_sum = vtable { call = @sla__c_repr_pair_sum }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__c_repr_pair_sum() -> u32:
L_ENTRY:
    pair = alloc 5
    tmp_0 = 1
    store pair+0, tmp_0 as u8
    tmp_1 = 2
    store pair+1, tmp_1 as u32
    tmp_2 = load pair+0 as u8
    tmp_3 = tmp_2 as u32
    left = tmp_3
    tmp_4 = load pair+1 as u32
    right = tmp_4
    tmp_5 = add left, right
    !pair
    return tmp_5

@main() -> i32:
L_ENTRY:
    pair = alloc 5
    tmp_6 = 1
    store pair+0, tmp_6 as u8
    tmp_7 = 2
    store pair+1, tmp_7 as u32
    tmp_8 = load pair+0 as u8
    tmp_9 = tmp_8 as u32
    left = tmp_9
    tmp_10 = load pair+1 as u32
    right = tmp_10
    tmp_11 = add left, right
    result = tmp_11
    tmp_12 = call @sa_fmt_u64(result, 10)
    tmp_13 = call @sa_fmt_buffer_data(tmp_12)
    tmp_14 = call @sa_fmt_buffer_len(tmp_12)
    tmp_15 = tmp_13
    call @sa_print_bytes(&tmp_15, tmp_14)
    call @sa_fmt_buffer_free(^tmp_12)
    !tmp_15
    !tmp_14
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_16 = 0
    !right
    !pair
    !left
    !result
    return tmp_16

@test "rosetta 150 150_c_repr_alignment"():
L_TEST_ENTRY_0:
    tmp_17 = call @sla__c_repr_pair_sum()
    got = tmp_17
    tmp_18 = 3
    tmp_19 = ne got, tmp_18
    !tmp_18
    br tmp_19 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_19
    panic(150)

L_ELSE_2:
    !tmp_19
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

