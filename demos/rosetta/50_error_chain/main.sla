// Sla companion for SA rosetta demo 050 Error Chain.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_050_value() -> int {
    let total = 0;
    for i in 1..5 {
        total = total + i;
    }    let result = total + 9;
    return result;
};

fn main() -> int {
    let result = rosetta_050_value();
    return result;
};

@test "rosetta 050 50_error_chain"() {
    let got = rosetta_050_value();
    if got != 19 {
        panic(50);
    }