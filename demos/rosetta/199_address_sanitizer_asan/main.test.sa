@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_asan_buffer_edge_sum = vtable { call = @sla__asan_buffer_edge_sum }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__asan_buffer_edge_sum() -> i32:
L_ENTRY:
    buf = alloc 4
    tmp_0 = 0
    tmp_1 = tmp_0 as u8
    EXPAND SLA_ARRAY_FILL_U8 buf, tmp_1, 4
    !tmp_1
    tmp_2 = 0
    tmp_3 = mul tmp_2, 1
    tmp_4 = ptr_add buf, tmp_3
    !tmp_3
    !tmp_2
    tmp_5 = 1
    store tmp_4+0, tmp_5 as u8
    !tmp_4
    tmp_6 = 1
    tmp_7 = mul tmp_6, 1
    tmp_8 = ptr_add buf, tmp_7
    !tmp_7
    !tmp_6
    tmp_9 = 2
    store tmp_8+0, tmp_9 as u8
    !tmp_8
    tmp_10 = 2
    tmp_11 = mul tmp_10, 1
    tmp_12 = ptr_add buf, tmp_11
    !tmp_11
    !tmp_10
    tmp_13 = 3
    store tmp_12+0, tmp_13 as u8
    !tmp_12
    tmp_14 = 3
    tmp_15 = mul tmp_14, 1
    tmp_16 = ptr_add buf, tmp_15
    !tmp_15
    !tmp_14
    tmp_17 = 4
    store tmp_16+0, tmp_17 as u8
    !tmp_16
    tmp_18 = 0
    tmp_19 = mul tmp_18, 1
    tmp_20 = ptr_add buf, tmp_19
    !tmp_19
    !tmp_18
    tmp_21 = load tmp_20+0 as u8
    !tmp_20
    tmp_22 = tmp_21 as i32
    first = tmp_22
    tmp_23 = 3
    tmp_24 = mul tmp_23, 1
    tmp_25 = ptr_add buf, tmp_24
    !tmp_24
    !tmp_23
    tmp_26 = load tmp_25+0 as u8
    !tmp_25
    tmp_27 = tmp_26 as i32
    last = tmp_27
    tmp_28 = add first, last
    !buf
    return tmp_28

@main() -> i32:
L_ENTRY:
    tmp_29 = call @sla__asan_buffer_edge_sum()
    result = tmp_29
    tmp_30 = call @sa_fmt_u64(result, 10)
    tmp_31 = call @sa_fmt_buffer_data(tmp_30)
    tmp_32 = call @sa_fmt_buffer_len(tmp_30)
    tmp_33 = tmp_31
    call @sa_print_bytes(&tmp_33, tmp_32)
    call @sa_fmt_buffer_free(^tmp_30)
    !tmp_33
    !tmp_32
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_34 = 0
    !result
    return tmp_34

@test "rosetta 199 199_address_sanitizer_asan"():
L_TEST_ENTRY_0:
    tmp_35 = call @sla__asan_buffer_edge_sum()
    got = tmp_35
    tmp_36 = 5
    tmp_37 = ne got, tmp_36
    !tmp_36
    br tmp_37 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_37
    panic(199)

L_ELSE_2:
    !tmp_37
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

