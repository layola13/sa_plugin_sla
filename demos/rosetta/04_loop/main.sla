// Sla companion for SA rosetta demo 004 Loop.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_004_value() -> int {
    let seed = 7;
    let shifted = seed + 4;
    let scaled = shifted * 6;
    let result = scaled - 9;
    return result;
}

fn main() -> int {
    let result = rosetta_004_value();
    return result;
};

@test "rosetta 004 04_loop"() {
    let got = rosetta_004_value();
    if got != 57 {
        panic(4);
    };
};
