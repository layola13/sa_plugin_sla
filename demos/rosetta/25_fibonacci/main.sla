@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn fib(n: i32) -> i32 {
    if n <= 1 {
        n
    } else {
        fib(n - 1) + fib(n - 2)
    }
}

fn main() -> i32 {
    let value = fib(8);
    println("{}", value);
    return 0;
};

@test "rosetta 025 fibonacci"() {
    let value = fib(8);
    if value != 21 {
        panic(25);
    };
};
