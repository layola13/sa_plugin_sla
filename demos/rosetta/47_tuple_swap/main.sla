@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn swap(a: (i32, i32)) -> (i32, i32) {
    (a.1, a.0)
}

fn main() -> i32 {
    let pair = swap((3, 8));
    println("{},{}", pair.0, pair.1);
    return 0;
}

@test "rosetta 047 tuple swap"() {
    let pair = swap((3, 8));
    if pair.0 != 8 {
        panic(47);
    };
    if pair.1 != 3 {
        panic(147);
    };
}
