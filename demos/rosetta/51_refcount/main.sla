@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/rc.sa"

fn main() -> i32 {
    let value = Rc::new(5);
    let clone = value.clone();
    println("{}", *value + *clone);
    return 0;
}

@test "rosetta 051 refcount"() {
    let value = Rc::new(5);
    let clone = value.clone();
    if *value + *clone != 10 {
        panic(51);
    };
}
