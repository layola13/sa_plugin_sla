@import "sa_std/core/box.sa"
@import "sa_std/core/refcell.sa"
@import "sa_std/core/rc.sa"

struct RefCellPayload {
    value: int,
    flag: bool,
}

fn refcell_payload_read(cell: &RefCell<RefCellPayload>) -> int {
    let borrowed: &RefCellPayload = cell.borrow();
    return borrowed.value;
}

fn refcell_payload_write(cell: &RefCell<RefCellPayload>, value: int) -> void {
    let borrowed: &RefCellPayload = cell.borrow_mut();
    borrowed.value = value;
}

fn refcell_box_payload_read(cell: &RefCell<Box<RefCellPayload>>) -> int {
    let borrowed: &Box<RefCellPayload> = cell.borrow();
    let payload: &RefCellPayload = &*borrowed;
    return payload.value;
}

fn refcell_box_payload_write(cell: &RefCell<Box<RefCellPayload>>, value: int) -> void {
    let borrowed: &Box<RefCellPayload> = cell.borrow_mut();
    let payload: &RefCellPayload = &*borrowed;
    payload.value = value;
}

@test "refcell struct payload borrow"() {
    let refcell = RefCell::new(RefCellPayload { value: 50, flag: false });
    if refcell_payload_read(&refcell) != 50 {
        panic(1);
    };

    refcell_payload_write(&refcell, 60);
    if refcell_payload_read(&refcell) != 60 {
        panic(2);
    };
}

@test "rc refcell struct payload shared mutation"() {
    let rc1 = Rc::new(RefCell::new(RefCellPayload { value: 10, flag: true }));
    let rc2 = Rc::clone(&rc1);

    let borrowed1: &RefCell<RefCellPayload> = &*rc1;
    refcell_payload_write(borrowed1, 25);

    let borrowed2: &RefCell<RefCellPayload> = &*rc2;
    if refcell_payload_read(borrowed2) != 25 {
        panic(3);
    };
}

@test "refcell boxed struct payload borrow"() {
    let refcell = RefCell::new(Box::new(RefCellPayload { value: 40, flag: false }));
    if refcell_box_payload_read(&refcell) != 40 {
        panic(4);
    };

    refcell_box_payload_write(&refcell, 52);
    if refcell_box_payload_read(&refcell) != 52 {
        panic(5);
    };
}
