fn option_match_value() -> i32 {
    let result: i32 = match Some(1) {
        Some(v) => {
            v
        },
        None => {
            panic("unreachable")
        },
    };
    return result;
}

@test "option match never fallback"() {
    if option_match_value() != 1 {
        panic(1);
    };
}
