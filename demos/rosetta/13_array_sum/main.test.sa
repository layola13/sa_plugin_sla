@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_main = vtable { call = @main }
@main() -> i32:
L_ENTRY:
    values = alloc 16
    tmp_0 = 1
    store values+0, tmp_0 as i32
    tmp_1 = 2
    store values+4, tmp_1 as i32
    tmp_2 = 3
    store values+8, tmp_2 as i32
    tmp_3 = 4
    store values+12, tmp_3 as i32
    tmp_4 = 0
    tmp_5 = 0
    tmp_6 = ptr_add values, tmp_5
    tmp_7 = load tmp_6+0 as i32
    tmp_8 = add tmp_4, tmp_7
    !tmp_5
    !tmp_6
    !tmp_7
    !tmp_4
    tmp_9 = 4
    tmp_10 = ptr_add values, tmp_9
    tmp_11 = load tmp_10+0 as i32
    tmp_12 = add tmp_8, tmp_11
    !tmp_9
    !tmp_10
    !tmp_11
    !tmp_8
    tmp_13 = 8
    tmp_14 = ptr_add values, tmp_13
    tmp_15 = load tmp_14+0 as i32
    tmp_16 = add tmp_12, tmp_15
    !tmp_13
    !tmp_14
    !tmp_15
    !tmp_12
    tmp_17 = 12
    tmp_18 = ptr_add values, tmp_17
    tmp_19 = load tmp_18+0 as i32
    tmp_20 = add tmp_16, tmp_19
    !tmp_17
    !tmp_18
    !tmp_19
    !tmp_16
    sum = tmp_20
    tmp_21 = call @sa_fmt_u64(sum, 10)
    tmp_22 = call @sa_fmt_buffer_data(tmp_21)
    tmp_23 = call @sa_fmt_buffer_len(tmp_21)
    tmp_24 = tmp_22
    call @sa_print_bytes(&tmp_24, tmp_23)
    call @sa_fmt_buffer_free(^tmp_21)
    !tmp_24
    !tmp_23
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_25 = 0
    !sum
    !values
    return tmp_25

@test "rosetta 013 array sum"():
L_TEST_ENTRY_0:
    values = alloc 16
    tmp_26 = 1
    store values+0, tmp_26 as i32
    tmp_27 = 2
    store values+4, tmp_27 as i32
    tmp_28 = 3
    store values+8, tmp_28 as i32
    tmp_29 = 4
    store values+12, tmp_29 as i32
    tmp_30 = 0
    tmp_31 = 0
    tmp_32 = ptr_add values, tmp_31
    tmp_33 = load tmp_32+0 as i32
    tmp_34 = add tmp_30, tmp_33
    !tmp_31
    !tmp_32
    !tmp_33
    !tmp_30
    tmp_35 = 4
    tmp_36 = ptr_add values, tmp_35
    tmp_37 = load tmp_36+0 as i32
    tmp_38 = add tmp_34, tmp_37
    !tmp_35
    !tmp_36
    !tmp_37
    !tmp_34
    tmp_39 = 8
    tmp_40 = ptr_add values, tmp_39
    tmp_41 = load tmp_40+0 as i32
    tmp_42 = add tmp_38, tmp_41
    !tmp_39
    !tmp_40
    !tmp_41
    !tmp_38
    tmp_43 = 12
    tmp_44 = ptr_add values, tmp_43
    tmp_45 = load tmp_44+0 as i32
    tmp_46 = add tmp_42, tmp_45
    !tmp_43
    !tmp_44
    !tmp_45
    !tmp_42
    sum = tmp_46
    tmp_47 = 10
    tmp_48 = ne sum, tmp_47
    !tmp_47
    br tmp_48 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_48
    panic(13)

L_ELSE_2:
    !tmp_48
    jmp L_MERGE_3

L_MERGE_3:
    !sum
    !values
    return

