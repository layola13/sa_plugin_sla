@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_const_generic_array_len = vtable { call = @sla__const_generic_array_len }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__const_generic_array_len() -> u64:
L_ENTRY:
    fixed_array = alloc 16
    tmp_0 = 1
    store fixed_array+0, tmp_0 as i32
    tmp_1 = 2
    store fixed_array+4, tmp_1 as i32
    tmp_2 = 3
    store fixed_array+8, tmp_2 as i32
    tmp_3 = 4
    store fixed_array+12, tmp_3 as i32
    tmp_4 = 4
    !fixed_array
    return tmp_4

@main() -> i32:
L_ENTRY:
    tmp_5 = call @sla__const_generic_array_len()
    result = tmp_5
    tmp_6 = call @sa_fmt_u64(result, 10)
    tmp_7 = call @sa_fmt_buffer_data(tmp_6)
    tmp_8 = call @sa_fmt_buffer_len(tmp_6)
    tmp_9 = tmp_7
    call @sa_print_bytes(&tmp_9, tmp_8)
    call @sa_fmt_buffer_free(^tmp_6)
    !tmp_9
    !tmp_8
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_10 = 0
    !result
    return tmp_10

@test "rosetta 167 167_const_generics_expansion"():
L_TEST_ENTRY_0:
    tmp_11 = call @sla__const_generic_array_len()
    got = tmp_11
    tmp_12 = 4
    tmp_13 = ne got, tmp_12
    !tmp_12
    br tmp_13 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_13
    panic(167)

L_ELSE_2:
    !tmp_13
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

