@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/future.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_async_stream_sum = vtable { call = @sla__async_stream_sum }
@const SLA_FNPTR_VT_stream_next = vtable { call = @sla__stream_next }
@const SLA_FNPTR_VT_stream_accumulate = vtable { call = @sla__stream_accumulate }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__async_stream_sum() -> i32:
L_ENTRY:
    tmp_0 = 0
    total = tmp_0
    tmp_1 = 0
    tmp_2 = call @sla__stream_next(tmp_1)
    !tmp_1
    tmp_3 = call @sla__stream_accumulate(total, tmp_2)
    !tmp_2
    !total
    total = tmp_3
    tmp_4 = 1
    tmp_5 = call @sla__stream_next(tmp_4)
    !tmp_4
    tmp_6 = call @sla__stream_accumulate(total, tmp_5)
    !tmp_5
    !total
    total = tmp_6
    tmp_7 = 2
    tmp_8 = call @sla__stream_next(tmp_7)
    !tmp_7
    tmp_9 = call @sla__stream_accumulate(total, tmp_8)
    !tmp_8
    !total
    total = tmp_9
    return total

@sla__stream_next(index: i32) -> i32:
L_ENTRY:
    tmp_10 = 1
    tmp_11 = add index, tmp_10
    !tmp_10
    !index
    return tmp_11

@sla__stream_accumulate(total: i32, item: i32) -> i32:
L_ENTRY:
    tmp_12 = add total, item
    !item
    !total
    return tmp_12

@main() -> i32:
L_ENTRY:
    tmp_13 = call @sla__async_stream_sum()
    result = tmp_13
    tmp_14 = call @sa_fmt_u64(result, 10)
    tmp_15 = call @sa_fmt_buffer_data(tmp_14)
    tmp_16 = call @sa_fmt_buffer_len(tmp_14)
    tmp_17 = tmp_15
    call @sa_print_bytes(&tmp_17, tmp_16)
    call @sa_fmt_buffer_free(^tmp_14)
    !tmp_17
    !tmp_16
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 135 135_async_streams"():
L_TEST_ENTRY_0:
    tmp_18 = call @sla__async_stream_sum()
    got = tmp_18
    tmp_19 = 6
    tmp_20 = ne got, tmp_19
    !tmp_19
    br tmp_20 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_20
    panic(135)

L_ELSE_2:
    !tmp_20
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

