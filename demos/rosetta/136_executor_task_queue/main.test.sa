@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/future.sa"
@import "sa_std/core/option.sa"
@import "sa_std/vec.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/option.sa"
@import "sa_std/vec.sa"
@const SLA_FNPTR_VT_task_one = vtable { call = @sla__task_one }
@const SLA_FNPTR_VT_task_two = vtable { call = @sla__task_two }
@const SLA_FNPTR_VT_task_three = vtable { call = @sla__task_three }
@const SLA_FNPTR_VT_executor_task_queue_sum = vtable { call = @sla__executor_task_queue_sum }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__task_one() -> ptr:
L_ENTRY:
    tmp_0 = 1
    EXPAND FUTURE_READY_STATE_NEW tmp_1, tmp_0
    return tmp_1

@sla__task_two() -> ptr:
L_ENTRY:
    tmp_2 = 2
    EXPAND FUTURE_READY_STATE_NEW tmp_3, tmp_2
    return tmp_3

@sla__task_three() -> ptr:
L_ENTRY:
    tmp_4 = 3
    EXPAND FUTURE_READY_STATE_NEW tmp_5, tmp_4
    return tmp_5

@sla__executor_task_queue_sum() -> i32:
L_ENTRY:
    EXPAND VEC_NEW tmp_6
    tmp_7 = call @sla__task_one()
    EXPAND VEC_PUSH tmp_6, tmp_7, 8
    !tmp_7
    tmp_8 = call @sla__task_two()
    EXPAND VEC_PUSH tmp_6, tmp_8, 8
    !tmp_8
    tmp_9 = call @sla__task_three()
    EXPAND VEC_PUSH tmp_6, tmp_9, 8
    !tmp_9
    queue = tmp_6
    tmp_10 = 0
    total = tmp_10
    jmp L_WHILE_HEAD_0

L_WHILE_HEAD_0:
    tmp_13 = alloc 8
    tmp_11 = call @sa_vec_try_pop(&queue, &tmp_13)
    tmp_12 = load tmp_13+0 as u64
    !tmp_13
    br tmp_11 -> L_VEC_POP_SOME_4, L_VEC_POP_NONE_5

L_VEC_POP_SOME_4:
    !tmp_11
    EXPAND OPTION_NEW_SOME tmp_14, tmp_12
    !tmp_12
    jmp L_VEC_POP_END_6

L_VEC_POP_NONE_5:
    !tmp_11
    !tmp_12
    EXPAND OPTION_NEW_NONE tmp_14
    jmp L_VEC_POP_END_6

L_VEC_POP_END_6:
    EXPAND OPTION_IS_SOME tmp_15, tmp_14
    br tmp_15 -> L_WHILE_BODY_1, L_WHILE_COND_FALSE_2

L_WHILE_BODY_1:
    !tmp_15
    EXPAND OPTION_GET tmp_16, tmp_14
    !tmp_14
    EXPAND FUTURE_READY_STATE_INTO_INNER tmp_17, tmp_16
    !tmp_16
    resolved = tmp_17
    tmp_18 = add total, resolved
    !total
    total = tmp_18
    !resolved
    jmp L_WHILE_HEAD_0

L_WHILE_COND_FALSE_2:
    !tmp_15
    !tmp_14
    jmp L_WHILE_EXIT_3

L_WHILE_EXIT_3:
    !queue
    return total

@main() -> i32:
L_ENTRY:
    EXPAND VEC_NEW tmp_19
    tmp_20 = call @sla__task_one()
    EXPAND VEC_PUSH tmp_19, tmp_20, 8
    !tmp_20
    tmp_21 = call @sla__task_two()
    EXPAND VEC_PUSH tmp_19, tmp_21, 8
    !tmp_21
    tmp_22 = call @sla__task_three()
    EXPAND VEC_PUSH tmp_19, tmp_22, 8
    !tmp_22
    queue = tmp_19
    tmp_23 = 0
    total = tmp_23
    jmp L_WHILE_HEAD_7

L_WHILE_HEAD_7:
    tmp_26 = alloc 8
    tmp_24 = call @sa_vec_try_pop(&queue, &tmp_26)
    tmp_25 = load tmp_26+0 as u64
    !tmp_26
    br tmp_24 -> L_VEC_POP_SOME_11, L_VEC_POP_NONE_12

L_VEC_POP_SOME_11:
    !tmp_24
    EXPAND OPTION_NEW_SOME tmp_27, tmp_25
    !tmp_25
    jmp L_VEC_POP_END_13

L_VEC_POP_NONE_12:
    !tmp_24
    !tmp_25
    EXPAND OPTION_NEW_NONE tmp_27
    jmp L_VEC_POP_END_13

L_VEC_POP_END_13:
    EXPAND OPTION_IS_SOME tmp_28, tmp_27
    br tmp_28 -> L_WHILE_BODY_8, L_WHILE_COND_FALSE_9

L_WHILE_BODY_8:
    !tmp_28
    EXPAND OPTION_GET tmp_29, tmp_27
    !tmp_27
    EXPAND FUTURE_READY_STATE_INTO_INNER tmp_30, tmp_29
    !tmp_29
    resolved = tmp_30
    tmp_31 = add total, resolved
    !total
    total = tmp_31
    !resolved
    jmp L_WHILE_HEAD_7

L_WHILE_COND_FALSE_9:
    !tmp_28
    !tmp_27
    jmp L_WHILE_EXIT_10

L_WHILE_EXIT_10:
    tmp_32 = call @sa_fmt_u64(total, 10)
    tmp_33 = call @sa_fmt_buffer_data(tmp_32)
    tmp_34 = call @sa_fmt_buffer_len(tmp_32)
    tmp_35 = tmp_33
    call @sa_print_bytes(&tmp_35, tmp_34)
    call @sa_fmt_buffer_free(^tmp_32)
    !tmp_35
    !tmp_34
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !queue
    return total

@test "rosetta 136 136_executor_task_queue"():
L_TEST_ENTRY_14:
    tmp_36 = call @sla__executor_task_queue_sum()
    got = tmp_36
    tmp_37 = 6
    tmp_38 = ne got, tmp_37
    !tmp_37
    br tmp_38 -> L_THEN_15, L_ELSE_16

L_THEN_15:
    !tmp_38
    panic(136)

L_ELSE_16:
    !tmp_38
    jmp L_MERGE_17

L_MERGE_17:
    !got
    return

