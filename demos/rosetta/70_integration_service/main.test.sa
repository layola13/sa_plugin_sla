@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_integrated_total = vtable { call = @sla__integrated_total }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__integrated_total(snapshot: ptr) -> i32:
L_ENTRY:
    tmp_0 = load snapshot+0 as u8
    tmp_1 = 0
    tmp_2 = eq tmp_0, tmp_1
    !tmp_0
    !tmp_1
    br tmp_2 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_2
    tmp_3 = 0
    tmp_4 = 1
    tmp_5 = sub tmp_3, tmp_4
    !tmp_3
    !tmp_4
    !snapshot
    return tmp_5

L_ELSE_1:
    !tmp_2
    jmp L_MERGE_2

L_MERGE_2:
    tmp_7 = load snapshot+1 as u8
    tmp_8 = 0
    tmp_9 = eq tmp_7, tmp_8
    !tmp_7
    !tmp_8
    br tmp_9 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_9
    tmp_10 = 0
    tmp_11 = 2
    tmp_12 = sub tmp_10, tmp_11
    !tmp_10
    !tmp_11
    !snapshot
    return tmp_12

L_ELSE_4:
    !tmp_9
    jmp L_MERGE_5

L_MERGE_5:
    tmp_14 = load snapshot+2 as i32
    users = tmp_14
    tmp_15 = load snapshot+6 as i32
    orders = tmp_15
    tmp_16 = add users, orders
    !snapshot
    return tmp_16

@main() -> i32:
L_ENTRY:
    snapshot = alloc 10
    tmp_17 = 1
    store snapshot+0, tmp_17 as u8
    tmp_18 = 1
    store snapshot+1, tmp_18 as u8
    tmp_19 = 2
    store snapshot+2, tmp_19 as i32
    tmp_20 = 4
    store snapshot+6, tmp_20 as i32
    tmp_21 = call @sla__integrated_total(snapshot)
    total = tmp_21
    tmp_22 = call @sa_fmt_u64(total, 10)
    tmp_23 = call @sa_fmt_buffer_data(tmp_22)
    tmp_24 = call @sa_fmt_buffer_len(tmp_22)
    tmp_25 = tmp_23
    call @sa_print_bytes(&tmp_25, tmp_24)
    call @sa_fmt_buffer_free(^tmp_22)
    !tmp_25
    !tmp_24
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !snapshot
    return total

@test "rosetta 070 70_integration_service"():
L_TEST_ENTRY_6:
    snapshot = alloc 10
    tmp_26 = 1
    store snapshot+0, tmp_26 as u8
    tmp_27 = 1
    store snapshot+1, tmp_27 as u8
    tmp_28 = 2
    store snapshot+2, tmp_28 as i32
    tmp_29 = 4
    store snapshot+6, tmp_29 as i32
    tmp_30 = call @sla__integrated_total(snapshot)
    got = tmp_30
    tmp_31 = 6
    tmp_32 = ne got, tmp_31
    !tmp_31
    br tmp_32 -> L_THEN_7, L_ELSE_8

L_THEN_7:
    !tmp_32
    panic(70)

L_ELSE_8:
    !tmp_32
    jmp L_MERGE_9

L_MERGE_9:
    !got
    !snapshot
    return

