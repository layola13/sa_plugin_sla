@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/cell.sa"

fn thread_local_cell_value() -> i32 {
    let value = Cell::new(6);
    value.set(value.get() + 2);
    return value.get();
}

fn main() -> i32 {
    let result = thread_local_cell_value();
    println("{}", result);
    return result;
};

@test "rosetta 124 124_thread_local_storage"() {
    let got = thread_local_cell_value();
    if got != 8 {
        panic(124);
    };
};
