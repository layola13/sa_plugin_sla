// Sla companion for SA rosetta demo 078 Cli Args.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_078_value() -> int {
    let total = 0;
    for i in 1..9 {
        total = total + i;
    }    let result = total + 14;
    return result;
};

fn main() -> int {
    let result = rosetta_078_value();
    return result;
};

@test "rosetta 078 78_cli_args"() {
    let got = rosetta_078_value();
    if got != 50 {
        panic(78);
    }