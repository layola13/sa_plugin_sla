@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@read_twice(&value: ptr) -> i32:
L_ENTRY:
    tmp_0 = load value+0 as i32
    tmp_1 = load value+0 as i32
    tmp_2 = add tmp_0, tmp_1
    !tmp_0
    !tmp_1
    return tmp_2

@main() -> i32:
L_ENTRY:
    tmp_3 = 6
    value = stack_alloc 4
    store value+0, tmp_3 as i32
    tmp_4 = call @read_twice(&value)
    tmp_5 = call @sa_fmt_u64(tmp_4, 10)
    tmp_6 = call @sa_fmt_buffer_data(tmp_5)
    tmp_7 = call @sa_fmt_buffer_len(tmp_5)
    tmp_8 = tmp_6
    call @sa_print_bytes(&tmp_8, tmp_7)
    call @sa_fmt_buffer_free(^tmp_5)
    !tmp_8
    !tmp_7
    !tmp_4
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_9 = 0
    return tmp_9

@test "rosetta 028 borrow chains"():
L_TEST_ENTRY_0:
    tmp_10 = 6
    value = stack_alloc 4
    store value+0, tmp_10 as i32
    tmp_11 = call @read_twice(&value)
    result = tmp_11
    tmp_12 = 12
    tmp_13 = ne result, tmp_12
    !tmp_12
    br tmp_13 -> L_THEN_1, L_ELSE_2

L_THEN_1:
