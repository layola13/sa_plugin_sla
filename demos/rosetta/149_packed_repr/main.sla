@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

struct Pair { a: i32, b: i32 }
fn packed_pair_sum() -> i32 { let pair = Pair { a: 1, b: 2 }; return pair.a + pair.b; }
fn main() -> i32 { let result = packed_pair_sum(); println("{}", result); return result; }
@test "rosetta 149 149_packed_repr"() { let got = packed_pair_sum(); if got != 3 { panic(149); }; }
