[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/box.sa"
@const SLA_FNPTR_VT_hazard_pointer_result = vtable { call = @sla__hazard_pointer_result }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__hazard_pointer_result() -> i32:
L_ENTRY:
    tmp_0 = 9
    EXPAND BOX_NEW tmp_1, tmp_0
    EXPAND BOX_INTO_RAW tmp_2, tmp_1
    raw = tmp_2
    shared = stack_alloc AtomicPtr_SIZE
    EXPAND ATOMIC_PTR_INIT shared, raw
    EXPAND ATOMIC_PTR_LOAD tmp_3, shared, acquire
    loaded = tmp_3
    hazard = stack_alloc AtomicPtr_SIZE
    EXPAND ATOMIC_PTR_INIT hazard, loaded
    EXPAND ATOMIC_PTR_LOAD tmp_4, hazard, acquire
    tmp_5 = eq tmp_4, loaded
    !tmp_4
    still_protected = tmp_5
    tmp_6 = 1
    tmp_7 = eq still_protected, tmp_6
    !tmp_6
    tmp_8 = alloc 4
    br tmp_7 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_7
    tmp_9 = 1
    store tmp_8+0, tmp_9 as i32
    !tmp_9
    jmp L_MERGE_2

L_ELSE_1:
    !tmp_7
    tmp_10 = 0
    store tmp_8+0, tmp_10 as i32
    !tmp_10
    jmp L_MERGE_2

L_MERGE_2:
    tmp_11 = load tmp_8+0 as i32
    !tmp_8
    protected = tmp_11
    tmp_13 = load loaded+0 as i32
    tmp_12 = tmp_13
    tmp_14 = add tmp_12, protected
    !tmp_12
    result = tmp_14
    EXPAND ATOMIC_PTR_LOAD tmp_16, shared, acquire
    EXPAND BOX_FROM_RAW tmp_17, tmp_16
    !tmp_16
    tmp_15 = tmp_17
    boxed = tmp_15
    !still_protected
    !raw
    !loaded
    !protected
    !boxed
    return result

@main() -> i32:
L_ENTRY:
    tmp_18 = 9
    EXPAND BOX_NEW tmp_19, tmp_18
    EXPAND BOX_INTO_RAW tmp_20, tmp_19
    raw = tmp_20
    shared = stack_alloc AtomicPtr_SIZE
    EXPAND ATOMIC_PTR_INIT shared, raw
    EXPAND ATOMIC_PTR_LOAD tmp_21, shared, acquire
    loaded = tmp_21
    hazard = stack_alloc AtomicPtr_SIZE
    EXPAND ATOMIC_PTR_INIT hazard, loaded
    EXPAND ATOMIC_PTR_LOAD tmp_22, hazard, acquire
    tmp_23 = eq tmp_22, loaded
    !tmp_22
    still_protected = tmp_23
    tmp_24 = 1
    tmp_25 = eq still_protected, tmp_24
    !tmp_24
    tmp_26 = alloc 4
    br tmp_25 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_25
    tmp_27 = 1
    store tmp_26+0, tmp_27 as i32
    !tmp_27
    jmp L_MERGE_5

L_ELSE_4:
    !tmp_25
    tmp_28 = 0
    store tmp_26+0, tmp_28 as i32
    !tmp_28
    jmp L_MERGE_5

L_MERGE_5:
    tmp_29 = load tmp_26+0 as i32
    !tmp_26
    protected = tmp_29
    tmp_31 = load loaded+0 as i32
    tmp_30 = tmp_31
    tmp_32 = add tmp_30, protected
    !tmp_30
    result = tmp_32
    EXPAND ATOMIC_PTR_LOAD tmp_34, shared, acquire
    EXPAND BOX_FROM_RAW tmp_35, tmp_34
    !tmp_34
    tmp_33 = tmp_35
    boxed = tmp_33
    tmp_36 = call @sa_fmt_u64(result, 10)
    tmp_37 = call @sa_fmt_buffer_data(tmp_36)
    tmp_38 = call @sa_fmt_buffer_len(tmp_36)
    tmp_39 = tmp_37
    call @sa_print_bytes(&tmp_39, tmp_38)
    call @sa_fmt_buffer_free(^tmp_36)
    !tmp_39
    !tmp_38
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !still_protected
    !raw
    !loaded
    !protected
