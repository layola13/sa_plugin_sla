@test "var supports i32 expression and compound assignment"():
L_TEST_ENTRY_76:
    tmp_174 = call @sla__var_i32_expression()
    tmp_175 = 30
    tmp_176 = ne tmp_174, tmp_175
    !tmp_174
    !tmp_175
    br tmp_176 -> L_THEN_77, L_ELSE_78

L_THEN_77:
    !tmp_176
    panic(17500)

L_ELSE_78:
    !tmp_176
    jmp L_MERGE_79

L_MERGE_79:
    return

