@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_main = vtable { call = @main }
@main() -> i32:
L_ENTRY:
    pair = alloc 8
    tmp_0 = 3
    store pair+0, tmp_0 as i32
    tmp_1 = 4
    store pair+4, tmp_1 as i32
    @const SLA_STR_0 = utf8:"("
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_2 = load pair+0 as i32
    tmp_3 = call @sa_fmt_u64(tmp_2, 10)
    tmp_4 = call @sa_fmt_buffer_data(tmp_3)
    tmp_5 = call @sa_fmt_buffer_len(tmp_3)
    tmp_6 = tmp_4
    call @sa_print_bytes(&tmp_6, tmp_5)
    call @sa_fmt_buffer_free(^tmp_3)
    !tmp_6
    !tmp_5
    !tmp_2
    @const SLA_STR_1 = utf8:", "
    call @sa_print_bytes(&SLA_STR_1, 2)
    tmp_7 = load pair+4 as i32
    tmp_8 = call @sa_fmt_u64(tmp_7, 10)
    tmp_9 = call @sa_fmt_buffer_data(tmp_8)
    tmp_10 = call @sa_fmt_buffer_len(tmp_8)
    tmp_11 = tmp_9
    call @sa_print_bytes(&tmp_11, tmp_10)
    call @sa_fmt_buffer_free(^tmp_8)
    !tmp_11
    !tmp_10
    !tmp_7
    @const SLA_STR_2 = utf8:")"
    call @sa_print_bytes(&SLA_STR_2, 1)
    @const SLA_STR_3 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_3, 1)
    tmp_12 = 0
    !pair
    return tmp_12

@test "rosetta 011 tuples"():
L_TEST_ENTRY_0:
    pair = alloc 8
    tmp_13 = 3
    store pair+0, tmp_13 as i32
    tmp_14 = 4
    store pair+4, tmp_14 as i32
    tmp_15 = load pair+0 as i32
    tmp_16 = 3
    tmp_17 = ne tmp_15, tmp_16
    !tmp_15
    !tmp_16
    br tmp_17 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_17
    panic(11)

L_ELSE_2:
    !tmp_17
    jmp L_MERGE_3

L_MERGE_3:
    tmp_20 = load pair+4 as i32
    tmp_21 = 4
    tmp_22 = ne tmp_20, tmp_21
    !tmp_20
    !tmp_21
    br tmp_22 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_22
    panic(11)

L_ELSE_5:
    !tmp_22
    jmp L_MERGE_6

L_MERGE_6:
    !pair
    return

