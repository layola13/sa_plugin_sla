@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_derive_take_entity = vtable { call = @sla__derive_take_entity }
@sla__derive_take_entity(entity: ptr) -> i32:
L_ENTRY:
    tmp_0 = load entity+0 as i32
    tmp_1 = load entity+4 as i32
    tmp_2 = add tmp_0, tmp_1
    !tmp_0
    !tmp_1
    !entity
    return tmp_2

@test "derive copy keeps source usable"():
L_TEST_ENTRY_0:
    a = alloc 8
    tmp_3 = 7
    store a+0, tmp_3 as i32
    !tmp_3
    tmp_4 = 3
    store a+4, tmp_4 as i32
    !tmp_4
    b = alloc 8
    tmp_5 = load a+0 as i32
    store b+0, tmp_5 as i32
    tmp_6 = load a+4 as i32
    store b+4, tmp_6 as i32
    tmp_7 = load b+0 as i32
    tmp_8 = 7
    tmp_9 = ne tmp_7, tmp_8
    !tmp_7
    !tmp_8
    br tmp_9 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_9
    panic(9301)

L_ELSE_2:
    !tmp_9
    jmp L_MERGE_3

L_MERGE_3:
    tmp_12 = load a+4 as i32
    tmp_13 = 3
    tmp_14 = ne tmp_12, tmp_13
    !tmp_12
    !tmp_13
    br tmp_14 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_14
    panic(9302)

L_ELSE_5:
    !tmp_14
    jmp L_MERGE_6

L_MERGE_6:
    tmp_17 = alloc 8
    tmp_18 = load a+0 as i32
    store tmp_17+0, tmp_18 as i32
    tmp_19 = load a+4 as i32
    store tmp_17+4, tmp_19 as i32
    tmp_20 = call @sla__derive_take_entity(tmp_17)
    !tmp_17
    tmp_21 = 10
    tmp_22 = ne tmp_20, tmp_21
    !tmp_20
    !tmp_21
    br tmp_22 -> L_THEN_7, L_ELSE_8

L_THEN_7:
    !tmp_22
    panic(9303)

L_ELSE_8:
    !tmp_22
    jmp L_MERGE_9

L_MERGE_9:
    tmp_25 = load a+0 as i32
    tmp_26 = 7
    tmp_27 = ne tmp_25, tmp_26
    !tmp_25
    !tmp_26
    br tmp_27 -> L_THEN_10, L_ELSE_11

L_THEN_10:
    !tmp_27
    panic(9304)

L_ELSE_11:
    !tmp_27
    jmp L_MERGE_12

L_MERGE_12:
    !b
    !a
    return

@test "derive eq ord hash debug"():
L_TEST_ENTRY_13:
    a = alloc 8
    tmp_30 = 7
    store a+0, tmp_30 as i32
    !tmp_30
    tmp_31 = 3
    store a+4, tmp_31 as i32
    !tmp_31
    same = alloc 8
    tmp_32 = 7
    store same+0, tmp_32 as i32
    !tmp_32
    tmp_33 = 3
    store same+4, tmp_33 as i32
    !tmp_33
    later = alloc 8
    tmp_34 = 7
    store later+0, tmp_34 as i32
    !tmp_34
    tmp_35 = 4
    store later+4, tmp_35 as i32
    !tmp_35
    tmp_36 = load a+0 as i32
    tmp_37 = load same+0 as i32
    tmp_38 = eq tmp_36, tmp_37
    tmp_39 = load a+4 as i32
    tmp_40 = load same+4 as i32
    tmp_41 = eq tmp_39, tmp_40
    tmp_42 = and tmp_38, tmp_41
    tmp_43 = or tmp_42, 0
    tmp_44 = 1
    tmp_45 = ne tmp_43, tmp_44
    !tmp_43
    !tmp_44
    br tmp_45 -> L_THEN_14, L_ELSE_15

L_THEN_14:
    !tmp_45
    panic(9311)

L_ELSE_15:
    !tmp_45
    jmp L_MERGE_16

L_MERGE_16:
    tmp_48 = load a+0 as i32
    tmp_49 = load later+0 as i32
    tmp_50 = eq tmp_48, tmp_49
    tmp_51 = load a+4 as i32
    tmp_52 = load later+4 as i32
    tmp_53 = eq tmp_51, tmp_52
    tmp_54 = and tmp_50, tmp_53
    tmp_55 = ne tmp_54, 1
    tmp_56 = 1
    tmp_57 = ne tmp_55, tmp_56
    !tmp_55
    !tmp_56
    br tmp_57 -> L_THEN_17, L_ELSE_18

L_THEN_17:
    !tmp_57
    panic(9312)

L_ELSE_18:
    !tmp_57
    jmp L_MERGE_19

L_MERGE_19:
    tmp_60 = load a+0 as i32
    tmp_61 = load later+0 as i32
    tmp_62 = slt tmp_60, tmp_61
    tmp_63 = eq tmp_60, tmp_61
    tmp_64 = load a+4 as i32
    tmp_65 = load later+4 as i32
    tmp_66 = slt tmp_64, tmp_65
    tmp_67 = eq tmp_64, tmp_65
    tmp_68 = and tmp_63, tmp_66
    tmp_69 = or tmp_62, tmp_68
    tmp_70 = and tmp_63, tmp_67
    tmp_71 = or tmp_69, 0
    tmp_72 = 1
    tmp_73 = ne tmp_71, tmp_72
    !tmp_71
    !tmp_72
    br tmp_73 -> L_THEN_20, L_ELSE_21

L_THEN_20:
    !tmp_73
    panic(9313)

L_ELSE_21:
    !tmp_73
    jmp L_MERGE_22

L_MERGE_22:
    tmp_76 = load later+0 as i32
    tmp_77 = load a+0 as i32
    tmp_78 = sgt tmp_76, tmp_77
    tmp_79 = eq tmp_76, tmp_77
    tmp_80 = load later+4 as i32
    tmp_81 = load a+4 as i32
    tmp_82 = sgt tmp_80, tmp_81
    tmp_83 = eq tmp_80, tmp_81
    tmp_84 = and tmp_79, tmp_82
    tmp_85 = or tmp_78, tmp_84
    tmp_86 = and tmp_79, tmp_83
    tmp_87 = or tmp_85, 0
    tmp_88 = 1
    tmp_89 = ne tmp_87, tmp_88
    !tmp_87
    !tmp_88
    br tmp_89 -> L_THEN_23, L_ELSE_24

L_THEN_23:
    !tmp_89
    panic(9314)

L_ELSE_24:
    !tmp_89
    jmp L_MERGE_25

L_MERGE_25:
    tmp_92 = 1469598103934665603
    tmp_93 = load a+0 as i32
    tmp_94 = tmp_93 as u64
    tmp_95 = xor tmp_92, tmp_94
    tmp_96 = mul tmp_95, 1099511628211
    tmp_97 = load a+4 as i32
    tmp_98 = tmp_97 as u64
    tmp_99 = xor tmp_96, tmp_98
    tmp_100 = mul tmp_99, 1099511628211
    tmp_101 = 1469598103934665603
    tmp_102 = load same+0 as i32
    tmp_103 = tmp_102 as u64
    tmp_104 = xor tmp_101, tmp_103
    tmp_105 = mul tmp_104, 1099511628211
    tmp_106 = load same+4 as i32
    tmp_107 = tmp_106 as u64
    tmp_108 = xor tmp_105, tmp_107
    tmp_109 = mul tmp_108, 1099511628211
    tmp_110 = ne tmp_100, tmp_109
    !tmp_100
    !tmp_109
    br tmp_110 -> L_THEN_26, L_ELSE_27

L_THEN_26:
    !tmp_110
    panic(9315)

L_ELSE_27:
    !tmp_110
    jmp L_MERGE_28

L_MERGE_28:
    tmp_113 = 1469598103934665603
    tmp_114 = load a+0 as i32
    tmp_115 = tmp_114 as u64
    tmp_116 = xor tmp_113, tmp_115
    tmp_117 = mul tmp_116, 1099511628211
    tmp_118 = load a+4 as i32
    tmp_119 = tmp_118 as u64
    tmp_120 = xor tmp_117, tmp_119
    tmp_121 = mul tmp_120, 1099511628211
    tmp_122 = 1469598103934665603
    tmp_123 = load later+0 as i32
    tmp_124 = tmp_123 as u64
    tmp_125 = xor tmp_122, tmp_124
    tmp_126 = mul tmp_125, 1099511628211
    tmp_127 = load later+4 as i32
    tmp_128 = tmp_127 as u64
    tmp_129 = xor tmp_126, tmp_128
    tmp_130 = mul tmp_129, 1099511628211
    tmp_131 = eq tmp_121, tmp_130
    !tmp_121
    !tmp_130
    br tmp_131 -> L_THEN_29, L_ELSE_30

L_THEN_29:
    !tmp_131
    panic(9316)

L_ELSE_30:
    !tmp_131
    jmp L_MERGE_31

L_MERGE_31:
    EXPAND FORMAT_BEGIN tmp_134, 128
    @const SLA_STR_0 = utf8:"DeriveEntity"
    tmp_135 = &SLA_STR_0
    EXPAND FORMAT_PUSH_BYTES tmp_136, tmp_134, tmp_135, 12
    !tmp_135
    @const SLA_STR_1 = utf8:" { "
    tmp_137 = &SLA_STR_1
    EXPAND FORMAT_PUSH_BYTES tmp_138, tmp_134, tmp_137, 3
    !tmp_137
    @const SLA_STR_2 = utf8:"id"
    tmp_139 = &SLA_STR_2
    EXPAND FORMAT_PUSH_BYTES tmp_140, tmp_134, tmp_139, 2
    !tmp_139
    @const SLA_STR_3 = utf8:": "
    tmp_141 = &SLA_STR_3
    EXPAND FORMAT_PUSH_BYTES tmp_142, tmp_134, tmp_141, 2
    !tmp_141
    tmp_143 = load a+0 as i32
    EXPAND FORMAT_PUSH_I64 tmp_144, tmp_134, tmp_143
    @const SLA_STR_4 = utf8:", "
    tmp_145 = &SLA_STR_4
    EXPAND FORMAT_PUSH_BYTES tmp_146, tmp_134, tmp_145, 2
    !tmp_145
    @const SLA_STR_5 = utf8:"gen"
    tmp_147 = &SLA_STR_5
    EXPAND FORMAT_PUSH_BYTES tmp_148, tmp_134, tmp_147, 3
    !tmp_147
    @const SLA_STR_6 = utf8:": "
    tmp_149 = &SLA_STR_6
    EXPAND FORMAT_PUSH_BYTES tmp_150, tmp_134, tmp_149, 2
    !tmp_149
    tmp_151 = load a+4 as i32
    EXPAND FORMAT_PUSH_I64 tmp_152, tmp_134, tmp_151
    @const SLA_STR_7 = utf8:" }"
    tmp_153 = &SLA_STR_7
    EXPAND FORMAT_PUSH_BYTES tmp_154, tmp_134, tmp_153, 2
    !tmp_153
    text = tmp_134
    EXPAND STRING_BUF_AS_STR tmp_155, text
    EXPAND STRING_LEN tmp_156, tmp_155
    !tmp_155
    tmp_157 = 0
    tmp_158 = eq tmp_156, tmp_157
    !tmp_156
    !tmp_157
    br tmp_158 -> L_THEN_32, L_ELSE_33

L_THEN_32:
    !tmp_158
    panic(9317)

L_ELSE_33:
    !tmp_158
    jmp L_MERGE_34

L_MERGE_34:
    !same
    !a
    EXPAND STRING_BUF_FREE text
    !later
    return

