@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn main() -> i32 {
    let pair = (3, 4);
    println("({}, {})", pair.0, pair.1);
    return 0;
};

@test "rosetta 011 tuples"() {
    let pair = (3, 4);
    if pair.0 != 3 {
        panic(11);
    };
    if pair.1 != 4 {
        panic(11);
    };
};
