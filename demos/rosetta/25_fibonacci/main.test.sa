@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@fib(n: i32) -> i32:
L_ENTRY:
    tmp_0 = 1
    tmp_1 = sle n, tmp_0
    !tmp_0
    tmp_2 = alloc 4
    br tmp_1 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_1
    tmp_3 = add n, 0
    store tmp_2+0, tmp_3 as i32
    !tmp_3
    jmp L_MERGE_2

L_ELSE_1:
    !tmp_1
    tmp_4 = 1
    tmp_5 = sub n, tmp_4
    !tmp_4
    tmp_6 = call @fib(tmp_5)
    !tmp_5
    tmp_7 = 2
    tmp_8 = sub n, tmp_7
    !tmp_7
    tmp_9 = call @fib(tmp_8)
    !tmp_8
    tmp_10 = add tmp_6, tmp_9
    !tmp_6
    !tmp_9
    store tmp_2+0, tmp_10 as i32
    jmp L_MERGE_2

L_MERGE_2:
    tmp_11 = load tmp_2+0 as i32
    !tmp_2
    return tmp_11

@main() -> i32:
L_ENTRY:
    tmp_12 = 8
    tmp_13 = call @fib(tmp_12)
    !tmp_12
    value = tmp_13
    tmp_14 = call @sa_fmt_u64(value, 10)
    tmp_15 = call @sa_fmt_buffer_data(tmp_14)
    tmp_16 = call @sa_fmt_buffer_len(tmp_14)
    tmp_17 = tmp_15
    call @sa_print_bytes(&tmp_17, tmp_16)
    call @sa_fmt_buffer_free(^tmp_14)
    !tmp_17
    !tmp_16
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_18 = 0
    !value
    return tmp_18

@test "rosetta 025 fibonacci"():
L_TEST_ENTRY_3:
    tmp_19 = 8
    tmp_20 = call @fib(tmp_19)
    !tmp_19
    value = tmp_20
    tmp_21 = 21
    tmp_22 = ne value, tmp_21
    !tmp_21
    br tmp_22 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_22
    panic(25)

L_ELSE_5:
    !tmp_22
    jmp L_MERGE_6

L_MERGE_6:
    !value
    return

