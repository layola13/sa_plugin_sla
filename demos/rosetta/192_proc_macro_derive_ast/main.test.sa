@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_proc_macro_derive_pair_sum_surrogate = vtable { call = @sla__proc_macro_derive_pair_sum_surrogate }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__proc_macro_derive_pair_sum_surrogate() -> i32:
L_ENTRY:
    pair = alloc 8
    tmp_0 = 1
    store pair+0, tmp_0 as i32
    tmp_1 = 2
    store pair+4, tmp_1 as i32
    tmp_2 = load pair+0 as i32
    left = tmp_2
    tmp_3 = load pair+4 as i32
    right = tmp_3
    tmp_4 = add left, right
    !pair
    return tmp_4

@main() -> i32:
L_ENTRY:
    tmp_5 = call @sla__proc_macro_derive_pair_sum_surrogate()
    result = tmp_5
    tmp_6 = call @sa_fmt_u64(result, 10)
    tmp_7 = call @sa_fmt_buffer_data(tmp_6)
    tmp_8 = call @sa_fmt_buffer_len(tmp_6)
    tmp_9 = tmp_7
    call @sa_print_bytes(&tmp_9, tmp_8)
    call @sa_fmt_buffer_free(^tmp_6)
    !tmp_9
    !tmp_8
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 192 192_proc_macro_derive_ast"():
L_TEST_ENTRY_0:
    tmp_10 = call @sla__proc_macro_derive_pair_sum_surrogate()
    got = tmp_10
    tmp_11 = 3
    tmp_12 = ne got, tmp_11
    !tmp_11
    br tmp_12 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_12
    panic(192)

L_ELSE_2:
    !tmp_12
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

