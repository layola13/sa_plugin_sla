@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_never_type_safe_path = vtable { call = @sla__never_type_safe_path }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__never_type_safe_path() -> i32:
L_ENTRY:
    tmp_0 = 1
    safe = tmp_0
    tmp_1 = 0
    tmp_2 = eq safe, tmp_1
    !tmp_1
    br tmp_2 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_2
    panic(143)

L_ELSE_1:
    !tmp_2
    jmp L_MERGE_2

L_MERGE_2:
    tmp_5 = 0
    !safe
    return tmp_5

@main() -> i32:
L_ENTRY:
    tmp_6 = 1
    safe = tmp_6
    tmp_7 = 0
    tmp_8 = eq safe, tmp_7
    !tmp_7
    br tmp_8 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_8
    panic(143)

L_ELSE_4:
    !tmp_8
    jmp L_MERGE_5

L_MERGE_5:
    tmp_11 = 0
    tmp_12 = call @sa_fmt_u64(tmp_11, 10)
    tmp_13 = call @sa_fmt_buffer_data(tmp_12)
    tmp_14 = call @sa_fmt_buffer_len(tmp_12)
    tmp_15 = tmp_13
    call @sa_print_bytes(&tmp_15, tmp_14)
    call @sa_fmt_buffer_free(^tmp_12)
    !tmp_15
    !tmp_14
    !tmp_11
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_16 = 0
    !safe
    return tmp_16

@test "rosetta 143 143_never_type_diverge"():
L_TEST_ENTRY_6:
    tmp_17 = call @sla__never_type_safe_path()
    got = tmp_17
    tmp_18 = 0
    tmp_19 = ne got, tmp_18
    !tmp_18
    br tmp_19 -> L_THEN_7, L_ELSE_8

L_THEN_7:
    !tmp_19
    panic(143)

L_ELSE_8:
    !tmp_19
    jmp L_MERGE_9

L_MERGE_9:
    !got
    return

