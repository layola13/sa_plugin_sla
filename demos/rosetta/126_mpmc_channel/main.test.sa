[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/result.sa"
@import "sa_std/sync/mpsc.sa"
@const SLA_THREAD_VT_1 = vtable { call = @sla_thread_worker_1 }
@const SLA_THREAD_VT_0 = vtable { call = @sla_thread_worker_0 }
@const SLA_THREAD_VT_2 = vtable { call = @sla_thread_worker_2 }
@const SLA_THREAD_VT_3 = vtable { call = @sla_thread_worker_3 }

@ffi_wrapper sla_thread_spawn_1(*slot: ptr) -> i32:
L_ENTRY:
    worker_vt = &SLA_THREAD_VT_1
    worker_fn = load worker_vt+0 as ptr
    worker_raw = *worker_fn
    worker_safe = assume_safe worker_raw
    EXPAND THREAD_SPAWN handle, *worker_safe, *slot
    !slot
    return handle

@sla_thread_worker_1(&slot: ptr) -> i32:
L_ENTRY:
    tmp_0 = load slot+16 as ptr
    tmp_1 = 3
    tmp_2 = 4
    tmp_3 = call @sla__send_pair(tmp_0, tmp_1, tmp_2)
    !tmp_1
    !tmp_2
    store slot+8, tmp_3 as i32
    !slot
    return tmp_3

@ffi_wrapper sla_thread_spawn_0(*slot: ptr) -> i32:
L_ENTRY:
    worker_vt = &SLA_THREAD_VT_0
    worker_fn = load worker_vt+0 as ptr
    worker_raw = *worker_fn
    worker_safe = assume_safe worker_raw
    EXPAND THREAD_SPAWN handle, *worker_safe, *slot
    !slot
    return handle

@sla_thread_worker_0(&slot: ptr) -> i32:
L_ENTRY:
    tmp_4 = load slot+16 as ptr
    tmp_5 = 1
    tmp_6 = 2
    tmp_7 = call @sla__send_pair(tmp_4, tmp_5, tmp_6)
    !tmp_5
    !tmp_6
    store slot+8, tmp_7 as i32
    !slot
    return tmp_7

@ffi_wrapper sla_thread_spawn_2(*slot: ptr) -> i32:
L_ENTRY:
    worker_vt = &SLA_THREAD_VT_2
    worker_fn = load worker_vt+0 as ptr
    worker_raw = *worker_fn
    worker_safe = assume_safe worker_raw
    EXPAND THREAD_SPAWN handle, *worker_safe, *slot
