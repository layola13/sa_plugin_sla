@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_seqlock_optimistic_value = vtable { call = @sla__seqlock_optimistic_value }
@const SLA_FNPTR_VT_seqlock_read = vtable { call = @sla__seqlock_read }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__seqlock_optimistic_value() -> i32:
L_ENTRY:
    tmp_0 = 2
    tmp_1 = 10
    tmp_2 = 2
    tmp_3 = call @sla__seqlock_read(tmp_0, tmp_1, tmp_2)
    !tmp_0
    !tmp_1
    !tmp_2
    return tmp_3

@sla__seqlock_read(begin_version: i32, value: i32, end_version: i32) -> i32:
L_ENTRY:
    tmp_4 = eq begin_version, end_version
    br tmp_4 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_4
    tmp_5 = 2
    tmp_6 = rem begin_version, tmp_5
    !tmp_5
    tmp_7 = 0
    tmp_8 = eq tmp_6, tmp_7
    !tmp_6
    !tmp_7
    br tmp_8 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_8
    tmp_9 = add value, end_version
    !begin_version
    return tmp_9

L_ELSE_4:
    !tmp_8
    tmp_10 = 0
    !value
    !end_version
    !begin_version
    return tmp_10


L_ELSE_1:
    !tmp_4
    tmp_12 = 0
    !value
    !end_version
    !begin_version
    return tmp_12


@main() -> i32:
L_ENTRY:
    tmp_14 = 2
    tmp_15 = 10
    tmp_16 = 2
    tmp_17 = call @sla__seqlock_read(tmp_14, tmp_15, tmp_16)
    !tmp_14
    !tmp_15
    !tmp_16
    result = tmp_17
    tmp_18 = call @sa_fmt_u64(result, 10)
    tmp_19 = call @sa_fmt_buffer_data(tmp_18)
    tmp_20 = call @sa_fmt_buffer_len(tmp_18)
    tmp_21 = tmp_19
    call @sa_print_bytes(&tmp_21, tmp_20)
    call @sa_fmt_buffer_free(^tmp_18)
    !tmp_21
    !tmp_20
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 129 129_seqlock_optimistic"():
L_TEST_ENTRY_6:
    tmp_22 = call @sla__seqlock_optimistic_value()
    got = tmp_22
    tmp_23 = 12
    tmp_24 = ne got, tmp_23
    !tmp_23
    br tmp_24 -> L_THEN_7, L_ELSE_8

L_THEN_7:
    !tmp_24
    panic(129)

L_ELSE_8:
    !tmp_24
    jmp L_MERGE_9

L_MERGE_9:
    !got
    return

