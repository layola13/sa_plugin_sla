@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
fn unwrap_value() -> i32 { let unwrapped_value = 5; return unwrapped_value; }
fn main() -> i32 { let result = unwrap_value(); println("{}", result); return result; }
@test "rosetta 177 177_unwrap_unwrap_err"() { let got = unwrap_value(); if got != 5 { panic(177); }; }
