@test "nested rc box field borrow releases all temporaries"():
L_TEST_ENTRY_35:
    holder = alloc 8
    tmp_115 = alloc 8
    tmp_116 = 41
    store tmp_115+0, tmp_116 as i64
    !tmp_116
    EXPAND BOX_NEW tmp_117, tmp_115
    !tmp_115
    EXPAND RC_NEW tmp_118, tmp_117
    !tmp_117
    store holder+0, tmp_118 as ptr
    !tmp_118
    tmp_119 = load holder+0 as ptr
    tmp_120 = &tmp_119
    borrowed_rc_box = tmp_120
    tmp_121 = call @sla__borrow_read_rc_box(borrowed_rc_box)
    tmp_122 = 41
    tmp_123 = ne tmp_121, tmp_122
    !tmp_121
    !tmp_122
    br tmp_123 -> L_THEN_36, L_ELSE_37

L_THEN_36:
    !tmp_123
    panic(6)

L_ELSE_37:
    !tmp_123
    jmp L_MERGE_38

L_MERGE_38:
    !borrowed_rc_box
    !tmp_119
    !holder
    return

