@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn main() -> i32 {
    let events = [1, 2, 3];
    let acc = 0;
    for event in events {
        acc += event;
    }
    println("{}", acc);
    return 0;
}

@test "rosetta 057 event loop"() {
    let events = [1, 2, 3];
    let acc = 0;
    for event in events {
        acc += event;
    }
    if acc != 6 {
        panic(57);
    };
}
