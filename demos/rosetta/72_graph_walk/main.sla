// Sla companion for SA rosetta demo 072 Graph Walk.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_072_value() -> int {
    let seed = 7;
    let shifted = seed + 72;
    let scaled = shifted * 2;
    let result = scaled - 8;
    return result;
};

fn main() -> int {
    let result = rosetta_072_value();
    return result;
};

@test "rosetta 072 72_graph_walk"() {
    let got = rosetta_072_value();
    if got != 150 {
        panic(72);
    };
