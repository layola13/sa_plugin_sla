@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_chosen_cost = vtable { call = @sla__chosen_cost }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__chosen_cost(plan: ptr) -> i32:
L_ENTRY:
    tmp_0 = load plan+0 as i32
    table_cost = tmp_0
    tmp_1 = load plan+4 as i32
    tmp_2 = load plan+8 as i32
    tmp_3 = add tmp_1, tmp_2
    !tmp_1
    !tmp_2
    index_cost = tmp_3
    tmp_4 = slt index_cost, table_cost
    br tmp_4 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_4
    !table_cost
    !plan
    return index_cost

L_ELSE_1:
    !tmp_4
    !index_cost
    !plan
    return table_cost


@main() -> i32:
L_ENTRY:
    plan = alloc 12
    tmp_6 = 120
    store plan+0, tmp_6 as i32
    tmp_7 = 18
    store plan+4, tmp_7 as i32
    tmp_8 = 7
    store plan+8, tmp_8 as i32
    tmp_9 = call @sla__chosen_cost(plan)
    result = tmp_9
    tmp_10 = call @sa_fmt_u64(result, 10)
    tmp_11 = call @sa_fmt_buffer_data(tmp_10)
    tmp_12 = call @sa_fmt_buffer_len(tmp_10)
    tmp_13 = tmp_11
    call @sa_print_bytes(&tmp_13, tmp_12)
    call @sa_fmt_buffer_free(^tmp_10)
    !tmp_13
    !tmp_12
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !plan
    return result

@test "rosetta 092 92_query_plan"():
L_TEST_ENTRY_3:
    plan = alloc 12
    tmp_14 = 120
    store plan+0, tmp_14 as i32
    tmp_15 = 18
    store plan+4, tmp_15 as i32
    tmp_16 = 7
    store plan+8, tmp_16 as i32
    tmp_17 = call @sla__chosen_cost(plan)
    got = tmp_17
    tmp_18 = 25
    tmp_19 = ne got, tmp_18
    !tmp_18
    br tmp_19 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_19
    panic(92)

L_ELSE_5:
    !tmp_19
    jmp L_MERGE_6

L_MERGE_6:
    !plan
    !got
    return

