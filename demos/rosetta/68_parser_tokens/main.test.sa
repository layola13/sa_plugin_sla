@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/slice.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_parser_token_count = vtable { call = @sla__parser_token_count }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__parser_token_count() -> u64:
L_ENTRY:
    tokens = alloc 32
    @const SLA_STR_0 = utf8:"let"
    tmp_1 = 3
    tmp_0 = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW tmp_0, &SLA_STR_0, tmp_1
    !tmp_1
    store tokens+0, tmp_0 as ptr
    @const SLA_STR_1 = utf8:"x"
    tmp_3 = 1
    tmp_2 = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW tmp_2, &SLA_STR_1, tmp_3
    !tmp_3
    store tokens+8, tmp_2 as ptr
    @const SLA_STR_2 = utf8:"="
    tmp_5 = 1
    tmp_4 = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW tmp_4, &SLA_STR_2, tmp_5
    !tmp_5
    store tokens+16, tmp_4 as ptr
    @const SLA_STR_3 = utf8:"1"
    tmp_7 = 1
    tmp_6 = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW tmp_6, &SLA_STR_3, tmp_7
    !tmp_7
    store tokens+24, tmp_6 as ptr
    tmp_8 = 4
    !tokens
    return tmp_8

@main() -> i32:
L_ENTRY:
    tmp_9 = call @sla__parser_token_count()
    count = tmp_9
    tmp_10 = call @sa_fmt_u64(count, 10)
    tmp_11 = call @sa_fmt_buffer_data(tmp_10)
    tmp_12 = call @sa_fmt_buffer_len(tmp_10)
    tmp_13 = tmp_11
    call @sa_print_bytes(&tmp_13, tmp_12)
    call @sa_fmt_buffer_free(^tmp_10)
    !tmp_13
    !tmp_12
    @const SLA_STR_4 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_4, 1)
    tmp_14 = 0
    !count
    return tmp_14

@test "rosetta 068 68_parser_tokens"():
L_TEST_ENTRY_0:
    tmp_15 = call @sla__parser_token_count()
    got = tmp_15
    tmp_16 = 4
    tmp_17 = ne got, tmp_16
    !tmp_16
    br tmp_17 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_17
    panic(68)

L_ELSE_2:
    !tmp_17
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

