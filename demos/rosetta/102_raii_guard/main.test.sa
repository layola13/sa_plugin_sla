@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/result.sa"
@import "sa_std/sync/mutex.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/result.sa"
@const SLA_FNPTR_VT_inspect = vtable { call = @sla__inspect }
@const SLA_FNPTR_VT_raii_guard_total = vtable { call = @sla__raii_guard_total }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__inspect(counter: ptr, skip: u8) -> i32:
L_ENTRY:
    EXPAND MUTEX_LOCK counter
    tmp_0 = ptr_add counter, Mutex_data
    EXPAND RESULT_NEW_OK tmp_1, tmp_0
    !tmp_0
    EXPAND RESULT_UNWRAP tmp_2, tmp_1
    !tmp_1
    guard = tmp_2
    br skip -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !skip
    tmp_3 = load guard+0 as i32
    EXPAND MUTEX_UNLOCK counter
    !guard
    return tmp_3

L_ELSE_1:
    !skip
    jmp L_MERGE_2

L_MERGE_2:
    tmp_5 = load guard+0 as i32
    tmp_6 = 3
    tmp_7 = add tmp_5, tmp_6
    !tmp_5
    !tmp_6
    store guard+0, tmp_7 as i32
    !tmp_7
    tmp_8 = load guard+0 as i32
    EXPAND MUTEX_UNLOCK counter
    !guard
    return tmp_8

@sla__raii_guard_total() -> i32:
L_ENTRY:
    tmp_9 = 0
    EXPAND MUTEX_NEW_I32 tmp_10, tmp_9
    !tmp_9
    counter = tmp_10
    tmp_11 = 1
    tmp_12 = call @sla__inspect(&counter, tmp_11)
    !tmp_11
    first = tmp_12
    tmp_13 = 0
    tmp_14 = call @sla__inspect(&counter, tmp_13)
    !tmp_13
    second = tmp_14
    tmp_15 = add first, second
    !counter
    return tmp_15

@main() -> i32:
L_ENTRY:
    tmp_16 = call @sla__raii_guard_total()
    result = tmp_16
    tmp_17 = call @sa_fmt_u64(result, 10)
    tmp_18 = call @sa_fmt_buffer_data(tmp_17)
    tmp_19 = call @sa_fmt_buffer_len(tmp_17)
    tmp_20 = tmp_18
    call @sa_print_bytes(&tmp_20, tmp_19)
    call @sa_fmt_buffer_free(^tmp_17)
    !tmp_20
    !tmp_19
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 102 102_raii_guard"():
L_TEST_ENTRY_3:
    tmp_21 = call @sla__raii_guard_total()
    got = tmp_21
    tmp_22 = 3
    tmp_23 = ne got, tmp_22
    !tmp_22
    br tmp_23 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_23
    panic(102)

L_ELSE_5:
    !tmp_23
    jmp L_MERGE_6

L_MERGE_6:
    !got
    return

