@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_make_iter_surrogate = vtable { call = @sla__make_iter_surrogate }
@const SLA_FNPTR_VT_type_alias_impl_trait_result = vtable { call = @sla__type_alias_impl_trait_result }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__make_iter_surrogate() -> ptr:
L_ENTRY:
    tmp_0 = alloc 12
    tmp_1 = 1
    store tmp_0+0, tmp_1 as i32
    tmp_2 = 2
    store tmp_0+4, tmp_2 as i32
    tmp_3 = 3
    store tmp_0+8, tmp_3 as i32
    return tmp_0

@sla__type_alias_impl_trait_result() -> i32:
L_ENTRY:
    tmp_4 = call @sla__make_iter_surrogate()
    _iter = tmp_4
    tmp_5 = 0
    !_iter
    return tmp_5

@main() -> i32:
L_ENTRY:
    tmp_6 = call @sla__type_alias_impl_trait_result()
    result = tmp_6
    tmp_7 = call @sa_fmt_u64(result, 10)
    tmp_8 = call @sa_fmt_buffer_data(tmp_7)
    tmp_9 = call @sa_fmt_buffer_len(tmp_7)
    tmp_10 = tmp_8
    call @sa_print_bytes(&tmp_10, tmp_9)
    call @sa_fmt_buffer_free(^tmp_7)
    !tmp_10
    !tmp_9
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 168 168_type_alias_impl_trait"():
L_TEST_ENTRY_0:
    tmp_11 = call @sla__type_alias_impl_trait_result()
    got = tmp_11
    tmp_12 = 0
    tmp_13 = ne got, tmp_12
    !tmp_12
    br tmp_13 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_13
    panic(168)

L_ELSE_2:
    !tmp_13
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

