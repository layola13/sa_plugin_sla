@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_build_parallel_codegen_units = vtable { call = @sla__build_parallel_codegen_units }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__build_parallel_codegen_units() -> i32:
L_ENTRY:
    tmp_0 = 1
    parser = tmp_0
    tmp_1 = 1
    checker = tmp_1
    tmp_2 = 1
    optimizer = tmp_2
    tmp_3 = 1
    emitter = tmp_3
    tmp_4 = add parser, checker
    tmp_5 = add tmp_4, optimizer
    !tmp_4
    tmp_6 = add tmp_5, emitter
    !tmp_5
    return tmp_6

@main() -> i32:
L_ENTRY:
    tmp_7 = 1
    parser = tmp_7
    tmp_8 = 1
    checker = tmp_8
    tmp_9 = 1
    optimizer = tmp_9
    tmp_10 = 1
    emitter = tmp_10
    tmp_11 = add parser, checker
    tmp_12 = add tmp_11, optimizer
    !tmp_11
    tmp_13 = add tmp_12, emitter
    !tmp_12
    result = tmp_13
    tmp_14 = call @sa_fmt_u64(result, 10)
    tmp_15 = call @sa_fmt_buffer_data(tmp_14)
    tmp_16 = call @sa_fmt_buffer_len(tmp_14)
    tmp_17 = tmp_15
    call @sa_print_bytes(&tmp_17, tmp_16)
    call @sa_fmt_buffer_free(^tmp_14)
    !tmp_17
    !tmp_16
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !checker
    !emitter
    !parser
    !optimizer
    return result

@test "rosetta 277 build parallel compilation"():
L_TEST_ENTRY_0:
    tmp_18 = call @sla__build_parallel_codegen_units()
    got = tmp_18
    tmp_19 = 4
    tmp_20 = ne got, tmp_19
    !tmp_19
    br tmp_20 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_20
    panic(277)

L_ELSE_2:
    !tmp_20
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

