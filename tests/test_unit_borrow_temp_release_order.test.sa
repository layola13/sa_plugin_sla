@test "vec rc refcell box indexed borrow releases nested owner temps"():
L_TEST_ENTRY_67:
    EXPAND VEC_NEW tmp_222
    items = tmp_222
    tmp_223 = alloc 8
    tmp_224 = 2
    store tmp_223+0, tmp_224 as i64
    !tmp_224
    EXPAND BOX_NEW tmp_225, tmp_223
    !tmp_223
    EXPAND REFCELL_U64_NEW tmp_226, tmp_225
    !tmp_225
    EXPAND RC_NEW tmp_227, tmp_226
    !tmp_226
