@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_main = vtable { call = @main }
@main() -> i32:
L_ENTRY:
    state = alloc 8
    store state+0, 2 as i64
    jmp L_MATCH_CHECK_0_2

L_MATCH_CHECK_0_2:
    tmp_0 = load state+0 as i64
    tmp_1 = 0
    tmp_2 = eq tmp_0, tmp_1
    !tmp_0
    !tmp_1
    br tmp_2 -> L_MATCH_CASE_0_2, L_MATCH_CHECK_1_2

L_MATCH_CASE_0_2:
    !tmp_2
    @const SLA_STR_0 = utf8:"0"
    call @sa_print_bytes(&SLA_STR_0, 1)
    @const SLA_STR_1 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_1, 1)
    jmp L_MATCH_MERGE_0

L_MATCH_CHECK_1_2:
    !tmp_2
    tmp_3 = load state+0 as i64
    tmp_4 = 1
    tmp_5 = eq tmp_3, tmp_4
    !tmp_3
    !tmp_4
    br tmp_5 -> L_MATCH_CASE_1_2, L_MATCH_CHECK_2_2

L_MATCH_CASE_1_2:
    !tmp_5
    @const SLA_STR_2 = utf8:"1"
    call @sa_print_bytes(&SLA_STR_2, 1)
    @const SLA_STR_3 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_3, 1)
    jmp L_MATCH_MERGE_0

L_MATCH_CHECK_2_2:
    !tmp_5
    tmp_6 = load state+0 as i64
    tmp_7 = 2
    tmp_8 = eq tmp_6, tmp_7
    !tmp_6
    !tmp_7
    br tmp_8 -> L_MATCH_CASE_2_2, L_MATCH_NO_MATCH_1

L_MATCH_CASE_2_2:
    !tmp_8
    @const SLA_STR_4 = utf8:"2"
    call @sa_print_bytes(&SLA_STR_4, 1)
    @const SLA_STR_5 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_5, 1)
    jmp L_MATCH_MERGE_0

L_MATCH_NO_MATCH_1:
    !tmp_8
    panic(1)

L_MATCH_MERGE_0:
    tmp_10 = 0
    !state
    return tmp_10

@test "rosetta 056 state machine"():
L_TEST_ENTRY_3:
    state = alloc 8
    store state+0, 2 as i64
    tmp_11 = alloc 4
    jmp L_MATCH_CHECK_0_6

L_MATCH_CHECK_0_6:
    tmp_12 = load state+0 as i64
    tmp_13 = 0
    tmp_14 = eq tmp_12, tmp_13
    !tmp_12
    !tmp_13
    br tmp_14 -> L_MATCH_CASE_0_6, L_MATCH_CHECK_1_6

L_MATCH_CASE_0_6:
    !tmp_14
    tmp_15 = 0
    store tmp_11+0, tmp_15 as i32
    !tmp_15
    jmp L_MATCH_MERGE_4

L_MATCH_CHECK_1_6:
    !tmp_14
    tmp_16 = load state+0 as i64
    tmp_17 = 1
    tmp_18 = eq tmp_16, tmp_17
    !tmp_16
    !tmp_17
    br tmp_18 -> L_MATCH_CASE_1_6, L_MATCH_CHECK_2_6

L_MATCH_CASE_1_6:
    !tmp_18
    tmp_19 = 1
    store tmp_11+0, tmp_19 as i32
    !tmp_19
    jmp L_MATCH_MERGE_4

L_MATCH_CHECK_2_6:
    !tmp_18
    tmp_20 = load state+0 as i64
    tmp_21 = 2
    tmp_22 = eq tmp_20, tmp_21
    !tmp_20
    !tmp_21
    br tmp_22 -> L_MATCH_CASE_2_6, L_MATCH_NO_MATCH_5

L_MATCH_CASE_2_6:
    !tmp_22
    tmp_23 = 2
    store tmp_11+0, tmp_23 as i32
    !tmp_23
    jmp L_MATCH_MERGE_4

L_MATCH_NO_MATCH_5:
    !tmp_22
    panic(1)

L_MATCH_MERGE_4:
    tmp_24 = load tmp_11+0 as i32
    !tmp_11
    code = tmp_24
    tmp_25 = 2
    tmp_26 = ne code, tmp_25
    !tmp_25
    br tmp_26 -> L_THEN_7, L_ELSE_8

L_THEN_7:
    !tmp_26
    panic(56)

L_ELSE_8:
    !tmp_26
    jmp L_MERGE_9

L_MERGE_9:
    !state
    !code
    return

