@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_pkg_patch_override_applied = vtable { call = @sla__pkg_patch_override_applied }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__pkg_patch_override_applied() -> i32:
L_ENTRY:
    tmp_0 = 1
    patched_source = tmp_0
    return patched_source

@main() -> i32:
L_ENTRY:
    tmp_1 = 1
    patched_source = tmp_1
    tmp_2 = call @sa_fmt_u64(patched_source, 10)
    tmp_3 = call @sa_fmt_buffer_data(tmp_2)
    tmp_4 = call @sa_fmt_buffer_len(tmp_2)
    tmp_5 = tmp_3
    call @sa_print_bytes(&tmp_5, tmp_4)
    call @sa_fmt_buffer_free(^tmp_2)
    !tmp_5
    !tmp_4
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return patched_source

@test "rosetta 215 pkg patch override"():
L_TEST_ENTRY_0:
    tmp_6 = call @sla__pkg_patch_override_applied()
    got = tmp_6
    tmp_7 = 1
    tmp_8 = ne got, tmp_7
    !tmp_7
    br tmp_8 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_8
    panic(215)

L_ELSE_2:
    !tmp_8
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

