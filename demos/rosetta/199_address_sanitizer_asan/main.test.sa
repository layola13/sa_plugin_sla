@test "rosetta 199 199_address_sanitizer_asan"():
L_TEST_ENTRY_0:
    tmp_63 = call @sla__asan_buffer_edge_sum()
    got = tmp_63
    tmp_64 = 5
    tmp_65 = ne got, tmp_64
    !tmp_64
    br tmp_65 -> L_THEN_1, L_ELSE_2

L_THEN_1:
