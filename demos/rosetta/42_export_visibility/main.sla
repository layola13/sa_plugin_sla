@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

pub fn exported_value() -> i32 {
    7
}

fn internal_value() -> i32 {
    5
}

fn main() -> i32 {
    let total = exported_value() + internal_value();
    println("{}", total);
    return 0;
}

@test "rosetta 042 export visibility"() {
    let total = exported_value() + internal_value();
    if total != 12 {
        panic(42);
    };
}
