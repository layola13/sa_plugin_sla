@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_generated_value_surrogate = vtable { call = @sla__generated_value_surrogate }
@const SLA_FNPTR_VT_build_script_generated_value = vtable { call = @sla__build_script_generated_value }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__generated_value_surrogate() -> i32:
L_ENTRY:
    tmp_0 = 1
    generated_constant = tmp_0
    return generated_constant

@sla__build_script_generated_value() -> i32:
L_ENTRY:
    tmp_1 = call @sla__generated_value_surrogate()
    return tmp_1

@main() -> i32:
L_ENTRY:
    tmp_2 = call @sla__build_script_generated_value()
    result = tmp_2
    tmp_3 = call @sa_fmt_u64(result, 10)
    tmp_4 = call @sa_fmt_buffer_data(tmp_3)
    tmp_5 = call @sa_fmt_buffer_len(tmp_3)
    tmp_6 = tmp_4
    call @sa_print_bytes(&tmp_6, tmp_5)
    call @sa_fmt_buffer_free(^tmp_3)
    !tmp_6
    !tmp_5
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 195 195_build_script_codegen"():
L_TEST_ENTRY_0:
    tmp_7 = call @sla__build_script_generated_value()
    got = tmp_7
    tmp_8 = 1
    tmp_9 = ne got, tmp_8
    !tmp_8
    br tmp_9 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_9
    panic(195)

L_ELSE_2:
    !tmp_9
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

