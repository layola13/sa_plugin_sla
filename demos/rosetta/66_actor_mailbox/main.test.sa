@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_mailbox_score = vtable { call = @sla__mailbox_score }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__mailbox_score(inbox: ptr) -> i32:
L_ENTRY:
    message_slot = stack_alloc 8
    tmp_0 = 0
    total = tmp_0
    store message_slot+0, 0 as i64
    jmp L_LOOP_HEAD_0

L_LOOP_HEAD_0:
    tmp_1 = load message_slot+0 as i64
    tmp_2 = slt tmp_1, 2
    br tmp_2 -> L_LOOP_BODY_1, L_LOOP_COND_FALSE_3

L_LOOP_BODY_1:
    !tmp_2
    tmp_3 = mul tmp_1, 8
    tmp_4 = ptr_add inbox, tmp_3
    message = load tmp_4+0 as ptr
    !tmp_3
    !tmp_4
    tmp_5 = load message+0 as i32
    actor = tmp_5
    tmp_6 = load message+4 as i32
    payload = tmp_6
    tmp_7 = add actor, payload
    score = tmp_7
    tmp_8 = add total, score
    !total
    total = tmp_8
    !payload
    !actor
    !score
L_LOOP_CONTINUE_2:
    tmp_9 = add tmp_1, 1
    store message_slot+0, tmp_9 as i64
    !tmp_9
    !tmp_1
    !message
    jmp L_LOOP_HEAD_0

L_LOOP_COND_FALSE_3:
    !tmp_2
    !tmp_1
    jmp L_LOOP_EXIT_4

L_LOOP_EXIT_4:
    !inbox
    return total

@main() -> i32:
L_ENTRY:
    inbox = alloc 16
    tmp_10 = alloc 8
    tmp_11 = 1
    store tmp_10+0, tmp_11 as i32
    tmp_12 = 2
    store tmp_10+4, tmp_12 as i32
    store inbox+0, tmp_10 as ptr
    tmp_13 = alloc 8
    tmp_14 = 2
    store tmp_13+0, tmp_14 as i32
    tmp_15 = 3
    store tmp_13+4, tmp_15 as i32
    store inbox+8, tmp_13 as ptr
    tmp_16 = call @sla__mailbox_score(inbox)
    sum = tmp_16
    tmp_17 = call @sa_fmt_u64(sum, 10)
    tmp_18 = call @sa_fmt_buffer_data(tmp_17)
    tmp_19 = call @sa_fmt_buffer_len(tmp_17)
    tmp_20 = tmp_18
    call @sa_print_bytes(&tmp_20, tmp_19)
    call @sa_fmt_buffer_free(^tmp_17)
    !tmp_20
    !tmp_19
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !inbox
    return sum

@test "rosetta 066 66_actor_mailbox"():
L_TEST_ENTRY_5:
    tmp_21 = call @main()
    tmp_22 = 8
    tmp_23 = ne tmp_21, tmp_22
    !tmp_21
    !tmp_22
    br tmp_23 -> L_THEN_6, L_ELSE_7

L_THEN_6:
    !tmp_23
    panic(66)

L_ELSE_7:
    !tmp_23
    jmp L_MERGE_8

L_MERGE_8:
    return

