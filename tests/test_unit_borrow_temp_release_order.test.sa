    !i
    !total
    !holder
    return

@test "box rc refcell box chained deref releases all owner temps"():
L_TEST_ENTRY_82:
    holder = alloc 8
    tmp_292 = alloc 8
    tmp_293 = 83
    store tmp_292+0, tmp_293 as i64
    !tmp_293
    EXPAND BOX_NEW tmp_294, tmp_292
    !tmp_292
    EXPAND REFCELL_U64_NEW tmp_295, tmp_294
    !tmp_294
