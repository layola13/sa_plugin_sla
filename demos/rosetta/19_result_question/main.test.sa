@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/result.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/result.sa"
@const SLA_FNPTR_VT_triple_ok = vtable { call = @sla__triple_ok }
@const SLA_FNPTR_VT_compute = vtable { call = @sla__compute }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__triple_ok(x: i32) -> ptr:
L_ENTRY:
    tmp_0 = 3
    tmp_1 = mul x, tmp_0
    !tmp_0
    EXPAND RESULT_NEW_OK tmp_2, tmp_1
    !tmp_1
    return tmp_2

@sla__compute() -> ptr:
L_ENTRY:
    tmp_3 = 7
    tmp_4 = call @sla__triple_ok(tmp_3)
    !tmp_3
    EXPAND RESULT_IS_OK tmp_5, tmp_4
    br tmp_5 -> L_TRY_RESULT_OK_0, L_TRY_RESULT_ERR_1

L_TRY_RESULT_ERR_1:
    !tmp_5
    return tmp_4

L_TRY_RESULT_OK_0:
    !tmp_5
    EXPAND RESULT_GET_OK tmp_6, tmp_4
    !tmp_4
    value = tmp_6
    EXPAND RESULT_NEW_OK tmp_7, value
    return tmp_7

@main() -> i32:
L_ENTRY:
    tmp_8 = call @sla__compute()
    tmp_9 = 0
    tmp_10 = 1
    tmp_11 = sub tmp_9, tmp_10
    !tmp_9
    !tmp_10
    EXPAND RESULT_UNWRAP_OR tmp_12, tmp_8, tmp_11
    !tmp_8
    !tmp_11
    result = tmp_12
    tmp_13 = call @sa_fmt_u64(result, 10)
    tmp_14 = call @sa_fmt_buffer_data(tmp_13)
    tmp_15 = call @sa_fmt_buffer_len(tmp_13)
    tmp_16 = tmp_14
    call @sa_print_bytes(&tmp_16, tmp_15)
    call @sa_fmt_buffer_free(^tmp_13)
    !tmp_16
    !tmp_15
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_17 = 0
    !result
    return tmp_17

@test "rosetta 019 result question"():
L_TEST_ENTRY_2:
    tmp_18 = call @sla__compute()
    tmp_19 = 0
    tmp_20 = 1
    tmp_21 = sub tmp_19, tmp_20
    !tmp_19
    !tmp_20
    EXPAND RESULT_UNWRAP_OR tmp_22, tmp_18, tmp_21
    !tmp_18
    !tmp_21
    result = tmp_22
    tmp_23 = 21
    tmp_24 = ne result, tmp_23
    !tmp_23
    br tmp_24 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_24
    panic(19)

L_ELSE_4:
    !tmp_24
    jmp L_MERGE_5

L_MERGE_5:
    !result
    return

