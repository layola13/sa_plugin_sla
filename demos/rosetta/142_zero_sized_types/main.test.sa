@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_process = vtable { call = @sla__process }
@const SLA_FNPTR_VT_zero_sized_process_result = vtable { call = @sla__zero_sized_process_result }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__process(_u: ptr) -> i32:
L_ENTRY:
    tmp_0 = 42
    !_u
    return tmp_0

@sla__zero_sized_process_result() -> i32:
L_ENTRY:
    u = alloc 1
    tmp_1 = call @sla__process(u)
    return tmp_1

@main() -> i32:
L_ENTRY:
    u = alloc 1
    tmp_2 = call @sla__process(u)
    result = tmp_2
    tmp_3 = call @sa_fmt_u64(result, 10)
    tmp_4 = call @sa_fmt_buffer_data(tmp_3)
    tmp_5 = call @sa_fmt_buffer_len(tmp_3)
    tmp_6 = tmp_4
    call @sa_print_bytes(&tmp_6, tmp_5)
    call @sa_fmt_buffer_free(^tmp_3)
    !tmp_6
    !tmp_5
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !u
    return result

@test "rosetta 142 142_zero_sized_types"():
L_TEST_ENTRY_0:
    tmp_7 = call @sla__zero_sized_process_result()
    got = tmp_7
    tmp_8 = 42
    tmp_9 = ne got, tmp_8
    !tmp_8
    br tmp_9 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_9
    panic(142)

L_ELSE_2:
    !tmp_9
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

