    tmp_267 = 2
    tmp_268 = slt i, tmp_267
    !tmp_267
    br tmp_268 -> L_THEN_76, L_ELSE_77

L_THEN_76:
    !tmp_268
    tmp_269 = load holder+0 as ptr
    tmp_270 = 0
    EXPAND VEC_GET tmp_271, tmp_269, tmp_270
    !tmp_270
    !tmp_269
    tmp_272 = tmp_271 as ptr
    EXPAND ARC_GET tmp_273, tmp_272
    !tmp_272
    tmp_274 = &tmp_273
    cell = tmp_274
    tmp_275 = call @sla__borrow_refcell_read(cell)
    tmp_276 = add total, tmp_275
    !tmp_275
    !total
    total = tmp_276
    !cell
    !tmp_273
