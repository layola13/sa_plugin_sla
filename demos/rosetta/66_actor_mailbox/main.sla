@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/vec.sa"

fn actor_mailbox_sum() -> i32 {
    let inbox = vec(1, 2, 3);
    let sum: i32 = inbox.into_iter().sum();
    return sum;
}

fn main() -> i32 {
    let sum = actor_mailbox_sum();
    println("{}", sum);
    return 0;
}

@test "rosetta 066 66_actor_mailbox"() {
    let got = actor_mailbox_sum();
    if got != 6 {
        panic(66);
    };
}
