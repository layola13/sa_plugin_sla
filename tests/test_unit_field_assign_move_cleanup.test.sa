@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_replace_item = vtable { call = @sla__replace_item }
@sla__replace_item(holder: ptr) -> ptr:
L_ENTRY:
    next = alloc 4
    tmp_0 = load holder+0 as ptr
    tmp_1 = load tmp_0+0 as i32
    tmp_2 = 1
    tmp_3 = add tmp_1, tmp_2
    !tmp_2
    store next+0, tmp_3 as i32
    !tmp_3
    store holder+0, next as ptr
    !next
    return holder

@test "field assign moved local cleanup"():
L_TEST_ENTRY_0:
    tmp_4 = alloc 8
    tmp_5 = alloc 4
    tmp_6 = 4
    store tmp_5+0, tmp_6 as i32
    !tmp_6
    store tmp_4+0, tmp_5 as ptr
    !tmp_5
    tmp_7 = call @sla__replace_item(tmp_4)
    !tmp_4
    out = tmp_7
    tmp_8 = load out+0 as ptr
    tmp_9 = load tmp_8+0 as i32
    tmp_10 = 5
    tmp_11 = ne tmp_9, tmp_10
    !tmp_10
    br tmp_11 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_11
    panic(1600)

L_ELSE_2:
    !tmp_11
    jmp L_MERGE_3

L_MERGE_3:
    !out
    return
