@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn bump(&value: i32) {
    *value += 1;
}

fn main() -> i32 {
    let value = 9;
    bump(&value);
    println("{}", value);
    return 0;
}

@test "rosetta 058 borrow update"() {
    let value = 9;
    bump(&value);
    if value != 10 {
        panic(58);
    };
}
