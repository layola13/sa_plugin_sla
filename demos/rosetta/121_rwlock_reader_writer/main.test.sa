@test "rosetta 121 121_rwlock_reader_writer"():
L_TEST_ENTRY_21:
    tmp_75 = call @sla__rwlock_reader_writer_total()
    got = tmp_75
    tmp_76 = 4
    tmp_77 = ne got, tmp_76
    !tmp_76
    br tmp_77 -> L_THEN_22, L_ELSE_23

L_THEN_22:
    !tmp_77
    panic(121)

L_ELSE_23:
    !tmp_77
    jmp L_MERGE_24

L_MERGE_24:
    !got
    return

