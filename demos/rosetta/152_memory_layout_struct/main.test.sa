[END_MACRO]
@const SLA_FNPTR_VT_memory_layout_size_plus_align = vtable { call = @sla__memory_layout_size_plus_align }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__memory_layout_size_plus_align() -> u64:
L_ENTRY:
    tmp_0 = 8
    size = tmp_0
    tmp_1 = 4
    align = tmp_1
    tmp_2 = add size, align
    !size
    !align
    return tmp_2

@main() -> i32:
L_ENTRY:
