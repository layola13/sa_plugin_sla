@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_mod_prelude_symbol_count = vtable { call = @sla__mod_prelude_symbol_count }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__mod_prelude_symbol_count() -> i32:
L_ENTRY:
    tmp_0 = 1
    option_symbol = tmp_0
    tmp_1 = 1
    result_symbol = tmp_1
    tmp_2 = 1
    println_symbol = tmp_2
    tmp_3 = add option_symbol, result_symbol
    tmp_4 = add tmp_3, println_symbol
    !tmp_3
    return tmp_4

@main() -> i32:
L_ENTRY:
    tmp_5 = 1
    option_symbol = tmp_5
    tmp_6 = 1
    result_symbol = tmp_6
    tmp_7 = 1
    println_symbol = tmp_7
    tmp_8 = add option_symbol, result_symbol
    tmp_9 = add tmp_8, println_symbol
    !tmp_8
    result = tmp_9
    tmp_10 = call @sa_fmt_u64(result, 10)
    tmp_11 = call @sa_fmt_buffer_data(tmp_10)
    tmp_12 = call @sa_fmt_buffer_len(tmp_10)
    tmp_13 = tmp_11
    call @sa_print_bytes(&tmp_13, tmp_12)
    call @sa_fmt_buffer_free(^tmp_10)
    !tmp_13
    !tmp_12
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !option_symbol
    !println_symbol
    !result_symbol
    return result

@test "rosetta 230 mod std prelude"():
L_TEST_ENTRY_0:
    tmp_14 = call @sla__mod_prelude_symbol_count()
    got = tmp_14
    tmp_15 = 3
    tmp_16 = ne got, tmp_15
    !tmp_15
    br tmp_16 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_16
    panic(230)

L_ELSE_2:
    !tmp_16
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

