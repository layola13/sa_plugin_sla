@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@rosetta_012_value() -> i64:
L_ENTRY:
    tmp_0 = alloc 16
    tmp_1 = 2
    store tmp_0+0, tmp_1 as i64
    tmp_2 = 5
    store tmp_0+8, tmp_2 as i64
    x = load tmp_0+0 as i64
    y = load tmp_0+8 as i64
    !tmp_0
    tmp_3 = add x, y
    sum = tmp_3
    !x
    !y
    return sum

@main() -> i64:
L_ENTRY:
    tmp_4 = call @rosetta_012_value()
    result = tmp_4
    tmp_5 = 7
    tmp_6 = ne result, tmp_5
    br tmp_6 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_6
    panic(12)

L_ELSE_1:
    !tmp_6
    jmp L_MERGE_2

L_MERGE_2:
    tmp_9 = call @sa_fmt_i64(result, 10)
    tmp_10 = call @sa_fmt_buffer_data(tmp_9)
    tmp_11 = call @sa_fmt_buffer_len(tmp_9)
    tmp_12 = tmp_10
    call @sa_print_bytes(&tmp_12, tmp_11)
    call @sa_fmt_buffer_free(^tmp_9)
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_13 = 0
    !result
    return tmp_13

@test "rosetta 012 destructuring"():
L_TEST_ENTRY_3:
    tmp_14 = call @rosetta_012_value()
    got = tmp_14
    tmp_15 = 7
    tmp_16 = ne got, tmp_15
    br tmp_16 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_16
    panic(12)

L_ELSE_5:
    !tmp_16
    jmp L_MERGE_6

L_MERGE_6:
    !got
    return

