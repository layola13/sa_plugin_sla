@import "sa_std/string.sa"
@rosetta_243_mix(left: i64, right: i64) -> i64:
L_ENTRY:
    tmp_0 = mul left, right
    product = tmp_0
    tmp_1 = add product, left
    tmp_2 = sub tmp_1, right
    result = tmp_2
    !product
    !right
    !left
    return result

@rosetta_243_value() -> i64:
L_ENTRY:
    tmp_3 = 9
    tmp_4 = 20
    tmp_5 = call @rosetta_243_mix(tmp_3, tmp_4)
    !tmp_3
    !tmp_4
    result = tmp_5
    return result

@main() -> i64:
L_ENTRY:
    tmp_6 = call @rosetta_243_value()
    result = tmp_6
