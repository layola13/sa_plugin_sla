@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

trait Draw {
    fn draw(&self) -> i32;
}

struct Button {
    id: i32,
}

impl Draw for Button {
    fn draw(&self) -> i32 {
        self.id
    }
}

fn render(&item: dyn Draw) -> i32 {
    item.draw()
}

fn main() -> i32 {
    let button = Button { id: 77 };
    let result = render(&button);
    println("{}", result);
    return 0;
}

@test "rosetta 007 trait vtable"() {
    if main() != 0 {
        panic(7);
    };
}
