@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/result.sa"
@import "sa_std/sync/mpsc.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_channel_pingpong_value = vtable { call = @sla__channel_pingpong_value }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__channel_pingpong_value() -> i32:
L_ENTRY:
    tx = 0
    EXPAND MPSC_NEW rx, 1
    tmp_0 = 8
    tmp_1 = add tmp_0, 0
    EXPAND MPSC_SEND rx, tmp_1
    !tmp_0
    EXPAND RESULT_NEW_OK tmp_2, 0
    EXPAND RESULT_UNWRAP tmp_3, tmp_2
    !tmp_2
    !tmp_3
    EXPAND MPSC_RECV tmp_4, rx
    EXPAND RESULT_NEW_OK tmp_5, tmp_4
    !tmp_4
    EXPAND RESULT_UNWRAP tmp_6, tmp_5
    !tmp_5
    value = tmp_6
    EXPAND MPSC_FREE rx
    return value

@main() -> i32:
L_ENTRY:
    tmp_7 = call @sla__channel_pingpong_value()
    value = tmp_7
    tmp_8 = call @sa_fmt_u64(value, 10)
    tmp_9 = call @sa_fmt_buffer_data(tmp_8)
    tmp_10 = call @sa_fmt_buffer_len(tmp_8)
    tmp_11 = tmp_9
    call @sa_print_bytes(&tmp_11, tmp_10)
    call @sa_fmt_buffer_free(^tmp_8)
    !tmp_11
    !tmp_10
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_12 = 0
    !value
    return tmp_12

@test "rosetta 062 62_channel_pingpong"():
L_TEST_ENTRY_0:
    tmp_13 = call @sla__channel_pingpong_value()
    got = tmp_13
    tmp_14 = 8
    tmp_15 = ne got, tmp_14
    !tmp_14
    br tmp_15 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_15
    panic(62)

L_ELSE_2:
    !tmp_15
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

