@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn main() -> i32 {
    let total: i32 = [1, 2, 3, 4, 5].into_iter().filter(|x: i32| x % 2 == 0).sum();
    println("{}", total);
    return 0;
}

@test "rosetta 034 iterator filter"() {
    let total: i32 = [1, 2, 3, 4, 5].into_iter().filter(|x: i32| x % 2 == 0).sum();
    if total != 6 {
        panic(34);
    };
}
