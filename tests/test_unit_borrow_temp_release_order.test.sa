@test "rc refcell box field borrow releases nested temporaries"():
L_TEST_ENTRY_43:
    holder = alloc 8
    tmp_137 = alloc 8
    tmp_138 = 53
    store tmp_137+0, tmp_138 as i64
    !tmp_138
    EXPAND BOX_NEW tmp_139, tmp_137
    !tmp_137
    EXPAND REFCELL_U64_NEW tmp_140, tmp_139
    !tmp_139
