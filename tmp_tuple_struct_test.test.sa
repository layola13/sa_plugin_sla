@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@score(&self: ptr) -> i32:
L_ENTRY:
    tmp_0 = load self+0 as i32
    tmp_1 = 1
    tmp_2 = add tmp_0, tmp_1
    !tmp_0
    !tmp_1
    return tmp_2

@main() -> i32:
L_ENTRY:
    tmp_3 = alloc 4
    tmp_4 = 4
    store tmp_3+0, tmp_4 as i32
    !tmp_4
    value = tmp_3
    tmp_5 = call @score(&value)
    tmp_6 = call @sa_fmt_u64(tmp_5, 10)
    tmp_7 = call @sa_fmt_buffer_data(tmp_6)
    tmp_8 = call @sa_fmt_buffer_len(tmp_6)
    tmp_9 = tmp_7
    call @sa_print_bytes(&tmp_9, tmp_8)
    call @sa_fmt_buffer_free(^tmp_6)
    !tmp_9
    !tmp_8
    !tmp_5
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_10 = 0
    !value
    return tmp_10

@test "tuple struct smoke"():
L_TEST_ENTRY_0:
    tmp_11 = alloc 4
    tmp_12 = 4
    store tmp_11+0, tmp_12 as i32
    !tmp_12
    value = tmp_11
    tmp_13 = call @score(&value)
    result = tmp_13
    tmp_14 = 5
    tmp_15 = ne result, tmp_14
    !tmp_14
    br tmp_15 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_15
    panic(901)

L_ELSE_2:
    !tmp_15
    jmp L_MERGE_3

L_MERGE_3:
    !value
    !result
    return

