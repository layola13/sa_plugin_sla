@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

const VALUES: [i32; 3] = [1, 2, 3];

fn main() -> i32 {
    let sum: i32 = VALUES.iter().sum();
    println("{}", sum);
    return 0;
};

@test "rosetta 029 const data"() {
    let sum: i32 = VALUES.iter().sum();
    if sum != 6 {
        panic(29);
    };
};
