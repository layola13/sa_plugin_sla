@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/ptr.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_raw_pointer_third_value = vtable { call = @sla__raw_pointer_third_value }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__raw_pointer_third_value() -> i32:
L_ENTRY:
    data = alloc 16
    tmp_0 = 1
    store data+0, tmp_0 as i32
    tmp_1 = 2
    store data+4, tmp_1 as i32
    tmp_2 = 3
    store data+8, tmp_2 as i32
    tmp_3 = 4
    store data+12, tmp_3 as i32
    tmp_5 = 2
    tmp_6 = mul tmp_5, 4
    tmp_7 = ptr_add data, tmp_6
    !tmp_6
    !tmp_5
    tmp_8 = load tmp_7+0 as i32
    tmp_4 = tmp_8
    third = tmp_4
    !data
    return third

@main() -> i32:
L_ENTRY:
    data = alloc 16
    tmp_9 = 1
    store data+0, tmp_9 as i32
    tmp_10 = 2
    store data+4, tmp_10 as i32
    tmp_11 = 3
    store data+8, tmp_11 as i32
    tmp_12 = 4
    store data+12, tmp_12 as i32
    tmp_14 = 2
    tmp_15 = mul tmp_14, 4
    tmp_16 = ptr_add data, tmp_15
    !tmp_15
    !tmp_14
    tmp_17 = load tmp_16+0 as i32
    tmp_13 = tmp_17
    third = tmp_13
    tmp_18 = call @sa_fmt_u64(third, 10)
    tmp_19 = call @sa_fmt_buffer_data(tmp_18)
    tmp_20 = call @sa_fmt_buffer_len(tmp_18)
    tmp_21 = tmp_19
    call @sa_print_bytes(&tmp_21, tmp_20)
    call @sa_fmt_buffer_free(^tmp_18)
    !tmp_21
    !tmp_20
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !data
    return third

@test "rosetta 112 112_raw_pointer_arithmetic"():
L_TEST_ENTRY_0:
    tmp_22 = call @sla__raw_pointer_third_value()
    got = tmp_22
    tmp_23 = 3
    tmp_24 = ne got, tmp_23
    !tmp_23
    br tmp_24 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_24
    panic(112)

L_ELSE_2:
    !tmp_24
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

