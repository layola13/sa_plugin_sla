@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn pkg_local_dependency_count() -> i32 {
    let path_dependency = 1;
    return path_dependency;
}

fn main() -> i32 { let result = pkg_local_dependency_count(); println("{}", result); return result; }
@test "rosetta 202 pkg dependencies local"() { let got = pkg_local_dependency_count(); if got != 1 { panic(202); }; }
