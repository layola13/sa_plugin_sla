struct Boxed {
    value: i32,
}

fn step(input: Boxed) -> Boxed {
    return Boxed { value: input.value + 1 };
}

fn run_n(boxed: Boxed, n: i32) -> Boxed {
    let i: i32 = 0;
    while i < n {
        let next = step(boxed);
        boxed = next;
        i = i + 1;
    }
    return boxed;
}

@test "assign moved local cleanup"() {
    let out = run_n(Boxed { value: 1 }, 3);
    if out.value != 4 { panic(1400); };
}
