@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/array.sa"
@import "sa_std/core/iter.sa"
@rosetta_014_value() -> i64:
L_ENTRY:
    values = alloc 32
    tmp_0 = 1
    store values+0, tmp_0 as i64
    tmp_1 = 2
    store values+8, tmp_1 as i64
    tmp_2 = 3
    store values+16, tmp_2 as i64
    tmp_3 = 4
    store values+24, tmp_3 as i64
    tmp_4 = 8
    tmp_5 = ptr_add values, tmp_4
    tmp_6 = alloc Slice_SIZE
    EXPAND ARRAY_AS_SLICE_U64 tmp_6, tmp_5, 2
    EXPAND ITER_FROM_SLICE tmp_7, tmp_6
    EXPAND ITER_SUM_U64 tmp_8, tmp_7
    !tmp_7
    !tmp_6
    window_sum = tmp_8
    !values
    return window_sum

@main() -> i64:
L_ENTRY:
    tmp_9 = call @rosetta_014_value()
    result = tmp_9
    tmp_10 = 5
    tmp_11 = ne result, tmp_10
    br tmp_11 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_11
    panic(14)

L_ELSE_1:
    !tmp_11
    jmp L_MERGE_2

L_MERGE_2:
    tmp_14 = call @sa_fmt_i64(result, 10)
    tmp_15 = call @sa_fmt_buffer_data(tmp_14)
    tmp_16 = call @sa_fmt_buffer_len(tmp_14)
    tmp_17 = tmp_15
    call @sa_print_bytes(&tmp_17, tmp_16)
    call @sa_fmt_buffer_free(^tmp_14)
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_18 = 0
    !result
    return tmp_18

@test "rosetta 014 slice window"():
L_TEST_ENTRY_3:
    tmp_19 = call @rosetta_014_value()
    got = tmp_19
    tmp_20 = 5
    tmp_21 = ne got, tmp_20
    br tmp_21 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_21
    panic(14)

L_ELSE_5:
    !tmp_21
    jmp L_MERGE_6

L_MERGE_6:
    !got
    return

