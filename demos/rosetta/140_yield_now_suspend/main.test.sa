@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/future.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_yield_once = vtable { call = @sla__yield_once }
@const SLA_FNPTR_VT_yield_now_value = vtable { call = @sla__yield_now_value }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__yield_once() -> ptr:
L_ENTRY:
    tmp_0 = 2
    EXPAND FUTURE_READY_STATE_NEW tmp_1, tmp_0
    return tmp_1

@sla__yield_now_value() -> i32:
L_ENTRY:
    tmp_2 = call @sla__yield_once()
    EXPAND FUTURE_READY_STATE_INTO_INNER tmp_3, tmp_2
    !tmp_2
    yielded = tmp_3
    return yielded

@main() -> i32:
L_ENTRY:
    tmp_4 = call @sla__yield_now_value()
    result = tmp_4
    tmp_5 = call @sa_fmt_u64(result, 10)
    tmp_6 = call @sa_fmt_buffer_data(tmp_5)
    tmp_7 = call @sa_fmt_buffer_len(tmp_5)
    tmp_8 = tmp_6
    call @sa_print_bytes(&tmp_8, tmp_7)
    call @sa_fmt_buffer_free(^tmp_5)
    !tmp_8
    !tmp_7
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 140 140_yield_now_suspend"():
L_TEST_ENTRY_0:
    tmp_9 = call @sla__yield_now_value()
    got = tmp_9
    tmp_10 = 2
    tmp_11 = ne got, tmp_10
    !tmp_10
    br tmp_11 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_11
    panic(140)

L_ELSE_2:
    !tmp_11
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

