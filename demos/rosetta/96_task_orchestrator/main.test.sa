@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_ready_score = vtable { call = @sla__ready_score }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__ready_score(task: ptr) -> i32:
L_ENTRY:
    tmp_0 = load task+0 as u8
    tmp_1 = 1
    tmp_2 = eq tmp_0, tmp_1
    !tmp_0
    !tmp_1
    br tmp_2 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_2
    tmp_3 = load task+1 as i32
    !task
    return tmp_3

L_ELSE_1:
    !tmp_2
    tmp_4 = 0
    !task
    return tmp_4


@main() -> i32:
L_ENTRY:
    task = alloc 5
    tmp_6 = 1
    store task+0, tmp_6 as u8
    tmp_7 = 7
    store task+1, tmp_7 as i32
    tmp_8 = call @sla__ready_score(task)
    result = tmp_8
    tmp_9 = call @sa_fmt_u64(result, 10)
    tmp_10 = call @sa_fmt_buffer_data(tmp_9)
    tmp_11 = call @sa_fmt_buffer_len(tmp_9)
    tmp_12 = tmp_10
    call @sa_print_bytes(&tmp_12, tmp_11)
    call @sa_fmt_buffer_free(^tmp_9)
    !tmp_12
    !tmp_11
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !task
    return result

@test "rosetta 096 96_task_orchestrator"():
L_TEST_ENTRY_3:
    task = alloc 5
    tmp_13 = 1
    store task+0, tmp_13 as u8
    tmp_14 = 7
    store task+1, tmp_14 as i32
    tmp_15 = call @sla__ready_score(task)
    got = tmp_15
    tmp_16 = 7
    tmp_17 = ne got, tmp_16
    !tmp_16
    br tmp_17 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_17
    panic(96)

L_ELSE_5:
    !tmp_17
    jmp L_MERGE_6

L_MERGE_6:
    !task
    !got
    return

