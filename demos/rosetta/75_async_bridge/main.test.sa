@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/future.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_compute = vtable { call = @sla__compute }
@const SLA_FNPTR_VT_async_bridge_value = vtable { call = @sla__async_bridge_value }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__compute() -> ptr:
L_ENTRY:
    tmp_0 = 2
    left = tmp_0
    tmp_1 = 3
    right = tmp_1
    tmp_2 = add left, right
    EXPAND FUTURE_READY_STATE_NEW tmp_3, tmp_2
    return tmp_3

@sla__async_bridge_value() -> i32:
L_ENTRY:
    tmp_4 = call @sla__compute()
    EXPAND FUTURE_READY_STATE_INTO_INNER tmp_5, tmp_4
    !tmp_4
    return tmp_5

@main() -> i32:
L_ENTRY:
    tmp_6 = call @sla__async_bridge_value()
    result = tmp_6
    tmp_7 = call @sa_fmt_u64(result, 10)
    tmp_8 = call @sa_fmt_buffer_data(tmp_7)
    tmp_9 = call @sa_fmt_buffer_len(tmp_7)
    tmp_10 = tmp_8
    call @sa_print_bytes(&tmp_10, tmp_9)
    call @sa_fmt_buffer_free(^tmp_7)
    !tmp_10
    !tmp_9
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 075 75_async_bridge"():
L_TEST_ENTRY_0:
    tmp_11 = call @sla__async_bridge_value()
    got = tmp_11
    tmp_12 = 5
    tmp_13 = ne got, tmp_12
    !tmp_12
    br tmp_13 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_13
    panic(75)

L_ELSE_2:
    !tmp_13
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

