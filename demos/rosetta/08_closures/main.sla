// Sla companion for SA rosetta demo 008 Closures.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_008_value() -> int {
    let seed = 11;
    let shifted = seed + 8;
    let scaled = shifted * 10;
    let result = scaled - 13;
    return result;
}

fn main() -> int {
    let result = rosetta_008_value();
    return result;
};

@test "rosetta 008 08_closures"() {
    let got = rosetta_008_value();
    if got != 177 {
        panic(8);
    };
};
