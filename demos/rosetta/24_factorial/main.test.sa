@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@factorial(n: i32) -> i32:
L_ENTRY:
    tmp_0 = 1
    tmp_1 = sle n, tmp_0
    !tmp_0
    br tmp_1 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_1
    tmp_3 = 1
    tmp_2 = tmp_3
    jmp L_MERGE_2

L_ELSE_1:
    !tmp_1
    tmp_4 = 1
    tmp_5 = sub n, tmp_4
    !tmp_4
    tmp_6 = call @factorial(tmp_5)
    !tmp_5
    tmp_7 = mul n, tmp_6
    !tmp_6
    tmp_2 = tmp_7
    jmp L_MERGE_2

L_MERGE_2:
    return tmp_2

@main() -> i32:
L_ENTRY:
    tmp_8 = 5
    tmp_9 = call @factorial(tmp_8)
    !tmp_8
    value = tmp_9
    tmp_10 = call @sa_fmt_u64(value, 10)
    tmp_11 = call @sa_fmt_buffer_data(tmp_10)
    tmp_12 = call @sa_fmt_buffer_len(tmp_10)
    tmp_13 = tmp_11
    call @sa_print_bytes(&tmp_13, tmp_12)
    call @sa_fmt_buffer_free(^tmp_10)
    !tmp_13
    !tmp_12
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_14 = 0
    !value
    return tmp_14

@test "rosetta 024 factorial"():
L_TEST_ENTRY_3:
    tmp_15 = 5
    tmp_16 = call @factorial(tmp_15)
    !tmp_15
    value = tmp_16
    tmp_17 = 120
    tmp_18 = ne value, tmp_17
    !tmp_17
    br tmp_18 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_18
    panic(24)

L_ELSE_5:
    !tmp_18
    jmp L_MERGE_6

L_MERGE_6:
    !value
    return

