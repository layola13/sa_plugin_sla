@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn ffi_opaque_handle_transfers() -> i32 { let handle_round_trip = 1; return handle_round_trip; }
fn main() -> i32 { let result = ffi_opaque_handle_transfers(); println("{}", result); return result; }
@test "rosetta 289 ffi opaque handle passing"() { let got = ffi_opaque_handle_transfers(); if got != 1 { panic(289); }; }
