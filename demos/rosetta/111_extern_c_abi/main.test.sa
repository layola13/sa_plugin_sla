@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_add_pair = vtable { call = @add_pair }
@const SLA_FNPTR_VT_extern_c_add_pair_value = vtable { call = @sla__extern_c_add_pair_value }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@add_pair(a: i32, b: i32) -> i32:
L_ENTRY:
    tmp_0 = add a, b
    return tmp_0

@sla__extern_c_add_pair_value() -> i32:
L_ENTRY:
    tmp_2 = 11
    tmp_3 = 12
    tmp_4 = call @add_pair(tmp_2, tmp_3)
    !tmp_2
    !tmp_3
    tmp_1 = tmp_4
    result = tmp_1
    return result

@main() -> i32:
L_ENTRY:
    tmp_5 = call @sla__extern_c_add_pair_value()
    result = tmp_5
    tmp_6 = call @sa_fmt_u64(result, 10)
    tmp_7 = call @sa_fmt_buffer_data(tmp_6)
    tmp_8 = call @sa_fmt_buffer_len(tmp_6)
    tmp_9 = tmp_7
    call @sa_print_bytes(&tmp_9, tmp_8)
    call @sa_fmt_buffer_free(^tmp_6)
    !tmp_9
    !tmp_8
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 111 111_extern_c_abi"():
L_TEST_ENTRY_0:
    tmp_10 = call @sla__extern_c_add_pair_value()
    got = tmp_10
    tmp_11 = 23
    tmp_12 = ne got, tmp_11
    !tmp_11
    br tmp_12 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_12
    panic(111)

L_ELSE_2:
    !tmp_12
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

