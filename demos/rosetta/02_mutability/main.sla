// Sla companion for SA rosetta demo 002 Mutability.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_002_value() -> int {
    let total = 0;
    for i in 1..5 {
        total = total + i;
    }
    let result = total + 7;
    return result;
}

fn main() -> int {
    let result = rosetta_002_value();
    return result;
};

@test "rosetta 002 02_mutability"() {
    let got = rosetta_002_value();
    if got != 17 {
        panic(2);
    };
};
