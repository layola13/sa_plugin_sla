@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
fn dynamic_lib_close_status() -> i32 { let closed_status = 1; return closed_status; }
fn main() -> i32 { let result = dynamic_lib_close_status(); println("{}", result); return result; }
@test "rosetta 185 185_dynamic_lib_dlopen"() { let got = dynamic_lib_close_status(); if got != 1 { panic(185); }; }
