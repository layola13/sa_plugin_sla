@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn process_unit() -> i32 { return 42; }
fn zero_sized_process_result() -> i32 { return process_unit(); }
fn main() -> i32 { let result = zero_sized_process_result(); println("{}", result); return result; }
@test "rosetta 142 142_zero_sized_types"() { let got = zero_sized_process_result(); if got != 42 { panic(142); }; }
