// Sla companion for SA rosetta demo 035 Iterator Fold.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_035_mix(left: int, right: int) -> int {
    let product = left * right;
    let result = product + left - right;
    return result;
};

fn rosetta_035_value() -> int {
    let result = rosetta_035_mix(6, 27);
    return result;
};

fn main() -> int {
    let result = rosetta_035_value();
    return result;
};

@test "rosetta 035 35_iterator_fold"() {
    let got = rosetta_035_value();
    if got != 141 {
        panic(35);
    }