@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/result.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/result.sa"
@const SLA_FNPTR_VT_flatten_result = vtable { call = @sla__flatten_result }
@const SLA_FNPTR_VT_result_flattened_value = vtable { call = @sla__result_flattened_value }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__flatten_result(value: ptr) -> ptr:
L_ENTRY:
    jmp L_OPTION_MATCH_CHECK_0_2

L_OPTION_MATCH_CHECK_0_2:
    EXPAND RESULT_IS_OK tmp_0, value
    br tmp_0 -> L_OPTION_MATCH_CASE_0_2, L_OPTION_MATCH_CHECK_1_2

L_OPTION_MATCH_CASE_0_2:
    EXPAND RESULT_GET_OK inner, value
    !tmp_0
    !value
    return inner

L_OPTION_MATCH_CHECK_1_2:
    !tmp_0
    EXPAND RESULT_IS_OK tmp_1, value
    br tmp_1 -> L_OPTION_MATCH_NO_MATCH_1, L_OPTION_MATCH_CASE_1_2

L_OPTION_MATCH_CASE_1_2:
    EXPAND RESULT_GET_ERR err, value
    !tmp_1
    EXPAND RESULT_NEW_ERR tmp_2, err
    !value
    return tmp_2

L_OPTION_MATCH_NO_MATCH_1:
    !tmp_1
    panic(1)


@sla__result_flattened_value() -> i32:
L_ENTRY:
    tmp_4 = 2
    EXPAND RESULT_NEW_OK tmp_5, tmp_4
    !tmp_4
    EXPAND RESULT_NEW_OK tmp_6, tmp_5
    !tmp_5
    nested = tmp_6
    tmp_7 = call @sla__flatten_result(nested)
    tmp_8 = 0
    tmp_9 = 1
    tmp_10 = sub tmp_8, tmp_9
    !tmp_8
    !tmp_9
    EXPAND RESULT_UNWRAP_OR tmp_11, tmp_7, tmp_10
    !tmp_7
    !tmp_10
    return tmp_11

@main() -> i32:
L_ENTRY:
    tmp_12 = call @sla__result_flattened_value()
    result = tmp_12
    tmp_13 = call @sa_fmt_u64(result, 10)
    tmp_14 = call @sa_fmt_buffer_data(tmp_13)
    tmp_15 = call @sa_fmt_buffer_len(tmp_13)
    tmp_16 = tmp_14
    call @sa_print_bytes(&tmp_16, tmp_15)
    call @sa_fmt_buffer_free(^tmp_13)
    !tmp_16
    !tmp_15
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 176 176_result_flattening"():
L_TEST_ENTRY_3:
    tmp_17 = call @sla__result_flattened_value()
    got = tmp_17
    tmp_18 = 2
    tmp_19 = ne got, tmp_18
    !tmp_18
    br tmp_19 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_19
    panic(176)

L_ELSE_5:
    !tmp_19
    jmp L_MERGE_6

L_MERGE_6:
    !got
    return

