    !tmp_258
    tmp_259 = alloc 8
    tmp_260 = 7
    store tmp_259+0, tmp_260 as i64
    !tmp_260
    EXPAND REFCELL_U64_NEW tmp_261, tmp_259
    !tmp_259
    EXPAND ARC_NEW tmp_262, tmp_261
    !tmp_261
    EXPAND VEC_PUSH items, tmp_262, 8
    !tmp_262
    holder = alloc 8
    store holder+0, items as ptr
    tmp_263 = 0
    total = tmp_263
    tmp_264 = 0
    i = tmp_264
    jmp L_WHILE_HEAD_72

L_WHILE_HEAD_72:
    tmp_265 = 4
    tmp_266 = slt i, tmp_265
    !tmp_265
    br tmp_266 -> L_WHILE_BODY_73, L_WHILE_COND_FALSE_74

L_WHILE_BODY_73:
