// Sla companion for SA rosetta demo 106 Cell Interior Mut.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_106_value() -> int {
    let total = 0;
    for i in 1..5 {
        total = total + i;
    }    let result = total + 19;
    return result;
};

fn main() -> int {
    let result = rosetta_106_value();
    return result;
};

@test "rosetta 106 106_cell_interior_mut"() {
