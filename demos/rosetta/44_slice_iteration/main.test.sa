@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/slice.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_sum = vtable { call = @sla__sum }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__sum(values: ptr) -> i32:
L_ENTRY:
    tmp_0 = values
    values = stack_alloc Slice_SIZE
    tmp_1 = load tmp_0+0 as ptr
    tmp_2 = load tmp_0+8 as u64
    store values+0, tmp_1 as ptr
    store values+8, tmp_2 as u64
    !tmp_1
    !tmp_2
    !tmp_0
    tmp_3 = load values+Slice_ptr as ptr
    tmp_4 = load values+Slice_len as u64
    tmp_5 = stack_alloc 4
    store tmp_5+0, 0 as i32
    tmp_6 = stack_alloc 8
    store tmp_6+0, 0 as u64
    jmp L_SLICE_SUM_HEAD_0

L_SLICE_SUM_HEAD_0:
    tmp_7 = load tmp_6+0 as u64
    tmp_8 = eq tmp_7, tmp_4
    br tmp_8 -> L_SLICE_SUM_DONE_2, L_SLICE_SUM_BODY_1

L_SLICE_SUM_BODY_1:
    !tmp_8
    tmp_9 = mul tmp_7, 4
    tmp_10 = ptr_add tmp_3, tmp_9
    tmp_11 = load tmp_10+0 as i32
    tmp_12 = load tmp_5+0 as i32
    tmp_13 = add tmp_12, tmp_11
    store tmp_5+0, tmp_13 as i32
    tmp_14 = add tmp_7, 1
    store tmp_6+0, tmp_14 as u64
    !tmp_9
    !tmp_10
    !tmp_11
    !tmp_12
    !tmp_13
    !tmp_14
    !tmp_7
    jmp L_SLICE_SUM_HEAD_0

L_SLICE_SUM_DONE_2:
    !tmp_8
    !tmp_7
    tmp_15 = load tmp_5+0 as i32
    !tmp_3
    !tmp_4
    return tmp_15

@main() -> i32:
L_ENTRY:
    values = alloc 16
    tmp_16 = 1
    store values+0, tmp_16 as i32
    tmp_17 = 2
    store values+4, tmp_17 as i32
    tmp_18 = 3
    store values+8, tmp_18 as i32
    tmp_19 = 4
    store values+12, tmp_19 as i32
    tmp_21 = 4
    tmp_20 = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW tmp_20, values, tmp_21
    !tmp_21
    tmp_22 = call @sla__sum(tmp_20)
    tmp_23 = call @sa_fmt_u64(tmp_22, 10)
    tmp_24 = call @sa_fmt_buffer_data(tmp_23)
    tmp_25 = call @sa_fmt_buffer_len(tmp_23)
    tmp_26 = tmp_24
    call @sa_print_bytes(&tmp_26, tmp_25)
    call @sa_fmt_buffer_free(^tmp_23)
    !tmp_26
    !tmp_25
    !tmp_22
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_27 = 0
    !values
    return tmp_27

@test "rosetta 044 slice iteration"():
L_TEST_ENTRY_3:
    values = alloc 16
    tmp_28 = 1
    store values+0, tmp_28 as i32
    tmp_29 = 2
    store values+4, tmp_29 as i32
    tmp_30 = 3
    store values+8, tmp_30 as i32
    tmp_31 = 4
    store values+12, tmp_31 as i32
    tmp_33 = 4
    tmp_32 = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW tmp_32, values, tmp_33
    !tmp_33
    tmp_34 = call @sla__sum(tmp_32)
    total = tmp_34
    tmp_35 = 10
    tmp_36 = ne total, tmp_35
    !tmp_35
    br tmp_36 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_36
    panic(44)

L_ELSE_5:
    !tmp_36
    jmp L_MERGE_6

L_MERGE_6:
    !values
    !total
    return

