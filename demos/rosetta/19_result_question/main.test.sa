@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@triple_ok(x: i32) -> ptr:
L_ENTRY:
    tmp_0 = alloc 20
    tmp_1 = 0
    store tmp_0+0, tmp_1 as u8
    tmp_2 = 0
    store tmp_0+8, tmp_2 as i64
    tmp_3 = 3
    tmp_4 = mul x, tmp_3
    !tmp_3
    store tmp_0+16, tmp_4 as i32
    !x
    return tmp_0

@compute() -> ptr:
L_ENTRY:
    tmp_5 = 7
    tmp_6 = call @triple_ok(tmp_5)
    !tmp_5
    tmp_7 = load tmp_6+0 as u8
    br tmp_7 -> L_TRY_ERR_1, L_TRY_OK_0

L_TRY_ERR_1:
    !tmp_7
    return tmp_6

L_TRY_OK_0:
    !tmp_7
    tmp_8 = load tmp_6+16 as i32
    !tmp_6
    value = tmp_8
    tmp_9 = alloc 20
    tmp_10 = 0
    store tmp_9+0, tmp_10 as u8
    tmp_11 = 0
    store tmp_9+8, tmp_11 as i64
    store tmp_9+16, value as i32
    !value
    return tmp_9

@main() -> i32:
L_ENTRY:
    tmp_12 = call @compute()
    computed = tmp_12
    tmp_13 = load computed+0 as u8
    br tmp_13 -> L_THEN_2, L_ELSE_3

L_THEN_2:
    !tmp_13
    tmp_15 = 0
    tmp_16 = 1
    tmp_17 = sub tmp_15, tmp_16
    !tmp_15
    !tmp_16
    tmp_14 = tmp_17
    jmp L_MERGE_4

L_ELSE_3:
    !tmp_13
    tmp_18 = load computed+16 as i32
    tmp_14 = tmp_18
    jmp L_MERGE_4

L_MERGE_4:
    result = tmp_14
    tmp_19 = call @sa_fmt_u64(result, 10)
    tmp_20 = call @sa_fmt_buffer_data(tmp_19)
    tmp_21 = call @sa_fmt_buffer_len(tmp_19)
    tmp_22 = tmp_20
    call @sa_print_bytes(&tmp_22, tmp_21)
    call @sa_fmt_buffer_free(^tmp_19)
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_23 = 0
    !result
    !computed
    return tmp_23

@test "rosetta 019 result question"():
L_TEST_ENTRY_5:
    tmp_24 = call @compute()
    computed = tmp_24
    tmp_25 = load computed+0 as u8
    br tmp_25 -> L_THEN_6, L_ELSE_7

L_THEN_6:
    !tmp_25
    tmp_27 = 0
    tmp_28 = 1
    tmp_29 = sub tmp_27, tmp_28
    !tmp_27
    !tmp_28
    tmp_26 = tmp_29
    jmp L_MERGE_8

L_ELSE_7:
    !tmp_25
    tmp_30 = load computed+16 as i32
    tmp_26 = tmp_30
    jmp L_MERGE_8

L_MERGE_8:
    result = tmp_26
    tmp_31 = 21
    tmp_32 = ne result, tmp_31
    !tmp_31
    br tmp_32 -> L_THEN_9, L_ELSE_10

L_THEN_9:
    !tmp_32
    panic(19)

L_ELSE_10:
    !tmp_32
    jmp L_MERGE_11

L_MERGE_11:
    !result
    !computed
    return

