@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
fn protobuf_varint_value() -> u32 { let decoded_varint: u32 = 6; return decoded_varint; }
fn main() -> i32 { let result = protobuf_varint_value(); println("{}", result); return 0; }
