@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_visible_weight = vtable { call = @sla__visible_weight }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__visible_weight(nodes: ptr) -> i32:
L_ENTRY:
    node_slot = stack_alloc 8
    tmp_0 = 0
    total = tmp_0
    store node_slot+0, 0 as i64
    jmp L_LOOP_HEAD_0

L_LOOP_HEAD_0:
    tmp_1 = load node_slot+0 as i64
    tmp_2 = slt tmp_1, 3
    br tmp_2 -> L_LOOP_BODY_1, L_LOOP_COND_FALSE_3

L_LOOP_BODY_1:
    !tmp_2
    tmp_3 = mul tmp_1, 8
    tmp_4 = ptr_add nodes, tmp_3
    node = load tmp_4+0 as ptr
    !tmp_3
    !tmp_4
    tmp_5 = load node+0 as u8
    tmp_6 = 1
    tmp_7 = eq tmp_5, tmp_6
    !tmp_5
    !tmp_6
    br tmp_7 -> L_THEN_5, L_ELSE_6

L_THEN_5:
    !tmp_7
    tmp_8 = load node+1 as i32
    weight = tmp_8
    tmp_9 = add total, weight
    !total
    total = tmp_9
    !weight
    jmp L_MERGE_7

L_ELSE_6:
    !tmp_7
    jmp L_MERGE_7

L_MERGE_7:
L_LOOP_CONTINUE_2:
    tmp_11 = add tmp_1, 1
    store node_slot+0, tmp_11 as i64
    !tmp_11
    !tmp_1
    !node
    jmp L_LOOP_HEAD_0

L_LOOP_COND_FALSE_3:
    !tmp_2
    !tmp_1
    jmp L_LOOP_EXIT_4

L_LOOP_EXIT_4:
    !nodes
    return total

@main() -> i32:
L_ENTRY:
    nodes = alloc 24
    tmp_12 = alloc 5
    tmp_13 = 1
    store tmp_12+0, tmp_13 as u8
    tmp_14 = 4
    store tmp_12+1, tmp_14 as i32
    store nodes+0, tmp_12 as ptr
    tmp_15 = alloc 5
    tmp_16 = 0
    store tmp_15+0, tmp_16 as u8
    tmp_17 = 5
    store tmp_15+1, tmp_17 as i32
    store nodes+8, tmp_15 as ptr
    tmp_18 = alloc 5
    tmp_19 = 1
    store tmp_18+0, tmp_19 as u8
    tmp_20 = 6
    store tmp_18+1, tmp_20 as i32
    store nodes+16, tmp_18 as ptr
    tmp_21 = call @sla__visible_weight(nodes)
    total = tmp_21
    tmp_22 = call @sa_fmt_u64(total, 10)
    tmp_23 = call @sa_fmt_buffer_data(tmp_22)
    tmp_24 = call @sa_fmt_buffer_len(tmp_22)
    tmp_25 = tmp_23
    call @sa_print_bytes(&tmp_25, tmp_24)
    call @sa_fmt_buffer_free(^tmp_22)
    !tmp_25
    !tmp_24
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !nodes
    return total

@test "rosetta 073 73_scene_nodes"():
L_TEST_ENTRY_8:
    tmp_26 = call @main()
    tmp_27 = 10
    tmp_28 = ne tmp_26, tmp_27
    !tmp_26
    !tmp_27
    br tmp_28 -> L_THEN_9, L_ELSE_10

L_THEN_9:
    !tmp_28
    panic(73)

L_ELSE_10:
    !tmp_28
    jmp L_MERGE_11

L_MERGE_11:
    return

