@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

mod math {
    pub fn double(x: i32) -> i32 {
        x * 2
    }
}

fn main() -> i32 {
    let value = math::double(21);
    println("{}", value);
    return 0;
}

@test "rosetta 041 module imports"() {
    let value = math::double(21);
    if value != 42 {
        panic(41);
    };
}
