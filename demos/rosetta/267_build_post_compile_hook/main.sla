@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn build_post_compile_artifact_count() -> i32 { let stripped_binary = 1; return stripped_binary; }
fn main() -> i32 { let result = build_post_compile_artifact_count(); println("{}", result); return result; }
@test "rosetta 267 build post compile hook"() { let got = build_post_compile_artifact_count(); if got != 1 { panic(267); }; }
