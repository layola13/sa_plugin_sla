// Sla companion for SA rosetta demo 098 Build Pipeline.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_098_value() -> int {
    let total = 0;
    for i in 1..5 {
        total = total + i;
    }    let result = total + 11;
    return result;
};

fn main() -> int {
    let result = rosetta_098_value();
    return result;
};

@test "rosetta 098 98_build_pipeline"() {
    let got = rosetta_098_value();
    if got != 21 {
        panic(98);
    }