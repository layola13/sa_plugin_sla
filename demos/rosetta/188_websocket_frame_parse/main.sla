@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
fn websocket_text_frame_flag() -> i32 { let fin = true; let opcode = 1; let masked = false; let payload_len = 3; if fin == true { if opcode == 1 { if masked == false { if payload_len == 3 { return 1; }; }; }; }; return 0; }
fn main() -> i32 { let fin = true; let opcode = 1; let masked = false; let payload_len = 3; if fin == true { if opcode == 1 { if masked == false { if payload_len == 3 { println("{}", 1); return 1; }; }; }; }; println("{}", 0); return 0; }
@test "rosetta 188 188_websocket_frame_parse"() { let got = websocket_text_frame_flag(); if got != 1 { panic(188); }; }
