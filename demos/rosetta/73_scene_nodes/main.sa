@test "rosetta 073 73_scene_nodes"():
L_TEST_ENTRY_0:
    tmp_37 = call @sla__scene_nodes_sum()
    got = tmp_37
    tmp_38 = 15
    tmp_39 = ne got, tmp_38
    !tmp_38
    br tmp_39 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_39
    panic(73)

L_ELSE_2:
    !tmp_39
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

