@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const VT_Item_A = vtable { a = @sla__Item_a }
@const VT_Item_B = vtable { a = @sla__Item_a, b = @sla__Item_b }
@const SLA_FNPTR_VT_super_trait_total = vtable { call = @sla__super_trait_total }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__Item_a(&self: ptr) -> i32:
L_ENTRY:
    tmp_0 = load self+0 as i32
    return tmp_0

@sla__Item_b(&self: ptr) -> i32:
L_ENTRY:
    tmp_1 = load self+0 as i32
    tmp_2 = 1
    tmp_3 = add tmp_1, tmp_2
    !tmp_1
    !tmp_2
    return tmp_3

@sla__super_trait_total() -> i32:
L_ENTRY:
    item = alloc 4
    tmp_4 = 7
    store item+0, tmp_4 as i32
    tmp_5 = call @sla__Item_a(&item)
    left = tmp_5
    tmp_6 = call @sla__Item_b(&item)
    right = tmp_6
    tmp_7 = add left, right
    !item
    return tmp_7

@main() -> i32:
L_ENTRY:
    item = alloc 4
    tmp_8 = 7
    store item+0, tmp_8 as i32
    tmp_9 = call @sla__Item_a(&item)
    left = tmp_9
    tmp_10 = call @sla__Item_b(&item)
    right = tmp_10
    tmp_11 = add left, right
    result = tmp_11
    tmp_12 = call @sa_fmt_u64(result, 10)
    tmp_13 = call @sa_fmt_buffer_data(tmp_12)
    tmp_14 = call @sa_fmt_buffer_len(tmp_12)
    tmp_15 = tmp_13
    call @sa_print_bytes(&tmp_15, tmp_14)
    call @sa_fmt_buffer_free(^tmp_12)
    !tmp_15
    !tmp_14
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !item
    !right
    !left
    return result

@test "rosetta 110 110_trait_super_vtable"():
L_TEST_ENTRY_0:
    tmp_16 = call @sla__super_trait_total()
    got = tmp_16
    tmp_17 = 15
    tmp_18 = ne got, tmp_17
    !tmp_17
    br tmp_18 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_18
    panic(110)

L_ELSE_2:
    !tmp_18
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

