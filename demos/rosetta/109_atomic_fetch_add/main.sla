fn rosetta_109_value() -> i32 {
    let value = AtomicI32::new(5);
    let old = value.fetch_add(3, Ordering::SeqCst);
    let new = value.load(Ordering::SeqCst);
    return old + new;
}

fn main() -> i32 {
    let value = rosetta_109_value();
    println("{}", value);
    return value;
}

@test "rosetta 109 109_atomic_fetch_add"() {
    let got = rosetta_109_value();
    if got != 13 {
        panic(109);
    }
}
