@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/cell.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/cell.sa"
@const SLA_FNPTR_VT_cell_update_sum = vtable { call = @sla__cell_update_sum }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__cell_update_sum() -> i32:
L_ENTRY:
    tmp_0 = 10
    value = stack_alloc Cell_SIZE
    EXPAND CELL_SET value, tmp_0
    !tmp_0
    EXPAND CELL_GET tmp_1, value
    first = tmp_1
    tmp_2 = 20
    EXPAND CELL_SET value, tmp_2
    !tmp_2
    EXPAND CELL_GET tmp_3, value
    second = tmp_3
    tmp_4 = add first, second
    return tmp_4

@main() -> i32:
L_ENTRY:
    tmp_5 = 10
    value = stack_alloc Cell_SIZE
    EXPAND CELL_SET value, tmp_5
    !tmp_5
    EXPAND CELL_GET tmp_6, value
    first = tmp_6
    tmp_7 = 20
    EXPAND CELL_SET value, tmp_7
    !tmp_7
    EXPAND CELL_GET tmp_8, value
    second = tmp_8
    tmp_9 = add first, second
    result = tmp_9
    tmp_10 = call @sa_fmt_u64(result, 10)
    tmp_11 = call @sa_fmt_buffer_data(tmp_10)
    tmp_12 = call @sa_fmt_buffer_len(tmp_10)
    tmp_13 = tmp_11
    call @sa_print_bytes(&tmp_13, tmp_12)
    call @sa_fmt_buffer_free(^tmp_10)
    !tmp_13
    !tmp_12
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !first
    !second
    return result

@test "rosetta 106 106_cell_interior_mut"():
L_TEST_ENTRY_0:
    tmp_14 = call @sla__cell_update_sum()
    got = tmp_14
    tmp_15 = 30
    tmp_16 = ne got, tmp_15
    !tmp_15
    br tmp_16 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_16
    panic(106)

L_ELSE_2:
    !tmp_16
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

