@import "sa_std/core/box.sa"
@import "sa_std/core/rc.sa"
@import "sa_std/core/trait_object.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/rc.sa"
@import "sa_std/core/box.sa"
@import "sa_std/vec.sa"
@import "sa_std/core/trait_object.sa"
@const VT_TypeA_Identified = vtable { get_id = @sla__TypeA_get_id }
@const VT_TypeB_Identified = vtable { get_id = @sla__TypeB_get_id }
@sla__TypeA_get_id(&self: ptr) -> i64:
L_ENTRY:
    tmp_0 = load self+0 as i64
    return tmp_0

@sla__TypeB_get_id(&self: ptr) -> i64:
L_ENTRY:
    tmp_1 = load self+0 as i64
    tmp_2 = load self+8 as i64
    tmp_3 = add tmp_1, tmp_2
    !tmp_1
    !tmp_2
    return tmp_3

@test "rc dyn trait borrowed dispatch"():
L_TEST_ENTRY_0:
    tmp_4 = alloc 8
    tmp_5 = 42
    store tmp_4+0, tmp_5 as i64
    !tmp_5
    tmp_6 = alloc Dyn_SIZE
    store tmp_6+Dyn_data, tmp_4 as ptr
    store tmp_6+Dyn_vtable, &VT_TypeA_Identified as ptr
    !tmp_4
    EXPAND RC_NEW tmp_7, tmp_6
    !tmp_6
    obj = tmp_7
    EXPAND RC_GET tmp_8, obj
    borrowed = tmp_8
    tmp_9 = load borrowed+Dyn_data as ptr
    tmp_10 = load borrowed+Dyn_vtable as ptr
    tmp_11 = load tmp_10+0 as ptr
    tmp_12 = call_indirect tmp_11(&tmp_9)
    !tmp_11
    !tmp_10
    !tmp_9
    tmp_13 = 42
    tmp_14 = ne tmp_12, tmp_13
    !tmp_12
    !tmp_13
    br tmp_14 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_14
    panic(1)

L_ELSE_2:
    !tmp_14
    jmp L_MERGE_3

L_MERGE_3:
    !borrowed
    !obj
    return

@test "rc dyn trait direct dispatch"():
L_TEST_ENTRY_4:
    tmp_17 = alloc 16
    tmp_18 = 20
    store tmp_17+0, tmp_18 as i64
    !tmp_18
    tmp_19 = 2
    store tmp_17+8, tmp_19 as i64
    !tmp_19
    tmp_20 = alloc Dyn_SIZE
    store tmp_20+Dyn_data, tmp_17 as ptr
    store tmp_20+Dyn_vtable, &VT_TypeB_Identified as ptr
    !tmp_17
    EXPAND RC_NEW tmp_21, tmp_20
    !tmp_20
    obj = tmp_21
    EXPAND RC_GET tmp_22, obj
    tmp_23 = load tmp_22+Dyn_data as ptr
    tmp_24 = load tmp_22+Dyn_vtable as ptr
    tmp_25 = load tmp_24+0 as ptr
    tmp_26 = call_indirect tmp_25(&tmp_23)
    !tmp_25
    !tmp_24
    !tmp_23
    !tmp_22
    tmp_27 = 22
    tmp_28 = ne tmp_26, tmp_27
    !tmp_26
    !tmp_27
    br tmp_28 -> L_THEN_5, L_ELSE_6

L_THEN_5:
    !tmp_28
    panic(2)

L_ELSE_6:
    !tmp_28
    jmp L_MERGE_7

L_MERGE_7:
    !obj
    return

@test "box dyn trait borrowed dispatch"():
L_TEST_ENTRY_8:
    tmp_31 = alloc 8
    tmp_32 = 7
    store tmp_31+0, tmp_32 as i64
    !tmp_32
    EXPAND BOX_NEW tmp_33, tmp_31
    !tmp_31
    tmp_34 = load tmp_33+Box_value as ptr
    tmp_35 = alloc Dyn_SIZE
    store tmp_35+Dyn_data, tmp_34 as ptr
    store tmp_35+Dyn_vtable, &VT_TypeA_Identified as ptr
    !tmp_34
    !tmp_33
    obj = tmp_35
    tmp_37 = load obj+Dyn_data as ptr
    tmp_38 = load obj+Dyn_vtable as ptr
    tmp_39 = alloc Dyn_SIZE
    store tmp_39+Dyn_data, tmp_37 as ptr
    store tmp_39+Dyn_vtable, tmp_38 as ptr
    !tmp_37
    !tmp_38
    borrowed = tmp_39
    tmp_40 = load borrowed+Dyn_data as ptr
    tmp_41 = load borrowed+Dyn_vtable as ptr
    tmp_42 = load tmp_41+0 as ptr
    tmp_43 = call_indirect tmp_42(&tmp_40)
    !tmp_42
    !tmp_41
    !tmp_40
    tmp_44 = 7
    tmp_45 = ne tmp_43, tmp_44
    !tmp_43
    !tmp_44
    br tmp_45 -> L_THEN_9, L_ELSE_10

L_THEN_9:
    !tmp_45
    panic(3)

L_ELSE_10:
    !tmp_45
    jmp L_MERGE_11

L_MERGE_11:
    !borrowed
    !obj
    return

