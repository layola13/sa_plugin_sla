@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_while_loop_sum = vtable { call = @sla__while_loop_sum }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__while_loop_sum() -> i32:
L_ENTRY:
    tmp_0 = 1
    i = tmp_0
    tmp_1 = 0
    sum = tmp_1
    jmp L_WHILE_HEAD_0

L_WHILE_HEAD_0:
    tmp_2 = 5
    tmp_3 = sle i, tmp_2
    !tmp_2
    br tmp_3 -> L_WHILE_BODY_1, L_WHILE_COND_FALSE_2

L_WHILE_BODY_1:
    !tmp_3
    tmp_4 = add sum, i
    !sum
    sum = tmp_4
    tmp_5 = 1
    tmp_6 = add i, tmp_5
    !tmp_5
    !i
    i = tmp_6
    jmp L_WHILE_HEAD_0

L_WHILE_COND_FALSE_2:
    !tmp_3
    jmp L_WHILE_EXIT_3

L_WHILE_EXIT_3:
    !i
    return sum

@main() -> i32:
L_ENTRY:
    tmp_7 = call @sla__while_loop_sum()
    result = tmp_7
    tmp_8 = call @sa_fmt_u64(result, 10)
    tmp_9 = call @sa_fmt_buffer_data(tmp_8)
    tmp_10 = call @sa_fmt_buffer_len(tmp_8)
    tmp_11 = tmp_9
    call @sa_print_bytes(&tmp_11, tmp_10)
    call @sa_fmt_buffer_free(^tmp_8)
    !tmp_11
    !tmp_10
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 021 21_while_loop"():
L_TEST_ENTRY_4:
    tmp_12 = call @sla__while_loop_sum()
    got = tmp_12
    tmp_13 = 15
    tmp_14 = ne got, tmp_13
    !tmp_13
    br tmp_14 -> L_THEN_5, L_ELSE_6

L_THEN_5:
    !tmp_14
    panic(21)

L_ELSE_6:
    !tmp_14
    jmp L_MERGE_7

L_MERGE_7:
    !got
    return

