@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_add = vtable { call = @sla__add }
@const SLA_FNPTR_VT_factorial = vtable { call = @sla__factorial }
@sla__add(a: i64, b: i64) -> i64:
L_ENTRY:
    tmp_0 = add a, b
    return tmp_0

@sla__factorial(n: i64) -> i64:
L_ENTRY:
    tmp_1 = 1
    tmp_2 = sle n, tmp_1
    !tmp_1
    br tmp_2 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_2
    tmp_3 = 1
    !n
    return tmp_3

L_ELSE_1:
    !tmp_2
    tmp_4 = 1
    tmp_5 = sub n, tmp_4
    !tmp_4
    tmp_6 = call @sla__factorial(tmp_5)
    !tmp_5
    tmp_7 = mul n, tmp_6
    !tmp_6
    return tmp_7


@test "add two positive numbers"():
L_TEST_ENTRY_3:
    tmp_9 = 3
    tmp_10 = 4
    tmp_11 = call @sla__add(tmp_9, tmp_10)
    !tmp_9
    !tmp_10
    result = tmp_11
    tmp_12 = 7
    tmp_13 = eq result, tmp_12
    !tmp_12
    ok = tmp_13
    tmp_14 = or ok, 0
    br tmp_14 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_14
    jmp L_MERGE_6

L_ELSE_5:
    !tmp_14
    panic(1)

L_MERGE_6:
    !ok
    !result
    return

@test "add with zero"():
L_TEST_ENTRY_7:
    tmp_17 = 0
    tmp_18 = 42
    tmp_19 = call @sla__add(tmp_17, tmp_18)
    !tmp_17
    !tmp_18
    result = tmp_19
    tmp_20 = 42
    tmp_21 = eq result, tmp_20
    !tmp_20
    ok = tmp_21
    tmp_22 = or ok, 0
    br tmp_22 -> L_THEN_8, L_ELSE_9

L_THEN_8:
    !tmp_22
    jmp L_MERGE_10

L_ELSE_9:
    !tmp_22
    panic(1)

L_MERGE_10:
    !ok
    !result
    return

@test "factorial of 5"():
L_TEST_ENTRY_11:
    tmp_25 = 5
    tmp_26 = call @sla__factorial(tmp_25)
    !tmp_25
    result = tmp_26
    tmp_27 = 120
    tmp_28 = eq result, tmp_27
    !tmp_27
    ok = tmp_28
    tmp_29 = or ok, 0
    br tmp_29 -> L_THEN_12, L_ELSE_13

L_THEN_12:
    !tmp_29
    jmp L_MERGE_14

L_ELSE_13:
    !tmp_29
    panic(1)

L_MERGE_14:
    !ok
    !result
    return

@test "add is commutative"():
L_TEST_ENTRY_15:
    tmp_32 = 2
    tmp_33 = 3
    tmp_34 = call @sla__add(tmp_32, tmp_33)
    !tmp_32
    !tmp_33
    ab = tmp_34
    tmp_35 = 3
    tmp_36 = 2
    tmp_37 = call @sla__add(tmp_35, tmp_36)
    !tmp_35
    !tmp_36
    ba = tmp_37
    tmp_38 = eq ab, ba
    ok = tmp_38
    tmp_39 = or ok, 0
    br tmp_39 -> L_THEN_16, L_ELSE_17

L_THEN_16:
    !tmp_39
    jmp L_MERGE_18

L_ELSE_17:
    !tmp_39
    panic(1)

L_MERGE_18:
    !ba
    !ok
    !ab
    return

@test ignored "this test is skipped by default"():
L_TEST_ENTRY_19:
    tmp_42 = 1
    tmp_43 = 1
    tmp_44 = call @sla__add(tmp_42, tmp_43)
    !tmp_42
    !tmp_43
    x = tmp_44
    !x
    return

