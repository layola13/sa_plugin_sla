@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_never_type_safe_path = vtable { call = @sla__never_type_safe_path }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__never_type_safe_path() -> i32:
L_ENTRY:
    tmp_0 = 1
    safe = tmp_0
    tmp_1 = 0
    tmp_2 = eq safe, tmp_1
    !tmp_1
    br tmp_2 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_2
    panic(143)

L_ELSE_1:
    !tmp_2
    jmp L_MERGE_2

L_MERGE_2:
    tmp_5 = 0
    !safe
    return tmp_5

@main() -> i32:
L_ENTRY:
    tmp_6 = call @sla__never_type_safe_path()
    result = tmp_6
    tmp_7 = call @sa_fmt_u64(result, 10)
    tmp_8 = call @sa_fmt_buffer_data(tmp_7)
    tmp_9 = call @sa_fmt_buffer_len(tmp_7)
    tmp_10 = tmp_8
    call @sa_print_bytes(&tmp_10, tmp_9)
    call @sa_fmt_buffer_free(^tmp_7)
    !tmp_10
    !tmp_9
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 143 143_never_type_diverge"():
L_TEST_ENTRY_3:
    tmp_11 = call @sla__never_type_safe_path()
    got = tmp_11
    tmp_12 = 0
    tmp_13 = ne got, tmp_12
    !tmp_12
    br tmp_13 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_13
    panic(143)

L_ELSE_5:
    !tmp_13
    jmp L_MERGE_6

L_MERGE_6:
    !got
    return

