@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

struct Color(u8, u8, u8);

fn main() -> i32 {
    let color = Color(2, 4, 8);
    let total = color.0 as i32 + color.1 as i32 + color.2 as i32;
    println("{}", total);
    return 0;
}

@test "rosetta 036 tuple struct"() {
    let color = Color(2, 4, 8);
    let total = color.0 as i32 + color.1 as i32 + color.2 as i32;
    if total != 14 {
        panic(36);
    };
}
