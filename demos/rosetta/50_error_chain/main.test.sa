@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/result.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_parse_ok = vtable { call = @sla__parse_ok }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__parse_ok() -> ptr:
L_ENTRY:
    tmp_0 = 7
    EXPAND RESULT_NEW_OK tmp_1, tmp_0
    !tmp_0
    return tmp_1

@main() -> i32:
L_ENTRY:
    tmp_2 = call @sla__parse_ok()
    EXPAND RESULT_UNWRAP tmp_3, tmp_2
    !tmp_2
    value = tmp_3
    tmp_4 = 5
    tmp_5 = add value, tmp_4
    !tmp_4
    tmp_6 = call @sa_fmt_u64(tmp_5, 10)
    tmp_7 = call @sa_fmt_buffer_data(tmp_6)
    tmp_8 = call @sa_fmt_buffer_len(tmp_6)
    tmp_9 = tmp_7
    call @sa_print_bytes(&tmp_9, tmp_8)
    call @sa_fmt_buffer_free(^tmp_6)
    !tmp_9
    !tmp_8
    !tmp_5
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_10 = 0
    !value
    return tmp_10

@test "rosetta 050 error chain"():
L_TEST_ENTRY_0:
    tmp_11 = call @sla__parse_ok()
    EXPAND RESULT_UNWRAP tmp_12, tmp_11
    !tmp_11
    value = tmp_12
    tmp_13 = 5
    tmp_14 = add value, tmp_13
    !tmp_13
    tmp_15 = 12
    tmp_16 = ne tmp_14, tmp_15
    !tmp_14
    !tmp_15
    br tmp_16 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_16
    panic(50)

L_ELSE_2:
    !tmp_16
    jmp L_MERGE_3

L_MERGE_3:
    !value
    return

