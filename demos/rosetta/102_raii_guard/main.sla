// Sla companion for SA rosetta demo 102 Raii Guard.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_102_value() -> int {
    let total = 0;
    for i in 1..9 {
        total = total + i;
    }
    let result = total + 15;
    return result;
}

fn main() -> int {
    let result = rosetta_102_value();
    return result;
};

@test "rosetta 102 102_raii_guard"() {
    let got = rosetta_102_value();
    if got != 51 {
        panic(102);
    };
};
