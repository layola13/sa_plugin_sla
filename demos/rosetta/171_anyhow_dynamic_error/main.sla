@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
fn anyhow_fallback_value() -> i32 { let fallback = 0; return fallback; }
fn main() -> i32 { let result = anyhow_fallback_value(); println("{}", result); return result; }
@test "rosetta 171 171_anyhow_dynamic_error"() { let got = anyhow_fallback_value(); if got != 0 { panic(171); }; }
