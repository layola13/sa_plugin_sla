// Sla companion for Rust rosetta demo 012 Destructuring.

@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn rosetta_012_value() -> int {
    let (x, y) = (2, 5);
    let sum = x + y;
    return sum;
}

fn main() -> int {
    let result = rosetta_012_value();
    if result != 7 {
        panic(12);
    };
    println("{}", result);
    return 0;
}

@test "rosetta 012 destructuring"() {
    let got = rosetta_012_value();
    if got != 7 {
        panic(12);
    };
}
