@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/option.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/option.sa"
@const SLA_FNPTR_VT_add_one_surrogate = vtable { call = @sla__add_one_surrogate }
@const SLA_FNPTR_VT_try_trait_unwrapped_value = vtable { call = @sla__try_trait_unwrapped_value }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__add_one_surrogate(value: ptr) -> ptr:
L_ENTRY:
    jmp L_OPTION_MATCH_CHECK_0_2

L_OPTION_MATCH_CHECK_0_2:
    EXPAND OPTION_IS_SOME tmp_0, value
    br tmp_0 -> L_OPTION_MATCH_CASE_0_2, L_OPTION_MATCH_CHECK_1_2

L_OPTION_MATCH_CASE_0_2:
    EXPAND OPTION_GET inner, value
    !tmp_0
    tmp_1 = 1
    tmp_2 = add inner, tmp_1
    !tmp_1
    EXPAND OPTION_NEW_SOME tmp_3, tmp_2
    !tmp_2
    !value
    return tmp_3

L_OPTION_MATCH_CHECK_1_2:
    !tmp_0
    EXPAND OPTION_IS_SOME tmp_4, value
    br tmp_4 -> L_OPTION_MATCH_NO_MATCH_1, L_OPTION_MATCH_CASE_1_2

L_OPTION_MATCH_CASE_1_2:
    !tmp_4
    EXPAND OPTION_NEW_NONE tmp_5
    !value
    return tmp_5

L_OPTION_MATCH_NO_MATCH_1:
    !tmp_4
    panic(1)


@sla__try_trait_unwrapped_value() -> i32:
L_ENTRY:
    tmp_7 = 2
    EXPAND OPTION_NEW_SOME tmp_8, tmp_7
    !tmp_7
    tmp_9 = call @sla__add_one_surrogate(tmp_8)
    !tmp_8
    EXPAND OPTION_UNWRAP tmp_10, tmp_9
    !tmp_9
    value = tmp_10
    return value

@main() -> i32:
L_ENTRY:
    tmp_11 = call @sla__try_trait_unwrapped_value()
    result = tmp_11
    tmp_12 = call @sa_fmt_u64(result, 10)
    tmp_13 = call @sa_fmt_buffer_data(tmp_12)
    tmp_14 = call @sa_fmt_buffer_len(tmp_12)
    tmp_15 = tmp_13
    call @sa_print_bytes(&tmp_15, tmp_14)
    call @sa_fmt_buffer_free(^tmp_12)
    !tmp_15
    !tmp_14
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 180 180_try_trait_v2"():
L_TEST_ENTRY_3:
    tmp_16 = call @sla__try_trait_unwrapped_value()
    got = tmp_16
    tmp_17 = 3
    tmp_18 = ne got, tmp_17
    !tmp_17
    br tmp_18 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_18
    panic(180)

L_ELSE_5:
    !tmp_18
    jmp L_MERGE_6

L_MERGE_6:
    !got
    return

