@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
fn worker(input: i32) -> i32 { return input + 4; }
fn pthread_joined_worker_value() -> i32 { return worker(1); }
fn main() -> i32 { let result = pthread_joined_worker_value(); println("{}", result); return result; }
@test "rosetta 184 184_pthread_spawn_join"() { let got = pthread_joined_worker_value(); if got != 5 { panic(184); }; }
