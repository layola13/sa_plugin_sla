@import "sa_std/core/box.sa"
@import "sa_std/core/cell.sa"
@import "sa_std/core/rc.sa"
@import "sa_std/core/arc.sa"
@import "sa_std/core/refcell.sa"
@import "sa_std/alloc/vec.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/rc.sa"
@import "sa_std/core/refcell.sa"
@import "sa_std/core/box.sa"
@import "sa_std/vec.sa"
@const SLA_FNPTR_VT_borrow_read_box = vtable { call = @sla__borrow_read_box }
@const SLA_FNPTR_VT_borrow_read_rc = vtable { call = @sla__borrow_read_rc }
@const SLA_FNPTR_VT_borrow_read_arc = vtable { call = @sla__borrow_read_arc }
@const SLA_FNPTR_VT_borrow_read_rc_box = vtable { call = @sla__borrow_read_rc_box }
@const SLA_FNPTR_VT_borrow_read_box_rc = vtable { call = @sla__borrow_read_box_rc }
@const SLA_FNPTR_VT_borrow_refcell_read = vtable { call = @sla__borrow_refcell_read }
@const SLA_FNPTR_VT_borrow_refcell_write = vtable { call = @sla__borrow_refcell_write }
@const SLA_FNPTR_VT_borrow_refcell_box_read = vtable { call = @sla__borrow_refcell_box_read }
@const SLA_FNPTR_VT_borrow_refcell_box_write = vtable { call = @sla__borrow_refcell_box_write }
@sla__borrow_read_box(item: ptr) -> i64:
L_ENTRY:
    tmp_0 = load item+0 as ptr
    tmp_1 = &tmp_0
    payload = tmp_1
    tmp_2 = load payload+0 as i64
    return tmp_2

@sla__borrow_read_rc(item: ptr) -> i64:
L_ENTRY:
    EXPAND RC_GET tmp_3, item
    tmp_4 = &tmp_3
    payload = tmp_4
    tmp_5 = load payload+0 as i64
    return tmp_5

@sla__borrow_read_arc(item: ptr) -> i64:
L_ENTRY:
    EXPAND ARC_GET tmp_6, item
    tmp_7 = &tmp_6
    payload = tmp_7
    tmp_8 = load payload+0 as i64
    return tmp_8

@sla__borrow_read_rc_box(item: ptr) -> i64:
L_ENTRY:
    EXPAND RC_GET tmp_9, item
    tmp_10 = &tmp_9
    boxed = tmp_10
    tmp_11 = load boxed+0 as ptr
    tmp_12 = &tmp_11
    payload = tmp_12
    tmp_13 = load payload+0 as i64
    return tmp_13

@sla__borrow_read_box_rc(item: ptr) -> i64:
L_ENTRY:
    tmp_14 = load item+0 as ptr
    tmp_15 = &tmp_14
    rc_value = tmp_15
    EXPAND RC_GET tmp_16, rc_value
    tmp_17 = &tmp_16
    payload = tmp_17
    tmp_18 = load payload+0 as i64
    return tmp_18

@sla__borrow_refcell_read(cell: ptr) -> i64:
L_ENTRY:
    EXPAND REFCELL_U64_TRY_BORROW tmp_19, tmp_20, cell
    br tmp_19 -> L_REFCELL_BORROW_END_1, L_REFCELL_BORROW_PANIC_0

L_REFCELL_BORROW_PANIC_0:
    !tmp_19
    panic(107)

L_REFCELL_BORROW_END_1:
    !tmp_19
    tmp_21 = load tmp_20+0 as ptr
    !tmp_20
    borrowed = tmp_21
    tmp_22 = load borrowed+0 as i64
    EXPAND REFCELL_U64_RELEASE_SHARED cell
    return tmp_22

@sla__borrow_refcell_write(cell: ptr, value: i64):
L_ENTRY:
    EXPAND REFCELL_U64_TRY_BORROW_MUT tmp_23, tmp_24, cell
    br tmp_23 -> L_REFCELL_BORROW_END_3, L_REFCELL_BORROW_PANIC_2

L_REFCELL_BORROW_PANIC_2:
    !tmp_23
    panic(107)

L_REFCELL_BORROW_END_3:
    !tmp_23
    tmp_25 = load tmp_24+0 as ptr
    !tmp_24
    borrowed = tmp_25
    store borrowed+0, value as i64
    EXPAND REFCELL_U64_RELEASE_MUT cell
    !borrowed
    return

@sla__borrow_refcell_box_read(cell: ptr) -> i64:
L_ENTRY:
    EXPAND REFCELL_U64_TRY_BORROW tmp_26, tmp_27, cell
    br tmp_26 -> L_REFCELL_BORROW_END_5, L_REFCELL_BORROW_PANIC_4

L_REFCELL_BORROW_PANIC_4:
    !tmp_26
    panic(107)

L_REFCELL_BORROW_END_5:
    !tmp_26
    tmp_28 = load tmp_27+0 as ptr
    !tmp_27
    borrowed_box = tmp_28
    tmp_29 = load borrowed_box+0 as ptr
    tmp_30 = &tmp_29
    payload = tmp_30
    tmp_31 = load payload+0 as i64
    EXPAND REFCELL_U64_RELEASE_SHARED cell
    return tmp_31

@sla__borrow_refcell_box_write(cell: ptr, value: i64):
L_ENTRY:
    EXPAND REFCELL_U64_TRY_BORROW_MUT tmp_32, tmp_33, cell
    br tmp_32 -> L_REFCELL_BORROW_END_7, L_REFCELL_BORROW_PANIC_6

L_REFCELL_BORROW_PANIC_6:
    !tmp_32
    panic(107)

L_REFCELL_BORROW_END_7:
    !tmp_32
    tmp_34 = load tmp_33+0 as ptr
    !tmp_33
    borrowed_box = tmp_34
    tmp_35 = load borrowed_box+0 as ptr
    tmp_36 = &tmp_35
    payload = tmp_36
    store payload+0, value as i64
    !payload
    !tmp_35
    EXPAND REFCELL_U64_RELEASE_MUT cell
    !borrowed_box
    return

@test "borrowed field call argument releases before field owner temp"():
L_TEST_ENTRY_8:
    nested = alloc 8
    tmp_37 = alloc 8
    tmp_38 = alloc 8
    tmp_39 = 11
    store tmp_38+0, tmp_39 as i64
    !tmp_39
    EXPAND BOX_NEW tmp_40, tmp_38
    !tmp_38
    store tmp_37+0, tmp_40 as ptr
    !tmp_40
    store nested+0, tmp_37 as ptr
    !tmp_37
    tmp_41 = load nested+0 as ptr
    tmp_42 = load tmp_41+0 as ptr
    !tmp_41
    tmp_43 = &tmp_42
    tmp_44 = call @sla__borrow_read_box(tmp_43)
    !tmp_43
    !tmp_42
    tmp_45 = 11
    tmp_46 = ne tmp_44, tmp_45
    !tmp_44
    !tmp_45
    br tmp_46 -> L_THEN_9, L_ELSE_10

L_THEN_9:
    !tmp_46
    panic(1)

L_ELSE_10:
    !tmp_46
    jmp L_MERGE_11

L_MERGE_11:
    !nested
    return

@test "borrowed field temp releases across loop iterations"():
L_TEST_ENTRY_12:
    tmp_49 = 0
    total = tmp_49
    tmp_50 = 0
    i = tmp_50
    jmp L_WHILE_HEAD_13

L_WHILE_HEAD_13:
    tmp_51 = 4
    tmp_52 = slt i, tmp_51
    !tmp_51
    br tmp_52 -> L_WHILE_BODY_14, L_WHILE_COND_FALSE_15

L_WHILE_BODY_14:
    !tmp_52
    slot = alloc 8
    tmp_53 = alloc 8
    tmp_54 = alloc 8
    tmp_55 = 1
    tmp_56 = add i, tmp_55
    !tmp_55
    store tmp_54+0, tmp_56 as i64
    !tmp_56
    EXPAND BOX_NEW tmp_57, tmp_54
    !tmp_54
    store tmp_53+0, tmp_57 as ptr
    !tmp_57
    store slot+0, tmp_53 as ptr
    !tmp_53
    tmp_58 = load slot+0 as ptr
    tmp_59 = load tmp_58+0 as ptr
    !tmp_58
    tmp_60 = &tmp_59
    borrowed_box = tmp_60
    tmp_61 = load borrowed_box+0 as ptr
    tmp_62 = &tmp_61
    payload = tmp_62
    tmp_63 = load payload+0 as i64
    tmp_64 = add total, tmp_63
    !tmp_63
    !total
    total = tmp_64
    tmp_65 = 1
    tmp_66 = add i, tmp_65
    !tmp_65
    !i
    i = tmp_66
    !payload
    !tmp_61
    !borrowed_box
    !tmp_59
    !slot
    jmp L_WHILE_HEAD_13

L_WHILE_COND_FALSE_15:
    !tmp_52
    jmp L_WHILE_EXIT_16

L_WHILE_EXIT_16:
    tmp_67 = 10
    tmp_68 = ne total, tmp_67
    !tmp_67
    br tmp_68 -> L_THEN_17, L_ELSE_18

L_THEN_17:
    !tmp_68
    panic(2)

L_ELSE_18:
    !tmp_68
    jmp L_MERGE_19

L_MERGE_19:
    !i
    !total
    return

@test "borrowed field temp releases across branch merge"():
L_TEST_ENTRY_20:
    left = alloc 8
    tmp_71 = alloc 8
    tmp_72 = 7
    store tmp_71+0, tmp_72 as i64
    !tmp_72
    EXPAND RC_NEW tmp_73, tmp_71
    !tmp_71
    store left+0, tmp_73 as ptr
    !tmp_73
    right = alloc 8
    tmp_74 = alloc 8
    tmp_75 = 13
    store tmp_74+0, tmp_75 as i64
    !tmp_75
    EXPAND BOX_NEW tmp_76, tmp_74
    !tmp_74
    store right+0, tmp_76 as ptr
    !tmp_76
    tmp_77 = 0
    total = tmp_77
    tmp_78 = 1
    choose_left = tmp_78
    br choose_left -> L_THEN_21, L_ELSE_22

L_THEN_21:
    !choose_left
    tmp_79 = load left+0 as ptr
    tmp_80 = &tmp_79
    borrowed_rc = tmp_80
    tmp_81 = call @sla__borrow_read_rc(borrowed_rc)
    tmp_82 = add total, tmp_81
    !tmp_81
    !total
    total = tmp_82
    !borrowed_rc
    !tmp_79
    jmp L_MERGE_23

L_ELSE_22:
    !choose_left
    tmp_83 = load right+0 as ptr
    tmp_84 = &tmp_83
    borrowed_box = tmp_84
    tmp_85 = call @sla__borrow_read_box(borrowed_box)
    tmp_86 = add total, tmp_85
    !tmp_85
    !total
    total = tmp_86
    !borrowed_box
    !tmp_83
    jmp L_MERGE_23

L_MERGE_23:
    tmp_88 = 7
    tmp_89 = ne total, tmp_88
    !tmp_88
    br tmp_89 -> L_THEN_24, L_ELSE_25

L_THEN_24:
    !tmp_89
    panic(3)

L_ELSE_25:
    !tmp_89
    jmp L_MERGE_26

L_MERGE_26:
    !right
    !left
    !total
    return

@test "borrowed rc refcell field releases before owner temp"():
L_TEST_ENTRY_27:
    holder = alloc 8
    tmp_92 = alloc 8
    tmp_93 = 5
    store tmp_92+0, tmp_93 as i64
    !tmp_93
    EXPAND REFCELL_U64_NEW tmp_94, tmp_92
    !tmp_92
    EXPAND RC_NEW tmp_95, tmp_94
    !tmp_94
    store holder+0, tmp_95 as ptr
    !tmp_95
    tmp_96 = load holder+0 as ptr
    EXPAND RC_GET tmp_97, tmp_96
    !tmp_96
    tmp_98 = &tmp_97
    borrowed_cell = tmp_98
    tmp_99 = 21
    call @sla__borrow_refcell_write(borrowed_cell, tmp_99)
    tmp_100 = call @sla__borrow_refcell_read(borrowed_cell)
    tmp_101 = 21
    tmp_102 = ne tmp_100, tmp_101
    !tmp_100
    !tmp_101
    br tmp_102 -> L_THEN_28, L_ELSE_29

L_THEN_28:
    !tmp_102
    panic(4)

L_ELSE_29:
    !tmp_102
    jmp L_MERGE_30

L_MERGE_30:
    !borrowed_cell
    !tmp_97
    !holder
    return

