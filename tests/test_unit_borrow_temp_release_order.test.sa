@test "vec field smart pointer index borrow releases owner temps"():
L_TEST_ENTRY_61:
    EXPAND VEC_NEW tmp_204
    items = tmp_204
    tmp_205 = alloc 8
    tmp_206 = 3
    store tmp_205+0, tmp_206 as i64
    !tmp_206
    EXPAND BOX_NEW tmp_207, tmp_205
    !tmp_205
    EXPAND VEC_PUSH items, tmp_207, 8
    !tmp_207
    tmp_208 = alloc 8
    tmp_209 = 4
    store tmp_208+0, tmp_209 as i64
    !tmp_209
    EXPAND BOX_NEW tmp_210, tmp_208
    !tmp_208
    EXPAND VEC_PUSH items, tmp_210, 8
    !tmp_210
    holder = alloc 8
    store holder+0, items as ptr
    tmp_211 = load holder+0 as ptr
    tmp_212 = 0
    EXPAND VEC_GET tmp_213, tmp_211, tmp_212
    !tmp_212
    !tmp_211
    tmp_214 = tmp_213 as ptr
    tmp_215 = &tmp_214
    first = tmp_215
    tmp_216 = load holder+0 as ptr
    tmp_217 = 1
    EXPAND VEC_GET tmp_218, tmp_216, tmp_217
    !tmp_217
    !tmp_216
    tmp_219 = tmp_218 as ptr
    tmp_220 = &tmp_219
    second = tmp_220
    tmp_221 = call @sla__borrow_read_box(first)
    tmp_222 = call @sla__borrow_read_box(second)
    tmp_223 = add tmp_221, tmp_222
    !tmp_221
    !tmp_222
    tmp_224 = 7
    tmp_225 = ne tmp_223, tmp_224
    !tmp_223
