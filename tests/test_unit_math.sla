@test "复合表达式 (a*a + b*b) == c*c 勾股定理 3-4-5"() {
    let a = 3;
    let b = 4;
    let c = 5;
    let lhs = (a * a) + (b * b);
    let rhs = c * c;
    let ok = lhs == rhs;
    if ok { } else { panic(1); };
}

@test "复合表达式 (a*a + b*b) 勾股 5-12-13"() {
    let a = 5;
    let b = 12;
    let c = 13;
    let lhs = (a * a) + (b * b);
    let rhs = c * c;
    let ok = lhs == rhs;
    if ok { } else { panic(1); };
}

@test "判别式 b*b - 4*a*c (a=1,b=5,c=6) == 1"() {
    let a = 1;
    let b = 5;
    let c = 6;
    let disc = (b * b) - (4 * a * c);
    let ok = disc == 1;
    if ok { } else { panic(1); };
}

@test "等差数列求和 sum(1..10) == 55"() {
    // sum = n*(n+1)/2
    let n = 10;
    let result = n * (n + 1) / 2;
    let ok = result == 55;
    if ok { } else { panic(1); };
}

@test "等比数列 (公比r=2, n=8项) 总和 == 255"() {
    // sum = r^n - 1 = 2^8 - 1 = 255 for r=2, first=1
    let r8 = power(2, 8);
    let result = r8 - 1;
    let ok = result == 255;
    if ok { } else { panic(1); };
}

