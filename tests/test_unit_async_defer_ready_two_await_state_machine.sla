@import "sa_std/future.sa"
@import "sa_std/core/task.sa"

async fn await_two_defer_ready_values() -> i32 {
    let a = future::defer_ready(20).await;
    let b = future::defer_ready(22).await;
    return a + b;
}

async fn await_local_two_defer_ready_values() -> i32 {
    let left = future::defer_ready(20);
    let a = left.await;
    let right = future::defer_ready(22);
    let b = right.await;
    return a + b;
}

fn direct_two_await_resume_on_third_poll() -> i32 {
    let fut = await_two_defer_ready_values();
    let task = task::new(fut);
    if task::poll(task) != false {
        panic(9961);
    };
    if task::is_ready(task) != false {
        panic(9962);
    };
    if task::poll(task) != false {
        panic(9963);
    };
    if task::is_ready(task) != false {
        panic(9964);
    };
    if task::poll(task) != true {
        panic(9965);
    };
    if task::is_ready(task) != true {
        panic(9966);
    };
    return task::result(task);
}

fn local_two_await_resume_on_third_poll() -> i32 {
    let fut = await_local_two_defer_ready_values();
    let task = task::new(fut);
    if task::poll(task) != false {
        panic(9971);
    };
    if task::is_ready(task) != false {
        panic(9972);
    };
    if task::poll(task) != false {
        panic(9973);
    };
    if task::is_ready(task) != false {
        panic(9974);
    };
    if task::poll(task) != true {
        panic(9975);
    };
    if task::is_ready(task) != true {
        panic(9976);
    };
    return task::result(task);
}

@test "async defer ready two await resumes"() {
    if direct_two_await_resume_on_third_poll() != 42 {
        panic(9967);
    };
    if local_two_await_resume_on_third_poll() != 42 {
        panic(9977);
    };
}
