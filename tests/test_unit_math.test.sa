@abs(x: i64) -> i64:
L_ENTRY:
    tmp_0 = 0
    tmp_1 = slt x, tmp_0
    neg = tmp_1
    br neg -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !neg
    tmp_2 = 0
    tmp_3 = sub tmp_2, x
    !x
    return tmp_3

L_ELSE_1:
    !neg
    return x


@max(a: i64, b: i64) -> i64:
L_ENTRY:
    tmp_5 = sgt a, b
    gt = tmp_5
    br gt -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !gt
    !b
    return a

L_ELSE_4:
    !gt
    !a
    return b


@min(a: i64, b: i64) -> i64:
L_ENTRY:
    tmp_7 = slt a, b
    lt = tmp_7
    br lt -> L_THEN_6, L_ELSE_7

L_THEN_6:
    !lt
    !b
    return a

L_ELSE_7:
    !lt
    !a
    return b


@gcd(a: i64, b: i64) -> i64:
L_ENTRY:
    tmp_9 = 0
    tmp_10 = eq b, tmp_9
    is_zero = tmp_10
    br is_zero -> L_THEN_9, L_ELSE_10

L_THEN_9:
    !is_zero
    !b
    return a

L_ELSE_10:
    !is_zero
    tmp_11 = rem a, b
    rem = tmp_11
    tmp_12 = call @gcd(b, rem)
    result = tmp_12
    !rem
    !b
    !a
    return result


@lcm(a: i64, b: i64) -> i64:
L_ENTRY:
    tmp_14 = call @gcd(a, b)
    g = tmp_14
    tmp_15 = div a, g
    tmp_16 = mul tmp_15, b
    result = tmp_16
    !g
    !b
    !a
    return result

@power(base: i64, exp: i64) -> i64:
L_ENTRY:
    tmp_17 = 0
    tmp_18 = eq exp, tmp_17
    is_zero = tmp_18
    br is_zero -> L_THEN_12, L_ELSE_13

L_THEN_12:
    !is_zero
    tmp_19 = 1
    !exp
    !base
    return tmp_19

L_ELSE_13:
    !is_zero
    tmp_20 = 2
    tmp_21 = div exp, tmp_20
    half = tmp_21
    tmp_22 = call @power(base, half)
    sub_result = tmp_22
    tmp_23 = 2
    tmp_24 = rem exp, tmp_23
    tmp_25 = 0
    tmp_26 = eq tmp_24, tmp_25
    even = tmp_26
    br even -> L_THEN_15, L_ELSE_16

L_THEN_15:
    !even
    tmp_27 = mul sub_result, sub_result
    result = tmp_27
    !half
    !sub_result
    !exp
    !base
    return result

L_ELSE_16:
    !even
    tmp_28 = mul sub_result, sub_result
    tmp_29 = mul tmp_28, base
    result = tmp_29
    !half
    !sub_result
    !exp
    !base
    return result



@clamp(val: i64, lo: i64, hi: i64) -> i64:
L_ENTRY:
    tmp_32 = slt val, lo
    below = tmp_32
    br below -> L_THEN_18, L_ELSE_19

L_THEN_18:
    !below
    !hi
    !val
    return lo

L_ELSE_19:
    !below
    tmp_33 = sgt val, hi
    above = tmp_33
    br above -> L_THEN_21, L_ELSE_22

L_THEN_21:
    !above
    !lo
    !val
    return hi

L_ELSE_22:
    !above
    !hi
    !lo
    return val



