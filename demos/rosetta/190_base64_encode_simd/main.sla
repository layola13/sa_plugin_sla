@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
fn base64_encoded_len() -> usize { let encoded_len: usize = 4; return encoded_len; }
fn main() -> i32 { let result = base64_encoded_len(); println("{}", result); return 0; }
@test "rosetta 190 190_base64_encode_simd"() { let got = base64_encoded_len(); if got != 4 { panic(190); }; }
