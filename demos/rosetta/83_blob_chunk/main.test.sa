@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_chunk_count = vtable { call = @sla__chunk_count }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__chunk_count(bytes: i32, chunk_size: i32) -> i32:
L_ENTRY:
    tmp_0 = add bytes, chunk_size
    tmp_1 = 1
    tmp_2 = sub tmp_0, tmp_1
    !tmp_0
    !tmp_1
    tmp_3 = div tmp_2, chunk_size
    !tmp_2
    !bytes
    !chunk_size
    return tmp_3

@main() -> i32:
L_ENTRY:
    tmp_4 = 10
    tmp_5 = 4
    tmp_6 = call @sla__chunk_count(tmp_4, tmp_5)
    !tmp_4
    !tmp_5
    result = tmp_6
    tmp_7 = call @sa_fmt_u64(result, 10)
    tmp_8 = call @sa_fmt_buffer_data(tmp_7)
    tmp_9 = call @sa_fmt_buffer_len(tmp_7)
    tmp_10 = tmp_8
    call @sa_print_bytes(&tmp_10, tmp_9)
    call @sa_fmt_buffer_free(^tmp_7)
    !tmp_10
    !tmp_9
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 083 83_blob_chunk"():
L_TEST_ENTRY_0:
    tmp_11 = 10
    tmp_12 = 4
    tmp_13 = call @sla__chunk_count(tmp_11, tmp_12)
    !tmp_11
    !tmp_12
    got = tmp_13
    tmp_14 = 3
    tmp_15 = ne got, tmp_14
    !tmp_14
    br tmp_15 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_15
    panic(83)

L_ELSE_2:
    !tmp_15
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

