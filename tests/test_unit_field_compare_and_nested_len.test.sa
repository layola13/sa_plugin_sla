@import "sa_std/vec.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/vec.sa"
@const SLA_FNPTR_VT_nested_len_column_new = vtable { call = @sla__nested_len_column_new }
@const SLA_FNPTR_VT_nested_len_world_new = vtable { call = @sla__nested_len_world_new }
@const SLA_FNPTR_VT_nested_len_field_compare = vtable { call = @sla__nested_len_field_compare }
@const SLA_FNPTR_VT_nested_len_after_index = vtable { call = @sla__nested_len_after_index }
@const SLA_FNPTR_VT_nested_len_move_last = vtable { call = @sla__nested_len_move_last }
@sla__nested_len_column_new() -> ptr:
L_ENTRY:
    EXPAND VEC_NEW tmp_0
    entity_ids = tmp_0
    tmp_1 = alloc 8
    store tmp_1+0, entity_ids as ptr
    return tmp_1

@sla__nested_len_world_new() -> ptr:
L_ENTRY:
    EXPAND VEC_NEW tmp_2
    archetypes = tmp_2
    EXPAND VEC_NEW tmp_3
    locations = tmp_3
    tmp_4 = alloc 16
    store tmp_4+0, archetypes as ptr
    store tmp_4+8, locations as ptr
    return tmp_4

@sla__nested_len_field_compare(location: ptr) -> u8:
L_ENTRY:
    tmp_5 = load location+0 as i32
    tmp_6 = 0
    tmp_7 = slt tmp_5, tmp_6
    !tmp_5
    !tmp_6
    br tmp_7 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_7
    tmp_8 = 1
    !location
    return tmp_8

L_ELSE_1:
    !tmp_7
    jmp L_MERGE_2

L_MERGE_2:
    tmp_10 = 0
    !location
    return tmp_10

@sla__nested_len_after_index(world: ptr, archetype_slot: i64) -> i64:
L_ENTRY:
    tmp_11 = load world+0 as ptr
    EXPAND VEC_GET tmp_12, tmp_11, archetype_slot
    !tmp_11
    tmp_13 = tmp_12 as ptr
    tmp_14 = load tmp_13+0 as ptr
    !tmp_13
    EXPAND VEC_LEN tmp_15, tmp_14
    !tmp_14
    tmp_16 = tmp_15 as i64
    !archetype_slot
    !world
    return tmp_16

@sla__nested_len_move_last(world: ptr, location: ptr) -> ptr:
L_ENTRY:
    tmp_17 = load location+0 as i32
    tmp_18 = 0
    tmp_19 = slt tmp_17, tmp_18
    !tmp_17
    !tmp_18
    br tmp_19 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_19
    !location
    return world

L_ELSE_4:
    !tmp_19
    jmp L_MERGE_5

L_MERGE_5:
    tmp_21 = load location+0 as i32
    tmp_22 = tmp_21 as i64
    archetype_slot = tmp_22
    tmp_23 = load world+0 as ptr
    EXPAND VEC_GET tmp_24, tmp_23, archetype_slot
    !tmp_23
    tmp_25 = tmp_24 as ptr
    tmp_26 = load tmp_25+0 as ptr
    !tmp_25
    EXPAND VEC_LEN tmp_27, tmp_26
    !tmp_26
    tmp_28 = tmp_27 as i64
    tmp_29 = 1
    tmp_30 = sub tmp_28, tmp_29
    !tmp_28
    !tmp_29
    last = tmp_30
    tmp_31 = load location+8 as i64
    tmp_32 = ne tmp_31, last
    !tmp_31
    br tmp_32 -> L_THEN_6, L_ELSE_7

L_THEN_6:
    !tmp_32
    tmp_33 = load world+0 as ptr
    EXPAND VEC_GET tmp_34, tmp_33, archetype_slot
    !tmp_33
    tmp_35 = tmp_34 as ptr
    tmp_36 = load tmp_35+0 as ptr
    !tmp_35
    EXPAND VEC_GET tmp_37, tmp_36, last
    !tmp_36
    tmp_38 = tmp_37 as i32
    moved_entity_id = tmp_38
    tmp_39 = load world+0 as ptr
    EXPAND VEC_GET tmp_40, tmp_39, archetype_slot
    !tmp_39
    tmp_41 = tmp_40 as ptr
    tmp_42 = load tmp_41+0 as ptr
    !tmp_41
    tmp_43 = load location+8 as i64
    tmp_44 = &tmp_42
    tmp_45 = load tmp_44+Vec_len as u64
    tmp_46 = ult tmp_43, tmp_45
    br tmp_46 -> L_VEC_INDEX_ASSIGN_OK_9, L_VEC_INDEX_ASSIGN_OOB_10

L_VEC_INDEX_ASSIGN_OOB_10:
    panic(87)

L_VEC_INDEX_ASSIGN_OK_9:
    !tmp_46
    tmp_47 = load tmp_44+Vec_ptr as ptr
    tmp_48 = mul tmp_43, 8
    tmp_49 = ptr_add tmp_47, tmp_48
    store tmp_49+0, moved_entity_id as u64
    !tmp_49
    !tmp_48
    !tmp_47
    !tmp_45
    !tmp_44
    !tmp_43
    !tmp_42
    tmp_50 = load world+8 as ptr
    EXPAND VEC_GET tmp_51, tmp_50, moved_entity_id
    !tmp_50
    tmp_52 = tmp_51 as ptr
    tmp_53 = load location+8 as i64
    store tmp_52+8, tmp_53 as i64
    !tmp_52
    !tmp_53
    !moved_entity_id
    jmp L_MERGE_8

L_ELSE_7:
    !tmp_32
    jmp L_MERGE_8

L_MERGE_8:
    tmp_55 = load world+0 as ptr
    EXPAND VEC_GET tmp_56, tmp_55, archetype_slot
    !tmp_55
    tmp_57 = tmp_56 as ptr
    tmp_58 = load tmp_57+0 as ptr
    !tmp_57
    EXPAND VEC_REMOVE tmp_59, tmp_60, tmp_58, last, 8
    br tmp_59 -> L_VEC_REMOVE_OK_11, L_VEC_REMOVE_OOB_12

L_VEC_REMOVE_OOB_12:
    panic(86)

L_VEC_REMOVE_OK_11:
    !tmp_59
    tmp_61 = tmp_60 as i32
    removed = tmp_61
    !archetype_slot
    !removed
    !last
    !location
    return world

@test "field less-than comparison parses after dot access"():
L_TEST_ENTRY_13:
    tmp_62 = alloc 16
    tmp_63 = 0
    tmp_64 = 1
    tmp_65 = sub tmp_63, tmp_64
    !tmp_63
    !tmp_64
    store tmp_62+0, tmp_65 as i32
    !tmp_65
    tmp_66 = 0
    store tmp_62+8, tmp_66 as i64
    !tmp_66
    tmp_67 = call @sla__nested_len_field_compare(tmp_62)
    !tmp_62
    tmp_68 = 1
    tmp_69 = ne tmp_67, tmp_68
    !tmp_67
    !tmp_68
    br tmp_69 -> L_THEN_14, L_ELSE_15

L_THEN_14:
    !tmp_69
    panic(1)

L_ELSE_15:
    !tmp_69
    jmp L_MERGE_16

L_MERGE_16:
    tmp_72 = alloc 16
    tmp_73 = 0
    store tmp_72+0, tmp_73 as i32
    !tmp_73
    tmp_74 = 0
    store tmp_72+8, tmp_74 as i64
    !tmp_74
    tmp_75 = call @sla__nested_len_field_compare(tmp_72)
    !tmp_72
    tmp_76 = 0
    tmp_77 = ne tmp_75, tmp_76
    !tmp_75
    !tmp_76
    br tmp_77 -> L_THEN_17, L_ELSE_18

L_THEN_17:
    !tmp_77
    panic(2)

L_ELSE_18:
    !tmp_77
    jmp L_MERGE_19

L_MERGE_19:
    return

@test "nested len after indexed field access works"():
L_TEST_ENTRY_20:
    tmp_80 = call @sla__nested_len_world_new()
    world0 = tmp_80
    tmp_81 = call @sla__nested_len_column_new()
    column = tmp_81
    tmp_82 = load world0+0 as ptr
    EXPAND VEC_PUSH tmp_82, column, 8
    !tmp_82
    tmp_83 = load world0+0 as ptr
    tmp_84 = 0
    EXPAND VEC_GET tmp_85, tmp_83, tmp_84
    !tmp_84
    !tmp_83
    tmp_86 = tmp_85 as ptr
    tmp_87 = load tmp_86+0 as ptr
    !tmp_86
    tmp_88 = 0
    EXPAND VEC_PUSH tmp_87, tmp_88, 8
    !tmp_88
    !tmp_87
    tmp_89 = load world0+0 as ptr
    tmp_90 = 0
    EXPAND VEC_GET tmp_91, tmp_89, tmp_90
    !tmp_90
    !tmp_89
    tmp_92 = tmp_91 as ptr
    tmp_93 = load tmp_92+0 as ptr
    !tmp_92
    tmp_94 = 1
    EXPAND VEC_PUSH tmp_93, tmp_94, 8
    !tmp_94
    !tmp_93
    tmp_95 = load world0+8 as ptr
    tmp_96 = alloc 16
    tmp_97 = 0
    store tmp_96+0, tmp_97 as i32
    !tmp_97
    tmp_98 = 0
    store tmp_96+8, tmp_98 as i64
    !tmp_98
    EXPAND VEC_PUSH tmp_95, tmp_96, 8
    !tmp_96
    !tmp_95
    tmp_99 = load world0+8 as ptr
    tmp_100 = alloc 16
    tmp_101 = 0
    store tmp_100+0, tmp_101 as i32
    !tmp_101
    tmp_102 = 1
    store tmp_100+8, tmp_102 as i64
    !tmp_102
    EXPAND VEC_PUSH tmp_99, tmp_100, 8
    !tmp_100
    !tmp_99
    tmp_103 = 0
    tmp_104 = call @sla__nested_len_after_index(world0, tmp_103)
    !tmp_103
    tmp_105 = 2
    tmp_106 = ne tmp_104, tmp_105
    !tmp_104
    !tmp_105
    br tmp_106 -> L_THEN_21, L_ELSE_22

L_THEN_21:
    !tmp_106
    panic(3)

L_ELSE_22:
    !tmp_106
    jmp L_MERGE_23

L_MERGE_23:
    tmp_109 = alloc 16
    tmp_110 = 0
    store tmp_109+0, tmp_110 as i32
    !tmp_110
    tmp_111 = 0
    store tmp_109+8, tmp_111 as i64
    !tmp_111
    tmp_112 = call @sla__nested_len_move_last(world0, tmp_109)
    !tmp_109
    world1 = tmp_112
    tmp_113 = 0
    tmp_114 = call @sla__nested_len_after_index(world1, tmp_113)
    !tmp_113
    tmp_115 = 1
    tmp_116 = ne tmp_114, tmp_115
    !tmp_114
    !tmp_115
    br tmp_116 -> L_THEN_24, L_ELSE_25

L_THEN_24:
    !tmp_116
    panic(4)

L_ELSE_25:
    !tmp_116
    jmp L_MERGE_26

L_MERGE_26:
    tmp_119 = load world1+0 as ptr
    tmp_120 = 0
    EXPAND VEC_GET tmp_121, tmp_119, tmp_120
    !tmp_120
    !tmp_119
    tmp_122 = tmp_121 as ptr
    tmp_123 = load tmp_122+0 as ptr
    !tmp_122
    tmp_124 = 0
    EXPAND VEC_GET tmp_125, tmp_123, tmp_124
    !tmp_124
    !tmp_123
    tmp_126 = tmp_125 as i32
    tmp_127 = 1
    tmp_128 = ne tmp_126, tmp_127
    !tmp_126
    !tmp_127
    br tmp_128 -> L_THEN_27, L_ELSE_28

L_THEN_27:
    !tmp_128
    panic(5)

L_ELSE_28:
    !tmp_128
    jmp L_MERGE_29

L_MERGE_29:
    tmp_131 = load world1+8 as ptr
    tmp_132 = 1
    EXPAND VEC_GET tmp_133, tmp_131, tmp_132
    !tmp_132
    !tmp_131
    tmp_134 = tmp_133 as ptr
    tmp_135 = load tmp_134+8 as i64
    !tmp_134
    tmp_136 = 0
    tmp_137 = ne tmp_135, tmp_136
    !tmp_135
    !tmp_136
    br tmp_137 -> L_THEN_30, L_ELSE_31

L_THEN_30:
    !tmp_137
    panic(6)

L_ELSE_31:
    !tmp_137
    jmp L_MERGE_32

L_MERGE_32:
    !world1
    !column
    !world0
    return
