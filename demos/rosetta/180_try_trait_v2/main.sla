@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
fn try_trait_unwrapped_value() -> i32 { let unwrapped_value = 3; return unwrapped_value; }
fn main() -> i32 { let result = try_trait_unwrapped_value(); println("{}", result); return result; }
@test "rosetta 180 180_try_trait_v2"() { let got = try_trait_unwrapped_value(); if got != 3 { panic(180); }; }
