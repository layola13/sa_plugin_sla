@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/result.sa"
@import "sa_std/sync/mpsc.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/result.sa"
@import "sa_std/sync/mpsc.sa"
@const SLA_FNPTR_VT_round_trip = vtable { call = @sla__round_trip }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__round_trip() -> i32:
L_ENTRY:
    tx = 0
    EXPAND MPSC_NEW rx, 1024
    tmp_0 = 8
    tmp_1 = add tmp_0, 0
    EXPAND MPSC_SEND rx, tmp_1
    !tmp_0
    EXPAND RESULT_NEW_OK tmp_2, 0
    EXPAND RESULT_UNWRAP tmp_3, tmp_2
    !tmp_2
    !tmp_3
    EXPAND MPSC_RECV tmp_4, rx
    EXPAND RESULT_NEW_OK tmp_5, tmp_4
    !tmp_4
    EXPAND RESULT_UNWRAP tmp_6, tmp_5
    !tmp_5
    value = tmp_6
    tmp_7 = 1
    tmp_8 = add value, tmp_7
    !tmp_7
    tmp_9 = add tmp_8, 0
    EXPAND MPSC_SEND rx, tmp_9
    !tmp_8
    EXPAND RESULT_NEW_OK tmp_10, 0
    EXPAND RESULT_UNWRAP tmp_11, tmp_10
    !tmp_10
    !tmp_11
    EXPAND MPSC_RECV tmp_12, rx
    EXPAND RESULT_NEW_OK tmp_13, tmp_12
    !tmp_12
    EXPAND RESULT_UNWRAP tmp_14, tmp_13
    !tmp_13
    !value
    return tmp_14

@main() -> i32:
L_ENTRY:
    tmp_15 = call @sla__round_trip()
    value = tmp_15
    tmp_16 = call @sa_fmt_u64(value, 10)
    tmp_17 = call @sa_fmt_buffer_data(tmp_16)
    tmp_18 = call @sa_fmt_buffer_len(tmp_16)
    tmp_19 = tmp_17
    call @sa_print_bytes(&tmp_19, tmp_18)
    call @sa_fmt_buffer_free(^tmp_16)
    !tmp_19
    !tmp_18
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_20 = 0
    !value
    return tmp_20

@test "rosetta 062 62_channel_pingpong"():
L_TEST_ENTRY_0:
    tmp_21 = call @sla__round_trip()
    got = tmp_21
    tmp_22 = 9
    tmp_23 = ne got, tmp_22
    !tmp_22
    br tmp_23 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_23
    panic(62)

L_ELSE_2:
    !tmp_23
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

