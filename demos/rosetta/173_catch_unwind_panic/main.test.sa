@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/result.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/result.sa"
@const SLA_FNPTR_VT_catch_unwind_observable = vtable { call = @sla__catch_unwind_observable }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__catch_unwind_observable() -> i32:
L_ENTRY:
    tmp_1 = 1
    EXPAND RESULT_NEW_ERR tmp_0, tmp_1
    !tmp_1
    result = tmp_0
    EXPAND RESULT_IS_OK tmp_2, result
    tmp_3 = alloc 4
    br tmp_2 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_2
    tmp_4 = 1
    store tmp_3+0, tmp_4 as i32
    !tmp_4
    jmp L_MERGE_2

L_ELSE_1:
    !tmp_2
    tmp_5 = 0
    store tmp_3+0, tmp_5 as i32
    !tmp_5
    jmp L_MERGE_2

L_MERGE_2:
    tmp_6 = load tmp_3+0 as i32
    !tmp_3
    got = tmp_6
    !result
    return got

@main() -> i32:
L_ENTRY:
    tmp_8 = 1
    EXPAND RESULT_NEW_ERR tmp_7, tmp_8
    !tmp_8
    result = tmp_7
    EXPAND RESULT_IS_OK tmp_9, result
    tmp_10 = alloc 4
    br tmp_9 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_9
    tmp_11 = 1
    store tmp_10+0, tmp_11 as i32
    !tmp_11
    jmp L_MERGE_5

L_ELSE_4:
    !tmp_9
    tmp_12 = 0
    store tmp_10+0, tmp_12 as i32
    !tmp_12
    jmp L_MERGE_5

L_MERGE_5:
    tmp_13 = load tmp_10+0 as i32
    !tmp_10
    got = tmp_13
    tmp_14 = call @sa_fmt_u64(got, 10)
    tmp_15 = call @sa_fmt_buffer_data(tmp_14)
    tmp_16 = call @sa_fmt_buffer_len(tmp_14)
    tmp_17 = tmp_15
    call @sa_print_bytes(&tmp_17, tmp_16)
    call @sa_fmt_buffer_free(^tmp_14)
    !tmp_17
    !tmp_16
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !result
    return got

@test "rosetta 173 173_catch_unwind_panic"():
L_TEST_ENTRY_6:
    tmp_18 = call @sla__catch_unwind_observable()
    got = tmp_18
    tmp_19 = 0
    tmp_20 = ne got, tmp_19
    !tmp_19
    br tmp_20 -> L_THEN_7, L_ELSE_8

L_THEN_7:
    !tmp_20
    panic(173)

L_ELSE_8:
    !tmp_20
    jmp L_MERGE_9

L_MERGE_9:
    !got
    return

