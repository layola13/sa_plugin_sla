@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

struct Counter(i32);

impl Counter {
    fn inc(&self) {
        self.0 += 1;
    }
}

fn main() -> i32 {
    let counter = Counter(3);
    counter.inc();
    println("{}", counter.0);
    return 0;
}

@test "rosetta 059 method counter"() {
    let counter = Counter(3);
    counter.inc();
    if counter.0 != 4 {
        panic(59);
    };
}
