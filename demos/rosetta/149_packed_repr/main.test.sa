@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_packed_pair_sum = vtable { call = @sla__packed_pair_sum }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__packed_pair_sum() -> i32:
L_ENTRY:
    pair = alloc 2
    tmp_0 = 1
    store pair+0, tmp_0 as u8
    tmp_1 = 2
    store pair+1, tmp_1 as u8
    tmp_2 = load pair+0 as u8
    tmp_3 = tmp_2 as i32
    left = tmp_3
    tmp_4 = load pair+1 as u8
    tmp_5 = tmp_4 as i32
    right = tmp_5
    tmp_6 = add left, right
    !pair
    return tmp_6

@main() -> i32:
L_ENTRY:
    tmp_7 = call @sla__packed_pair_sum()
    result = tmp_7
    tmp_8 = call @sa_fmt_u64(result, 10)
    tmp_9 = call @sa_fmt_buffer_data(tmp_8)
    tmp_10 = call @sa_fmt_buffer_len(tmp_8)
    tmp_11 = tmp_9
    call @sa_print_bytes(&tmp_11, tmp_10)
    call @sa_fmt_buffer_free(^tmp_8)
    !tmp_11
    !tmp_10
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 149 149_packed_repr"():
L_TEST_ENTRY_0:
    tmp_12 = call @sla__packed_pair_sum()
    got = tmp_12
    tmp_13 = 3
    tmp_14 = ne got, tmp_13
    !tmp_13
    br tmp_14 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_14
    panic(149)

L_ELSE_2:
    !tmp_14
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

