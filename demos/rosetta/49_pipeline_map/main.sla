@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn main() -> i32 {
    let values = [1, 2, 3];
    let total: i32 = values.iter().map(|x| x * 2).sum();
    println("{}", total);
    return 0;
}

@test "rosetta 049 pipeline map"() {
    let values = [1, 2, 3];
    let total: i32 = values.iter().map(|x| x * 2).sum();
    if total != 12 {
        panic(49);
    };
}
