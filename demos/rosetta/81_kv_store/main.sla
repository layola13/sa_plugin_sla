@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/option.sa"
@import "sa_std/btree_map.sa"

fn kv_lookup_beta() -> i32 {
    let kv = BTreeMap::new();
    kv.insert("alpha", 5);
    kv.insert("beta", 8);
    return kv["beta"];
}

fn main() -> i32 {
    let result = kv_lookup_beta();
    println("{}", result);
    return result;
};

@test "rosetta 081 81_kv_store"() {
    let got = kv_lookup_beta();
    if got != 8 {
        panic(81);
    };
};
