    product = tmp_0
    tmp_1 = add product, left
    tmp_2 = sub tmp_1, right
    result = tmp_2
    !product
    !right
    !left
    return result

@rosetta_063_value() -> i64:
L_ENTRY:
    tmp_3 = 23
    tmp_4 = 24
    tmp_5 = call @rosetta_063_mix(tmp_3, tmp_4)
    result = tmp_5
    return result

@main() -> i64:
