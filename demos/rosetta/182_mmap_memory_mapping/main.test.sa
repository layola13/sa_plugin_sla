@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/result.sa"
@import "sa_std/fs.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_mmap_mapped_fd = vtable { call = @sla__mmap_mapped_fd }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__mmap_mapped_fd() -> i32:
L_ENTRY:
    tmp_0 = 0
    mapped_fd = tmp_0
    @const SLA_STR_0 = utf8:"/dev/zero"
    tmp_2 = 9
    tmp_1 = stack_alloc Slice_SIZE
    EXPAND SLICE_NEW tmp_1, &SLA_STR_0, tmp_2
    !tmp_2
    tmp_3 = load tmp_1+Slice_ptr as ptr
    tmp_4 = load tmp_1+Slice_len as u64
    EXPAND FS_OPEN_READ tmp_5, tmp_6, tmp_3, tmp_4
    tmp_8 = eq tmp_5, SA_FS_OK
    br tmp_8 -> L_FILE_OPEN_OK_0, L_FILE_OPEN_ERR_1

L_FILE_OPEN_OK_0:
    EXPAND RESULT_NEW_OK tmp_7, tmp_6
    !tmp_5
    !tmp_6
    jmp L_FILE_OPEN_END_2

L_FILE_OPEN_ERR_1:
    EXPAND RESULT_NEW_ERR tmp_7, tmp_5
    !tmp_5
    !tmp_6
    jmp L_FILE_OPEN_END_2

L_FILE_OPEN_END_2:
    !tmp_8
    !tmp_4
    !tmp_3
    EXPAND RESULT_UNWRAP tmp_9, tmp_7
    !tmp_7
    file = tmp_9
    tmp_10 = add file, 0
    tmp_11 = tmp_10 as i32
    raw_fd = tmp_11
    tmp_12 = 1
    tmp_13 = add raw_fd, tmp_12
    !tmp_12
    !mapped_fd
    mapped_fd = tmp_13
    EXPAND FS_CLOSE tmp_14, file
    !tmp_14
    !raw_fd
    return mapped_fd

@main() -> i32:
L_ENTRY:
    tmp_15 = call @sla__mmap_mapped_fd()
    result = tmp_15
    tmp_16 = call @sa_fmt_u64(result, 10)
    tmp_17 = call @sa_fmt_buffer_data(tmp_16)
    tmp_18 = call @sa_fmt_buffer_len(tmp_16)
    tmp_19 = tmp_17
    call @sa_print_bytes(&tmp_19, tmp_18)
    call @sa_fmt_buffer_free(^tmp_16)
    !tmp_19
    !tmp_18
    @const SLA_STR_1 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_1, 1)
    return result

@test "rosetta 182 182_mmap_memory_mapping"():
L_TEST_ENTRY_3:
    tmp_20 = call @sla__mmap_mapped_fd()
    got = tmp_20
    tmp_21 = 0
    tmp_22 = sle got, tmp_21
    !tmp_21
    br tmp_22 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_22
    panic(182)

L_ELSE_5:
    !tmp_22
    jmp L_MERGE_6

L_MERGE_6:
    !got
    return

