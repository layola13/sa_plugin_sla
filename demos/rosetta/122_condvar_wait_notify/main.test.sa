@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/arc.sa"
@import "sa_std/core/result.sa"
@import "sa_std/sync/mutex.sa"
@import "sa_std/thread.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/result.sa"
@const SLA_THREAD_VT_0 = vtable { call = @sla_thread_worker_0 }

@ffi_wrapper sla_thread_spawn_0(*slot: ptr) -> i32:
L_ENTRY:
    worker_vt = &SLA_THREAD_VT_0
    worker_fn = load worker_vt+0 as ptr
    worker_raw = *worker_fn
    worker_safe = assume_safe worker_raw
    EXPAND THREAD_SPAWN handle, *worker_safe, *slot
    !slot
    return handle

@sla_thread_worker_0(&slot: ptr) -> i32:
L_ENTRY:
    tmp_0 = load slot+16 as ptr
    tmp_1 = call @sla__notify_ready(tmp_0)
    store slot+8, tmp_1 as i32
    !slot
    return tmp_1

@const SLA_FNPTR_VT_notify_ready = vtable { call = @sla__notify_ready }
@const SLA_FNPTR_VT_condvar_wait_result = vtable { call = @sla__condvar_wait_result }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__notify_ready(shared: ptr) -> i32:
L_ENTRY:
    EXPAND ARC_GET tmp_2, shared
    EXPAND MUTEX_LOCK tmp_2
    tmp_3 = ptr_add tmp_2, Mutex_data
    EXPAND RESULT_NEW_OK tmp_4, tmp_3
    !tmp_3
    EXPAND RESULT_UNWRAP tmp_5, tmp_4
    !tmp_4
    ready = tmp_5
    tmp_6 = 4
    store ready+0, tmp_6 as i32
    !tmp_6
    tmp_7 = 0
    EXPAND MUTEX_UNLOCK tmp_2
    !tmp_2
    !ready
    !shared
    return tmp_7

@sla__condvar_wait_result() -> i32:
L_ENTRY:
    tmp_8 = 0
    EXPAND MUTEX_NEW_I32 tmp_9, tmp_8
    !tmp_8
    EXPAND ARC_NEW tmp_10, tmp_9
    !tmp_9
    pair = tmp_10
    tmp_11 = add pair, 0
    EXPAND ARC_CLONE tmp_11
    notifier = tmp_11
    tmp_12 = alloc 24
    store tmp_12+0, 0 as i32
    store tmp_12+8, 0 as i32
    store tmp_12+16, notifier as ptr
    tmp_13 = call @sla_thread_spawn_0(*tmp_12)
    store tmp_12+0, tmp_13 as i32
    !tmp_13
    handle = tmp_12
    tmp_14 = load handle+0 as i32
    EXPAND THREAD_JOIN_STATUS tmp_15, tmp_14, *handle
    EXPAND THREAD_DROP tmp_14
    tmp_16 = eq tmp_15, 0
    br tmp_16 -> L_THREAD_JOIN_OK_0, L_THREAD_JOIN_ERR_1

L_THREAD_JOIN_OK_0:
    !tmp_16
    tmp_18 = load handle+8 as i32
    EXPAND RESULT_NEW_OK tmp_17, tmp_18
    !tmp_18
    jmp L_THREAD_JOIN_END_2

L_THREAD_JOIN_ERR_1:
    !tmp_16
    tmp_19 = add tmp_15, 0
    EXPAND RESULT_NEW_ERR tmp_17, tmp_19
    !tmp_19
    jmp L_THREAD_JOIN_END_2

L_THREAD_JOIN_END_2:
    !tmp_15
    !tmp_14
    !handle
    EXPAND RESULT_UNWRAP tmp_20, tmp_17
    !tmp_17
    !tmp_20
    EXPAND ARC_GET tmp_21, pair
    EXPAND MUTEX_LOCK tmp_21
    tmp_22 = ptr_add tmp_21, Mutex_data
    EXPAND RESULT_NEW_OK tmp_23, tmp_22
    !tmp_22
    EXPAND RESULT_UNWRAP tmp_24, tmp_23
    !tmp_23
    ready = tmp_24
    tmp_25 = load ready+0 as i32
    tmp_26 = 4
    tmp_27 = eq tmp_25, tmp_26
    !tmp_25
    !tmp_26
    br tmp_27 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_27
    tmp_28 = load ready+0 as i32
    EXPAND MUTEX_UNLOCK tmp_21
    !tmp_21
    !ready
    !pair
    !notifier
    return tmp_28

L_ELSE_4:
    !tmp_27
    tmp_29 = 0
    EXPAND MUTEX_UNLOCK tmp_21
    !ready
    !pair
    !notifier
    return tmp_29


@main() -> i32:
L_ENTRY:
    tmp_31 = call @sla__condvar_wait_result()
    result = tmp_31
    tmp_32 = call @sa_fmt_u64(result, 10)
    tmp_33 = call @sa_fmt_buffer_data(tmp_32)
    tmp_34 = call @sa_fmt_buffer_len(tmp_32)
    tmp_35 = tmp_33
    call @sa_print_bytes(&tmp_35, tmp_34)
    call @sa_fmt_buffer_free(^tmp_32)
    !tmp_35
    !tmp_34
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 122 122_condvar_wait_notify"():
L_TEST_ENTRY_6:
    tmp_36 = call @sla__condvar_wait_result()
    got = tmp_36
    tmp_37 = 4
    tmp_38 = ne got, tmp_37
    !tmp_37
    br tmp_38 -> L_THEN_7, L_ELSE_8

L_THEN_7:
    !tmp_38
    panic(122)

L_ELSE_8:
    !tmp_38
    jmp L_MERGE_9

L_MERGE_9:
    !got
    return

