@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn eco_crypto_simd_lanes() -> i32 { let lane0 = 1; let lane1 = 1; let lane2 = 1; let lane3 = 1; return lane0 + lane1 + lane2 + lane3; }
fn main() -> i32 { let lane0 = 1; let lane1 = 1; let lane2 = 1; let lane3 = 1; let result = lane0 + lane1 + lane2 + lane3; println("{}", result); return result; }
@test "rosetta 298 eco cryptography simd"() { let got = eco_crypto_simd_lanes(); if got != 4 { panic(298); }; }
