@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/result.sa"
@import "sa_std/thread.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/result.sa"
@const SLA_THREAD_VT_0 = vtable { call = @sla_thread_worker_0 }
@const SLA_THREAD_VT_1 = vtable { call = @sla_thread_worker_1 }
@const SLA_THREAD_VT_2 = vtable { call = @sla_thread_worker_2 }

@ffi_wrapper sla_thread_spawn_0(*slot: ptr) -> i32:
L_ENTRY:
    worker_vt = &SLA_THREAD_VT_0
    worker_fn = load worker_vt+0 as ptr
    worker_raw = *worker_fn
    worker_safe = assume_safe worker_raw
    EXPAND THREAD_SPAWN handle, *worker_safe, *slot
    !slot
    return handle

@sla_thread_worker_0(&slot: ptr) -> i32:
L_ENTRY:
    tmp_0 = 1
    tmp_1 = 2
    tmp_2 = call @sla__worker_score(tmp_0, tmp_1)
    !tmp_0
    !tmp_1
    store slot+8, tmp_2 as i32
    !slot
    return tmp_2

@ffi_wrapper sla_thread_spawn_1(*slot: ptr) -> i32:
L_ENTRY:
    worker_vt = &SLA_THREAD_VT_1
    worker_fn = load worker_vt+0 as ptr
    worker_raw = *worker_fn
    worker_safe = assume_safe worker_raw
    EXPAND THREAD_SPAWN handle, *worker_safe, *slot
    !slot
    return handle

@sla_thread_worker_1(&slot: ptr) -> i32:
L_ENTRY:
    tmp_3 = 2
    tmp_4 = 3
    tmp_5 = call @sla__worker_score(tmp_3, tmp_4)
    !tmp_3
    !tmp_4
    store slot+8, tmp_5 as i32
    !slot
    return tmp_5

@ffi_wrapper sla_thread_spawn_2(*slot: ptr) -> i32:
L_ENTRY:
    worker_vt = &SLA_THREAD_VT_2
    worker_fn = load worker_vt+0 as ptr
    worker_raw = *worker_fn
    worker_safe = assume_safe worker_raw
    EXPAND THREAD_SPAWN handle, *worker_safe, *slot
    !slot
    return handle

@sla_thread_worker_2(&slot: ptr) -> i32:
L_ENTRY:
    tmp_6 = 3
    tmp_7 = 4
    tmp_8 = call @sla__worker_score(tmp_6, tmp_7)
    !tmp_6
    !tmp_7
    store slot+8, tmp_8 as i32
    !slot
    return tmp_8

@const SLA_FNPTR_VT_worker_score = vtable { call = @sla__worker_score }
@const SLA_FNPTR_VT_thread_pool_total = vtable { call = @sla__thread_pool_total }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__worker_score(base: i32, delta: i32) -> i32:
L_ENTRY:
    tmp_9 = add base, delta
    return tmp_9

@sla__thread_pool_total() -> i32:
L_ENTRY:
    tmp_10 = alloc 16
    store tmp_10+0, 0 as i32
    store tmp_10+8, 0 as i32
    tmp_11 = call @sla_thread_spawn_0(*tmp_10)
    store tmp_10+0, tmp_11 as i32
    !tmp_11
    a = tmp_10
    tmp_12 = alloc 16
    store tmp_12+0, 0 as i32
    store tmp_12+8, 0 as i32
    tmp_13 = call @sla_thread_spawn_1(*tmp_12)
    store tmp_12+0, tmp_13 as i32
    !tmp_13
    b = tmp_12
    tmp_14 = alloc 16
    store tmp_14+0, 0 as i32
    store tmp_14+8, 0 as i32
    tmp_15 = call @sla_thread_spawn_2(*tmp_14)
    store tmp_14+0, tmp_15 as i32
    !tmp_15
    c = tmp_14
    tmp_16 = load a+0 as i32
    EXPAND THREAD_JOIN_STATUS tmp_17, tmp_16, *a
    EXPAND THREAD_DROP tmp_16
    tmp_18 = eq tmp_17, 0
    br tmp_18 -> L_THREAD_JOIN_OK_0, L_THREAD_JOIN_ERR_1

L_THREAD_JOIN_OK_0:
    !tmp_18
    tmp_20 = load a+8 as i32
    EXPAND RESULT_NEW_OK tmp_19, tmp_20
    !tmp_20
    jmp L_THREAD_JOIN_END_2

L_THREAD_JOIN_ERR_1:
    !tmp_18
    tmp_21 = add tmp_17, 0
    EXPAND RESULT_NEW_ERR tmp_19, tmp_21
    !tmp_21
    jmp L_THREAD_JOIN_END_2

L_THREAD_JOIN_END_2:
    !tmp_17
    !tmp_16
    !a
    EXPAND RESULT_UNWRAP tmp_22, tmp_19
    !tmp_19
    av = tmp_22
    tmp_23 = load b+0 as i32
    EXPAND THREAD_JOIN_STATUS tmp_24, tmp_23, *b
    EXPAND THREAD_DROP tmp_23
    tmp_25 = eq tmp_24, 0
    br tmp_25 -> L_THREAD_JOIN_OK_3, L_THREAD_JOIN_ERR_4

L_THREAD_JOIN_OK_3:
    !tmp_25
    tmp_27 = load b+8 as i32
    EXPAND RESULT_NEW_OK tmp_26, tmp_27
    !tmp_27
    jmp L_THREAD_JOIN_END_5

L_THREAD_JOIN_ERR_4:
    !tmp_25
    tmp_28 = add tmp_24, 0
    EXPAND RESULT_NEW_ERR tmp_26, tmp_28
    !tmp_28
    jmp L_THREAD_JOIN_END_5

L_THREAD_JOIN_END_5:
    !tmp_24
    !tmp_23
    !b
    EXPAND RESULT_UNWRAP tmp_29, tmp_26
    !tmp_26
    bv = tmp_29
    tmp_30 = load c+0 as i32
    EXPAND THREAD_JOIN_STATUS tmp_31, tmp_30, *c
    EXPAND THREAD_DROP tmp_30
    tmp_32 = eq tmp_31, 0
    br tmp_32 -> L_THREAD_JOIN_OK_6, L_THREAD_JOIN_ERR_7

L_THREAD_JOIN_OK_6:
    !tmp_32
    tmp_34 = load c+8 as i32
    EXPAND RESULT_NEW_OK tmp_33, tmp_34
    !tmp_34
    jmp L_THREAD_JOIN_END_8

L_THREAD_JOIN_ERR_7:
    !tmp_32
    tmp_35 = add tmp_31, 0
    EXPAND RESULT_NEW_ERR tmp_33, tmp_35
    !tmp_35
    jmp L_THREAD_JOIN_END_8

L_THREAD_JOIN_END_8:
    !tmp_31
    !tmp_30
    !c
    EXPAND RESULT_UNWRAP tmp_36, tmp_33
    !tmp_33
    cv = tmp_36
    tmp_37 = add av, bv
    tmp_38 = add tmp_37, cv
    !tmp_37
    total = tmp_38
    !cv
    !av
    !bv
    return total

@main() -> i32:
L_ENTRY:
    tmp_39 = call @sla__thread_pool_total()
    total = tmp_39
    tmp_40 = call @sa_fmt_u64(total, 10)
    tmp_41 = call @sa_fmt_buffer_data(tmp_40)
    tmp_42 = call @sa_fmt_buffer_len(tmp_40)
    tmp_43 = tmp_41
    call @sa_print_bytes(&tmp_43, tmp_42)
    call @sa_fmt_buffer_free(^tmp_40)
    !tmp_43
    !tmp_42
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_44 = 0
    !total
    return tmp_44

@test "rosetta 061 61_thread_pool"():
L_TEST_ENTRY_9:
    tmp_45 = call @sla__thread_pool_total()
    got = tmp_45
    tmp_46 = 15
    tmp_47 = ne got, tmp_46
    !tmp_46
    br tmp_47 -> L_THEN_10, L_ELSE_11

L_THEN_10:
    !tmp_47
    panic(61)

L_ELSE_11:
    !tmp_47
    jmp L_MERGE_12

L_MERGE_12:
    !got
    return

