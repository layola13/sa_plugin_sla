@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/cmp.sa"
@const SLA_FNPTR_VT_ordering_value = vtable { call = @sla__ordering_value }
@sla__Ordering_less() -> ptr:
L_ENTRY:
    tmp_0 = alloc 8
    tmp_1 = 0
    tmp_2 = 1
    tmp_3 = sub tmp_1, tmp_2
    !tmp_1
    !tmp_2
    store tmp_0+0, tmp_3 as i64
    !tmp_3
    return tmp_0

@sla__Ordering_equal() -> ptr:
L_ENTRY:
    tmp_4 = alloc 8
    tmp_5 = 0
    store tmp_4+0, tmp_5 as i64
    !tmp_5
    return tmp_4

@sla__Ordering_greater() -> ptr:
L_ENTRY:
    tmp_6 = alloc 8
    tmp_7 = 1
    store tmp_6+0, tmp_7 as i64
    !tmp_7
    return tmp_6

@sla__Ordering_is_lt(self: ptr) -> u8:
L_ENTRY:
    tmp_8 = load self+0 as i64
    tmp_9 = 0
    tmp_10 = 1
    tmp_11 = sub tmp_9, tmp_10
    !tmp_9
    !tmp_10
    tmp_12 = eq tmp_8, tmp_11
    !tmp_8
    !tmp_11
    !self
    return tmp_12

@sla__Ordering_is_eq(self: ptr) -> u8:
L_ENTRY:
    tmp_13 = load self+0 as i64
    tmp_14 = 0
    tmp_15 = eq tmp_13, tmp_14
    !tmp_13
    !tmp_14
    !self
    return tmp_15

@sla__Ordering_is_gt(self: ptr) -> u8:
L_ENTRY:
    tmp_16 = load self+0 as i64
    tmp_17 = 1
    tmp_18 = eq tmp_16, tmp_17
    !tmp_16
    !tmp_17
    !self
    return tmp_18

@sla__Ordering_is_le(self: ptr) -> u8:
L_ENTRY:
    tmp_19 = load self+0 as i64
    tmp_20 = 0
    tmp_21 = sle tmp_19, tmp_20
    !tmp_19
    !tmp_20
    !self
    return tmp_21

@sla__Ordering_is_ge(self: ptr) -> u8:
L_ENTRY:
    tmp_22 = load self+0 as i64
    tmp_23 = 0
    tmp_24 = sge tmp_22, tmp_23
    !tmp_22
    !tmp_23
    !self
    return tmp_24

@sla__Ordering_reverse(self: ptr) -> ptr:
L_ENTRY:
    tmp_25 = load self+0 as i64
    tmp_26 = 0
    tmp_27 = slt tmp_25, tmp_26
    !tmp_25
    !tmp_26
    br tmp_27 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_27
    tmp_28 = call @sla__Ordering_greater()
    !self
    return tmp_28

L_ELSE_1:
    !tmp_27
    jmp L_MERGE_2

L_MERGE_2:
    tmp_30 = load self+0 as i64
    tmp_31 = 0
    tmp_32 = sgt tmp_30, tmp_31
    !tmp_30
    !tmp_31
    br tmp_32 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_32
    tmp_33 = call @sla__Ordering_less()
    !self
    return tmp_33

L_ELSE_4:
    !tmp_32
    jmp L_MERGE_5

L_MERGE_5:
    tmp_35 = call @sla__Ordering_equal()
    !self
    return tmp_35

@sla__Ordering_then(self: ptr, other: ptr) -> ptr:
L_ENTRY:
    tmp_36 = load self+0 as i64
    tmp_37 = 0
    tmp_38 = eq tmp_36, tmp_37
    !tmp_36
    !tmp_37
    br tmp_38 -> L_THEN_6, L_ELSE_7

L_THEN_6:
    !tmp_38
    !self
    return other

L_ELSE_7:
    !tmp_38
    jmp L_MERGE_8

L_MERGE_8:
    !other
    return self

@sla__ordering_value(ordering: ptr) -> i64:
L_ENTRY:
    tmp_40 = load ordering+0 as i64
    !ordering
    return tmp_40

@test "spaceship returns std Ordering"():
L_TEST_ENTRY_9:
    earlier = alloc 16
    tmp_41 = 1
    store earlier+0, tmp_41 as i64
    !tmp_41
    tmp_42 = 20
    store earlier+8, tmp_42 as i64
    !tmp_42
    later = alloc 16
    tmp_43 = 2
    store later+0, tmp_43 as i64
    !tmp_43
    tmp_44 = 0
    store later+8, tmp_44 as i64
    !tmp_44
    same = alloc 16
    tmp_45 = 1
    store same+0, tmp_45 as i64
    !tmp_45
    tmp_46 = 20
    store same+8, tmp_46 as i64
    !tmp_46
    tmp_47 = alloc 8
    store tmp_47+0, CMP_ORDERING_EQUAL as i64
    tmp_48 = load earlier+0 as i64
    tmp_49 = load later+0 as i64
    tmp_50 = slt tmp_48, tmp_49
    br tmp_50 -> L_SPACESHIP_STRUCT_LESS_11, L_SPACESHIP_STRUCT_CHECK_GREATER_12

L_SPACESHIP_STRUCT_LESS_11:
    store tmp_47+0, CMP_ORDERING_LESS as i64
    jmp L_SPACESHIP_STRUCT_DONE_10

L_SPACESHIP_STRUCT_CHECK_GREATER_12:
    tmp_51 = sgt tmp_48, tmp_49
    br tmp_51 -> L_SPACESHIP_STRUCT_GREATER_13, L_SPACESHIP_STRUCT_NEXT_14

L_SPACESHIP_STRUCT_GREATER_13:
    store tmp_47+0, CMP_ORDERING_GREATER as i64
    jmp L_SPACESHIP_STRUCT_DONE_10

L_SPACESHIP_STRUCT_NEXT_14:
    tmp_52 = load earlier+8 as i64
    tmp_53 = load later+8 as i64
    tmp_54 = slt tmp_52, tmp_53
    br tmp_54 -> L_SPACESHIP_STRUCT_LESS_15, L_SPACESHIP_STRUCT_CHECK_GREATER_16

L_SPACESHIP_STRUCT_LESS_15:
    store tmp_47+0, CMP_ORDERING_LESS as i64
    jmp L_SPACESHIP_STRUCT_DONE_10

L_SPACESHIP_STRUCT_CHECK_GREATER_16:
    tmp_55 = sgt tmp_52, tmp_53
    br tmp_55 -> L_SPACESHIP_STRUCT_GREATER_17, L_SPACESHIP_STRUCT_NEXT_18

L_SPACESHIP_STRUCT_GREATER_17:
    store tmp_47+0, CMP_ORDERING_GREATER as i64
    jmp L_SPACESHIP_STRUCT_DONE_10

L_SPACESHIP_STRUCT_NEXT_18:
L_SPACESHIP_STRUCT_DONE_10:
    first_order = tmp_47
    tmp_56 = call @sla__Ordering_is_lt(first_order)
    tmp_57 = 1
    tmp_58 = ne tmp_56, tmp_57
    !tmp_56
    !tmp_57
    br tmp_58 -> L_THEN_19, L_ELSE_20

L_THEN_19:
    !tmp_58
    panic(34200)

L_ELSE_20:
    !tmp_58
    jmp L_MERGE_21

L_MERGE_21:
    tmp_61 = call @sla__ordering_value(first_order)
    tmp_62 = 0
    tmp_63 = 1
    tmp_64 = sub tmp_62, tmp_63
    !tmp_62
    !tmp_63
    tmp_65 = ne tmp_61, tmp_64
    !tmp_61
    !tmp_64
    br tmp_65 -> L_THEN_22, L_ELSE_23

L_THEN_22:
    !tmp_65
    panic(34201)

L_ELSE_23:
    !tmp_65
    jmp L_MERGE_24

L_MERGE_24:
    tmp_68 = alloc 8
    store tmp_68+0, CMP_ORDERING_EQUAL as i64
    tmp_69 = load earlier+0 as i64
    tmp_70 = load same+0 as i64
    tmp_71 = slt tmp_69, tmp_70
    br tmp_71 -> L_SPACESHIP_STRUCT_LESS_26, L_SPACESHIP_STRUCT_CHECK_GREATER_27

L_SPACESHIP_STRUCT_LESS_26:
    store tmp_68+0, CMP_ORDERING_LESS as i64
    jmp L_SPACESHIP_STRUCT_DONE_25

L_SPACESHIP_STRUCT_CHECK_GREATER_27:
    tmp_72 = sgt tmp_69, tmp_70
    br tmp_72 -> L_SPACESHIP_STRUCT_GREATER_28, L_SPACESHIP_STRUCT_NEXT_29

L_SPACESHIP_STRUCT_GREATER_28:
    store tmp_68+0, CMP_ORDERING_GREATER as i64
    jmp L_SPACESHIP_STRUCT_DONE_25

L_SPACESHIP_STRUCT_NEXT_29:
    tmp_73 = load earlier+8 as i64
    tmp_74 = load same+8 as i64
    tmp_75 = slt tmp_73, tmp_74
    br tmp_75 -> L_SPACESHIP_STRUCT_LESS_30, L_SPACESHIP_STRUCT_CHECK_GREATER_31

L_SPACESHIP_STRUCT_LESS_30:
    store tmp_68+0, CMP_ORDERING_LESS as i64
    jmp L_SPACESHIP_STRUCT_DONE_25

L_SPACESHIP_STRUCT_CHECK_GREATER_31:
    tmp_76 = sgt tmp_73, tmp_74
    br tmp_76 -> L_SPACESHIP_STRUCT_GREATER_32, L_SPACESHIP_STRUCT_NEXT_33

L_SPACESHIP_STRUCT_GREATER_32:
    store tmp_68+0, CMP_ORDERING_GREATER as i64
    jmp L_SPACESHIP_STRUCT_DONE_25

L_SPACESHIP_STRUCT_NEXT_33:
L_SPACESHIP_STRUCT_DONE_25:
    equal_order = tmp_68
    tmp_77 = call @sla__Ordering_is_eq(equal_order)
    tmp_78 = 1
    tmp_79 = ne tmp_77, tmp_78
    !tmp_77
    !tmp_78
    br tmp_79 -> L_THEN_34, L_ELSE_35

L_THEN_34:
    !tmp_79
    panic(34202)

L_ELSE_35:
    !tmp_79
    jmp L_MERGE_36

L_MERGE_36:
    tmp_82 = 9
    tmp_83 = 4
    EXPAND CMP_COMPARE_I64 tmp_84, tmp_82, tmp_83
    tmp_85 = alloc 8
    store tmp_85+0, tmp_84 as i64
    !tmp_82
    !tmp_83
    numeric_order = tmp_85
    tmp_86 = call @sla__Ordering_is_gt(numeric_order)
    tmp_87 = 1
    tmp_88 = ne tmp_86, tmp_87
    !tmp_86
    !tmp_87
    br tmp_88 -> L_THEN_37, L_ELSE_38

L_THEN_37:
    !tmp_88
    panic(34203)

L_ELSE_38:
    !tmp_88
    jmp L_MERGE_39

L_MERGE_39:
    !same
    !earlier
    !first_order
    !equal_order
    !numeric_order
    !later
    return

