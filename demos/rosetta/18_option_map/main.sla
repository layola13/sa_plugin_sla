// Sla companion for SA rosetta demo 018 Option Map.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_018_value() -> int {
    let total = 0;
    for i in 1..5 {
        total = total + i;
    }    let result = total + 23;
    return result;
};

fn main() -> int {
    let result = rosetta_018_value();
    return result;
};

@test "rosetta 018 18_option_map"() {
    let got = rosetta_018_value();
    if got != 33 {
        panic(18);
    }