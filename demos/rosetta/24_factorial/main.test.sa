@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_factorial = vtable { call = @sla__factorial }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__factorial(n: i32) -> i32:
L_ENTRY:
    tmp_0 = 1
    tmp_1 = sle n, tmp_0
    !tmp_0
    tmp_2 = alloc 4
    br tmp_1 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_1
    tmp_3 = 1
    store tmp_2+0, tmp_3 as i32
    !tmp_3
    jmp L_MERGE_2

L_ELSE_1:
    !tmp_1
    tmp_4 = 1
    tmp_5 = sub n, tmp_4
    !tmp_4
    tmp_6 = call @sla__factorial(tmp_5)
    !tmp_5
    tmp_7 = mul n, tmp_6
    !tmp_6
    store tmp_2+0, tmp_7 as i32
    !tmp_7
    jmp L_MERGE_2

L_MERGE_2:
    tmp_8 = load tmp_2+0 as i32
    !tmp_2
    return tmp_8

@main() -> i32:
L_ENTRY:
    tmp_9 = 5
    tmp_10 = call @sla__factorial(tmp_9)
    !tmp_9
    value = tmp_10
    tmp_11 = call @sa_fmt_u64(value, 10)
    tmp_12 = call @sa_fmt_buffer_data(tmp_11)
    tmp_13 = call @sa_fmt_buffer_len(tmp_11)
    tmp_14 = tmp_12
    call @sa_print_bytes(&tmp_14, tmp_13)
    call @sa_fmt_buffer_free(^tmp_11)
    !tmp_14
    !tmp_13
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_15 = 0
    !value
    return tmp_15

@test "rosetta 024 factorial"():
L_TEST_ENTRY_3:
    tmp_16 = 5
    tmp_17 = call @sla__factorial(tmp_16)
    !tmp_16
    value = tmp_17
    tmp_18 = 120
    tmp_19 = ne value, tmp_18
    !tmp_18
    br tmp_19 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_19
    panic(24)

L_ELSE_5:
    !tmp_19
    jmp L_MERGE_6

L_MERGE_6:
    !value
    return

