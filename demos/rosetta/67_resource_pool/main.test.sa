@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_available_id = vtable { call = @sla__available_id }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__available_id(pool: ptr) -> i32:
L_ENTRY:
    tmp_0 = 0
    tmp_1 = mul tmp_0, 8
    tmp_2 = ptr_add pool, tmp_1
    !tmp_1
    !tmp_0
    tmp_3 = load tmp_2+0 as ptr
    !tmp_2
    tmp_4 = load tmp_3+4 as u8
    tmp_5 = 0
    tmp_6 = eq tmp_4, tmp_5
    !tmp_4
    !tmp_5
    br tmp_6 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_6
    tmp_7 = 0
    tmp_8 = mul tmp_7, 8
    tmp_9 = ptr_add pool, tmp_8
    !tmp_8
    !tmp_7
    tmp_10 = load tmp_9+0 as ptr
    !tmp_9
    tmp_11 = load tmp_10+0 as i32
    !pool
    return tmp_11

L_ELSE_1:
    !tmp_6
    jmp L_MERGE_2

L_MERGE_2:
    tmp_13 = 1
    tmp_14 = mul tmp_13, 8
    tmp_15 = ptr_add pool, tmp_14
    !tmp_14
    !tmp_13
    tmp_16 = load tmp_15+0 as ptr
    !tmp_15
    tmp_17 = load tmp_16+4 as u8
    tmp_18 = 0
    tmp_19 = eq tmp_17, tmp_18
    !tmp_17
    !tmp_18
    br tmp_19 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_19
    tmp_20 = 1
    tmp_21 = mul tmp_20, 8
    tmp_22 = ptr_add pool, tmp_21
    !tmp_21
    !tmp_20
    tmp_23 = load tmp_22+0 as ptr
    !tmp_22
    tmp_24 = load tmp_23+0 as i32
    !pool
    return tmp_24

L_ELSE_4:
    !tmp_19
    jmp L_MERGE_5

L_MERGE_5:
    tmp_26 = 2
    tmp_27 = mul tmp_26, 8
    tmp_28 = ptr_add pool, tmp_27
    !tmp_27
    !tmp_26
    tmp_29 = load tmp_28+0 as ptr
    !tmp_28
    tmp_30 = load tmp_29+0 as i32
    !pool
    return tmp_30

@main() -> i32:
L_ENTRY:
    pool = alloc 24
    tmp_31 = alloc 5
    tmp_32 = 10
    store tmp_31+0, tmp_32 as i32
    tmp_33 = 1
    store tmp_31+4, tmp_33 as u8
    store pool+0, tmp_31 as ptr
    tmp_34 = alloc 5
    tmp_35 = 20
    store tmp_34+0, tmp_35 as i32
    tmp_36 = 0
    store tmp_34+4, tmp_36 as u8
    store pool+8, tmp_34 as ptr
    tmp_37 = alloc 5
    tmp_38 = 30
    store tmp_37+0, tmp_38 as i32
    tmp_39 = 1
    store tmp_37+4, tmp_39 as u8
    store pool+16, tmp_37 as ptr
    tmp_40 = call @sla__available_id(pool)
    value = tmp_40
    tmp_41 = call @sa_fmt_u64(value, 10)
    tmp_42 = call @sa_fmt_buffer_data(tmp_41)
    tmp_43 = call @sa_fmt_buffer_len(tmp_41)
    tmp_44 = tmp_42
    call @sa_print_bytes(&tmp_44, tmp_43)
    call @sa_fmt_buffer_free(^tmp_41)
    !tmp_44
    !tmp_43
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    !pool
    return value

@test "rosetta 067 67_resource_pool"():
L_TEST_ENTRY_6:
    tmp_45 = call @main()
    tmp_46 = 20
    tmp_47 = ne tmp_45, tmp_46
    !tmp_45
    !tmp_46
    br tmp_47 -> L_THEN_7, L_ELSE_8

L_THEN_7:
    !tmp_47
    panic(67)

L_ELSE_8:
    !tmp_47
    jmp L_MERGE_9

L_MERGE_9:
    return

