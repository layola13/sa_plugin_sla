    !tmp_227
    tmp_228 = alloc 8
    tmp_229 = 5
    store tmp_228+0, tmp_229 as i64
    !tmp_229
    EXPAND BOX_NEW tmp_230, tmp_228
    !tmp_228
    EXPAND REFCELL_U64_NEW tmp_231, tmp_230
    !tmp_230
    EXPAND RC_NEW tmp_232, tmp_231
    !tmp_231
    EXPAND VEC_PUSH items, tmp_232, 8
    !tmp_232
    holder = alloc 8
    store holder+0, items as ptr
    tmp_233 = load holder+0 as ptr
    tmp_234 = 0
    EXPAND VEC_GET tmp_235, tmp_233, tmp_234
    !tmp_234
    !tmp_233
    tmp_236 = tmp_235 as ptr
    EXPAND RC_GET tmp_237, tmp_236
    !tmp_236
    tmp_238 = &tmp_237
    first_cell = tmp_238
    tmp_239 = load holder+0 as ptr
