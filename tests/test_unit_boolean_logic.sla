fn bool_and(a: bool, b: bool) -> bool {
    return a && b;
}

fn bool_or(a: bool, b: bool) -> bool {
    return a || b;
}

@test "boolean logic operators"() {
    if bool_and(true, true) != true { panic(30501); };
    if bool_and(true, false) { panic(30502); };
    if bool_or(false, true) != true { panic(30503); };
    if bool_or(false, false) { panic(30504); };
}
