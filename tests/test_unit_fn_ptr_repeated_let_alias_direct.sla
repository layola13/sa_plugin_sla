@import "sa_std/vec.sa"

fn repeated_alias_add_one(value: i32) -> i32 {
    return value + 1;
}

fn repeated_alias_add_two(value: i32) -> i32 {
    return value + 2;
}

fn repeated_alias_call_twice(runs: Vec<fn(i32) -> i32>) -> i32 {
    let total: i32 = 0;
    let i: i64 = 0;
    while i < len(runs) as i64 {
        let run = runs[i];
        total = total + run(i as i32);
        i = i + 1;
    }

    let j: i64 = 0;
    while j < len(runs) as i64 {
        let run = runs[j];
        total = total + run(j as i32);
        j = j + 1;
    }
    return total;
}

@test "function pointer repeated let aliases keep callable type"() {
    let runs: Vec<fn(i32) -> i32> = Vec::new();
    runs.push(repeated_alias_add_one);
    runs.push(repeated_alias_add_two);
    if repeated_alias_call_twice(runs) != 8 { panic(51400); };
}
