@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"
@import "sa_std/core/mem.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const VT_Item_A = vtable { a = @sla__Item_a }
@const VT_Item_B = vtable { b = @sla__Item_b }
@sla__Item_a(&self: ptr) -> i32:
L_ENTRY:
    tmp_0 = load self+0 as i32
    return tmp_0

@sla__Item_b(&self: ptr) -> i32:
L_ENTRY:
    tmp_1 = load self+0 as i32
    tmp_2 = 1
    tmp_3 = add tmp_1, tmp_2
    !tmp_1
    !tmp_2
    return tmp_3

@sla__rosetta_110_value() -> i32:
L_ENTRY:
    item = alloc 4
    tmp_4 = 7
    store item+0, tmp_4 as i32
    tmp_5 = call @sla__Item_a(&item)
    tmp_6 = call @sla__Item_b(&item)
    tmp_7 = add tmp_5, tmp_6
    !tmp_5
    !tmp_6
    !item
    return tmp_7

@main() -> i32:
L_ENTRY:
    tmp_8 = call @sla__rosetta_110_value()
    result = tmp_8
    tmp_9 = call @sa_fmt_u64(result, 10)
    tmp_10 = call @sa_fmt_buffer_data(tmp_9)
    tmp_11 = call @sa_fmt_buffer_len(tmp_9)
    tmp_12 = tmp_10
    call @sa_print_bytes(&tmp_12, tmp_11)
    call @sa_fmt_buffer_free(^tmp_9)
    !tmp_12
    !tmp_11
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 110 110_trait_super_vtable"():
L_TEST_ENTRY_0:
    tmp_13 = call @sla__rosetta_110_value()
    got = tmp_13
    tmp_14 = 15
    tmp_15 = ne got, tmp_14
    !tmp_14
    br tmp_15 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_15
    panic(110)

L_ELSE_2:
    !tmp_15
    jmp L_MERGE_3

L_MERGE_3:
    !got
    return

