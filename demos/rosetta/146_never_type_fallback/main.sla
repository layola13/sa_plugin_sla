// Sla companion for SA rosetta demo 146 Never Type Fallback.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_146_value() -> int {
    let total = 0;
    for i in 1..5 {
        total = total + i;
    }    let result = total + 13;
    return result;
};

fn main() -> int {
    let result = rosetta_146_value();
    return result;
};

@test "rosetta 146 146_never_type_fallback"() {
    let got = rosetta_146_value();
    if got != 23 {
        panic(146);
    }