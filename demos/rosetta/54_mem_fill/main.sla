// Sla companion for SA rosetta demo 054 Mem Fill.
// Generated from the catalog name; Rust reference lives in main.rs.

fn rosetta_054_value() -> int {
    let total = 0;
    for i in 1..9 {
        total = total + i;
    }    let result = total + 13;
    return result;
};

fn main() -> int {
    let result = rosetta_054_value();
    return result;
};

@test "rosetta 054 54_mem_fill"() {
    let got = rosetta_054_value();
    if got != 49 {
        panic(54);
    };
