@import "sa_std/vec.sa"

struct MoveBag {
    values: Vec<i32>,
}

fn move_bag_new() -> MoveBag {
    let values: Vec<i32> = Vec::new();
    return MoveBag { values: values };
}

fn move_bag_advance(bag: MoveBag, value: i32) -> (MoveBag, i32) {
    bag.values.push(value);
    return (bag, value);
}

fn move_bag_reassign_sum(limit: i32) -> i32 {
    let bag = move_bag_new();
    let i: i32 = 0;
    let total: i32 = 0;
    while i < limit {
        let (next_bag, value) = move_bag_advance(bag, i + 1);
        bag = next_bag;
        total = total + value;
        i = i + 1;
    }
    if len(bag.values) != (limit as i64) { panic(44001); };
    return total;
}

@test "aggregate identifier reassign consumes moved rhs cleanup"() {
    let got = move_bag_reassign_sum(4);
    if got != 10 { panic(44002); };
}
