@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/option.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_choose = vtable { call = @sla__choose }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__choose(opt: ptr, fallback: i32) -> i32:
L_ENTRY:
    EXPAND OPTION_UNWRAP_OR tmp_0, opt, fallback
    return tmp_0

@main() -> i32:
L_ENTRY:
    tmp_1 = 9
    EXPAND OPTION_NEW_SOME tmp_2, tmp_1
    !tmp_1
    tmp_3 = 1
    tmp_4 = call @sla__choose(tmp_2, tmp_3)
    !tmp_2
    !tmp_3
    value = tmp_4
    tmp_5 = call @sa_fmt_u64(value, 10)
    tmp_6 = call @sa_fmt_buffer_data(tmp_5)
    tmp_7 = call @sa_fmt_buffer_len(tmp_5)
    tmp_8 = tmp_6
    call @sa_print_bytes(&tmp_8, tmp_7)
    call @sa_fmt_buffer_free(^tmp_5)
    !tmp_8
    !tmp_7
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_9 = 0
    !value
    return tmp_9

@test "rosetta 046 option default"():
L_TEST_ENTRY_0:
    tmp_10 = 9
    EXPAND OPTION_NEW_SOME tmp_11, tmp_10
    !tmp_10
    tmp_12 = 1
    tmp_13 = call @sla__choose(tmp_11, tmp_12)
    !tmp_11
    !tmp_12
    value = tmp_13
    tmp_14 = 9
    tmp_15 = ne value, tmp_14
    !tmp_14
    br tmp_15 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_15
    panic(46)

L_ELSE_2:
    !tmp_15
    jmp L_MERGE_3

L_MERGE_3:
    !value
    return

