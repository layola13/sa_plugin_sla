@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
fn opengl_swap_result() -> i32 { let swapped_status = 1; return swapped_status; }
fn main() -> i32 { let result = opengl_swap_result(); println("{}", result); return result; }
@test "rosetta 187 187_opengl_context_swap"() { let got = opengl_swap_result(); if got != 1 { panic(187); }; }
