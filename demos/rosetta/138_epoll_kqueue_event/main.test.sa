@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_event_loop_ready_mask = vtable { call = @sla__event_loop_ready_mask }
@const SLA_FNPTR_VT_event_ready = vtable { call = @sla__event_ready }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__event_loop_ready_mask() -> i32:
L_ENTRY:
    tmp_0 = 1
    tmp_1 = 1
    tmp_2 = call @sla__event_ready(tmp_0, tmp_1)
    !tmp_0
    !tmp_1
    ready_read = tmp_2
    tmp_3 = 2
    tmp_4 = 1
    tmp_5 = call @sla__event_ready(tmp_3, tmp_4)
    !tmp_3
    !tmp_4
    ready_write = tmp_5
    tmp_6 = 4
    tmp_7 = 0
    tmp_8 = call @sla__event_ready(tmp_6, tmp_7)
    !tmp_6
    !tmp_7
    blocked = tmp_8
    tmp_9 = add ready_read, ready_write
    tmp_10 = add tmp_9, blocked
    !tmp_9
    return tmp_10

@sla__event_ready(token: i32, ready: u8) -> i32:
L_ENTRY:
    br ready -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !ready
    return token

L_ELSE_1:
    !ready
    tmp_11 = 0
    !token
    return tmp_11


@main() -> i32:
L_ENTRY:
    tmp_13 = call @sla__event_loop_ready_mask()
    result = tmp_13
    tmp_14 = call @sa_fmt_u64(result, 10)
    tmp_15 = call @sa_fmt_buffer_data(tmp_14)
    tmp_16 = call @sa_fmt_buffer_len(tmp_14)
    tmp_17 = tmp_15
    call @sa_print_bytes(&tmp_17, tmp_16)
    call @sa_fmt_buffer_free(^tmp_14)
    !tmp_17
    !tmp_16
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 138 138_epoll_kqueue_event"():
L_TEST_ENTRY_3:
    tmp_18 = call @sla__event_loop_ready_mask()
    got = tmp_18
    tmp_19 = 3
    tmp_20 = ne got, tmp_19
    !tmp_19
    br tmp_20 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_20
    panic(138)

L_ELSE_5:
    !tmp_20
    jmp L_MERGE_6

L_MERGE_6:
    !got
    return

