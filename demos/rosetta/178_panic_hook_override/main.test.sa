@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_panic_hook_observable_surrogate = vtable { call = @sla__panic_hook_observable_surrogate }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__panic_hook_observable_surrogate() -> i32:
L_ENTRY:
    tmp_0 = 1
    hook_installed = tmp_0
    tmp_1 = 1
    panic_triggered = tmp_1
    tmp_2 = 1
    tmp_3 = eq hook_installed, tmp_2
    !tmp_2
    br tmp_3 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_3
    tmp_4 = 1
    tmp_5 = eq panic_triggered, tmp_4
    !tmp_4
    br tmp_5 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_5
    tmp_6 = 1
    !panic_triggered
    !hook_installed
    return tmp_6

L_ELSE_4:
    !tmp_5
    jmp L_MERGE_5

L_MERGE_5:
    jmp L_MERGE_2

L_ELSE_1:
    !tmp_3
    jmp L_MERGE_2

L_MERGE_2:
    tmp_9 = 0
    !panic_triggered
    !hook_installed
    return tmp_9

@main() -> i32:
L_ENTRY:
    tmp_10 = call @sla__panic_hook_observable_surrogate()
    result = tmp_10
    tmp_11 = call @sa_fmt_u64(result, 10)
    tmp_12 = call @sa_fmt_buffer_data(tmp_11)
    tmp_13 = call @sa_fmt_buffer_len(tmp_11)
    tmp_14 = tmp_12
    call @sa_print_bytes(&tmp_14, tmp_13)
    call @sa_fmt_buffer_free(^tmp_11)
    !tmp_14
    !tmp_13
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 178 178_panic_hook_override"():
L_TEST_ENTRY_6:
    tmp_15 = call @sla__panic_hook_observable_surrogate()
    got = tmp_15
    tmp_16 = 1
    tmp_17 = ne got, tmp_16
    !tmp_16
    br tmp_17 -> L_THEN_7, L_ELSE_8

L_THEN_7:
    !tmp_17
    panic(178)

L_ELSE_8:
    !tmp_17
    jmp L_MERGE_9

L_MERGE_9:
    !got
    return

