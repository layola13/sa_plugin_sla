@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/option.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/option.sa"
@const SLA_FNPTR_VT_let_else_unwrapped_value = vtable { call = @sla__let_else_unwrapped_value }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__let_else_unwrapped_value() -> i32:
L_ENTRY:
    tmp_0 = 5
    EXPAND OPTION_NEW_SOME tmp_1, tmp_0
    !tmp_0
    value = tmp_1
    EXPAND OPTION_IS_SOME tmp_2, value
    br tmp_2 -> L_LET_ELSE_OK_0, L_LET_ELSE_ELSE_1

L_LET_ELSE_ELSE_1:
    !tmp_2
    tmp_3 = 0
    tmp_4 = call @sa_fmt_u64(tmp_3, 10)
    tmp_5 = call @sa_fmt_buffer_data(tmp_4)
    tmp_6 = call @sa_fmt_buffer_len(tmp_4)
    tmp_7 = tmp_5
    call @sa_print_bytes(&tmp_7, tmp_6)
    call @sa_fmt_buffer_free(^tmp_4)
    !tmp_7
    !tmp_6
    !tmp_3
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_8 = 0
    !value
    return tmp_8

L_LET_ELSE_OK_0:
    !tmp_2
    EXPAND OPTION_GET tmp_9, value
    jmp L_LET_ELSE_CONT_2

L_LET_ELSE_CONT_2:
    !value
    return tmp_9

@main() -> i32:
L_ENTRY:
    tmp_10 = call @sla__let_else_unwrapped_value()
    value = tmp_10
    tmp_11 = call @sa_fmt_u64(value, 10)
    tmp_12 = call @sa_fmt_buffer_data(tmp_11)
    tmp_13 = call @sa_fmt_buffer_len(tmp_11)
    tmp_14 = tmp_12
    call @sa_print_bytes(&tmp_14, tmp_13)
    call @sa_fmt_buffer_free(^tmp_11)
    !tmp_14
    !tmp_13
    @const SLA_STR_1 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_1, 1)
    return value

@test "rosetta 105 105_let_else"():
L_TEST_ENTRY_3:
    tmp_15 = call @sla__let_else_unwrapped_value()
    got = tmp_15
    tmp_16 = 5
    tmp_17 = ne got, tmp_16
    !tmp_16
    br tmp_17 -> L_THEN_4, L_ELSE_5

L_THEN_4:
    !tmp_17
    panic(105)

L_ELSE_5:
    !tmp_17
    jmp L_MERGE_6

L_MERGE_6:
    !got
    return

