@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
fn result_flattened_value() -> i32 { let flattened_result = 2; return flattened_result; }
fn main() -> i32 { let result = result_flattened_value(); println("{}", result); return result; }
@test "rosetta 176 176_result_flattening"() { let got = result_flattened_value(); if got != 2 { panic(176); }; }
