@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"

fn gate_open(arrived: i32, required: i32) -> bool {
    return arrived >= required;
}

fn main() -> i32 {
    let ready = gate_open(3, 3);
    println("{}", ready);
    return 0;
};

@test "rosetta 084 84_sync_gate"() {
    let got = gate_open(3, 3);
    if got != true {
        panic(84);
    };
};
