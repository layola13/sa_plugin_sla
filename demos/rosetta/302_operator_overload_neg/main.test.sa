@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/ops.sa"
@import "sa_std/string.sa"
@import "sa_std/string_format.sa"
@import "sa_std/io/print.sai"
@import "sa_std/fmt.sai"
@import "sa_std/core/panic.sa"

[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@const SLA_FNPTR_VT_negated_vec3_score = vtable { call = @sla__negated_vec3_score }
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__negated_vec3_score() -> i32:
L_ENTRY:
    a = alloc 12
    tmp_0 = 1.0
    store a+0, tmp_0 as f32
    tmp_1 = 0
    tmp_2 = 2.0
    tmp_3 = fsub tmp_1, tmp_2
    !tmp_1
    !tmp_2
    store a+4, tmp_3 as f32
    tmp_4 = 3.0
    store a+8, tmp_4 as f32
    tmp_5 = alloc 12
    tmp_6 = 0
    !tmp_6
    tmp_7 = load a+0 as f32
    tmp_8 = sub 0.0, tmp_7
    store tmp_5+0, tmp_8 as f32
    tmp_9 = load a+4 as f32
    tmp_10 = sub 0.0, tmp_9
    store tmp_5+4, tmp_10 as f32
    tmp_11 = load a+8 as f32
    tmp_12 = sub 0.0, tmp_11
    store tmp_5+8, tmp_12 as f32
    b = tmp_5
    tmp_13 = load b+0 as f32
    tmp_14 = 0
    tmp_15 = 1.0
    tmp_16 = fsub tmp_14, tmp_15
    !tmp_14
    !tmp_15
    tmp_17 = fcmp_ne tmp_13, tmp_16
    !tmp_13
    !tmp_16
    br tmp_17 -> L_THEN_0, L_ELSE_1

L_THEN_0:
    !tmp_17
    tmp_18 = 0
    !b
    !a
    return tmp_18

L_ELSE_1:
    !tmp_17
    jmp L_MERGE_2

L_MERGE_2:
    tmp_20 = load b+4 as f32
    tmp_21 = 2.0
    tmp_22 = fcmp_ne tmp_20, tmp_21
    !tmp_20
    !tmp_21
    br tmp_22 -> L_THEN_3, L_ELSE_4

L_THEN_3:
    !tmp_22
    tmp_23 = 0
    !b
    !a
    return tmp_23

L_ELSE_4:
    !tmp_22
    jmp L_MERGE_5

L_MERGE_5:
    tmp_25 = load b+8 as f32
    tmp_26 = 0
    tmp_27 = 3.0
    tmp_28 = fsub tmp_26, tmp_27
    !tmp_26
    !tmp_27
    tmp_29 = fcmp_ne tmp_25, tmp_28
    !tmp_25
    !tmp_28
    br tmp_29 -> L_THEN_6, L_ELSE_7

L_THEN_6:
    !tmp_29
    tmp_30 = 0
    !b
    !a
    return tmp_30

L_ELSE_7:
    !tmp_29
    jmp L_MERGE_8

L_MERGE_8:
    tmp_32 = 123
    !b
    !a
    return tmp_32

@main() -> i32:
L_ENTRY:
    tmp_33 = call @sla__negated_vec3_score()
    result = tmp_33
    tmp_34 = call @sa_fmt_u64(result, 10)
    tmp_35 = call @sa_fmt_buffer_data(tmp_34)
    tmp_36 = call @sa_fmt_buffer_len(tmp_34)
    tmp_37 = tmp_35
    call @sa_print_bytes(&tmp_37, tmp_36)
    call @sa_fmt_buffer_free(^tmp_34)
    !tmp_37
    !tmp_36
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    return result

@test "rosetta 302 operator_overload_neg"():
L_TEST_ENTRY_9:
    a = alloc 12
    tmp_38 = 1.0
    store a+0, tmp_38 as f32
    tmp_39 = 0
    tmp_40 = 2.0
    tmp_41 = fsub tmp_39, tmp_40
    !tmp_39
    !tmp_40
    store a+4, tmp_41 as f32
    tmp_42 = 3.0
    store a+8, tmp_42 as f32
    tmp_43 = alloc 12
    tmp_44 = 0
    !tmp_44
    tmp_45 = load a+0 as f32
    tmp_46 = sub 0.0, tmp_45
    store tmp_43+0, tmp_46 as f32
    tmp_47 = load a+4 as f32
    tmp_48 = sub 0.0, tmp_47
    store tmp_43+4, tmp_48 as f32
    tmp_49 = load a+8 as f32
    tmp_50 = sub 0.0, tmp_49
    store tmp_43+8, tmp_50 as f32
    b = tmp_43
    tmp_51 = load b+0 as f32
    tmp_52 = 0
    tmp_53 = 1.0
    tmp_54 = fsub tmp_52, tmp_53
    !tmp_52
    !tmp_53
    tmp_55 = fcmp_ne tmp_51, tmp_54
    !tmp_51
    !tmp_54
    br tmp_55 -> L_THEN_10, L_ELSE_11

L_THEN_10:
    !tmp_55
    panic(302)

L_ELSE_11:
    !tmp_55
    jmp L_MERGE_12

L_MERGE_12:
    tmp_58 = load b+4 as f32
    tmp_59 = 2.0
    tmp_60 = fcmp_ne tmp_58, tmp_59
    !tmp_58
    !tmp_59
    br tmp_60 -> L_THEN_13, L_ELSE_14

L_THEN_13:
    !tmp_60
    panic(303)

L_ELSE_14:
    !tmp_60
    jmp L_MERGE_15

L_MERGE_15:
    tmp_63 = load b+8 as f32
    tmp_64 = 0
    tmp_65 = 3.0
    tmp_66 = fsub tmp_64, tmp_65
    !tmp_64
    !tmp_65
    tmp_67 = fcmp_ne tmp_63, tmp_66
    !tmp_63
    !tmp_66
    br tmp_67 -> L_THEN_16, L_ELSE_17

L_THEN_16:
    !tmp_67
    panic(304)

L_ELSE_17:
    !tmp_67
    jmp L_MERGE_18

L_MERGE_18:
    !b
    !a
    return

