[MACRO] SLA_ARRAY_FILL_U8 %array_ptr, %value, %length
    call @sa_mem_set(&%array_ptr, %value, %length)
[END_MACRO]
@import "sa_std/core/cell.sa"
@const SLA_FNPTR_VT_main = vtable { call = @main }
@sla__Counter_inc(self: ptr):
L_ENTRY:
    tmp_0 = load self+0 as ptr
    EXPAND CELL_GET tmp_1, tmp_0
    !tmp_0
    current = tmp_1
    tmp_2 = load self+0 as ptr
    tmp_3 = 1
    tmp_4 = add current, tmp_3
    !tmp_3
    EXPAND CELL_SET tmp_2, tmp_4
    !tmp_2
    !tmp_4
    !current
    return

@main() -> i32:
L_ENTRY:
    counter = alloc 8
    tmp_5 = 3
    tmp_6 = stack_alloc Cell_SIZE
    EXPAND CELL_SET tmp_6, tmp_5
    !tmp_5
    store counter+0, tmp_6 as ptr
    call @sla__Counter_inc(counter)
    tmp_7 = load counter+0 as ptr
    EXPAND CELL_GET tmp_8, tmp_7
    !tmp_7
    tmp_9 = call @sa_fmt_u64(tmp_8, 10)
    tmp_10 = call @sa_fmt_buffer_data(tmp_9)
    tmp_11 = call @sa_fmt_buffer_len(tmp_9)
    tmp_12 = tmp_10
    call @sa_print_bytes(&tmp_12, tmp_11)
    call @sa_fmt_buffer_free(^tmp_9)
    !tmp_12
    !tmp_11
    !tmp_8
    @const SLA_STR_0 = utf8:"\n"
    call @sa_print_bytes(&SLA_STR_0, 1)
    tmp_13 = 0
    !counter
    return tmp_13

@test "rosetta 059 method counter"():
L_TEST_ENTRY_0:
    counter = alloc 8
    tmp_14 = 3
    tmp_15 = stack_alloc Cell_SIZE
    EXPAND CELL_SET tmp_15, tmp_14
    !tmp_14
    store counter+0, tmp_15 as ptr
    call @sla__Counter_inc(counter)
    tmp_16 = load counter+0 as ptr
    EXPAND CELL_GET tmp_17, tmp_16
    !tmp_16
    tmp_18 = 4
    tmp_19 = ne tmp_17, tmp_18
    !tmp_17
    !tmp_18
    br tmp_19 -> L_THEN_1, L_ELSE_2

L_THEN_1:
    !tmp_19
    panic(59)

L_ELSE_2:
    !tmp_19
    jmp L_MERGE_3

L_MERGE_3:
    !counter
    return

